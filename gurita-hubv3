local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")

-- 1. UI MENU (Prioritas Utama - Muncul Instant)
local SG = Instance.new("ScreenGui", game.CoreGui)
local Main = Instance.new("Frame", SG); Main.Size = UDim2.new(0, 180, 0, 120); Main.Position = UDim2.new(0.5, -90, 0.2, 0)
Main.BackgroundColor3 = Color3.fromRGB(5, 5, 10); Main.Active = true; Main.Draggable = true; Instance.new("UICorner", Main)
local Border = Instance.new("Frame", Main); Border.Size = UDim2.new(1, 4, 1, 4); Border.Position = UDim2.new(0, -2, 0, -2); Border.BackgroundColor3 = Color3.fromRGB(0, 160, 255); Border.ZIndex = 0; Instance.new("UICorner", Border)

local function CreateBtn(txt, pos, cb)
    local b = Instance.new("TextButton", Main); b.Size = UDim2.new(0.9, 0, 0, 35); b.Position = pos; b.BackgroundColor3 = Color3.fromRGB(0, 160, 255); b.BackgroundTransparency = 0.8; b.TextColor3 = Color3.new(1,1,1); b.Font = Enum.Font.GothamBold; b.TextSize = 10; b.Text = txt; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function() cb(b) end) return b
end

_G.TracerActive = false
_G.XrayActive = false

-- 2. FUNGSI VISUAL (WARNA ASLI + ANTI LAG)
local function ProcessObject(v)
    if v:IsA("BasePart") or v:IsA("MeshPart") then
        if v:IsDescendantOf(lp.Character) or v.Parent:FindFirstChild("Humanoid") then return end

        -- FLAT COLOR (Hanya Material, Warna Tetap Asli)
        v.Material = Enum.Material.Plastic
        if v:IsA("MeshPart") then v.TextureID = "" end
        v.CastShadow = false

        -- XRAY (Khusus Tembok)
        local name = v.Name:lower()
        if name:find("wall") or name:find("base") or name:find("roof") then
            v.Transparency = _G.XrayActive and 0.5 or 0
        end
    end
end

-- 3. TRACER BIRU (STABIL)
local function AddTracer(plr)
    local Line = Drawing.new("Line")
    Line.Visible = false; Line.Color = Color3.fromRGB(0, 160, 255); Line.Thickness = 1.5
    
    RunService.RenderStepped:Connect(function()
        if _G.TracerActive and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local pos, onScreen = Camera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position)
            if onScreen then
                Line.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                Line.To = Vector2.new(pos.X, pos.Y); Line.Visible = true
            else Line.Visible = false end
        else Line.Visible = false end
    end)
end

-- 4. BUTTONS
CreateBtn("TRACER BIRU: OFF", UDim2.new(0.05, 0, 0.2, 0), function(b)
    _G.TracerActive = not _G.TracerActive
    b.Text = _G.TracerActive and "TRACER: ON" or "TRACER BIRU: OFF"
end)

CreateBtn("XRAY BASE: OFF", UDim2.new(0.05, 0, 0.6, 0), function(b)
    _G.XrayActive = not _G.XrayActive
    b.Text = _G.XrayActive and "XRAY: ON" or "XRAY BASE: OFF"
    -- Scan ulang dengan jeda biar gak lag
    task.spawn(function()
        local count = 0
        for _, v in pairs(workspace:GetDescendants()) do
            ProcessObject(v)
            count = count + 1
            if count >= 100 then count = 0; task.wait() end -- Jeda per 100 objek
        end
    end)
end)

-- 5. INIT DENGAN OPTIMASI (ANTI-LAG EXECUTE)
task.spawn(function()
    local allObj = workspace:GetDescendants()
    local count = 0
    for i = 1, #allObj do
        ProcessObject(allObj[i])
        count = count + 1
        if count >= 100 then count = 0; task.wait() end -- Nyicil biar executor gak freeze
    end
end)

for _, p in pairs(Players:GetPlayers()) do if p ~= lp then AddTracer(p) end end
Players.PlayerAdded:Connect(AddTracer)
workspace.DescendantAdded:Connect(ProcessObject)

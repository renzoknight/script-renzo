local lp = game.Players.LocalPlayer
local mouse = lp:GetMouse()
local camera = workspace.CurrentCamera
local Net = game:GetService("ReplicatedStorage"):WaitForChild("Packages"):WaitForChild("Net")
local uis = game:GetService("UserInputService")

_G.GrappleFlyActive = false
local flySpeed = 80

-- 1. FUNGSI NYARI REMOTE ALAT YANG LAGI DIPAKE
local function GetCurrentRemote()
    for _, v in pairs(Net:GetChildren()) do
        if v:IsA("RemoteEvent") and string.find(v.Name, "RE/") then
            return v
        end
    end
    return nil
end

-- 2. LOGIKA TERBANG (SPAM PULL)
task.spawn(function()
    while true do
        task.wait(0.05) -- Jeda biar nggak kena spam detect tapi tetep narik
        if _G.GrappleFlyActive then
            local char = lp.Character
            local remote = GetCurrentRemote()
            
            if char and char:FindFirstChild("HumanoidRootPart") and remote then
                local root = char.HumanoidRootPart
                local camCF = camera.CFrame
                
                -- Tentukan arah tujuan berdasarkan tombol yang dipencet
                local moveDir = Vector3.new(0, 0, 0)
                if uis:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camCF.LookVector end
                if uis:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camCF.LookVector end
                if uis:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camCF.RightVector end
                if uis:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camCF.RightVector end
                
                -- Kalau nggak mencet apa-apa, nahan di udara (melayang)
                if moveDir.Magnitude == 0 then
                    moveDir = Vector3.new(0, 0.1, 0) -- Nahan dikit biar nggak jatuh
                end
                
                -- Posisi imajiner buat narik jaring (20 meter depan karakter)
                local targetPos = root.Position + (moveDir * 20)
                
                -- Kirim perintah ke server seolah-olah kita nembak jaring ke situ
                remote:FireServer(targetPos, workspace.Map:FindFirstChildOfClass("Part") or workspace.Map)
            end
        end
    end
end)


-- [[ GURITA HUB V60 - SILENT AIM RE-INJECTOR ]] --

local lp = game.Players.LocalPlayer
local mouse = lp:GetMouse()
local camera = workspace.CurrentCamera
local Net = game:GetService("ReplicatedStorage").Packages.Net
local RemoteName = "RE/2bb23bfe7d10041c4b3e572f3e8bbfe860849d2daa7bb33a08501c4482045c4b"
local Remote = Net:FindFirstChild(RemoteName)

_G.AutoAimPlayer = false

-- 1. LOGIKA CARI PLAYER TERDEKAT
local function GetClosestPlayer()
    local closest, dist = nil, 400
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = v.Character.HumanoidRootPart
            local pos, onScreen = camera:WorldToViewportPoint(hrp.Position)
            if onScreen then
                local mag = (Vector2.new(mouse.X, mouse.Y) - Vector2.new(pos.X, pos.Y)).Magnitude
                if mag < dist then
                    closest = v.Character
                    dist = mag
                end
            end
        end
    end
    return closest
end

-- 2. HOOKING REMOTE (SUNTIK DATA)
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    
    -- Cek apakah game lagi manggil Remote Laser/Slinger tadi
    if _G.AutoAimPlayer and self.Name == RemoteName and method == "FireServer" then
        local targetChar = GetClosestPlayer()
        if targetChar then
            local hrp = targetChar.HumanoidRootPart
            -- Ganti posisi klik jadi posisi badan musuh
            args[1] = hrp.Position 
            -- Ganti objek target jadi badan musuh
            args[2] = hrp 
            return oldNamecall(self, unpack(args))
        end
    end
    return oldNamecall(self, ...)
end)


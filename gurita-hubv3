-- [[ X-RAY SPECIALIST: PLAYER BASE ONLY ]] --
-- Sifat: Otomatis & Spesifik (Tanpa Tombol)

local transparencyValue = 0.7

local function ApplyXrayToBase(obj)
    pcall(function()
        if obj:IsA("BasePart") then
            -- 1. CEK: Apakah ini bagian dari Markas/Base? 
            -- (Melihat dari nama Parent-nya sesuai struktur Tycoon)
            local isBase = obj.Parent.Name:find("Base") or obj.Parent.Name:find("Tycoon") or obj.Name == "Baseplate"
            
            -- 2. CEK: Pastikan bukan Karakter Pemain (Humanoid)
            local isNotHuman = obj.Parent:FindFirstChild("Humanoid") == nil
            
            if isBase and isNotHuman then
                -- Target hanya lantai atau bagian dalam gedung base
                if obj.Name:lower():find("floor") or obj.Name == "Baseplate" or obj.Name == "Part" then
                    obj.LocalTransparencyModifier = transparencyValue
                end
            else
                -- Objek selain markas (tembok merah, rumput, dll) dipaksa normal
                obj.LocalTransparencyModifier = 0
            end
        end
    end)
end

-- [[ SISTEM OTOMATIS ]] --

-- 1. Jalankan awal untuk objek yang sudah ada
for _, v in pairs(workspace:GetDescendants()) do
    ApplyXrayToBase(v)
end

-- 2. Jalankan otomatis untuk objek baru (Pas Abang beli upgrade markas)
workspace.DescendantAdded:Connect(function(newObj)
    task.wait(0.1) -- Kasih jeda dikit biar objeknya ke-load sempurna
    ApplyXrayToBase(newObj)
end)

print("X-Ray Markas Aktif & Otomatis.")

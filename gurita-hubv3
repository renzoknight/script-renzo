-- [[ GURITA HUB V64 - ADAPTIVE SILENT AIM ]] --

local lp = game.Players.LocalPlayer
local mouse = lp:GetMouse()
local camera = workspace.CurrentCamera
local PlayerGui = lp:WaitForChild("PlayerGui")
local NetFolder = game:GetService("ReplicatedStorage"):WaitForChild("Packages"):WaitForChild("Net")

_G.AutoAimPlayer = false

-- 1. CARI PLAYER TERDEKAT
local function GetClosestPlayer()
    local closest, dist = nil, 400
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = v.Character.HumanoidRootPart
            local pos, onScreen = camera:WorldToViewportPoint(hrp.Position)
            if onScreen then
                local mag = (Vector2.new(mouse.X, mouse.Y) - Vector2.new(pos.X, pos.Y)).Magnitude
                if mag < dist then
                    closest = hrp
                    dist = mag
                end
            end
        end
    end
    return closest
end

-- 2. HOOKING SISTEM (ADAPTIVE MODE)
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    
    -- Cek apakah Remote ini ada di dalam folder Net (tempat Remote acak tadi ngumpul)
    if _G.AutoAimPlayer and method == "FireServer" and self:IsDescendantOf(NetFolder) then
        -- Cek apakah argumennya mirip sama pola Web Slinger/Laser (Vector3 di index 1)
        if typeof(args[1]) == "Vector3" then
            local target = GetClosestPlayer()
            if target then
                -- SUNTIK POSISI: Ganti tujuan ke badan musuh
                args[1] = target.Position
                -- SUNTIK TARGET: Ganti objek yang kena (Carpet/Ground) jadi badan musuh
                args[2] = target
                
                return oldNamecall(self, unpack(args))
            end
        end
    end
    return oldNamecall(self, ...)
end)

-- 3. UI PANEL V64
if PlayerGui:FindFirstChild("GuritaV64") then PlayerGui.GuritaV64:Destroy() end
local SG = Instance.new("ScreenGui", PlayerGui); SG.Name = "GuritaV64"; SG.ResetOnSpawn = false

local Main = Instance.new("Frame", SG)
Main.Size = UDim2.new(0, 220, 0, 110); Main.Position = UDim2.new(0.5, -110, 0.05, 0)
Main.BackgroundColor3 = Color3.fromRGB(10, 10, 10); Instance.new("UICorner", Main)
local s = Instance.new("UIStroke", Main); s.Color = Color3.fromRGB(0, 170, 255); s.Thickness = 2

local Btn = Instance.new("TextButton", Main)
Btn.Size = UDim2.new(1, -20, 1, -20); Btn.Position = UDim2.new(0, 10, 0, 10)
Btn.Font = "GothamBlack"; Btn.TextSize = 14; Btn.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", Btn)

local function UpdateUI()
    Btn.Text = "AUTO AIM PLAYER: " .. (_G.AutoAimPlayer and "ON" or "OFF")
    Btn.BackgroundColor3 = _G.AutoAimPlayer and Color3.fromRGB(0, 120, 200) or Color3.fromRGB(150, 0, 0)
end

Btn.MouseButton1Down:Connect(function()
    _G.AutoAimPlayer = not _G.AutoAimPlayer
    UpdateUI()
end)

UpdateUI()
print("Gurita Hub V64 - Adaptive Silent Aim Ready!")

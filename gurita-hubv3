-- [[ GURITA HUB: EGG HUNT & ESP - FULL AUTO ]] --
-- Fitur: Auto Scan, HighLight ESP, Distance Tag, Sound Notif

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local StarterGui = game:GetService("StarterGui")

-- [[ 1. CONFIG TELOR TARGET ]] --
local TargetEggs = {
    "hydra bunny", "noo my eggs", "baskito", "churrito", 
    "quackini", "snackini", "bunny bunny sahur"
}

local NotifiedEggs = {} 

-- [[ 2. FUNGSI PASANG ESP (HIGHLIGHT & JARAK) ]] --
local function ApplyHuntESP(obj)
    -- Bersihkan jika sudah ada tanda lama
    if obj:FindFirstChild("HuntMarker") then obj.HuntMarker:Destroy() end
    if obj:FindFirstChild("HuntTag") then obj.HuntTag:Destroy() end

    -- Efek Glow Kuning
    local h = Instance.new("Highlight", obj)
    h.Name = "HuntMarker"
    h.FillColor = Color3.fromRGB(255, 255, 0)
    h.FillTransparency = 0.4
    h.OutlineColor = Color3.fromRGB(255, 255, 255)
    
    -- Label Jarak di Atas Telor
    local b = Instance.new("BillboardGui", obj)
    b.Name = "HuntTag"
    b.Size = UDim2.new(0, 150, 0, 50)
    b.AlwaysOnTop = true
    b.ExtentsOffset = Vector3.new(0, 3, 0)
    
    local t = Instance.new("TextLabel", b)
    t.Size = UDim2.new(1, 0, 1, 0)
    t.BackgroundTransparency = 1
    t.TextColor3 = Color3.new(1, 1, 0)
    t.Font = Enum.Font.GothamBlack
    t.TextSize = 14
    t.TextStrokeTransparency = 0

    -- Update Jarak secara Real-time
    task.spawn(function()
        while obj and obj.Parent do
            if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                local dist = math.floor((obj.Position - lp.Character.HumanoidRootPart.Position).Magnitude)
                t.Text = "✨ " .. obj.Name:upper() .. " ✨\n[" .. dist .. "m]"
            end
            task.wait(0.5)
        end
    end)
end

-- [[ 3. ENGINE SCANNER ]] --
local function ScanEggs()
    local all = workspace:GetDescendants()
    for i, v in pairs(all) do
        local name = v.Name:lower()
        if table.find(TargetEggs, name) then
            -- Pasang ESP
            ApplyHuntESP(v)
            
            -- Kasih Notifikasi & Suara (Hanya jika baru ketemu)
            if not NotifiedEggs[v] then
                NotifiedEggs[v] = true
                StarterGui:SetCore("SendNotification", {
                    Title = "🥚 EGG FOUND!",
                    Text = "Ketemu: " .. v.Name:upper(),
                    Duration = 5
                })
                
                -- Bunyi Notif
                local s = Instance.new("Sound", game:GetService("SoundService"))
                s.SoundId = "rbxassetid://4590662762"
                s:Play()
                
                -- Reset data kalau telornya diambil/hilang
                v.AncestryChanged:Connect(function(_, p)
                    if not p then NotifiedEggs[v] = nil end
                end)
            end
        end
        -- Jeda scan biar nggak lag
        if i % 150 == 0 then task.wait() end 
    end
end

-- [[ 4. RUNTIME (AUTO EXECUTE) ]] --
-- Scan saat baru inject
task.spawn(ScanEggs)

-- Scan setiap 10 detik (buat telor yang baru spawn)
task.spawn(function()
    while true do
        ScanEggs()
        task.wait(10)
    end
end)

-- Pantau part baru yang masuk ke workspace (StreamingEnabled Safe)
workspace.DescendantAdded:Connect(function(v)
    if table.find(TargetEggs, v.Name:lower()) then
        task.wait(0.5) -- Tunggu part ke-load sempurna
        ApplyHuntESP(v)
    end
end)

print("GURITA HUB: Egg Hunt & ESP Active!")

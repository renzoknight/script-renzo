-- [[ GURITA HUB V61 - UNIVERSAL REMOTE AIM ]] --

local lp = game.Players.LocalPlayer
local mouse = lp:GetMouse()
local camera = workspace.CurrentCamera
local PlayerGui = lp:WaitForChild("PlayerGui")

_G.AutoAimPlayer = false

-- 1. CARI TARGET PLAYER TERDEKAT
local function GetClosestPlayer()
    local closest, dist = nil, 400
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = v.Character.HumanoidRootPart
            local pos, onScreen = camera:WorldToViewportPoint(hrp.Position)
            if onScreen then
                local mag = (Vector2.new(mouse.X, mouse.Y) - Vector2.new(pos.X, pos.Y)).Magnitude
                if mag < dist then
                    closest = hrp
                    dist = mag
                end
            end
        end
    end
    return closest
end

-- 2. HOOK SEMUA REMOTE YANG DIAWALI "RE/"
-- Karena di foto SimpleSpy Abang, hampir semua namanya diawali "RE/"
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    
    if _G.AutoAimPlayer and method == "FireServer" and self.Name:sub(1,3) == "RE/" then
        local target = GetClosestPlayer()
        if target then
            -- Cari argumen Vector3 (Posisi) dan Part (Target) di dalam data tembakan
            for i, v in pairs(args) do
                if typeof(v) == "Vector3" then
                    args[i] = target.Position
                elseif typeof(v) == "Instance" and (v:IsA("BasePart") or v:IsA("Model")) then
                    args[i] = target
                end
            end
            return oldNamecall(self, unpack(args))
        end
    end
    return oldNamecall(self, ...)
end)


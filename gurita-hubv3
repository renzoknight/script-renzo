-- [[ GURITA HUB - AUTO AIM PLAYER V3 LIGHT ]] --

local lp = game.Players.LocalPlayer
local mouse = lp:GetMouse()
local camera = workspace.CurrentCamera
local PlayerGui = lp:WaitForChild("PlayerGui")

_G.AutoAimPlayer = false

-- 1. CARI PLAYER TERDEKAT (OPTIMIZED)
local function GetTarget()
    local closest, dist = nil, 300
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = v.Character.HumanoidRootPart
            local pos, onScreen = camera:WorldToViewportPoint(hrp.Position)
            
            if onScreen then
                local mag = (Vector2.new(mouse.X, mouse.Y) - Vector2.new(pos.X, pos.Y)).Magnitude
                if mag < dist then
                    closest = hrp
                    dist = mag
                end
            end
        end
    end
    return closest
end

-- 2. AUTO AIM PAS KLIK (RINGAN)
local function DoAim()
    if _G.AutoAimPlayer then
        local target = GetTarget()
        if target then
            -- Gerakin kamera dikit ke target pas klik biar slinger/laser auto kena
            camera.CFrame = CFrame.new(camera.CFrame.Position, target.Position)
        end
    end
end

-- Deteksi Klik (Biar gak nyecan terus-terusan, cuma pas klik aja)
mouse.Button1Down:Connect(DoAim)


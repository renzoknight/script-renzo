local lp = game.Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local HttpService = game:GetService("HttpService")
local FileName = "GuritaHubV55.json"

-- 1. SAVE/LOAD SYSTEM
local function SaveSettings()
    if writefile then 
        local data = { HuntingMode = _G.HuntingMode, NotifMode = _G.NotifMode }
        pcall(function() writefile(FileName, HttpService:JSONEncode(data)) end) 
    end
end

local function LoadSettings()
    if isfile and isfile(FileName) then
        local s, res = pcall(function() return HttpService:JSONDecode(readfile(FileName)) end)
        if s then 
            _G.HuntingMode = res.HuntingMode
            _G.NotifMode = res.NotifMode
            return
        end
    end
    _G.HuntingMode = false
    _G.NotifMode = false
end
LoadSettings()

-- 2. LIGHTING & OPTIMIZE (SOFT)
local function SmoothOptimize()
    task.spawn(function()
        settings().Rendering.QualityLevel = 1
        local lighting = game:GetService("Lighting")
        lighting.GlobalShadows = false
        lighting.Brightness = 1
        lighting.Ambient = Color3.fromRGB(130, 130, 130)
        lighting.OutdoorAmbient = Color3.fromRGB(130, 130, 130)
        for i, v in pairs(workspace:GetDescendants()) do
            if i % 300 == 0 then task.wait() end 
            if v:IsA("BasePart") then v.Material = Enum.Material.Plastic; v.Reflectance = 0
            elseif v:IsA("Decal") or v:IsA("Texture") then v:Destroy() end
        end
    end)
end


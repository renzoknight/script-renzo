if PlayerGui:FindFirstChild("GuritaV60") then PlayerGui.GuritaV60:Destroy() end
local SG = Instance.new("ScreenGui", PlayerGui); SG.Name = "GuritaV60"; SG.ResetOnSpawn = false

local Main = Instance.new("Frame", SG)
Main.Size = UDim2.new(0, 200, 0, 100); Main.Position = UDim2.new(0.5, -100, 0.1, 0)
Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Instance.new("UICorner", Main)
local s = Instance.new("UIStroke", Main); s.Color = Color3.fromRGB(0, 170, 255); s.Thickness = 2

local Btn = Instance.new("TextButton", Main)
Btn.Size = UDim2.new(1, -20, 1, -20); Btn.Position = UDim2.new(0, 10, 0, 10)
Btn.Font = "GothamBlack"; Btn.TextSize = 14; Btn.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", Btn)

local function UpdateUI()
    Btn.Text = "AUTO AIM: " .. (_G.AutoAimPlayer and "ON" or "OFF")
    Btn.BackgroundColor3 = _G.AutoAimPlayer and Color3.fromRGB(0, 150, 100) or Color3.fromRGB(150, 0, 0)
end

Btn.MouseButton1Down:Connect(function()
    _G.AutoAimPlayer = not _G.AutoAimPlayer
    UpdateUI()
end)

UpdateUI()
print("Gurita Hub V60 Loaded - Target: " .. RemoteName)

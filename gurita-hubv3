-- [[ GURITA HUB V65 - MOUSE OBJECT OVERRIDE ]] --

local lp = game.Players.LocalPlayer
local mouse = lp:GetMouse()
local camera = workspace.CurrentCamera
local PlayerGui = lp:WaitForChild("PlayerGui")

_G.AutoAimPlayer = false

-- 1. CARI PLAYER TERDEKAT (KHUSUS YANG DI LAYAR)
local function GetClosestPlayer()
    local closest, dist = nil, 400
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = v.Character.HumanoidRootPart
            local pos, onScreen = camera:WorldToViewportPoint(hrp.Position)
            if onScreen then
                local mag = (Vector2.new(mouse.X, mouse.Y) - Vector2.new(pos.X, pos.Y)).Magnitude
                if mag < dist then
                    closest = hrp
                    dist = mag
                end
            end
        end
    end
    return closest
end

-- 2. OVERRIDE MOUSE INPUT (BUKAN REMOTE HOOK)
-- Cara ini bikin laser tetep keluar karena kita nggak otak-atik Remotenya
local mt = getrawmetatable(game)
local oldIndex = mt.__index
setreadonly(mt, false)

mt.__index = newcclosure(function(self, index)
    if _G.AutoAimPlayer and not checkcaller() then
        if self == mouse then
            local target = GetClosestPlayer()
            if target then
                if index == "Hit" then
                    return target.CFrame -- Nipu posisi tembakan
                elseif index == "Target" then
                    return target -- Nipu benda yang kena
                end
            end
        end
    end
    return oldIndex(self, index)
end)

-- 3. UI PANEL V65 (MODERN & SIMPLE)
if PlayerGui:FindFirstChild("GuritaV65") then PlayerGui.GuritaV65:Destroy() end
local SG = Instance.new("ScreenGui", PlayerGui); SG.Name = "GuritaV65"; SG.ResetOnSpawn = false

local Main = Instance.new("Frame", SG)
Main.Size = UDim2.new(0, 200, 0, 100); Main.Position = UDim2.new(0.5, -100, 0.05, 0)
Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Instance.new("UICorner", Main)
local s = Instance.new("UIStroke", Main); s.Color = Color3.fromRGB(0, 170, 255); s.Thickness = 2

local Btn = Instance.new("TextButton", Main)
Btn.Size = UDim2.new(1, -20, 1, -20); Btn.Position = UDim2.new(0, 10, 0, 10)
Btn.Font = "GothamBlack"; Btn.TextSize = 14; Btn.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", Btn)

local function UpdateUI()
    Btn.Text = "AUTO AIM: " .. (_G.AutoAimPlayer and "ACTIVE" or "OFF")
    Btn.BackgroundColor3 = _G.AutoAimPlayer and Color3.fromRGB(0, 120, 200) or Color3.fromRGB(150, 0, 0)
end

Btn.MouseButton1Down:Connect(function()
    _G.AutoAimPlayer = not _G.AutoAimPlayer
    UpdateUI()
end)

UpdateUI()
print("Gurita Hub V65 - Mouse Override Loaded!")

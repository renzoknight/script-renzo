-- [[ GURITA HUB - AUTO AIM PLAYER TESTER ]] --

local lp = game.Players.LocalPlayer
local mouse = lp:GetMouse()
local PlayerGui = lp:WaitForChild("PlayerGui")

-- Variable Kontrol
_G.AutoAimPlayer = false

-- 1. LOGIKA PENCARI TARGET (KHUSUS PLAYER)
local function GetTarget()
    local closest, dist = nil, 400 -- Jarak FOV (radius kunci di layar)
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = v.Character.HumanoidRootPart
            local pos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(hrp.Position)
            
            if onScreen then
                local mag = (Vector2.new(mouse.X, mouse.Y) - Vector2.new(pos.X, pos.Y)).Magnitude
                if mag < dist then
                    closest = hrp
                    dist = mag
                end
            end
        end
    end
    return closest
end

-- 2. SISTEM MEMBELOKKAN TEMBAKAN (NAME_CALL HOOK)
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    
    if _G.AutoAimPlayer and (method == "FireServer" or method == "InvokeServer") then
        local target = GetTarget()
        if target then
            -- Cari argumen Vector3 (posisi tembakan) dan paksa ke badan target
            for i, arg in pairs(args) do
                if typeof(arg) == "Vector3" then
                    args[i] = target.Position
                end
            end
        end
    end
    return oldNamecall(self, unpack(args))
end)


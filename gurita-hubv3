local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")
local HttpService = game:GetService("HttpService")

-- 1. SISTEM AUTO-SAVE (Langsung Simpan Pas Diklik)
local filename = "GuritaConfig_V3.json"
_G.Settings = {
    ESP = false,
    Xray = false
}

local function SaveSettings()
    if writefile then
        writefile(filename, HttpService:JSONEncode(_G.Settings))
    end
end

local function LoadSettings()
    if isfile and isfile(filename) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(filename)) end)
        if success then _G.Settings = data end
    end
end

LoadSettings() -- Ambil settingan lama pas start

-- 2. FUNGSI PROTEKSI & FLAT COLOR (BAWAAN KODE ABANG)
local function IsSafe(v)
    local name = v.Name:lower()
    if name:find("floor") or name:find("lantai") or name:find("grass") or name:find("terrain") then return true end
    if v:IsDescendantOf(lp.Character) or v.Parent:FindFirstChild("Humanoid") then return true end
    return false
end

local function ApplyFlat(v)
    pcall(function()
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            if not IsSafe(v) then
                v.Material = Enum.Material.Plastic
                v.CastShadow = false
                if v:IsA("MeshPart") then v.TextureID = "" end
            end
        end
    end)
end

local function DoXray()
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and not IsSafe(v) then
            local name = v.Name:lower()
            if name:find("wall") or name:find("base") or name:find("door") or name:find("roof") then
                v.Transparency = _G.Settings.Xray and 0.5 or 0
            end
        end
    end
end


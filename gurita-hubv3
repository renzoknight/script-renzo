-- [[ GURITA HUB - AUTO AIM PLAYER TESTER V2 ]] --

local lp = game.Players.LocalPlayer
local mouse = lp:GetMouse()
local PlayerGui = lp:WaitForChild("PlayerGui")

_G.AutoAimPlayer = false

-- 1. LOGIKA CARI PLAYER TERDEKAT
local function GetClosestPlayer()
    local closest, dist = nil, 400
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = v.Character.HumanoidRootPart
            local pos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(hrp.Position)
            
            if onScreen then
                local mag = (Vector2.new(mouse.X, mouse.Y) - Vector2.new(pos.X, pos.Y)).Magnitude
                if mag < dist then
                    closest = hrp
                    dist = mag
                end
            end
        end
    end
    return closest
end

-- 2. REDIRECT MOUSE TARGET (CARA BARU)
-- Ini bakal maksa mouse.Target seolah-olah lagi nempel di musuh pas klik
local oldIndex
oldIndex = hookmetamethod(game, "__index", function(self, index)
    if self == mouse and index == "Target" and _G.AutoAimPlayer then
        local t = GetClosestPlayer()
        if t then return t end
    end
    if self == mouse and index == "Hit" and _G.AutoAimPlayer then
        local t = GetClosestPlayer()
        if t then return t.CFrame end
    end
    return oldIndex(self, index)
end)


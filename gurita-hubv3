-- 5. ESP LOGIC
local function PasangESP(obj)
    if not _G.HuntingMode or obj:FindFirstChild("GuritaTag") then return end
    task.spawn(function()
        task.wait(1.5)
        local name = obj.Name:lower()
        if name == "part" or name == "model" then return end
        local pos = (obj:IsA("Model") and obj.PrimaryPart) and obj.PrimaryPart.Position or (obj:IsA("BasePart") and obj.Position)
        if not pos or pos.Y < 100 then return end

        local tipe = nil
        for _, r in pairs(SuperRare) do if name:find(r) then tipe = "rare"; break end end
        if not tipe then for _, e in pairs(NormalTargets) do if name:find(e) then tipe = "normal"; break end end end
        if not tipe then return end

        if tipe == "rare" and _G.NotifMode and not NotifHistory[obj.Name] then
            NotifHistory[obj.Name] = true
            table.insert(NotifQueue, obj.Name)
        end

        local col = (tipe == "rare") and Color3.new(1, 0, 0) or Color3.fromRGB(0, 170, 255)
        local b = Instance.new("BillboardGui", obj)
        b.Name = "GuritaTag"; b.Size = UDim2.new(0, 180, 0, 45); b.AlwaysOnTop = true; b.MaxDistance = math.huge
        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = col
        t.Font = "GothamBlack"; t.TextSize = 12; t.TextStrokeTransparency = 0.3
        
        while obj and obj.Parent and _G.HuntingMode do
            local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if hrp then t.Text = obj.Name:upper() .. "\n[" .. math.floor((hrp.Position - pos).Magnitude) .. "s]" end
            task.wait(2)
        end
        if b then b:Destroy() end
    end)
end


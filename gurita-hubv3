local function CreateBtn(txt, pos, cb)
    local b = Instance.new("TextButton", Main); b.Size = UDim2.new(0.9, 0, 0, 35); b.Position = pos; b.BackgroundColor3 = Color3.fromRGB(0, 160, 255); b.BackgroundTransparency = 0.8; b.TextColor3 = Color3.new(1,1,1); b.Font = Enum.Font.GothamBold; b.TextSize = 10; b.Text = txt; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function() cb(b) end) return b
end

-- Toggles
_G.TracerActive = false
_G.XrayActive = false

-- 2. FUNGSI VISUAL FIX (WARNA ASLI + FLAT)
local function ApplyVisual(v)
    if v:IsA("BasePart") or v:IsA("MeshPart") then
        -- Blacklist Player & Ava
        if v:IsDescendantOf(lp.Character) or v.Parent:FindFirstChild("Humanoid") then return end

        local name = v.Name:lower()
        
        -- FLAT COLOR: Cuma ganti Material, JANGAN ganti Color (Biar gak biru/pelangi)
        v.Material = Enum.Material.Plastic
        if v:IsA("MeshPart") then v.TextureID = "" end
        v.CastShadow = false

        -- XRAY LOGIC
        if _G.XrayActive then
            if name:find("wall") or name:find("base") or name:find("dinding") or name:find("roof") then
                v.Transparency = 0.5
            end
        else
            if name:find("wall") or name:find("base") or name:find("dinding") or name:find("roof") then
                v.Transparency = 0
            end
        end

        -- Hapus Rumput pengganggu
        if name:find("grass") or name:find("leaf") then
            v.Transparency = 1
        end
    end
end

-- 3. TRACER BIRU (STABIL)
local function AddTracer(plr)
    local Line = Drawing.new("Line")
    Line.Visible = false; Line.Color = Color3.fromRGB(0, 160, 255); Line.Thickness = 1.5
    
    RunService.RenderStepped:Connect(function()
        if _G.TracerActive and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local pos, onScreen = Camera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position)
            if onScreen then
                Line.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                Line.To = Vector2.new(pos.X, pos.Y); Line.Visible = true
            else Line.Visible = false end
        else Line.Visible = false end
    end)
end

-- 4. TOMBOL MENU
CreateBtn("TRACER BIRU: OFF", UDim2.new(0.05, 0, 0.2, 0), function(b)
    _G.TracerActive = not _G.TracerActive
    b.Text = _G.TracerActive and "TRACER: ON" or "TRACER BIRU: OFF"
end)

CreateBtn("XRAY BASE: OFF", UDim2.new(0.05, 0, 0.6, 0), function(b)
    _G.XrayActive = not _G.XrayActive
    b.Text = _G.XrayActive and "XRAY: ON" or "XRAY BASE: OFF"
    for _, v in pairs(workspace:GetDescendants()) do ApplyVisual(v) end
end)

-- INIT
for _, p in pairs(Players:GetPlayers()) do if p ~= lp then AddTracer(p) end end

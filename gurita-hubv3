-- [[ GURITA HUB - SILENT AIM PLAYER V4 ]] --

local lp = game.Players.LocalPlayer
local mouse = lp:GetMouse()
local camera = workspace.CurrentCamera
local PlayerGui = lp:WaitForChild("PlayerGui")

_G.AutoAimPlayer = false

-- 1. CARI PLAYER TERDEKAT (FOV 300)
local function GetClosestPlayer()
    local closest, dist = nil, 300
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = v.Character.HumanoidRootPart
            local pos, onScreen = camera:WorldToViewportPoint(hrp.Position)
            
            if onScreen then
                local mag = (Vector2.new(mouse.X, mouse.Y) - Vector2.new(pos.X, pos.Y)).Magnitude
                if mag < dist then
                    closest = hrp
                    dist = mag
                end
            end
        end
    end
    return closest
end

-- 2. SILENT AIM LOGIC (Membelokkan Mouse Target & Hit)
local oldIndex
oldIndex = hookmetamethod(game, "__index", function(self, index)
    if not checkcaller() and _G.AutoAimPlayer and self == mouse then
        local target = GetClosestPlayer()
        if target then
            if index == "Target" then
                return target
            elseif index == "Hit" then
                return target.CFrame
            end
        end
    end
    return oldIndex(self, index)
end)


-- 4. TRACER LOGIC
local function CreateSmartESP(plr)
    local Line = Drawing.new("Line")
    Line.Visible = false; Line.Color = Color3.fromRGB(0, 160, 255); Line.Thickness = 1.5
    RunService.RenderStepped:Connect(function()
        if _G.Settings.ESP and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local Root = plr.Character.HumanoidRootPart
            local Pos, OnScreen = Camera:WorldToViewportPoint(Root.Position)
            if OnScreen then
                Line.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                Line.To = Vector2.new(Pos.X, Pos.Y); Line.Visible = true
            else Line.Visible = false end
        else Line.Visible = false end
    end)
end

-- 5. EXECUTION
task.spawn(function()
    local d = workspace:GetDescendants()
    for i = 1, #d do ApplyFlat(d[i]) if i % 250 == 0 then task.wait() end end
    DoXray() -- Jalankan xray kalo di settingan lama emang ON
end)

workspace.DescendantAdded:Connect(ApplyFlat)
for _, p in ipairs(Players:GetPlayers()) do if p ~= lp then CreateSmartESP(p) end end
Players.PlayerAdded:Connect(CreateSmartESP)

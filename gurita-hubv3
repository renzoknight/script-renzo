-- [[ X-RAY KHUSUS GEDUNG MARKAS - BUKAN MAP ]] --

local _G = getgenv and getgenv() or _G
_G.XrayMarkas = false

-- Fungsi untuk mengatur bening/tidaknya gedung
local function UpdateVisual(obj, state)
    pcall(function()
        if obj:IsA("BasePart") then
            -- KUNCI TELITI: Cari apakah part ini milik folder "Base" atau "Tycoon"
            -- Kita cek dari nama Parent-nya (Gedung Markas)
            local isGedungMarkas = obj.Parent.Name:find("Base") or obj.Parent.Name:find("Tycoon")
            local bukanOrang = obj.Parent:FindFirstChild("Humanoid") == nil
            
            if isGedungMarkas and bukanOrang then
                -- Hanya bikin bening gedung markas
                obj.LocalTransparencyModifier = state and 0.7 or 0
            else
                -- Selain gedung markas (rumput, jalan, pembatas map) TETAP PADAT
                obj.LocalTransparencyModifier = 0
            end
        end
    end)
end

-- UI SIMPEL ON/OFF
local CG = game:GetService("CoreGui")
if CG:FindFirstChild("MarkasXrayUI") then CG.MarkasXrayUI:Destroy() end

local SG = Instance.new("ScreenGui", CG); SG.Name = "MarkasXrayUI"
local Btn = Instance.new("TextButton", SG)
Btn.Size = UDim2.new(0, 140, 0, 50); Btn.Position = UDim2.new(0, 10, 0.5, 0); Btn.Font = Enum.Font.GothamBold; Btn.TextSize = 14; Btn.Draggable = true; Btn.Active = true
Instance.new("UICorner", Btn)

local function ToggleUI()
    Btn.Text = _G.XrayMarkas and "X-RAY MARKAS: ON" or "X-RAY MARKAS: OFF"
    Btn.BackgroundColor3 = _G.XrayMarkas and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(200, 50, 50)
    Btn.TextColor3 = Color3.new(1,1,1)
end

Btn.MouseButton1Click:Connect(function()
    _G.XrayMarkas = not _G.XrayMarkas
    ToggleUI()
    -- Scan ulang semua objek biar efeknya ganti
    for _, v in pairs(workspace:GetDescendants()) do
        UpdateVisual(v, _G.XrayMarkas)
    end
end)

ToggleUI()

-- SISTEM OTOMATIS (Biar pas beli gedung baru langsung bening)
workspace.DescendantAdded:Connect(function(newPart)
    if _G.XrayMarkas then
        task.wait(0.2) -- Jeda biar part-nya muncul dulu
        UpdateVisual(newPart, true)
    end
end)

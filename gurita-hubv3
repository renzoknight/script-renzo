-- [[ GURITA HUB V3.6 - FLAT COLOR & RAINBOW STABLE ]] --

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")
local HttpService = game:GetService("HttpService")

-- 1. SISTEM CONFIG
local filename = "GuritaEzra_V36.json"
_G.Settings = { ESP = false, Xray = false }

local function SaveSettings()
    if writefile then
        pcall(function() writefile(filename, HttpService:JSONEncode(_G.Settings)) end)
    end
end

local function LoadSettings()
    if isfile and isfile(filename) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(filename)) end)
        if success and data then _G.Settings = data end
    end
end
LoadSettings()

-- 2. PROTEKSI LANTAI (ANTI ABU-ABU)
local function IsSafe(v)
    if not v:IsA("BasePart") then return true end
    local name = v.Name:lower()
    -- Cek nama objek agar warna asli lantai tidak berubah
    if name:find("floor") or name:find("lantai") or name:find("grass") or name:find("terrain") or name:find("ground") then
        return true
    end
    if v:IsDescendantOf(lp.Character) or (v.Parent and v.Parent:FindFirstChild("Humanoid")) then
        return true
    end
    return false
end

-- 3. FITUR FLAT COLOR (DIBALIKIN LAGI)
local function ApplyFlat(v)
    pcall(function()
        if (v:IsA("BasePart") or v:IsA("MeshPart")) and not IsSafe(v) then
            v.Material = Enum.Material.Plastic -- Jadi polosan (Flat)
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end -- Hapus tekstur mesh
        end
    end)
end

-- 4. XRAY & ESP LOGIC
local function RefreshXray()
    task.spawn(function()
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and not IsSafe(v) then
                local n = v.Name:lower()
                if n:find("wall") or n:find("base") or n:find("door") or n:find("roof") then
                    v.Transparency = _G.Settings.Xray and 0.5 or 0
                end
            end
        end
    end)
end

local function CreateTracer(plr)
    local Line = Drawing.new("Line")
    Line.Visible = false; Line.Thickness = 1.5
    RunService.RenderStepped:Connect(function()
        if _G.Settings.ESP and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local pos, onScreen = Camera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position)
            if onScreen then
                Line.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                Line.To = Vector2.new(pos.X, pos.Y); Line.Visible = true
                Line.Color = Color3.fromHSV(tick() % 5 / 5, 0.8, 1) -- Tracer Pelangi
            else Line.Visible = false end
        else Line.Visible = false end
    end)
end

-- 5. UI: RAINBOW LOGO & MENU
local SG = Instance.new("ScreenGui")
SG.Name = "GuritaV36"
SG.ResetOnSpawn = false
local guiParent = pcall(function() return game:GetService("CoreGui") end) and game:GetService("CoreGui") or lp:WaitForChild("PlayerGui")
SG.Parent = guiParent

-- Logo GH Rainbow
local LogoFrame = Instance.new("Frame", SG)
LogoFrame.Size = UDim2.new(0, 50, 0, 50); LogoFrame.Position = UDim2.new(0, 15, 0.45, 0)
LogoFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 20); LogoFrame.Active = true; LogoFrame.Draggable = true
Instance.new("UICorner", LogoFrame).CornerRadius = UDim.new(1, 0)
local LogoStroke = Instance.new("UIStroke", LogoFrame); LogoStroke.Thickness = 3

local LogoBtn = Instance.new("TextButton", LogoFrame)
LogoBtn.Size = UDim2.new(1, 0, 1, 0); LogoBtn.BackgroundTransparency = 1
LogoBtn.Text = "GH"; LogoBtn.TextColor3 = Color3.new(1, 1, 1)
LogoBtn.Font = Enum.Font.GothamBold; LogoBtn.TextSize = 20

-- Main Menu
local Main = Instance.new("Frame", SG)
Main.Size = UDim2.new(0, 220, 0, 150); Main.Position = UDim2.new(0, 80, 0.45, -75)
Main.BackgroundColor3 = Color3.fromRGB(12, 12, 18); Main.Visible = false; Main.Active = true; Main.Draggable = true
Instance.new("UICorner", Main)
local MainStroke = Instance.new("UIStroke", Main); MainStroke.Thickness = 3

LogoBtn.MouseButton1Click:Connect(function() Main.Visible = not Main.Visible end)

local function CreateBtn(txt, pos, cb)
    local b = Instance.new("TextButton", Main); b.Size = UDim2.new(0.9, 0, 0, 40); b.Position = pos; b.BackgroundColor3 = Color3.fromRGB(25, 25, 35); b.Text = txt; b.TextColor3 = Color3.new(1,1,1); b.Font = Enum.Font.GothamBold; b.TextSize = 11; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function() cb(b) end) return b
end

local btnESP = CreateBtn(_G.Settings.ESP and "ESP: ON" or "ESP: OFF", UDim2.new(0.05, 0, 0.2, 0), function(b)
    _G.Settings.ESP = not _G.Settings.ESP
    b.Text = _G.Settings.ESP and "ESP: ON" or "ESP: OFF"
    SaveSettings()
end)

local btnXray = CreateBtn(_G.Settings.Xray and "XRAY: ON" or "XRAY: OFF", UDim2.new(0.05, 0, 0.6, 0), function(b)
    _G.Settings.Xray = not _G.Settings.Xray
    b.Text = _G.Settings.Xray and "XRAY: ON" or "XRAY: OFF"
    RefreshXray(); SaveSettings()
end)

-- 6. ANIMASI RAINBOW & RUNNER
RunService.RenderStepped:Connect(function()
    local color = Color3.fromHSV(tick() % 5 / 5, 0.9, 1)
    LogoStroke.Color = color
    MainStroke.Color = color
end)

task.spawn(function()
    local d = workspace:GetDescendants()
    for i = 1, #d do 
        ApplyFlat(d[i]) 
        if i % 300 == 0 then task.wait() end 
    end
    if _G.Settings.Xray then RefreshXray() end
end)

workspace.DescendantAdded:Connect(ApplyFlat)
for _, p in ipairs(Players:GetPlayers()) do if p ~= lp then CreateTracer(p) end end
Players.PlayerAdded:Connect(CreateTracer)

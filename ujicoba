local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local RunService = game:GetService("RunService")

-- Database Nama Egg
local EggNames = {
    "Hydra Bunny", "Noo my Eggs", "Sahur", "Easter", 
    "Eggdin", "Buntteo", "Baskito", "Churrito", 
    "Tralala", "Bunny Bunny", "Dun Egg"
}

_G.AutoCollectCoin_EHS = false
_G.AutoESP_Egg_EHS = false

-- 1. FUNGSI OPTIMASI (Cek Base Kilat)
local function IsInPlayerBase(v)
    local p = v.Parent
    if not p then return false end
    local n = p.Name:lower()
    -- Cek 2 level aja biar gak makan CPU
    if n:find("base") or n:find("plot") or n:find("house") then return true end
    local pp = p.Parent
    if pp and (pp.Name:lower():find("base") or pp.Name:lower():find("plot")) then return true end
    return false
end

-- 2. ESP EGG (Sistem Sekali Pasang)
local function CreateTag(v, name)
    if v:FindFirstChild("EHSTag") then return end
    local bg = Instance.new("BillboardGui", v)
    bg.Name = "EHSTag"; bg.AlwaysOnTop = true; bg.Size = UDim2.new(0, 150, 0, 40); bg.ExtentsOffset = Vector3.new(0, 3, 0)
    local lbl = Instance.new("TextLabel", bg)
    lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1
    lbl.Text = "<b>[EGG] " .. name .. "</b>"; lbl.RichText = true; lbl.TextColor3 = Color3.fromRGB(0, 170, 255)
    lbl.TextSize = 15; lbl.Font = Enum.Font.GothamBold; lbl.TextStrokeTransparency = 0.5
end

local function ScanMap()
    if not _G.AutoESP_Egg_EHS then return end
    -- Hanya scan objek yang ada di Workspace (bukan dalam folder dalam)
    for _, v in ipairs(workspace:GetChildren()) do
        if (v:IsA("BasePart") or v:IsA("Model")) and not IsInPlayerBase(v) then
            local objName = v.Name:lower()
            for _, name in ipairs(EggNames) do
                if objName:find(name:lower()) then
                    local target = v:IsA("Model") and (v:FindFirstChild("Handle") or v:FindFirstChildWhichIsA("BasePart")) or v
                    if target then CreateTag(target, name) end
                    break
                end
            end
        end
    end
end

-- 3. AUTO COLLECT COIN (Sistem Radius - ANTI LAG)
local function AutoCollectCoin()
    task.spawn(function()
        while _G.AutoCollectCoin_EHS do
            local char = lp.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                -- Scan koin di sekitar aja (Radius 500 studs) biar gak lag
                for _, v in ipairs(workspace:GetChildren()) do
                    if v:IsA("BasePart") and v.Name:lower():find("coin") and v:FindFirstChild("TouchInterest") then
                        if (v.Position - root.Position).Magnitude < 500 and not IsInPlayerBase(v) then
                            root.CFrame = v.CFrame
                            task.wait(0.2) -- Jeda biar server gak kaget
                            if not _G.AutoCollectCoin_EHS then break end
                        end
                    end
                end
            end
            task.wait(1.5)
        end
    end)
end


-- 1. DATABASE NAMA EGG LENGKAP (SESUAI LIST ABANG)
local EggNames = {
    "Hydra Bunny", "Noo my Eggs", "Sahur", "Easter", 
    "Eggdin", "Buntteo", "Baskito", "Churrito", 
    "Tralala", "Bunny Bunny", "Dun Egg"
}

_G.AutoCollectCoin_EHS = false
_G.AutoESP_Egg_EHS = false

-- 2. FILTER LOKASI (MAP ONLY)
local function IsInPlayerBase(v)
    local p = v.Parent
    while p and p ~= workspace do
        local n = p.Name:lower()
        if n:find("base") or n:find("plot") or n:find("house") then
            return true
        end
        p = p.Parent
    end
    return false
end

-- 3. ESP EGG HUNT (MAP ONLY)
local function ApplyEggESP()
    if not _G.AutoESP_Egg_EHS then return end
    for _, v in pairs(workspace:GetDescendants()) do
        if (v:IsA("BasePart") or v:IsA("MeshPart")) and not IsInPlayerBase(v) then
            local objName = v.Name:lower()
            local foundName = ""
            
            for _, name in pairs(EggNames) do
                if objName:find(name:lower()) then
                    foundName = name
                    break
                end
            end

            if foundName ~= "" and not v:FindFirstChild("EHSTag") then
                local bg = Instance.new("BillboardGui", v)
                bg.Name = "EHSTag"; bg.AlwaysOnTop = true; bg.Size = UDim2.new(0, 200, 0, 50); bg.ExtentsOffset = Vector3.new(0, 3, 0)
                local lbl = Instance.new("TextLabel", bg)
                lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1
                lbl.Text = "<b>[EHS] " .. foundName .. "</b>"
                lbl.RichText = true; lbl.TextColor3 = Color3.fromRGB(0, 170, 255)
                lbl.TextSize = 18; lbl.Font = Enum.Font.GothamBold; lbl.TextStrokeTransparency = 0
            end
        end
    end
end

-- 4. AUTO COLLECT KOIN (BIAR GACOR)
local function AutoCollectCoin()
    task.spawn(function()
        while _G.AutoCollectCoin_EHS do
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("BasePart") and v:FindFirstChild("TouchInterest") and not IsInPlayerBase(v) then
                    if v.Name:lower():find("coin") then
                        if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                            lp.Character.HumanoidRootPart.CFrame = v.CFrame
                            task.wait(0.1)
                        end
                    end
                end
            end
            task.wait(0.5)
        end
    end)
end


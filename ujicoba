local function IsPlayer(v)
    return v:IsDescendantOf(lp.Character) or (v.Parent and v.Parent:FindFirstChild("Humanoid"))
end

local function ApplyFlat(v)
    pcall(function()
        if (v:IsA("BasePart") or v:IsA("MeshPart")) and not IsPlayer(v) then
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
            for _, tex in pairs(v:GetChildren()) do
                if tex:IsA("Texture") or tex:IsA("Decal") then tex:Destroy() end
            end
        end
    end)
end

local function CustomNotif(eggName)
    local sg = lp.PlayerGui:FindFirstChild("EHS_Notif") or Instance.new("ScreenGui", lp.PlayerGui)
    sg.Name = "EHS_Notif"
    local frame = Instance.new("Frame", sg)
    frame.Size = UDim2.new(0, 240, 0, 40); frame.Position = UDim2.new(0.5, -120, -0.1, 0)
    frame.BackgroundColor3 = Color3.fromRGB(15, 20, 35); frame.BorderSizePixel = 0
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)
    local stroke = Instance.new("UIStroke", frame); stroke.Color = Color3.fromRGB(0, 150, 255); stroke.Thickness = 2
    local txt = Instance.new("TextLabel", frame)
    txt.Size = UDim2.new(1, 0, 1, 0); txt.BackgroundTransparency = 1; txt.Font = Enum.Font.GothamBold; txt.TextSize = 10; txt.TextColor3 = Color3.new(1, 1, 1); txt.Text = "📩 VIP DETECTED: " .. eggName:upper()
    local sound = Instance.new("Sound", workspace); sound.SoundId = "rbxassetid://4835664299"; sound.Volume = 1; sound:Play()
    game:GetService("Debris"):AddItem(sound, 2)
    frame:TweenPosition(UDim2.new(0.5, -120, 0.05, 0), "Out", "Back", 0.5, true)
    task.delay(4, function() if frame then frame:TweenPosition(UDim2.new(0.5, -120, -0.2, 0), "In", "Linear", 0.5, true); task.wait(0.5); frame:Destroy() end end)
end


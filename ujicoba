local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local RunService = game:GetService("RunService")

-- 1. DATABASE NAMA EGG (FIXED LIST)
local EggNames = {
    "Hydra Bunny", "Noo my Eggs", "Bunny Sahur", "Easter", 
    "Eggdin", "Buntteo", "Baskito", "Churrito", 
    "Tralala", "Bunny Bunny", "Dun Egg"
}

_G.AutoCollectCoin_EHS = false
_G.AutoESP_Egg_EHS = false

-- 2. FUNGSI FILTER BASE (SUPER CEPAT)
local function IsInPlayerBase(v)
    local p = v.Parent
    if not p then return false end
    if p.Name:lower():find("base") or p.Name:lower():find("plot") then return true end
    local pp = p.Parent
    if pp and (pp.Name:lower():find("base") or pp.Name:lower():find("plot")) then return true end
    return false
end

-- 3. ESP EGG (SISTEM TANPA LOOPING BERAT)
local function CreateTag(v, name)
    if not v or v:FindFirstChild("EHSTag") then return end
    local bg = Instance.new("BillboardGui", v)
    bg.Name = "EHSTag"; bg.AlwaysOnTop = true; bg.Size = UDim2.new(0, 150, 0, 40); bg.ExtentsOffset = Vector3.new(0, 3, 0)
    local lbl = Instance.new("TextLabel", bg)
    lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1
    lbl.Text = "<b>[EGG] " .. name .. "</b>"; lbl.RichText = true; lbl.TextColor3 = Color3.fromRGB(0, 170, 255)
    lbl.TextSize = 15; lbl.Font = Enum.Font.GothamBold; lbl.TextStrokeTransparency = 0.5
end

local function ScanEgg()
    if not _G.AutoESP_Egg_EHS then return end
    for _, v in ipairs(workspace:GetChildren()) do
        if not IsInPlayerBase(v) then
            local n = v.Name:lower()
            for _, name in ipairs(EggNames) do
                if n:find(name:lower()) then
                    local target = v:IsA("Model") and (v:FindFirstChild("Handle") or v:FindFirstChildWhichIsA("BasePart")) or v
                    if target then CreateTag(target, name) end
                    break
                end
            end
        end
    end
end

-- 4. AUTO COLLECT COIN (SISTEM "SAYAT" - ANTI BANDEL)
-- Kita pake sistem teleport ke koin yang beneran ada TouchInterest-nya
local function SikatKoin(v)
    if _G.AutoCollectCoin_EHS and v:IsA("BasePart") and v.Name:lower():find("coin") then
        if not IsInPlayerBase(v) and v:FindFirstChildWhichIsA("TouchInterest") then
            local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                -- Teleport langsung ke koin
                hrp.CFrame = v.CFrame
                task.wait(0.1) -- Jeda dikit biar gak bug
            end
        end
    end
end

-- Monitor koin baru yang muncul di map (Biar gak usah looping terus)
workspace.ChildAdded:Connect(function(v)
    if _G.AutoCollectCoin_EHS then
        task.wait(0.5) -- Nunggu koin stabil spawn
        SikatKoin(v)
    end
end)


local function CreateBtn(txt, pos, var, callback)
    local b = Instance.new("TextButton", Main)
    b.Size = UDim2.new(0.9, 0, 0, 35); b.Position = pos; b.BackgroundColor3 = Color3.fromRGB(20, 20, 45)
    b.Text = txt .. ": OFF"; b.TextColor3 = Color3.new(1, 0, 0); b.Font = Enum.Font.GothamBold; b.TextSize = 9
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function()
        _G[var] = not _G[var]
        b.Text = txt .. (_G[var] and ": ON" or ": OFF")
        b.TextColor3 = _G[var] and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
        callback()
    end)
end

CreateBtn("COLLECT COIN", UDim2.new(0.05, 0, 0.25, 0), "AutoCollectCoin_EHS", function()
    if _G.AutoCollectCoin_EHS then AutoCollectCoin() end
end)

CreateBtn("ESP EGG HUNT", UDim2.new(0.05, 0, 0.6, 0), "AutoESP_Egg_EHS", function()
    if not _G.AutoESP_Egg_EHS then
        for _, v in pairs(workspace:GetDescendants()) do if v.Name == "EHSTag" then v:Destroy() end end
    end
end)


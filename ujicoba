local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local RunService = game:GetService("RunService")

-- 1. DATABASE NAMA EGG (Optimized List)
local EggNames = {
    "Hydra Bunny", "Noo my Eggs", "Sahur", "Easter", 
    "Eggdin", "Buntteo", "Baskito", "Churrito", 
    "Tralala", "Bunny Bunny", "Dun Egg"
}

_G.AutoCollectCoin_EHS = false
_G.AutoESP_Egg_EHS = false

-- 2. OPTIMIZED FILTER (Pake limit biar gak looping dalem banget)
local function IsInPlayerBase(v)
    local p = v.Parent
    for i = 1, 5 do -- Cek 5 level ke atas saja, udah cukup buat deteksi Base
        if not p or p == workspace then break end
        local n = p.Name:lower()
        if n:find("base") or n:find("plot") or n:find("house") then return true end
        p = p.Parent
    end
    return false
end

-- 3. ESP EGG HUNT (Sistem Cluster Scan - ANTI LAG)
local function CreateTag(v, name)
    if v:FindFirstChild("EHSTag") then return end
    local bg = Instance.new("BillboardGui", v)
    bg.Name = "EHSTag"; bg.AlwaysOnTop = true; bg.Size = UDim2.new(0, 150, 0, 40); bg.ExtentsOffset = Vector3.new(0, 3, 0)
    local lbl = Instance.new("TextLabel", bg)
    lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1
    lbl.Text = "<b>[EGG] " .. name .. "</b>"
    lbl.RichText = true; lbl.TextColor3 = Color3.fromRGB(0, 170, 255)
    lbl.TextSize = 16; lbl.Font = Enum.Font.GothamBold; lbl.TextStrokeTransparency = 0.5
end

local function FastScan()
    if not _G.AutoESP_Egg_EHS then return end
    -- Cukup scan objek yang ada di Workspace langsung (lebih enteng)
    local children = workspace:GetChildren() 
    for i = 1, #children do
        local v = children[i]
        if (v:IsA("BasePart") or v:IsA("Model")) and not IsInPlayerBase(v) then
            local objName = v.Name:lower()
            for _, name in ipairs(EggNames) do
                if objName:find(name:lower()) then
                    local target = v:IsA("Model") and (v:FindFirstChild("Handle") or v:FindFirstChildWhichIsA("BasePart")) or v
                    if target then CreateTag(target, name) end
                    break
                end
            end
        end
        -- Jeda tipis tiap 100 objek biar CPU napas
        if i % 100 == 0 then task.wait() end
    end
end

-- 4. AUTO COLLECT KOIN (Fokus Radius Terdekat)
local function AutoCollectCoin()
    task.spawn(function()
        while _G.AutoCollectCoin_EHS do
            local d = workspace:GetChildren()
            for i = 1, #d do
                local v = d[i]
                if v:IsA("BasePart") and v.Name:lower():find("coin") and v:FindFirstChild("TouchInterest") then
                    if not IsInPlayerBase(v) then
                        if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                            lp.Character.HumanoidRootPart.CFrame = v.CFrame
                            task.wait(0.15) -- Delay ditambah biar gak kick/lag
                        end
                    end
                end
            end
            task.wait(1) -- Scan koin tiap 1 detik aja biar gak spam
        end
    end)
end


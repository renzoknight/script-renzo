local function CreateToggle(txt, var, callback)
    local b = Instance.new("TextButton", Content)
    b.Size = UDim2.new(1, 0, 0, 38); b.BackgroundColor3 = Color3.fromRGB(20, 20, 30); b.Text = txt..": OFF"
    b.TextColor3 = Color3.new(1, 0, 0); b.Font = Enum.Font.GothamBold; b.TextSize = 10; Instance.new("UICorner", b)
    local s = Instance.new("UIStroke", b); s.Color = Color3.fromRGB(40, 40, 60); s.Thickness = 1

    b.MouseButton1Click:Connect(function()
        _G[var] = not _G[var]
        b.Text = txt..(_G[var] and ": ON" or ": OFF")
        b.TextColor3 = _G[var] and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
        s.Color = _G[var] and Color3.fromRGB(0, 150, 255) or Color3.fromRGB(40, 40, 60)
        callback()
    end)
end


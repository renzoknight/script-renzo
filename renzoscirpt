local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local RunService = game:GetService("RunService")

_G.ESP_Ezra = true

-- Fungsi hapus sisa ESP biar bersih
local function Cleanup()
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "EzraBox" or v.Name == "EzraTag" then
            v:Destroy()
        end
    end
end

-- Fungsi pasang Box & Label (Mirip Nameless)
local function CreateESP(part, txt)
    -- Label Nama & Perm/s
    local billboard = Instance.new("BillboardGui", part)
    billboard.Name = "EzraTag"
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.ExtentsOffset = Vector3.new(0, 3, 0)
    
    local label = Instance.new("TextLabel", billboard)
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, 0, 1, 0)
    label.Text = "★ " .. txt .. " ★"
    label.Font = Enum.Font.GothamBold
    label.TextSize = 22 -- Ukuran pas sesuai request
    label.TextColor3 = Color3.fromRGB(255, 255, 0)
    label.TextStrokeTransparency = 0

    -- Box Highlight (Biar barangnya kelihatan)
    local box = Instance.new("BoxHandleAdornment", part)
    box.Name = "EzraBox"
    box.AlwaysOnTop = true
    box.Size = part.Size + Vector3.new(0.5, 0.5, 0.5)
    box.Color3 = Color3.fromRGB(0, 255, 255)
    box.Transparency = 0.5
    box.ZIndex = 5
end

-- Scanner Pintar (Hanya scan yang penting)
local function ScanSultan()
    Cleanup()
    if not _G.ESP_Ezra then return end
    
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("TextLabel") and v.Parent and v.Parent:IsA("BasePart") then
            local t = v.Text:upper()
            -- Scan hanya yang punya income Million atau Billion
            if t:find("M") or t:find("B") then
                local num = tonumber(t:match("%d+%.?%d*"))
                if num and num >= 15 then -- Sesuai target Abang (15M+)
                    CreateESP(v.Parent, v.Text)
                end
            end
        end
    end
end

-- UI Tombol Simple
local sg = Instance.new("ScreenGui", game:GetService("CoreGui"))

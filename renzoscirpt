btn.Size = UDim2.new(0, 130, 0, 40)
btn.Position = UDim2.new(0, 15, 0.5, 0)
btn.Text = "ESP BOX: ON"
btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
btn.TextColor3 = Color3.new(1, 1, 1)
btn.Font = Enum.Font.GothamBold
Instance.new("UICorner", btn)

btn.MouseButton1Click:Connect(function()
    _G.ESP_Ezra = not _G.ESP_Ezra
    btn.Text = _G.ESP_Ezra and "ESP BOX: ON" or "ESP BOX: OFF"
    if _G.ESP_Ezra then ScanSultan() else Cleanup() end
end)

-- Auto refresh setiap 15 detik biar gak berat
task.spawn(function()
    while true do
        if _G.ESP_Ezra then ScanSultan() end
        task.wait(15)
    end
end)

ScanSultan()

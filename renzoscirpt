local Players = game:GetService("Players")
local lp = Players.LocalPlayer

_G.ESP_Ezra = true

local function Cleanup()
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "EzraTag" or v.Name == "EzraBox" then
            v:Destroy()
        end
    end
end

-- Fungsi mencari Nama Brainrot yang murni
local function GetRealBrainrotName(labelObj)
    local scope = labelObj:FindFirstAncestorWhichIsA("Model") or labelObj:FindFirstAncestorWhichIsA("Folder") or labelObj.Parent
    local foundName = "Brainrot"
    
    for _, child in pairs(scope:GetDescendants()) do
        if child:IsA("TextLabel") and child ~= labelObj then
            local t = child.Text
            -- Filter Nama Player: Buang yang ada 's Base, LVL, atau angka murni
            if not t:find("'s") and not t:find("/") and not t:find("LVL") and not tonumber(t) and #t > 1 then
                foundName = t
                break
            end
        end
    end
    return foundName
end

local function ApplyFullESP(part, bName, incomeTxt)
    local billboard = Instance.new("BillboardGui", part)
    billboard.Name = "EzraTag"
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 300, 0, 100)
    billboard.ExtentsOffset = Vector3.new(0, 5, 0)
    
    local label = Instance.new("TextLabel", billboard)
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, 0, 1, 0)
    -- Nama Putih BOLD, Income KUNING
    label.Text = "<b>" .. bName .. "</b>\n<font color='#FFFF00'>" .. incomeTxt .. "</font>"
    label.RichText = true
    label.Font = Enum.Font.GothamBold
    label.TextSize = 25 -- Tetap Gede & Jelas
    label.TextColor3 = Color3.new(1, 1, 1)
    label.TextStrokeTransparency = 0

    local box = Instance.new("BoxHandleAdornment", part)
    box.Name = "EzraBox"
    box.AlwaysOnTop = true
    box.Size = part.Size + Vector3.new(0.3, 0.3, 0.3)
    box.Color3 = Color3.fromRGB(0, 255, 255) -- Warna Cyan (Biru Muda)
    box.Transparency = 0.7
    box.Adornee = part
end

local function ScanAllBrainrots()
    Cleanup()
    if not _G.ESP_Ezra then return end
    
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("TextLabel") then
            local t = v.Text:upper()
            -- Scan SEMUA yang ada tanda penghasilan, mau 1 atau 100B
            if t:find("/S") or t:find("M/S") or t:find("B/S") or t:find("PERM/S") then
                local targetPart = v:FindFirstAncestorWhichIsA("BasePart") or (v.Parent:IsA("BasePart") and v.Parent)
                
                if targetPart then
                    local realName = GetRealBrainrotName(v)
                    ApplyFullESP(targetPart, realName, v.Text)
                end
            end
        end
    end
end


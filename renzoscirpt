-- [[ GURITA HUB V4.8 - THE BILLIONAIRE HUNTER ]] --

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local HttpService = game:GetService("HttpService")
local TPS = game:GetService("TeleportService")
local RunService = game:GetService("RunService")

-- 1. CONFIG TARGET ANGKA (15M Sampai 100B)
local MIN_M = 15          -- Minimal 15 Juta
local MAX_B = 100         -- Maksimal 100 Miliar (Billion)

local filename = "GuritaEzra_Billion.json"
_G.Settings = { ESP = false, Xray = false, AutoHop = false }

local function SaveSettings()
    if writefile then pcall(function() writefile(filename, HttpService:JSONEncode(_G.Settings)) end) end
end

local function LoadSettings()
    if isfile and isfile(filename) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(filename)) end)
        if success and data then _G.Settings = data end
    end
end
LoadSettings()

-- 2. LOGIKA SCANNER ANGKA PINTAR (M & B)
local function ScanNumbers()
    local found = false
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("TextLabel") then
            local txt = v.Text:upper():gsub(",", "")
            
            -- Ambil angkanya saja
            local numStr = txt:match("%d+%.?%d*")
            local num = tonumber(numStr)
            
            if num then
                -- DETEKSI BILLION (B)
                if txt:find("B") then
                    if num >= 1 and num <= MAX_B then
                        found = true
                        warn("TARGET BILLION DITEMUKAN: " .. num .. "B/s")
                        break
                    end
                -- DETEKSI MILLION (M)
                elseif txt:find("M") then
                    if num >= MIN_M then
                        found = true
                        warn("TARGET MILLION DITEMUKAN: " .. num .. "M/s")
                        break
                    end
                end
            end
        end
    end
    return found
end

-- 3. SERVER HOPPER
local function DoServerHop()
    local ID = game.PlaceId
    local success, Servers = pcall(function()
        return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..ID.."/servers/Public?sortOrder=Asc&limit=100"))
    end)
    if success then
        for _, s in pairs(Servers.data) do
            if s.playing < s.maxPlayers and s.id ~= game.JobId then
                TPS:TeleportToPlaceInstance(ID, s.id, lp)
                break
            end
        end
    end
end

-- 4. VISUAL & FLAT COLOR (BAWAAN EZRA)
local function ApplyFlat(v)
    pcall(function()
        if (v:IsA("BasePart") or v:IsA("MeshPart")) and not v:IsDescendantOf(lp.Character) then
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
            for _, t in pairs(v:GetChildren()) do
                if t:IsA("Texture") or t:IsA("Decal") then t:Destroy() end
            end
        end
    end)
end

-- 5. UI GURITA HUB
local SG = Instance.new("ScreenGui", pcall(function() return game:GetService("CoreGui") end) and game:GetService("CoreGui") or lp.PlayerGui)

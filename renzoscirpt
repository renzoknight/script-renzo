local function Cleanup()
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "EzraFinalTag" or v.Name == "EzraFinalBox" then
            v:Destroy()
        end
    end
end

-- LOGIKA NAMA PALING AKURAT (Spesifik Steal a Brainrot)
local function GetProperName(baseObj)
    local parent = baseObj.Parent
    local model = baseObj:FindFirstAncestorWhichIsA("Model")
    local finalName = "Unknown Brainrot"
    
    -- Cari di seluruh isi model brainrotnya
    if model then
        for _, v in pairs(model:GetDescendants()) do
            if v:IsA("TextLabel") then
                local t = v.Text
                -- FILTER KETAT: Bukan Perm/s, Bukan Player, Bukan Lock, Bukan Base, Bukan Level
                if not t:find("/") and not t:find("'s") and not t:find("Lock") and 
                   not t:find("Base") and not t:find("Level") and not t:find("LVL") and 
                   not tonumber(t) and #t > 2 then
                    finalName = t
                    break -- Ambil yang pertama ketemu setelah difilter
                end
            end
        end
    end
    return finalName
end


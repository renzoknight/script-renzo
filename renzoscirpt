local sg = Instance.new("ScreenGui", game:GetService("CoreGui"))
local btn = Instance.new("TextButton", sg)
btn.Size = UDim2.new(0, 120, 0, 40)
btn.Position = UDim2.new(0, 20, 0.45, 0)
btn.Text = "ESP: ON"
btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
btn.TextColor3 = Color3.new(1,1,1)
btn.Font = Enum.Font.SourceSansBold
Instance.new("UICorner", btn)

btn.MouseButton1Click:Connect(function()
    _G.ESP_Ezra = not _G.ESP_Ezra
    btn.Text = _G.ESP_Ezra and "ESP: ON" or "ESP: OFF"
    if _G.ESP_Ezra then ScanSultan() else Cleanup() end
end)

-- Scan tiap 10 detik biar gak berat
task.spawn(function()
    while true do
        if _G.ESP_Ezra then ScanSultan() end
        task.wait(10)
    end
end)

ScanSultan()

-- [[ GURITA HUB V6.0 - THE FINAL PERFECTION ]] --

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local CoreGui = game:GetService("CoreGui")

_G.EzraESP = false

-- 1. FUNGSI MEMBERSIHKAN (Penting biar Gak Lag)
local function Cleanup()
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "EzraFinalTag" or v.Name == "EzraFinalBox" then
            v:Destroy()
        end
    end
end

-- 2. LOGIKA SCANNER TERBAIK (MURNI DARI BASE)
local function GetBestBrainrot()
    local bestVal = 0
    local bestPart = nil
    local bName = ""
    local bIncome = ""

    for _, v in pairs(workspace:GetDescendants()) do
        -- Cari label income asli game ($.../s)
        if v:IsA("TextLabel") and (v.Text:find("/") or v.Text:find("$")) then
            local rawTxt = v.Text:gsub("%$", ""):gsub(",", "")
            local num = tonumber(rawTxt:match("%d+%.?%d*"))
            
            if num then
                local power = num
                if v.Text:find("M") then power = num * 1000000
                elseif v.Text:find("B") then power = num * 1000000000 end
                
                -- Cari yang paling tinggi di server
                if power > bestVal then
                    bestVal = power
                    bestIncome = v.Text
                    -- Cari nama asli di sekitar label income
                    local model = v:FindFirstAncestorWhichIsA("Model")
                    if model then
                        bestPart = model.PrimaryPart or v.Parent:FindFirstChildWhichIsA("BasePart") or v.Parent
                        for _, child in pairs(model:GetDescendants()) do
                            if child:IsA("TextLabel") and child ~= v and not child.Text:find("/") then
                                bName = child.Text
                                break
                            end
                        end
                    end
                end
            end
        end
    end
    return bestPart, bName, bestIncome
end

-- 3. FUNGSI PASANG ESP
local function ApplyESP()
    Cleanup()
    if not _G.EzraESP then return end

    local part, name, income = GetBestBrainrot()
    if part and name ~= "" then
        local bg = Instance.new("BillboardGui", part)
        bg.Name = "EzraFinalTag"
        bg.AlwaysOnTop = true
        bg.Size = UDim2.new(0, 300, 0, 100)
        bg.ExtentsOffset = Vector3.new(0, 8, 0)

        local txt = Instance.new("TextLabel", bg)
        txt.Size = UDim2.new(1, 0, 1, 0)
        txt.BackgroundTransparency = 1
        txt.Text = "<b>" .. name .. "</b>\n<font color='#00FF00'>" .. income .. "</font>"
        txt.RichText = true
        txt.Font = Enum.Font.GothamBold
        txt.TextSize = 30 -- GEDE sesuai permintaan
        txt.TextColor3 = Color3.new(1, 1, 1)
        txt.TextStrokeTransparency = 0
    end
end

-- 4. UI KONTROL (BIAR BISA ON/OFF)
local sg = Instance.new("ScreenGui", CoreGui)
local btn = Instance.new("TextButton", sg)
btn.Size = UDim2.new(0, 150, 0, 50)
btn.Position = UDim2.new(0, 15, 0.4, 0)
btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
btn.Text = "GURITA ESP: OFF"
btn.TextColor3 = Color3.new(1, 0, 0)
btn.Font = Enum.Font.GothamBold
Instance.new("UICorner", btn)

btn.MouseButton1Click:Connect(function()
    _G.EzraESP = not _G.EzraESP
    if _G.EzraESP then
        btn.Text = "GURITA ESP: ON"
        btn.TextColor3 = Color3.new(0, 1, 0)
        ApplyESP()
    else
        btn.Text = "GURITA ESP: OFF"
        btn.TextColor3 = Color3.new(1, 0, 0)
        Cleanup()
    end
end)

-- Auto Update setiap 10 detik kalau player ganti barang
task.spawn(function()
    while true do
        if _G.EzraESP then ApplyESP() end
        task.wait(10)
    end
end)

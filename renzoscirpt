local function ScanOnlyTheBest()
    if not _G.ESP_Ezra then Cleanup() return end

    local bestIncomeValue = 0
    local targetLabel = nil
    
    -- SCAN SELURUH MAP CARI ANGKA TERGEDE
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("TextLabel") then
            local t = v.Text:upper():gsub(",", "")
            if t:find("/S") or t:find("M/S") or t:find("B/S") then
                -- Pastikan bukan spawn liar (Hanya di Base)
                if v:FindFirstAncestor("Bases") or v:FindFirstAncestor("PlayerBases") then
                    local num = tonumber(t:match("%d+%.?%d*"))
                    if num then
                        local power = num
                        if t:find("B") then power = num * 1000 end
                        
                        if power > bestIncomeValue then
                            bestIncomeValue = power
                            targetLabel = v
                        end
                    end
                end
            end
        end
    end

    if targetLabel then
        local targetPart = targetLabel.Parent:IsA("BasePart") and targetLabel.Parent or targetLabel:FindFirstAncestorWhichIsA("BasePart")
        if targetPart then
            local finalName = GetProperName(targetLabel)
            ApplySultanESP(targetPart, finalName, targetLabel.Text)
        end
    end
end


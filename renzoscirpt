-- [[ GURITA ESP V5.0 - FIXED & BOLD ]] --

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local RunService = game:GetService("RunService")

_G.ESP_Ezra = true

-- Fungsi buat bersihin ESP lama
local function ClearOldESP()
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "GuritaLabel" or v.Name == "GuritaLine" then
            v:Destroy()
        end
    end
end

-- Fungsi Utama ESP
local function ApplyESP(part, nameText, incomeText)
    -- 1. Buat Label Nama & Perm/s (BOLD & GEDE)
    local bgui = Instance.new("BillboardGui")
    bgui.Name = "GuritaLabel"
    bgui.AlwaysOnTop = true
    bgui.ExtentsOffset = Vector3.new(0, 3, 0)
    bgui.Size = UDim2.new(0, 200, 0, 50)
    bgui.Adornee = part
    bgui.Parent = part

    local tl = Instance.new("TextLabel", bgui)
    tl.BackgroundTransparency = 1
    tl.Size = UDim2.new(1, 0, 1, 0)
    tl.Text = nameText .. "\n" .. incomeText
    tl.Font = Enum.Font.GothamBold
    tl.TextSize = 25 -- Ukuran Mantap sesuai request
    tl.TextColor3 = Color3.fromRGB(255, 255, 0) -- Kuning
    tl.TextStrokeTransparency = 0
    tl.TextStrokeColor3 = Color3.new(0,0,0)

    -- 2. Buat Tali (Tracer)
    local line = Instance.new("LineHandleAdornment")
    line.Name = "GuritaLine"
    line.AlwaysOnTop = true
    line.Color3 = Color3.fromRGB(0, 255, 255) -- Cyan
    line.Thickness = 3
    line.ZIndex = 10
    line.Parent = part

    task.spawn(function()
        while part and part.Parent and _G.ESP_Ezra do
            if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                local pos1 = lp.Character.HumanoidRootPart.Position
                local pos2 = part.Position
                line.CFrame = CFrame.new(pos1, pos2)
                line.Length = (pos1 - pos2).Magnitude
            end
            task.wait()
        end
        bgui:Destroy()
        line:Destroy()
    end)
end

-- Fungsi Scan Ulang
local function StartScanning()
    ClearOldESP()
    if not _G.ESP_Ezra then return end

    for _, v in pairs(workspace:GetDescendants()) do
        -- Cari TextLabel yang isinya "Perm/s" atau "M/s" atau "B/s"
        if v:IsA("TextLabel") and (v.Text:find("/") or v.Text:find("M") or v.Text:find("B")) then
            local parentPart = v.Parent
            if parentPart:IsA("BasePart") or parentPart:IsA("Model") then
                local target = parentPart:IsA("Model") and (parentPart.PrimaryPart or parentPart:FindFirstChildWhichIsA("BasePart")) or parentPart
                if target then
                    ApplyESP(target, "BRAINROT", v.Text)
                end
            end
        end
    end
end

-- UI Tombol Gede di Kiri
local sg = Instance.new("ScreenGui", game:GetService("CoreGui"))
local btn = Instance.new("TextButton", sg)
btn.Size = UDim2.new(0, 150, 0, 50)
btn.Position = UDim2.new(0, 20, 0.5, 0)
btn.Text = "REFRESH ESP"
btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
btn.TextColor3 = Color3.new(1,1,1)
btn.Font = Enum.Font.GothamBold
Instance.new("UICorner", btn)
local str = Instance.new("UIStroke", btn); str.Color = Color3.new(0,1,1); str.Thickness = 2

btn.MouseButton1Click:Connect(function()
    _G.ESP_Ezra = true
    StartScanning()
    btn.Text = "SCANNING..."
    task.wait(1)
    btn.Text = "REFRESH ESP"
end)

-- Auto scan tiap kali ada objek baru masuk map
workspace.DescendantAdded:Connect(function()
    if _G.ESP_Ezra then
        task.wait(2)
        StartScanning()
    end
end)

StartScanning()

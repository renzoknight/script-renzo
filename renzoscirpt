-- [[ GURITA HUB V3.8 - HYBRID: FLAT WORLD + HD SKY ]] --

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local Lighting = game:GetService("Lighting")

-- 1. PROTEKSI KHUSUS (Biar Ezra & Langit Gak Kena Flat)
local function IsProtected(v)
    -- Jangan bikin Character kita jadi polos
    if v:IsDescendantOf(lp.Character) or (v.Parent and v.Parent:FindFirstChild("Humanoid")) then
        return true
    end
    -- Jangan hapus Awan, Langit, atau Efek Atmosfer
    if v:IsA("Sky") or v:IsA("Clouds") or v:IsA("Atmosphere") or v.Name == "Terrain" then
        return true
    end
    return false
end

-- 2. FITUR FLAT COLOR (Khusus Lantai & Objek Map)
local function ApplyFlat(v)
    pcall(function()
        if (v:IsA("BasePart") or v:IsA("MeshPart")) and not IsProtected(v) then
            -- Bikin jadi Plastik biar enteng
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            
            -- Hapus tekstur (skin lantai/dinding) biar Flat
            if v:IsA("MeshPart") then v.TextureID = "" end
            for _, tex in pairs(v:GetChildren()) do
                if tex:IsA("Texture") or tex:IsA("Decal") then
                    tex:Destroy()
                end
            end
        end
    end)
end

-- 3. FITUR HD SKY (Paksa Langit Jadi Jernih & HD)
local function SetHDSky()
    -- Hapus langit bawaan yang buram
    for _, v in pairs(Lighting:GetChildren()) do
        if v:IsA("Sky") then v:Destroy() end
    end

    local Sky = Instance.new("Sky", Lighting)
    Sky.Name = "EzraHDSky"
    -- ID Skybox HD (Cerah)
    Sky.SkyboxBk = "rbxassetid://151165214"
    Sky.SkyboxDn = "rbxassetid://151165191"
    Sky.SkyboxFt = "rbxassetid://151165224"
    Sky.SkyboxLf = "rbxassetid://151165231"
    Sky.SkyboxRt = "rbxassetid://151165274"
    Sky.SkyboxUp = "rbxassetid://151165281"
    
    -- Pasang Awan HD di Terrain
    local terrain = workspace:FindFirstChildOfClass("Terrain")
    if terrain then
        local clouds = terrain:FindFirstChildOfClass("Clouds") or Instance.new("Clouds", terrain)
        clouds.Enabled = true
        clouds.Cover = 0.5
        clouds.Density = 0.7
    end
    
    -- Setting Cahaya biar HD
    Lighting.ClockTime = 14
    Lighting.Brightness = 2
    Lighting.GlobalShadows = true
end

-- 4. RUNNER SYSTEM
task.spawn(function()
    SetHDSky() -- Pasang Langit HD dulu
    
    local d = workspace:GetDescendants()
    for i = 1, #d do 
        ApplyFlat(d[i]) 
        -- Biar gak freeze pas ngerubah ribuan part
        if i % 350 == 0 then task.wait() end 
    end
end)

-- Biar kalau ada base baru spawn tetep jadi Flat
workspace.DescendantAdded:Connect(ApplyFlat)

print("Gurita V3.8 Sukses: Lantai Polos, Langit HD!")

local function CreateBtn(txt, pos, cb)
    local b = Instance.new("TextButton", Main); b.Size = UDim2.new(0.9, 0, 0, 35); b.Position = pos; b.BackgroundColor3 = Color3.fromRGB(25, 25, 35); b.Text = txt; b.TextColor3 = Color3.new(1,1,1); b.Font = Enum.Font.GothamBold; b.TextSize = 10; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function() cb(b) end) return b
end

local huntBtn = CreateBtn(_G.Settings.AutoHop and "HUNT 15M-100B: ON" or "HUNT 15M-100B: OFF", UDim2.new(0.05, 0, 0.2, 0), function(b)
    _G.Settings.AutoHop = not _G.Settings.AutoHop; b.Text = _G.Settings.AutoHop and "HUNT 15M-100B: ON" or "HUNT 15M-100B: OFF"; SaveSettings()
end)

CreateBtn("MANUAL SERVER HOP", UDim2.new(0.05, 0, 0.55, 0), function() DoServerHop() end)

-- 6. RUNNER
RunService.RenderStepped:Connect(function()
    local color = Color3.fromHSV(tick() % 5 / 5, 0.9, 1)
    LogoStroke.Color = color; MainStroke.Color = color
end)

task.spawn(function()
    for _, v in pairs(workspace:GetDescendants()) do ApplyFlat(v) end
    workspace.DescendantAdded:Connect(ApplyFlat)
    
    task.wait(10)
    if _G.Settings.AutoHop then
        if ScanNumbers() then
            _G.Settings.AutoHop = false
            SaveSettings()
            huntBtn.Text = "TARGET FOUND!"
        else
            DoServerHop()
        end
    end
end)

local Players = game:GetService("Players")
local lp = Players.LocalPlayer

_G.EzraESP = true

local function Cleanup()
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "EzraFinalTag" or v.Name == "EzraFinalBox" then
            v:Destroy()
        end
    end
end

-- LOGIKA TERBARU: Mencari Nama Asli Brainrot
local function GetActualItemName(model)
    local finalName = "Unknown"
    local foundTexts = {}

    -- Ambil semua teks yang ada di model tersebut
    for _, v in pairs(model:GetDescendants()) do
        if v:IsA("TextLabel") then
            local t = v.Text
            -- Filter ketat: Bukan income, bukan base, bukan lock, bukan angka murni
            if not t:find("/") and not t:find("$") and not t:find("'s") and 
               not t:find("Lock") and not t:find("Level") and #t > 2 then
                table.insert(foundTexts, v)
            end
        end
    end

    -- Nama Brainrot asli biasanya punya TextSize paling besar di antara label lainnya
    table.sort(foundTexts, function(a, b)
        return a.TextSize > b.TextSize
    end)

    if #foundTexts > 0 then
        finalName = foundTexts[1].Text
    end

    return finalName
end

local function ScanBestOnly()
    if not _G.EzraESP then Cleanup() return end

    local bestVal = 0
    local bestTarget = nil
    local bestIncomeTxt = ""

    -- 1. Scan semua Base Player untuk mencari Income tertinggi
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("TextLabel") and (v.Text:find("/") or v.Text:find("$")) then
            -- Pastikan hanya di area Base (Bukan yang baru spawn di map)
            if v:FindFirstAncestor("Bases") or v:FindFirstAncestor("PlayerBases") then
                local raw = v.Text:gsub("%$", ""):gsub(",", "")
                local num = tonumber(raw:match("%d+%.?%d*"))
                if num then
                    local power = num
                    if v.Text:find("M") then power = num * 1000000
                    elseif v.Text:find("B") then power = num * 1000000000 end
                    
                    if power > bestVal then
                        bestVal = power
                        bestTarget = v
                        bestIncomeTxt = v.Text
                    end
                end
            end
        end
    end

    -- 2. Pasang Visual ke Target Sultan tersebut
    if bestTarget then
        local model = bestTarget:FindFirstAncestorWhichIsA("Model")
        local part = bestTarget.Parent:IsA("BasePart") and bestTarget.Parent or bestTarget:FindFirstAncestorWhichIsA("BasePart")
        
        if model and part then
            Cleanup() -- Pastikan cuma satu yang muncul!
            
            local realName = GetActualItemName(model)
            
            local bg = Instance.new("BillboardGui", part)
            bg.Name = "EzraFinalTag"
            bg.AlwaysOnTop = true
            bg.Size = UDim2.new(0, 300, 0, 100)
            bg.ExtentsOffset = Vector3.new(0, 8, 0)

            local lbl = Instance.new("TextLabel", bg)
            lbl.Size = UDim2.new(1, 0, 1, 0)
            lbl.BackgroundTransparency = 1
            lbl.Text = "<b>" .. realName .. "</b>\n<font color='#FFFF00'>" .. bestIncomeTxt .. "</font>"
            lbl.RichText = true
            lbl.Font = Enum.Font.GothamBold
            lbl.TextSize = 28 -- Ukuran Gede Sesuai Request Bang Ezra
            lbl.TextColor3 = Color3.new(1, 1, 1)
            lbl.TextStrokeTransparency = 0

            local box = Instance.new("BoxHandleAdornment", part)
            box.Name = "EzraFinalBox"
            box.AlwaysOnTop = true
            box.Size = part.Size + Vector3.new(0.5, 0.5, 0.5)
            box.Color3 = Color3.fromRGB(0, 255, 255)
            box.Transparency = 0.6
            box.Adornee = part
        end
    end
end


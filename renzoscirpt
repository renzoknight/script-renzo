-- [[ GURITA ESP V5.1 - ANTI-LAG & SUPER LIGHT ]] --

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local RunService = game:GetService("RunService")

_G.ESP_Ezra = true

-- Bersihin semua sisa-sisa tali biar gak lag
local function Cleanup()
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "EzraLabel" or v.Name == "EzraLine" then
            v:Destroy()
        end
    end
end

-- Fungsi buat pasang ESP (Hanya di 1 target terbaik)
local function ApplyESP(part, txt)
    Cleanup()
    
    local bgui = Instance.new("BillboardGui", part)
    bgui.Name = "EzraLabel"
    bgui.AlwaysOnTop = true
    bgui.ExtentsOffset = Vector3.new(0, 3, 0)
    bgui.Size = UDim2.new(0, 200, 0, 50)
    
    local tl = Instance.new("TextLabel", bgui)
    tl.BackgroundTransparency = 1
    tl.Size = UDim2.new(1, 0, 1, 0)
    tl.Text = "TARGET TERBAIK\n" .. txt
    tl.Font = Enum.Font.GothamBold
    tl.TextSize = 25 -- Tetap Gede
    tl.TextColor3 = Color3.fromRGB(255, 255, 0)
    tl.TextStrokeTransparency = 0

    local line = Instance.new("LineHandleAdornment", part)
    line.Name = "EzraLine"
    line.AlwaysOnTop = true
    line.Color3 = Color3.fromRGB(0, 255, 255)
    line.Thickness = 3
    line.ZIndex = 10

    task.spawn(function()
        while part and part.Parent and _G.ESP_Ezra do
            if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                local p1 = lp.Character.HumanoidRootPart.Position
                local p2 = part.Position
                line.CFrame = CFrame.new(p1, p2)
                line.Length = (p1 - p2).Magnitude
            else
                task.wait(1)
            end
            RunService.Heartbeat:Wait()
        end
        Cleanup()
    end)
end

-- Scan cari 1 yang paling GG di server
local function ScanSultan()
    if not _G.ESP_Ezra then Cleanup() return end
    
    local bestVal = 0
    local bestPart = nil
    local bestTxt = ""

    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("TextLabel") then
            local t = v.Text:upper():gsub(",", "")
            local n = tonumber(t:match("%d+%.?%d*"))
            if n then
                local power = n
                if t:find("B") then power = n * 1000 end
                
                if power > bestVal then
                    bestVal = power
                    bestPart = v.Parent
                    bestTxt = v.Text
                end
            end
        end
    end

    if bestPart then
        if bestPart:IsA("BasePart") then
            ApplyESP(bestPart, bestTxt)
        elseif bestPart:IsA("Model") and bestPart.PrimaryPart then
            ApplyESP(bestPart.PrimaryPart, bestTxt)
        end
    end
end


local Main = Instance.new("Frame", SG); Main.Size = UDim2.new(0, 220, 0, 180); Main.Position = UDim2.new(0, 80, 0.45, -90); Main.BackgroundColor3 = Color3.fromRGB(12, 12, 18); Main.Visible = false; Main.Active = true; Main.Draggable = true

-- [[ GURITA HUB - STANDALONE ESP BRAINROT ]] --

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local RunService = game:GetService("RunService")

_G.ESP_Active = true

-- 1. FUNGSI UNTUK MEMBUAT VISUAL ESP
local function CreateVisuals(part, brainrotName, permsValue)
    -- Hapus ESP lama biar gak numpuk
    for _, old in pairs(part:GetChildren()) do
        if old.Name == "EzraESP" then old:Destroy() end
    end

    -- [ LABEL NAMA & PERMS ]
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "EzraESP"
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 250, 0, 120) -- Box label
    billboard.Adornee = part
    billboard.MaxDistance = 10000 -- Biar kelihatan dari jauh banget
    billboard.Parent = part

    local label = Instance.new("TextLabel", billboard)
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, 0, 1, 0)
    label.Text = brainrotName .. "\n" .. permsValue
    label.TextColor3 = Color3.fromRGB(255, 255, 0) -- Kuning
    label.TextStrokeTransparency = 0 -- Outline hitam biar kebaca
    label.Font = Enum.Font.GothamBold
    label.TextSize = 22 -- Ukuran "Agak Besar tapi Normal" sesuai request
    label.TextYAlignment = Enum.TextYAlignment.Center

    -- [ TALI / TRACER ]
    local line = Instance.new("LineHandleAdornment")
    line.Name = "EzraTracer"
    line.Length = 0
    line.Thickness = 2.5
    line.Color3 = Color3.fromRGB(0, 255, 255) -- Cyan (Biru Muda)
    line.AlwaysOnTop = true
    line.ZIndex = 10
    line.Parent = part

    -- Loop update posisi tali
    task.spawn(function()
        while part and part.Parent and _G.ESP_Active do
            local char = lp.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local origin = char.HumanoidRootPart.Position
                local target = part.Position
                local dist = (target - origin).Magnitude
                
                line.Length = dist
                line.CFrame = CFrame.new(origin, target)
            end
            task.wait()
        end
        line:Destroy()
        billboard:Destroy()
    end)
end

-- 2. SCANNER (Cari Brainrot Paling Bagus di Server)
local function RefreshESP()
    if not _G.ESP_Active then return end
    
    local bestPart = nil
    local bestVal = 0
    local bestPermsText = ""
    local finalName = "TARGET"

    -- Scan semua objek yang ada teks penghasilannya
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("TextLabel") and v.Parent and v.Parent:IsA("BasePart") then
            local rawText = v.Text:upper():gsub(",", "")
            local numStr = rawText:match("%d+%.?%d*")
            local num = tonumber(numStr)
            
            if num then
                -- Konversi ke angka murni untuk perbandingan
                local currentVal = num
                if rawText:find("B") then currentVal = num * 1000 end -- Billion lebih berat
                
                if currentVal > bestVal then
                    bestVal = currentVal
                    bestPart = v.Parent
                    bestPermsText = v.Text -- Ngambil tulisan asli (misal: "500M/s")
                end
            end
        end
    end

    if bestPart then
        CreateVisuals(bestPart, "BEST BRAINROT", bestPermsText)
    end
end


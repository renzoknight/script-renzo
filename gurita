-- 3. LOGIKA STEAL (FIXED & AGRESSIVE)
_G.StealActive = false

ActionBtn.MouseButton1Click:Connect(function()
    _G.StealActive = not _G.StealActive
    ActionBtn.Text = _G.StealActive and "STOP" or "START"
    ActionBtn.BackgroundColor3 = _G.StealActive and Color3.fromRGB(200, 0, 0) or Color3.fromRGB(0, 150, 255)
end)

task.spawn(function()
    local lp = game.Players.LocalPlayer
    while task.wait(0.05) do -- Sangat cepat (0.05 detik)
        if _G.StealActive then
            pcall(function()
                local root = lp.Character.HumanoidRootPart
                
                -- Cari semua ProximityPrompt di workspace (Tombol E Collect)
                for _, v in ipairs(workspace:GetDescendants()) do
                    if v:IsA("ProximityPrompt") then
                        -- Cek jarak antara karakter dan tombol E (Radius 40 meter)
                        local pos = v.Parent:IsA("Model") and v.Parent:GetPivot().Position or v.Parent.Position
                        if (pos - root.Position).Magnitude < 40 then
                            -- PAKSA eksekusi tombol E tanpa nunggu (Instant Steal)
                            fireproximityprompt(v)
                        end
                    end
                    
                    -- Tambahan: Sedot item yang jatoh/melayang pakai TouchInterest
                    if v:IsA("TouchTransmitter") and (v.Parent.Position - root.Position).Magnitude < 40 then
                        firetouchinterest(root, v.Parent, 0)
                        firetouchinterest(root, v.Parent, 1)
                    end
                end
            end)
        end
    end
end)


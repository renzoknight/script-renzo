-- 1. FLAT COLOR (INSTAN & OPTIMIZED)
local function SetFlat(v)
    pcall(function()
        if v:IsA("BasePart") then
            v.Material = Enum.Material.Plastic
            v.Reflectance = 0
            v.CastShadow = false
        elseif v:IsA("Texture") or v:IsA("Decal") then
            v:Destroy()
        end
    end)
end

-- Langsung sikat tanpa loading lama
task.spawn(function()
    for _, v in ipairs(workspace:GetDescendants()) do SetFlat(v) end
end)
workspace.DescendantAdded:Connect(SetFlat)


-- [[ RENZO ULTIMATE POTATO - NO TEXTURE ]] --

local function Smooth(v)
    if v:IsA("BasePart") or v:IsA("MeshPart") then
        v.Material = Enum.Material.SmoothPlastic
        v.Reflectance = 0
        v.CastShadow = false
    elseif v:IsA("Texture") then
        v:Destroy()
    end
end

-- 1. Bersihkan yang sudah ada
for _, v in ipairs(game:GetDescendants()) do
    Smooth(v)
end

-- 2. Pantau objek baru (biar tetap semut kalau ada yang spawn)
game.DescendantAdded:Connect(Smooth)

-- 3. Paksa Lighting jadi Flat (Kunci utama grafik semut)
local Lighting = game:GetService("Lighting")
Lighting.GlobalShadows = false
Lighting.FogEnd = 9e9
Lighting.Brightness = 2
Lighting.ColorShift_Bottom = Color3.fromRGB(255, 255, 255)
Lighting.ColorShift_Top = Color3.fromRGB(255, 255, 255)

-- 4. Matikan Terrain Decoration (Rumput/Grid)
local Terrain = workspace:FindFirstChildOfClass("Terrain")
if Terrain then
    sethiddenproperty(Terrain, "Decoration", false)
end

-- 5. Rendahkan Rendering Quality via Script
settings().Rendering.QualityLevel = 1

-- [[ 1. FLAT COLOR (WAJIB JALAN PERTAMA & INSTAN) ]] --
local function ApplyFlat(v)
    pcall(function()
        if v:IsA("BasePart") then
            v.Material = Enum.Material.Plastic
            v.Reflectance = 0
            v.CastShadow = false
        elseif v:IsA("Texture") or v:IsA("Decal") then
            v:Destroy()
        end
    end)
end

-- Langsung sikat semua objek di map (Cepat & Ringan)
for _, v in ipairs(workspace:GetDescendants()) do ApplyFlat(v) end
workspace.DescendantAdded:Connect(ApplyFlat)


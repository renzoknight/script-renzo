-- 3. LOGIKA REAL STEAL (PROXIMITY & TOUCH BYPASS)
_G.StealActive = false

ActionBtn.MouseButton1Click:Connect(function()
    _G.StealActive = not _G.StealActive
    ActionBtn.Text = _G.StealActive and "STOP" or "START"
    ActionBtn.BackgroundColor3 = _G.StealActive and Color3.fromRGB(200, 0, 0) or Color3.fromRGB(0, 150, 255)
end)

task.spawn(function()
    local lp = game.Players.LocalPlayer
    while task.wait(0.01) do -- Speed gila (0.01s) biar instan
        if _G.StealActive then
            pcall(function()
                local char = lp.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                if not root then return end

                -- Gunakan GetPartBoundsInRadius agar radiusnya AKURAT (40 meter)
                local parts = workspace:GetPartBoundsInRadius(root.Position, 40)
                
                for _, p in ipairs(parts) do
                    -- 1. BYPASS PROXIMITY (Tombol E Collect/Steal)
                    -- Ini yang bikin dia gak cuma 'klik' tapi benar-benar ngambil
                    local prompt = p:FindFirstChildOfClass("ProximityPrompt") or p.Parent:FindFirstChildOfClass("ProximityPrompt")
                    if prompt then
                        -- Set HoldDuration jadi 0 biar instan tanpa loading bar
                        prompt.HoldDuration = 0
                        fireproximityprompt(prompt)
                    end
                    
                    -- 2. FORCE TOUCH (Item yang melayang/jatuh)
                    -- Kita tembak langsung ke TouchInterest-nya
                    if p:FindFirstChildOfClass("TouchTransmitter") then
                        firetouchinterest(root, p, 0)
                        firetouchinterest(root, p, 1)
                    end
                end
            end)
        end
    end
end)


-- [[ 3. LOGIKA STEAL BRAINROT (FIXED & LITE) ]] --
_G.StealActive = false

ActionBtn.MouseButton1Click:Connect(function()
    _G.StealActive = not _G.StealActive
    if _G.StealActive then
        ActionBtn.Text = "STOP" -- Ganti teks saat ON (sesuai foto)
        ActionBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0) -- Ganti jadi Merah biar jelas
    else
        ActionBtn.Text = "START"
        ActionBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 255) -- Ganti jadi Biru lagi
    end
end)

task.spawn(function()
    local lp = game.Players.LocalPlayer
    while task.wait(0.1) do
        if _G.StealActive then
            pcall(function()
                local root = lp.Character.HumanoidRootPart
                -- Hanya scan objek dalam radius 35 stud di sekitar kamu agar TIDAK LAG
                local region = workspace:GetPartBoundsInRadius(root.Position, 35)
                
                for _, part in ipairs(region) do
                    -- Strategi: Ambil semua yang bisa disentuh (Anomali/Brainrot/Dropped Item)
                    if part:FindFirstChildOfClass("TouchTransmitter") then
                        firetouchinterest(root, part, 0)
                        firetouchinterest(root, part, 1)
                    end
                    
                    -- Tekan tombol E otomatis (Collect)
                    local prompt = part:FindFirstChildOfClass("ProximityPrompt") or part.Parent:FindFirstChildOfClass("ProximityPrompt")
                    if prompt then
                        fireproximityprompt(prompt)
                    end
                end
            end)
        end
    end
end)

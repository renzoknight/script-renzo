-- 3. LOGIKA STEAL (FORCE INTERACTION)
_G.StealActive = false

ActionBtn.MouseButton1Click:Connect(function()
    _G.StealActive = not _G.StealActive
    ActionBtn.Text = _G.StealActive and "STOP" or "START"
    ActionBtn.BackgroundColor3 = _G.StealActive and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 150, 255)
end)

task.spawn(function()
    local lp = game.Players.LocalPlayer
    while task.wait(0.01) do -- Speed sangat cepat
        if _G.StealActive then
            pcall(function()
                local root = lp.Character.HumanoidRootPart
                -- Radius dipersempit (10 stud) supaya fokus ke barang di depan muka
                local parts = workspace:GetPartBoundsInRadius(root.Position, 10)
                
                for _, p in ipairs(parts) do
                    local prompt = p:FindFirstChildOfClass("ProximityPrompt") or p.Parent:FindFirstChildOfClass("ProximityPrompt")
                    if prompt then
                        -- BYPASS: Paksa ambil instan
                        prompt.HoldDuration = 0
                        prompt.RequiresLineOfSight = false
                        
                        -- Simulasi pencetan (Trigger)
                        fireproximityprompt(prompt)
                    end
                end
            end)
        end
    end
end)

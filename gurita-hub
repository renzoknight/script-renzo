-- [[ 1. FLAT COLOR (Prioritas Pertama) ]] --
local function ApplyFlat(v)
    pcall(function()
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            v.Material = Enum.Material.Plastic
            v.Reflectance = 0
            v.CastShadow = false
        end
        if v:IsA("Texture") or v:IsA("Decal") then v:Destroy() end
        if v:IsA("SpecialMesh") then v.TextureId = "" end
    end)
end

-- Langsung sikat tanpa loading lama
for _, v in ipairs(game:GetDescendants()) do ApplyFlat(v) end
game.DescendantAdded:Connect(ApplyFlat)
game:GetService("Lighting").GlobalShadows = false

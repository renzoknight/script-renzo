-- [[ GURITA-HUB: PURE FLAT COLOR MODE ]] --

local Lighting = game:GetService("Lighting")
local Terrain = workspace:FindFirstChildOfClass("Terrain")

-- 1. OPTIMASI ENGINE (DETIK KE-0)
settings().Rendering.QualityLevel = 1
Lighting.GlobalShadows = false
Lighting.FogEnd = 9e9
Lighting.Brightness = 2

-- 2. Bantai Efek Cuaca & Langit
for _, v in ipairs(Lighting:GetChildren()) do
    if v:IsA("PostEffect") or v:IsA("Atmosphere") or v:IsA("Clouds") or v:IsA("Sky") then
        v:Destroy()
    end
end

-- 3. Bantai Tekstur Map (Biar jadi Flat Color kayak foto)
local function MakeFlat(obj)
    if obj:IsA("BasePart") or obj:IsA("MeshPart") then
        -- Jangan ganggu folder Brainrot biar gak error gamenya
        if not obj:IsDescendantOf(workspace:FindFirstChild("RenderedMovingAnimal")) then
            obj.Material = Enum.Material.SmoothPlastic
            obj.Reflectance = 0
            obj.CastShadow = false
            if obj:IsA("MeshPart") then
                obj.TextureID = "" -- Ini yang bikin jadi warna blok solid
            end
        end
    elseif obj:IsA("Decal") or obj:IsA("Texture") then
        obj:Destroy()
    end
end

-- Eksekusi ke seluruh map sekarang juga
for _, v in ipairs(workspace:GetDescendants()) do
    pcall(MakeFlat, v)
end

-- Pantau kalau ada map baru yang ke-load
workspace.DescendantAdded:Connect(function(v)
    pcall(MakeFlat, v)
end)

if Terrain then
    Terrain.WaterWaveSize = 0
    Terrain.WaterWaveSpeed = 0
    Terrain.WaterReflectance = 0
    Terrain.WaterTransparency = 0
end

print("GURITA HUB: FLAT COLOR ACTIVE - NO LAG")

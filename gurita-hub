-- [[ GURITA-HUB: AUTO STEAL - STEALTH VERSION ]] --

local lp = game.Players.LocalPlayer
_G.StealActive = false

-- 1. UI GOST STEAL v2
local SG = Instance.new("ScreenGui", game.CoreGui)
local Main = Instance.new("Frame", SG)
Main.Size = UDim2.new(0, 180, 0, 110)
Main.Position = UDim2.new(0.5, -90, 0.4, 0)
Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 10)
Main.Active = true
Main.Draggable = true

local ActionBtn = Instance.new("TextButton", Main)
ActionBtn.Size = UDim2.new(0, 160, 0, 35)
ActionBtn.Position = UDim2.new(0.05, 0, 1, -40)
ActionBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
ActionBtn.Text = "START"
ActionBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
ActionBtn.Font = Enum.Font.SourceSansBold
Instance.new("UICorner", ActionBtn).CornerRadius = UDim.new(0, 8)

ActionBtn.MouseButton1Click:Connect(function()
    _G.StealActive = not _G.StealActive
    ActionBtn.Text = _G.StealActive and "STOP" or "START"
    ActionBtn.BackgroundColor3 = _G.StealActive and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 150, 255)
end)

-- 2. LOGIKA AUTO-DETECT (BIAR GAK CAPEK CEK SIMPLESPY)
task.spawn(function()
    while task.wait(0.3) do
        if _G.StealActive then
            pcall(function()
                local root = lp.Character.HumanoidRootPart
                
                -- Cari Remote Event yang namanya kode acak (Panjang karakternya banyak)
                local targetRemote = nil
                for _, v in ipairs(game:GetService("ReplicatedStorage"):GetChildren()) do
                    if v:IsA("RemoteEvent") and string.len(v.Name) > 20 then
                        targetRemote = v
                        break
                    end
                end

                -- Jika dapet remotenya, langsung sikat barang terdekat
                if targetRemote then
                    for _, obj in ipairs(workspace:GetDescendants()) do
                        if obj:IsA("ProximityPrompt") and (obj.ActionText:lower():find("steal") or obj.ActionText:lower():find("mencuri")) then
                            local parent = obj.Parent
                            if parent:IsA("BasePart") and (parent.Position - root.Position).Magnitude < 15 then
                                
                                -- Bypass Lapis 1: Friend System Sync
                                pcall(function()
                                    game:GetService("ReplicatedStorage").Friends.FriendMain:FireServer()
                                end)

                                -- Bypass Lapis 2: Steal Trigger
                                local args = { [1] = "33\163A33\163A" }
                                targetRemote:FireServer(unpack(args))
                                
                                -- Trigger Visual (Biar server gak curiga)
                                fireproximityprompt(obj)
                            end
                        end
                    end
                end
            end)
        end
    end
end)

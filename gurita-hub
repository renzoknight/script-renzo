-- [[ RENZO GURITA - FLAT GRAPHIC + FAST AUTO GRAB ]] --

local function ApplyFast(v)
    if v:IsA("BasePart") or v:IsA("MeshPart") then
        v.Material = Enum.Material.Plastic
        v.Reflectance = 0
        v.CastShadow = false
    end
    if v:IsA("Texture") then v:Destroy() end
    if v:IsA("SpecialMesh") then v.TextureId = "" end
end

-- 1. OPTIMASI GRAFIK (Anti-Lag)
task.spawn(function()
    local descendants = game:GetDescendants()
    for i = 1, #descendants do
        ApplyFast(descendants[i])
        if i % 150 == 0 then task.wait() end
    end
end)
game.DescendantAdded:Connect(ApplyFast)

-- 2. AUTO GRAB / STEAL (0.1s - Khusus Steal a Brainrot)
local Player = game.Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local Root = Character:WaitForChild("HumanoidRootPart")

task.spawn(function()
    while task.wait(0.1) do
        pcall(function()
            -- Mencari item di Workspace (biasanya di folder 'Items' atau 'Dropped')
            local itemsFolder = workspace:FindFirstChild("Items") or workspace:FindFirstChild("DroppedItems") or workspace
            
            for _, item in ipairs(itemsFolder:GetChildren()) do
                if item:IsA("BasePart") or item:IsA("Model") then
                    local touchPart = item:IsA("Model") and (item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart")) or item
                    
                    if touchPart then
                        -- Metode Firetouch untuk ambil instan tanpa gerak
                        firetouchinterest(Root, touchPart, 0)
                        firetouchinterest(Root, touchPart, 1)
                    end
                end
            end
        end)
    end
end)


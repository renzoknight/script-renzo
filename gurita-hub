_G.ESPActive = false

-- 1. TOTAL SMOOTH OPTIMIZATION (INSTANT AUTO-RUN)
local function MakeItSuperSemut()
    -- Bantai Pencahayaan & Efek
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.Brightness = 2
    settings().Rendering.QualityLevel = 1
    
    for _, v in ipairs(Lighting:GetChildren()) do
        if v:IsA("PostEffect") or v:IsA("Atmosphere") or v:IsA("Clouds") or v:IsA("Sky") then
            v:Destroy()
        end
    end

    -- Bantai Tekstur & Partikel di Seluruh Dunia
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            v.Reflectance = 0
            if v:IsA("MeshPart") then v.TextureID = "" end -- Bikin Flat Color Total
        elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") then
            v:Destroy()
        end
    end
end
MakeItSuperSemut() -- Eksekusi langsung!

-- Sikat kalau ada objek baru yang muncul (Real-time)
workspace.DescendantAdded:Connect(function(v)
    pcall(function()
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
        elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("ParticleEmitter") then
            v:Destroy()
        end
    end)
end)

-- 2. ADVANCED ESP LOGIC (NAME + HELD ITEM)
local function GetHeldItem(plr)
    if plr.Character then
        -- Cek Tool yang sedang di-equip (biasanya ada di dalam Character)
        local tool = plr.Character:FindFirstChildOfClass("Tool")
        if tool then
            return tool.Name
        end
        -- Beberapa game nyimpen barang di Folder khusus, tapi Tool paling umum
    end
    return "None"
end

local function CreateAdvancedESP(plr)
    local function Setup()
        local char = plr.Character or plr.CharacterAdded:Wait()
        local root = char:WaitForChild("HumanoidRootPart", 10)
        if root then
            -- Buat BillboardGui (Raksasa)
            local bbg = root:FindFirstChild("GuritaESP") or Instance.new("BillboardGui", root)
            bbg.Name = "GuritaESP"
            bbg.AlwaysOnTop = true
            bbg.Size = UDim2.new(0, 400, 0, 150) -- Ukuran Raksasa
            bbg.ExtentsOffset = Vector3.new(0, 6, 0) -- Di atas kepala
            bbg.Enabled = false -- Dimatikan di awal

            -- Label NAMA (Kuning Besar)
            local nameTxt = bbg:FindFirstChild("NameLabel") or Instance.new("TextLabel", bbg)
            nameTxt.Name = "NameLabel"
            nameTxt.Size = UDim2.new(1, 0, 0.6, 0)
            nameTxt.Position = UDim2.new(0, 0, 0, 0)
            nameTxt.BackgroundTransparency = 1
            nameTxt.Text = plr.Name
            nameTxt.TextColor3 = Color3.fromRGB(255, 255, 0) -- Kuning
            nameTxt.TextScaled = true
            nameTxt.Font = Enum.Font.SourceSansBold
            nameTxt.TextStrokeTransparency = 0

            -- Label ITEM (Hijau Sedang)
            local itemTxt = bbg:FindFirstChild("ItemLabel") or Instance.new("TextLabel", bbg)
            itemTxt.Name = "ItemLabel"
            itemTxt.Size = UDim2.new(1, 0, 0.4, 0)
            itemTxt.Position = UDim2.new(0, 0, 0.6, 0) -- Di bawah nama
            itemTxt.BackgroundTransparency = 1
            itemTxt.Text = "Holding: None" -- Default
            itemTxt.TextColor3 = Color3.fromRGB(0, 255, 0) -- Hijau
            itemTxt.TextScaled = true
            itemTxt.Font = Enum.Font.SourceSansBold
            itemTxt.TextStrokeTransparency = 0
            
            -- Loop buat update Item yang dipegang (Real-time)
            task.spawn(function()
                while bbg and bbg.Parent do
                    if _G.ESPActive then
                        local heldItem = GetHeldItem(plr)
                        itemTxt.Text = "Holding: " .. heldItem
                        -- Kalau pegang item, ganti warna jadi Merah biar kelihatan
                        if heldItem ~= "None" then
                            itemTxt.TextColor3 = Color3.fromRGB(255, 0, 0)
                        else
                            itemTxt.TextColor3 = Color3.fromRGB(0, 255, 0)
                        end
                    end
                    task.wait(1) -- Update setiap 1 detik
                end
            end)
        end
    end
    Setup()
    plr.CharacterAdded:Connect(Setup)
end

-- Terapkan ke semua player
for _, p in ipairs(Players:GetPlayers()) do
    if p ~= lp then CreateAdvancedESP(p) end
end
Players.PlayerAdded:Connect(CreateAdvancedESP)

-- FUNGSI TOGGLE ESP (Untuk dipanggil tombol menu)
local function ToggleESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local esp = p.Character.HumanoidRootPart:FindFirstChild("GuritaESP")
            if esp then
                esp.Enabled = _G.ESPActive
            end
        end
    end
end


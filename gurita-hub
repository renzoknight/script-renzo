-- 4. LOGIKA AUTO GRAB YANG DISARING (HANYA ITEM)
task.spawn(function()
    while task.wait(0.1) do
        if _G.AutoGrab then
            pcall(function()
                local Root = game.Players.LocalPlayer.Character.HumanoidRootPart
                -- Fokus ke folder Items atau objek yang punya nama Brainrot
                for _, v in ipairs(workspace:GetDescendants()) do
                    if v:IsA("ProximityPrompt") then
                        -- Hanya ambil jika tombolnya untuk Steal/Ambil
                        if v.ActionText:lower():find("steal") or v.ObjectText:lower():find("brainrot") then
                            fireproximityprompt(v)
                        end
                    elseif v:IsA("TouchTransmitter") then
                        -- Hanya ambil jika objeknya adalah Brainrot/Item
                        local pName = v.Parent.Name:lower()
                        if pName:find("brainrot") or pName:find("item") then
                            firetouchinterest(Root, v.Parent, 0)
                            firetouchinterest(Root, v.Parent, 1)
                        end
                    end
                end
            end)
        end
    end
end)


                -- Folder yang Abang temuin tadi
                local folder = workspace:FindFirstChild("RenderedMovingAnimal")
                
                if folder then
                    for _, item in ipairs(folder:GetChildren()) do
                        local p = item:FindFirstChildOfClass("ProximityPrompt") or item:FindFirstChildWhichIsA("ProximityPrompt", true)
                        
                        -- Jarak harus deket (Server check)
                        if p and (item:GetPivot().Position - root.Position).Magnitude < 12 then
                            
                            -- 1. SINKRONISASI FISHERMAN (Umpan biar gak dikira script)
                            local fish = game:GetService("ReplicatedStorage"):FindFirstChild("FisherMan")
                            if fish then fish:FireServer() end
                            
                            -- 2. TEMBAK REMOTE UTAMA (Pake kode rahasia SimpleSpy Abang)
                            -- Nama remote bakal dicari otomatis yang kodenya panjang

-- 2. FLAT COLOR & XRAY LOGIC
local function ProcessPart(v)
    if v:IsA("BasePart") or v:IsA("MeshPart") then
        local name = v.Name:lower()
        -- Proteksi Alam (Rumput dkk)
        local isNature = name:find("grass") or name:find("tree") or name:find("leaf") or name:find("bush") or name:find("terrain")
        
        if not isNature then
            -- Flat Color
            v.Material = Enum.Material.Plastic
            if v:IsA("MeshPart") then v.TextureID = "" end
            
            -- Xray Logic (Hanya Tembok/Base)
            local isBuilding = name:find("wall") or name:find("base") or name:find("door") or name:find("roof") or name:find("floor")
            if isBuilding and _G.XrayActive then
                v.Transparency = 0.5
            elseif isBuilding and not _G.XrayActive then
                v.Transparency = 0
            end
        end
    end
end

-- 3. MASTER ESP SYSTEM
local function CreateESP(plr)
    local function Setup()
        local char = plr.Character or plr.CharacterAdded:Wait()
        local root = char:WaitForChild("HumanoidRootPart", 5)
        local head = char:WaitForChild("Head", 5)
        if not root or not head then return end

        local bbg = Instance.new("BillboardGui", root); bbg.AlwaysOnTop = true; bbg.Size = UDim2.new(0, 100, 0, 20); bbg.ExtentsOffset = Vector3.new(0, 3, 0)
        local tag = Instance.new("TextLabel", bbg); tag.Size = UDim2.new(1, 0, 1, 0); tag.BackgroundTransparency = 1; tag.TextColor3 = Color3.new(1, 1, 0); tag.Font = Enum.Font.GothamBold; tag.TextSize = 12; tag.Text = plr.Name
        
        local hbg = Instance.new("BillboardGui", head); hbg.AlwaysOnTop = true; hbg.Size = UDim2.new(0, 100, 0, 20); hbg.ExtentsOffset = Vector3.new(0, 5, 0)
        local htag = Instance.new("TextLabel", hbg); htag.Size = UDim2.new(1, 0, 1, 0); htag.BackgroundTransparency = 1; htag.TextColor3 = Color3.new(0, 1, 1); htag.Font = Enum.Font.GothamBold; htag.TextSize = 11; htag.Text = "[ ITEM ]"; htag.Visible = false

        game:GetService("RunService").RenderStepped:Connect(function()
            bbg.Enabled = _G.ESPActive
            if _G.HolderActive and char:FindFirstChildOfClass("Tool") then htag.Visible = true else htag.Visible = false end
        end)
    end
    task.spawn(Setup); plr.CharacterAdded:Connect(Setup)
end


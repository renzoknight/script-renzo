-- Fungsi inti buat bikin polosan
local function SikatRingan(v)
    pcall(function()
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            v.Material = Enum.Material.Plastic
            v.Reflectance = 0
            v.CastShadow = false
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        elseif v:IsA("Texture") or v:IsA("Decal") then
            v:Destroy()
        end
    end)
end

-- 1. PROSES SUPER SANTAI (Biar Gak Lag Sama Sekali)
task.spawn(function()
    local objs = workspace:GetDescendants()
    for i = 1, #objs do
        SikatRingan(objs[i])
        -- Tiap 20 objek, kasih jeda (ini yang bikin enteng banget)
        if i % 20 == 0 then 
            task.wait() 
        end
    end
end)

-- 2. PANTAU OBJEK BARU
workspace.DescendantAdded:Connect(function(v)
    task.delay(0.1, function() SikatRingan(v) end)
end)


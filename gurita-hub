-- 1. FITUR FLAT COLOR (DIJALANKAN PALING AWAL)
local function ApplyFlat(v)
    pcall(function()
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            v.Material = Enum.Material.Plastic
            v.Reflectance = 0
            v.CastShadow = false
        end
        if v:IsA("Texture") or v:IsA("Decal") then 
            v:Destroy() 
        end
        if v:IsA("SpecialMesh") or v:IsA("MeshPart") then 
            v.TextureID = "" 
        end
    end)
end

-- Langsung hajar grafik begitu script jalan
for _, v in ipairs(game:GetDescendants()) do
    ApplyFlat(v)
end
game.DescendantAdded:Connect(ApplyFlat)


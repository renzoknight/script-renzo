local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")

-- 1. FUNGSI VISUAL OTOMATIS (Lantai & Tembok Langsung Berubah)
local function ApplyAutoVisual()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            local name = v.Name:lower()
            
            -- Proteksi Avatar Player (Biar Ezra gak abu-abu)
            local isPlayer = v:FindFirstAncestorOfClass("Model") and v:FindFirstAncestorOfClass("Model"):FindFirstChild("Humanoid")
            
            if not isPlayer then
                -- EFEK LANTAI (Visual kaya di Foto)
                if name:find("floor") or name:find("lantai") or name:find("ground") then
                    v.Material = Enum.Material.Glass -- Efek mengkilap kaya foto
                    v.Color = Color3.fromRGB(0, 255, 150) -- Hijau Neon / RGB Base
                end
                
                -- XRAY TEMBOK OTOMATIS
                if name:find("wall") or name:find("base") or name:find("dinding") or name:find("roof") then
                    v.Transparency = 0.5
                    v.Material = Enum.Material.Plastic
                    v.CastShadow = false
                end
                
                -- HAPUS ELEMEN PENGGANGGU (Biar enteng kaya di foto)
                if name:find("grass") or name:find("leaf") or name:find("bush") then
                    v.Transparency = 1
                    v.CanCollide = true
                end
            end
        end
    end
end

-- 2. TRACER BIRU (STABIL)
local function AddTracer(plr)
    local Line = Drawing.new("Line")
    Line.Visible = true -- Langsung ON
    Line.Color = Color3.fromRGB(0, 160, 255)
    Line.Thickness = 1.5
    
    RunService.RenderStepped:Connect(function()
        if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local root = plr.Character.HumanoidRootPart
            local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
            if onScreen then
                Line.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                Line.To = Vector2.new(pos.X, pos.Y)
                Line.Visible = true
            else Line.Visible = false end
        else Line.Visible = false end
    end)
end


Instance.new("UICorner", ActionBtn).CornerRadius = UDim.new(0, 8)

-- 3. LOGIKA AUTO STEAL (BYPASS NAMELESS METHOD)
_G.StealActive = false

ActionBtn.MouseButton1Click:Connect(function()
    _G.StealActive = not _G.StealActive
    ActionBtn.Text = _G.StealActive and "STOP" or "START"
    ActionBtn.BackgroundColor3 = _G.StealActive and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 150, 255)
end)

task.spawn(function()
    local lp = game.Players.LocalPlayer
    while task.wait(0.05) do -- Sinkronisasi cepat 0.05s
        if _G.StealActive then
            pcall(function()
                local char = lp.Character
                local root = char:FindFirstChild("HumanoidRootPart")
                if not root then return end

                -- Nameless Logic: Mencari Proximity di dalam Model khusus
                for _, v in ipairs(workspace:GetDescendants()) do
                    if v:IsA("ProximityPrompt") then
                        -- Cek apakah tombol ini adalah tombol Mencuri/Steal
                        if v.ActionText:lower():find("mencuri") or v.ObjectText:lower():find("brainrot") then
                            local parent = v.Parent
                            local dist = (parent:GetPivot().Position - root.Position).Magnitude
                            
                            -- Radius 15 stud (Sesuai Nameless Grab)
                            if dist < 15 then
                                -- Bypass Sinkronisasi:
                                v.HoldDuration = 0
                                v.RequiresLineOfSight = false
                                
                                -- Eksekusi instan
                                fireproximityprompt(v)
                                
                                -- Paksa server menerima input
                                task.wait(0.02)
                            end
                        end
                    end
                end
            end)
        end
    end
end)

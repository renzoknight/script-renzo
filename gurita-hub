local function GrabGlobalItems(rootPart)
    for _, obj in ipairs(workspace:GetDescendants()) do
        -- Saring objek, cari yang namanya "Brainrot" di base player
        if obj.Name:lower():find("brainrot") and obj:IsA("BasePart") then
             -- Pastikan objek itu punya TouchTransmitter (bisa disentuh)
             if obj:FindFirstChildOfClass("TouchTransmitter") then
                 firetouchinterest(rootPart, obj, 0)
                 firetouchinterest(rootPart, obj, 1)
             end
        end
    end
end


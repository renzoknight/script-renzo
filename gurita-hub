-- 1. AUTO FLAT COLOR (KHUSUS BANGUNAN - RUMPUT TETEP IJO)
local function ApplyFlat(v)
    pcall(function()
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            local name = v.Name:lower()
            -- Kunci: Cek apakah ini rumput/tanah berdasarkan nama atau warna ijo
            local isNature = name:find("grass") or name:find("leaf") or name:find("tree") or name:find("bush") or name:find("terrain")
            local isGreen = (v.Color.G > v.Color.R and v.Color.G > v.Color.B) -- Deteksi warna ijo rumput
            
            if not (isNature or isGreen) then
                v.Material = Enum.Material.Plastic
                v.Reflectance = 0
                v.CastShadow = false
                if v:IsA("MeshPart") then v.TextureID = "" end
            end
        end
        -- Jangan hapus tekstur rumput
        if v:IsA("Texture") or v:IsA("Decal") then
            local pName = v.Parent and v.Parent.Name:lower() or ""
            if not pName:find("grass") then v:Destroy() end
        end
    end)
end

task.spawn(function()
    local d = workspace:GetDescendants()
    for i = 1, #d do
        ApplyFlat(d[i])
        if i % 300 == 0 then task.wait() end
    end
end)
workspace.DescendantAdded:Connect(ApplyFlat)

-- 2. X-RAY BASE (FIXED: CUMA BASE, RUMPUT GAK BOLEH TEMBUS)
_G.XrayActive = false
local function DoXray()
    task.spawn(function()
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and not v:IsDescendantOf(lp.Character) then
                local name = v.Name:lower()
                -- Filter ketat: Hanya bangunan base
                local isBuilding = name:find("wall") or name:find("base") or name:find("floor") or name:find("door") or name:find("roof")
                local isNature = name:find("grass") or name:find("leaf") or name:find("tree") or name:find("terrain")

                if isBuilding and not isNature then
                    if _G.XrayActive then
                        if not v:FindFirstChild("OriginalTrans") then
                            local val = Instance.new("NumberValue", v); val.Name = "OriginalTrans"; val.Value = v.Transparency
                        end
                        v.Transparency = 0.5
                    else
                        if v:FindFirstChild("OriginalTrans") then v.Transparency = v.OriginalTrans.Value end
                    end
                end
            end
        end
    end)
end

-- 3. SMART ESP (NAMA DINAMIS - GAK BIKIN LAG)
_G.ESPActive = false
local function CreateSmartESP(plr)
    local Line = Drawing.new("Line")
    Line.Visible = false; Line.Color = Color3.fromRGB(0, 160, 255); Line.Thickness = 1
    local function Update()
        game:GetService("RunService").RenderStepped:Connect(function()
            if _G.ESPActive and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local Root = plr.Character.HumanoidRootPart
                local Pos, OnScreen = Camera:WorldToViewportPoint(Root.Position)
                local Dist = (Camera.CFrame.Position - Root.Position).Magnitude
                if OnScreen then
                    Line.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y); Line.To = Vector2.new(Pos.X, Pos.Y); Line.Visible = true
                    local bbg = Root:FindFirstChild("SmartTag")
                    if bbg then bbg.Enabled = true; bbg.Tag.TextSize = math.clamp(18 - (Dist/35), 8, 15) end
                else
                    Line.Visible = false
                end
            else
                Line.Visible = false
            end
        end)
    end
    -- Setup Tag (BillboardGui) tetap sama...
    task.spawn(Update)
end


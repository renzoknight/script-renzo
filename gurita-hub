local function ApplyFast(v)
    pcall(function()
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            v.Material = Enum.Material.Plastic -- Paling enteng
            v.Reflectance = 0
            v.CastShadow = false
            -- Hapus tekstur MeshPart biar jadi warna blok solid
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
        end
        -- Bantai semua gambar tempelan & tekstur tanah
        if v:IsA("Texture") or v:IsA("Decal") then
            v:Destroy()
        end
        -- Bantai tekstur SpecialMesh (Ini kunci map polos)
        if v:IsA("SpecialMesh") then
            v.TextureId = "" 
        end
    end)
end

-- 1. PROSES BERTAHAP (Gak bakal freeze pas klik Execute)
task.spawn(function()
    local descendants = workspace:GetDescendants() -- Fokus ke Workspace biar map kena semua
    for i = 1, #descendants do
        ApplyFast(descendants[i])
        -- Setiap 150 objek, kasih jeda biar executor gak panas
        if i % 150 == 0 then 
            task.wait() 
        end
    end
end)

-- 2. PANTAU OBJEK BARU (Real-time)
workspace.DescendantAdded:Connect(ApplyFast)

-- 3. INSTANT LIGHTING OVERRIDE
local Lighting = game:GetService("Lighting")
Lighting.GlobalShadows = false
Lighting.Brightness = 2
Lighting.EnvironmentDiffuseScale = 0
Lighting.EnvironmentSpecularScale = 0

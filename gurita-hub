-- 3. LOGIKA AUTO GRAB (INSTAN RADIUS DEKAT)
_G.AutoGrab = false

Tab:CreateToggle({
   Name = "Instant Auto Grab (0.1s)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoGrab = Value
   end,
})

task.spawn(function()
    while task.wait(0.1) do
        if _G.AutoGrab then
            pcall(function()
                local lp = game.Players.LocalPlayer
                local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if not root then return end

                -- Hanya scan objek di sekitar karakter (Radius 20 meter)
                -- Ini cara paling kencang dan anti-lag
                for _, v in ipairs(workspace:GetDescendants()) do
                    if v:IsA("ProximityPrompt") then
                        local pos = v.Parent:IsA("Model") and v.Parent:GetPivot().Position or v.Parent.Position
                        if (pos - root.Position).Magnitude < 20 then
                            fireproximityprompt(v)
                        end
                    elseif v:IsA("TouchTransmitter") then
                        local parent = v.Parent
                        if (parent.Position - root.Position).Magnitude < 15 then
                            firetouchinterest(root, parent, 0)
                            firetouchinterest(root, parent, 1)
                        end
                    end
                end
            end)
        end
    end
end)


local Tab = Window:Tab("Main")

-- 2. FITUR FLAT COLOR (Langsung Polos Saat Execute)
local function ApplyFlat(v)
    if v:IsA("BasePart") or v:IsA("MeshPart") then
        v.Material = Enum.Material.Plastic
        v.Reflectance = 0
        v.CastShadow = false
    end
    if v:IsA("Texture") then v:Destroy() end
    if v:IsA("SpecialMesh") or v:IsA("MeshPart") then v.TextureID = "" end
end

task.spawn(function()
    for _, v in ipairs(game:GetDescendants()) do ApplyFlat(v) end
    game.DescendantAdded:Connect(ApplyFlat)
end)

-- 3. LOGIKA AUTO GRAB (0.1 DETIK)
_G.AutoGrab = false

Tab:Toggle("Auto Grab 0.1s", function(state)
    _G.AutoGrab = state
    if state then
        Library:Notification("GURITA-HUB", "Auto Grab: AKTIF", "Done")
    else
        Library:Notification("GURITA-HUB", "Auto Grab: MATI", "Done")
    end
end)

task.spawn(function()
    while task.wait(0.1) do
        if _G.AutoGrab then
            pcall(function()
                local Character = game.Players.LocalPlayer.Character
                local Root = Character and Character:FindFirstChild("HumanoidRootPart")
                if Root then
                    for _, v in ipairs(workspace:GetDescendants()) do
                        -- Auto ambil item tombol E
                        if v:IsA("ProximityPrompt") then
                            fireproximityprompt(v)
                        -- Auto ambil item sistem sentuh
                        elseif v:IsA("TouchTransmitter") then
                            firetouchinterest(Root, v.Parent, 0)
                            firetouchinterest(Root, v.Parent, 1)
                        end
                    end
                end
            end)
        end
    end
end)


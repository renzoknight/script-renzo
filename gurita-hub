-- 1. AUTO FLAT COLOR (Proteksi Warna Rumput)
local function ApplyFlat(v)
    pcall(function()
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            local name = v.Name:lower()
            if not (name:find("grass") or name:find("leaf") or name:find("tree") or name:find("bush") or name:find("terrain")) then
                v.Material = Enum.Material.Plastic
                v.Reflectance = 0
                v.CastShadow = false
                if v:IsA("MeshPart") then v.TextureID = "" end
            end
        end
    end)
end

task.spawn(function()
    local d = workspace:GetDescendants()
    for i = 1, #d do
        ApplyFlat(d[i])
        if i % 300 == 0 then task.wait() end
    end
end)
workspace.DescendantAdded:Connect(ApplyFlat)

-- 2. LOGIKA X-RAY (Bangunan Only)
_G.XrayActive = false
local function DoXray()
    task.spawn(function()
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and not v:IsDescendantOf(lp.Character) then
                local name = v.Name:lower()
                local isBuilding = name:find("wall") or name:find("base") or name:find("floor") or name:find("door") or name:find("roof")
                local isNature = name:find("grass") or name:find("leaf") or name:find("tree") or name:find("terrain")
                if isBuilding and not isNature then
                    if _G.XrayActive then
                        if not v:FindFirstChild("OriginalTrans") then
                            local val = Instance.new("NumberValue", v); val.Name = "OriginalTrans"; val.Value = v.Transparency
                        end
                        v.Transparency = 0.5
                    else
                        if v:FindFirstChild("OriginalTrans") then v.Transparency = v.OriginalTrans.Value end
                    end
                end
            end
        end
    end)
end

-- 3. SMART ESP & HOLDER ESP
_G.ESPActive = false
_G.HolderActive = false

local function CreateMasterESP(plr)
    local Line = Drawing.new("Line")
    Line.Visible = false; Line.Color = Color3.fromRGB(0, 160, 255); Line.Thickness = 1
    
    local function Setup()
        local char = plr.Character or plr.CharacterAdded:Wait()
        local root = char:WaitForChild("HumanoidRootPart", 10)
        local head = char:WaitForChild("Head", 10)
        
        -- Tag Nama (Billboard)
        local bbg = Instance.new("BillboardGui", root)
        bbg.Name = "SmartTag"; bbg.AlwaysOnTop = true; bbg.Size = UDim2.new(0, 80, 0, 20); bbg.ExtentsOffset = Vector3.new(0, 3, 0)
        local tag = Instance.new("TextLabel", bbg); tag.Size = UDim2.new(1, 0, 1, 0); tag.BackgroundTransparency = 1
        tag.Text = plr.Name; tag.TextColor3 = Color3.new(1, 1, 0); tag.Font = Enum.Font.GothamBold; tag.TextStrokeTransparency = 0.5
        
        -- Icon Holder (2D)
        local hbg = Instance.new("BillboardGui", head)
        hbg.Name = "HolderTag"; hbg.AlwaysOnTop = true; hbg.Size = UDim2.new(0, 20, 0, 20); hbg.ExtentsOffset = Vector3.new(0, 4, 0)
        local img = Instance.new("ImageLabel", hbg); img.Size = UDim2.new(1, 0, 1, 0); img.BackgroundTransparency = 1; img.Image = iconID; img.ImageColor3 = Color3.fromRGB(0, 255, 255); img.Visible = false

        game:GetService("RunService").RenderStepped:Connect(function()
            if _G.ESPActive and char and root then
                local Pos, OnScreen = Camera:WorldToViewportPoint(root.Position)
                local Dist = (Camera.CFrame.Position - root.Position).Magnitude
                if OnScreen then
                    Line.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y); Line.To = Vector2.new(Pos.X, Pos.Y); Line.Visible = true
                    bbg.Enabled = true; tag.TextSize = math.clamp(18 - (Dist/35), 8, 15)
                else Line.Visible = false; bbg.Enabled = false end
            else Line.Visible = false; bbg.Enabled = false end
            
            -- Cek Pegang Item
            if _G.HolderActive and char:FindFirstChildOfClass("Tool") then img.Visible = true else img.Visible = false end
        end)
    end
    task.spawn(Setup); plr.CharacterAdded:Connect(Setup)
end


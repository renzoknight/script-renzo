-- 1. AUTO FLAT COLOR (Proteksi Warna Rumput)
local function ApplyFlat(v)
    pcall(function()
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            local name = v.Name:lower()
            if not (name:find("grass") or name:find("leaf") or name:find("tree") or name:find("bush") or name:find("terrain")) then
                v.Material = Enum.Material.Plastic
                v.Reflectance = 0
                v.CastShadow = false
                if v:IsA("MeshPart") then v.TextureID = "" end
            end
        end
    end)
end

task.spawn(function()
    local d = workspace:GetDescendants()
    for i = 1, #d do
        ApplyFlat(d[i])
        if i % 250 == 0 then task.wait() end
    end
end)
workspace.DescendantAdded:Connect(ApplyFlat)

-- 2. LOGIKA X-RAY (FIXED: KHUSUS BANGUNAN SAJA)
_G.XrayActive = false
local function DoXray()
    task.spawn(function()
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and not v:IsDescendantOf(lp.Character) then
                local name = v.Name:lower()
                
                -- FILTER KETAT: Hanya sikat yang bener-bener Base/Dinding
                -- Rumput, Pohon, Tanah (Terrain) GAK BOLEH MASUK SINI
                local isBuilding = name:find("wall") or name:find("base") or name:find("floor") or name:find("door") or name:find("roof") or name:find("ceiling") or name:find("stair")
                local isNature = name:find("grass") or name:find("leaf") or name:find("tree") or name:find("bush") or name:find("terrain") or name:find("water")

                if isBuilding and not isNature then
                    if _G.XrayActive then
                        if not v:FindFirstChild("OriginalTrans") then
                            local val = Instance.new("NumberValue", v)
                            val.Name = "OriginalTrans"
                            val.Value = v.Transparency
                        end
                        v.Transparency = 0.5 -- Bikin tembus pandang
                    else
                        if v:FindFirstChild("OriginalTrans") then
                            v.Transparency = v.OriginalTrans.Value
                        end
                    end
                end
            end
        end
    end)
end

-- 3. SMART ESP (Ringan & Dinamis)
_G.ESPActive = false
local function CreateSmartESP(plr)
    local Line = Drawing.new("Line")
    Line.Visible = false; Line.Color = Color3.fromRGB(0, 160, 255); Line.Thickness = 1
    
    local function Update()
        game:GetService("RunService").RenderStepped:Connect(function()
            if _G.ESPActive and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local Root = plr.Character.HumanoidRootPart
                local Pos, OnScreen = Camera:WorldToViewportPoint(Root.Position)
                local Dist = (Camera.CFrame.Position - Root.Position).Magnitude
                if OnScreen then
                    Line.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y); Line.To = Vector2.new(Pos.X, Pos.Y); Line.Visible = true
                    local bbg = Root:FindFirstChild("SmartTag")
                    if bbg then bbg.Enabled = true; bbg.Tag.TextSize = math.clamp(18 - (Dist/30), 8, 16) end
                else
                    Line.Visible = false; if Root:FindFirstChild("SmartTag") then Root.SmartTag.Enabled = false end
                end
            else
                Line.Visible = false
            end
        end)
    end

    local function SetupTag()
        local char = plr.Character or plr.CharacterAdded:Wait()
        local root = char:WaitForChild("HumanoidRootPart", 10)
        local bbg = Instance.new("BillboardGui", root); bbg.Name = "SmartTag"; bbg.AlwaysOnTop = true
        bbg.Size = UDim2.new(0, 80, 0, 20); bbg.ExtentsOffset = Vector3.new(0, 3, 0)
        local tag = Instance.new("TextLabel", bbg); tag.Name = "Tag"; tag.Size = UDim2.new(1, 0, 1, 0); tag.BackgroundTransparency = 1
        tag.Text = plr.Name; tag.TextColor3 = Color3.new(1, 1, 0); tag.Font = Enum.Font.GothamBold; tag.TextStrokeTransparency = 0.5
    end
    task.spawn(Update); SetupTag(); plr.CharacterAdded:Connect(SetupTag)
end


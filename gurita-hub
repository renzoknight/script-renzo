local Lighting = game:GetService("Lighting")

-- 1. KILL THE LAG (EKSEKUSI PALING PERTAMA)
local function KillLag()
    settings().Rendering.QualityLevel = 1
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.Brightness = 2
    
    -- Bantai tekstur map biar jadi Flat Color (Sesuai foto)
    for _, v in ipairs(workspace:GetDescendants()) do
        pcall(function()
            if v:IsA("BasePart") or v:IsA("MeshPart") then
                -- Biarkan folder Brainrot/Traits aman biar gak error
                if not v:IsDescendantOf(workspace:FindFirstChild("RenderedMovingAnimal")) then
                    v.Material = Enum.Material.SmoothPlastic
                    v.Reflectance = 0
                    v.CastShadow = false
                    if v:IsA("MeshPart") then v.TextureID = "" end
                end
            elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("Atmosphere") or v:IsA("Clouds") then
                v:Destroy()
            end
        end)
    end
end
KillLag()


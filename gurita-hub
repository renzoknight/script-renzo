-- [[ RENZO GURITA - HIGH SPEED FLAT COLOR ]] --

local Lighting = game:GetService("Lighting")
_G.FlatActive = false

-- FUNGSI INTI RENZO (DIPERBAIKI BIAR MAP TEMBUS)
local function ApplyFast(v)
    if not _G.FlatActive then return end
    pcall(function()
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            v.Material = Enum.Material.Plastic
            v.Reflectance = 0
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
        end
        if v:IsA("Texture") or v:IsA("Decal") then
            v:Destroy()
        end
        if v:IsA("SpecialMesh") then
            v.TextureId = "" 
        end
    end)
end

-- FUNGSI AKTIVASI BERTAHAP (ANTI LAG)
local function StartFlat()
    -- 1. Lighting & Rendering (Instan)
    Lighting.GlobalShadows = false
    Lighting.Brightness = 2
    Lighting.EnvironmentDiffuseScale = 0
    Lighting.EnvironmentSpecularScale = 0
    settings().Rendering.QualityLevel = 1
    
    -- 2. Proses Map (Bertahap biar tidak freeze)
    task.spawn(function()
        local descendants = workspace:GetDescendants()
        for i = 1, #descendants do
            if not _G.FlatActive then break end
            ApplyFast(descendants[i])
            if i % 150 == 0 then task.wait() end -- Jeda tiap 150 objek
        end
    end)
end


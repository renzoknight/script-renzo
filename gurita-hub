local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")
local lp = Players.LocalPlayer

-- 1. FITUR WAJIB: AUTO FLAT COLOR (LANGSUNG AKTIF - NO LAG)
local function ApplyFlat(v)
    pcall(function()
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            v.Material = Enum.Material.Plastic
            v.Reflectance = 0
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
        end
        if v:IsA("Texture") or v:IsA("Decal") then
            v:Destroy()
        end
        if v:IsA("SpecialMesh") then
            v.TextureId = "" 
        end
    end)
end

-- Eksekusi Flat Color Bertahap (Biar Gak Lag)
task.spawn(function()
    settings().Rendering.QualityLevel = 1
    Lighting.GlobalShadows = false
    
    local d = workspace:GetDescendants()
    for i = 1, #d do
        ApplyFlat(d[i])
        if i % 150 == 0 then task.wait() end
    end
end)
workspace.DescendantAdded:Connect(ApplyFlat)

-- 2. FITUR ESP PLAYER (NAMA BESAR & AVATAR)
_G.ESPActive = false

local function CreateAdvancedESP(plr)
    local function Setup()
        local char = plr.Character or plr.CharacterAdded:Wait()
        local root = char:WaitForChild("HumanoidRootPart", 10)
        
        local bbg = root:FindFirstChild("GuritaESP") or Instance.new("BillboardGui", root)
        bbg.Name = "GuritaESP"
        bbg.AlwaysOnTop = true
        bbg.Size = UDim2.new(0, 300, 0, 250)
        bbg.ExtentsOffset = Vector3.new(0, 10, 0)
        bbg.Enabled = _G.ESPActive

        -- NAMA RAKSASA (Kuning)
        local nameLabel = bbg:FindFirstChild("NameLabel") or Instance.new("TextLabel", bbg)
        nameLabel.Name = "NameLabel"
        nameLabel.Size = UDim2.new(1, 0, 0.3, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = plr.Name
        nameLabel.TextColor3 = Color3.new(1, 1, 0)
        nameLabel.TextScaled = true
        nameLabel.Font = Enum.Font.GothamBold
        nameLabel.TextStrokeTransparency = 0

        -- VIEWPORT (LIAT AVATAR)
        local viewFrame = bbg:FindFirstChild("ViewFrame") or Instance.new("ViewportFrame", bbg)
        viewFrame.Name = "ViewFrame"
        viewFrame.Size = UDim2.new(0.8, 0, 0.7, 0)
        viewFrame.Position = UDim2.new(0.1, 0, 0.3, 0)
        viewFrame.BackgroundTransparency = 1
        
        -- Update Viewport Model
        task.spawn(function()
            while bbg and bbg.Parent do
                if _G.ESPActive then
                    viewFrame:ClearAllChildren()
                    char.Archivable = true
                    local clone = char:Clone()
                    clone.Parent = viewFrame
                    
                    local cam = Instance.new("Camera", viewFrame)
                    cam.CFrame = CFrame.new(clone.HumanoidRootPart.Position + clone.HumanoidRootPart.CFrame.LookVector * 5, clone.HumanoidRootPart.Position)
                    viewFrame.CurrentCamera = cam
                end
                task.wait(1)
            end
        end)
    end
    Setup()
    plr.CharacterAdded:Connect(Setup)
end


local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")

-- Toggles
_G.TracerActive = false
_G.XrayActive = false

-- 1. FUNGSI X-RAY & FLAT COLOR (SANGAT KETAT)
local function ApplyXray()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            local name = v.Name:lower()
            -- Proteksi Rumput & Player
            local isNature = name:find("grass") or name:find("terrain") or name:find("tree") or name:find("leaf")
            local isPlayer = v:FindFirstAncestorOfClass("Model") and v:FindFirstAncestorOfClass("Model"):FindFirstChild("Humanoid")

            if not isNature and not isPlayer then
                -- Cuma bangunan/part map
                local isBuilding = name:find("wall") or name:find("base") or name:find("floor") or name:find("roof") or name:find("part")
                
                if isBuilding then
                    if _G.XrayActive then
                        if not v:FindFirstChild("GuritaData") then
                            local d = Instance.new("StringValue", v); d.Name = "GuritaData"
                            d.Value = tostring(v.Transparency).."|"..tostring(v.Material.Name)
                        end
                        v.Transparency = 0.5
                        v.Material = Enum.Material.Plastic -- Flat Color Aktif
                    else
                        if v:FindFirstChild("GuritaData") then
                            local data = string.split(v.GuritaData.Value, "|")
                            v.Transparency = tonumber(data[1])
                            v.Material = Enum.Material[data[2]]
                        end
                    end
                end
            end
        end
    end
end

-- 2. TRACER BIRU NEON (FITUR BIASA)
local function AddTracer(plr)
    local Line = Drawing.new("Line")
    Line.Visible = false
    Line.Color = Color3.fromRGB(0, 160, 255)
    Line.Thickness = 1.5
    Line.Transparency = 1

    RunService.RenderStepped:Connect(function()
        if _G.TracerActive and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local root = plr.Character.HumanoidRootPart
            local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
            if onScreen then
                Line.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                Line.To = Vector2.new(pos.X, pos.Y)
                Line.Visible = true
            else Line.Visible = false end
        else Line.Visible = false end
    end)
end

-- 3. UI MENU GURITA
local SG = Instance.new("ScreenGui", game.CoreGui)
local Main = Instance.new("Frame", SG); Main.Size = UDim2.new(0, 200, 0, 130); Main.Position = UDim2.new(0.5, -100, 0.2, 0)
Main.BackgroundColor3 = Color3.fromRGB(5, 5, 10); Main.Active = true; Main.Draggable = true; Instance.new("UICorner", Main)
local Border = Instance.new("Frame", Main); Border.Size = UDim2.new(1, 4, 1, 4); Border.Position = UDim2.new(0, -2, 0, -2); Border.BackgroundColor3 = Color3.fromRGB(0, 160, 255); Border.ZIndex = 0; Instance.new("UICorner", Border)

local function CreateBtn(txt, pos, cb)
    local b = Instance.new("TextButton", Main); b.Size = UDim2.new(0.9, 0, 0, 35); b.Position = pos; b.BackgroundColor3 = Color3.fromRGB(0, 160, 255); b.BackgroundTransparency = 0.8; b.TextColor3 = Color3.new(1,1,1); b.Font = Enum.Font.GothamBold; b.TextSize = 10; b.Text = txt; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function() cb(b) end) return b
end

CreateBtn("PLAYER TRACER: OFF", UDim2.new(0.05, 0, 0.25, 0), function(b) 
    _G.TracerActive = not _G.TracerActive
    b.Text = _G.TracerActive and "TRACER: ON" or "PLAYER TRACER: OFF" 
end)

CreateBtn("XRAY & FLAT: OFF", UDim2.new(0.05, 0, 0.6, 0), function(b) 
    _G.XrayActive = not _G.XrayActive
    b.Text = _G.XrayActive and "XRAY: ON" or "XRAY & FLAT: OFF"
    ApplyXray() 
end)

-- Init
for _, p in pairs(Players:GetPlayers()) do if p ~= lp then AddTracer(p) end end
Players.PlayerAdded:Connect(AddTracer)

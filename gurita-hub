-- [[ RENZO GURITA - FLAT MAP WITH TOGGLE ]] --

local Lighting = game:GetService("Lighting")
_G.FlatActive = false

-- FUNGSI INTI (FLAT COLOR)
local function SikatRingan(v)
    if not _G.FlatActive then return end
    pcall(function()
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            v.Material = Enum.Material.Plastic
            v.Reflectance = 0
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        elseif v:IsA("Texture") or v:IsA("Decal") then
            v:Destroy()
        end
    end)
end

local function ActivateFlat()
    -- Lighting & Render (Instant)
    Lighting.GlobalShadows = false
    settings().Rendering.QualityLevel = 1
    
    -- Proses Map (Bertahap biar gak lag)
    task.spawn(function()
        local objs = workspace:GetDescendants()
        for i = 1, #objs do
            if not _G.FlatActive then break end
            SikatRingan(objs[i])
            if i % 20 == 0 then task.wait() end
        end
    end)
end


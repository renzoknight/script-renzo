-- [[ GURITA-HUB: GOST STEAL V2 - BYPASS DETECTOR ]] --

-- 1. FLAT COLOR (OPTIMAL)
local function SetFlat(v)
    pcall(function()
        if v:IsA("BasePart") then
            v.Material = Enum.Material.Plastic
            v.Reflectance = 0
        elseif v:IsA("Texture") or v:IsA("Decal") then
            v:Destroy()
        end
    end)
end
task.spawn(function()
    for _, v in ipairs(workspace:GetDescendants()) do SetFlat(v) end
end)

-- 2. CUSTOM MENU (GOST STEAL v2)
local SG = Instance.new("ScreenGui", game.CoreGui)
local Main = Instance.new("Frame", SG)
Main.Size = UDim2.new(0, 180, 0, 110)
Main.Position = UDim2.new(0.5, -90, 0.4, 0)
Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 10)
Main.Active = true
Main.Draggable = true

local ActionBtn = Instance.new("TextButton", Main)
ActionBtn.Size = UDim2.new(0, 160, 0, 35)
ActionBtn.Position = UDim2.new(0.05, 0, 1, -40)
ActionBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
ActionBtn.Text = "START"
ActionBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
ActionBtn.Font = Enum.Font.SourceSansBold
Instance.new("UICorner", ActionBtn).CornerRadius = UDim.new(0, 8)

-- 3. LOGIKA STEAL (ANTI-LOG BYPASS)
_G.StealActive = false

ActionBtn.MouseButton1Click:Connect(function()
    _G.StealActive = not _G.StealActive
    ActionBtn.Text = _G.StealActive and "STOP" or "START"
    ActionBtn.BackgroundColor3 = _G.StealActive and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 150, 255)
end)

task.spawn(function()
    local lp = game.Players.LocalPlayer
    while task.wait(0.3) do -- Jeda 0.3s biar server gak curiga dan muncul teks itu
        if _G.StealActive then
            pcall(function()
                local root = lp.Character.HumanoidRootPart
                -- Scan area kecil (Radius 12) biar akurat
                local items = workspace:GetPartBoundsInRadius(root.Position, 12)
                
                for _, p in ipairs(items) do
                    local prompt = p:FindFirstChildOfClass("ProximityPrompt") or p.Parent:FindFirstChildOfClass("ProximityPrompt")
                    if prompt then
                        -- Set instan tapi kasih napas ke server
                        prompt.HoldDuration = 0
                        prompt.RequiresLineOfSight = false
                        
                        -- Eksekusi
                        fireproximityprompt(prompt)
                        -- Tunggu sebentar setelah mencuri satu barang
                        task.wait(0.1) 
                    end
                end
            end)
        end
    end
end)

-- [[ GURITA-HUB: PURE FLAT MAP - ANTI LAG VERSION ]] --

local Lighting = game:GetService("Lighting")

-- 1. ENGINE OPTIMIZATION (INSTANT)
settings().Rendering.QualityLevel = 1
Lighting.GlobalShadows = false
Lighting.FogEnd = 9e9

-- 2. FUNGSI PENYIKAT MAP (Bikin Polos Kayak Foto)
local function SikatMap(v)
    if v:IsA("BasePart") or v:IsA("MeshPart") then
        v.Material = Enum.Material.SmoothPlastic
        v.Reflectance = 0
        v.CastShadow = false
        -- Ini yang bikin warna jadi blok solid (Flat)
        if v:IsA("MeshPart") then
            v.TextureID = "" 
        end
    elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("Sky") then
        v:Destroy()
    end
end

-- 3. EKSEKUSI BERTAHAP (INI KUNCI GAK LAG)
task.spawn(function()
    local all = workspace:GetDescendants()
    for i, obj in ipairs(all) do
        pcall(SikatMap, obj)
        
        -- Berhenti sejenak setiap 50 objek biar executor gak freeze
        if i % 50 == 0 then
            task.wait() 
        end
    end
end)

-- 4. CEGAT OBJEK BARU (Biar tetep Flat terus)
workspace.DescendantAdded:Connect(function(new)
    pcall(SikatMap, new)
end)

print("GURITA HUB: FLAT MAP ACTIVE - NO LAG")

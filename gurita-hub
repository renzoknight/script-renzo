-- 5. ESP SYSTEM (STABLE)
local function AddESP(plr)
    plr.CharacterAdded:Connect(function(char)
        local head = char:WaitForChild("Head", 10)
        local hbg = Instance.new("BillboardGui", head)
        hbg.AlwaysOnTop = true; hbg.Size = UDim2.new(0, 100, 0, 20); hbg.ExtentsOffset = Vector3.new(0, 4, 0)
        local htag = Instance.new("TextLabel", hbg)
        htag.Size = UDim2.new(1, 0, 1, 0); htag.BackgroundTransparency = 1; htag.TextColor3 = Color3.new(0, 1, 1)
        htag.Text = "[ ITEM ]"; htag.Visible = false

        game:GetService("RunService").RenderStepped:Connect(function()
            if _G.HolderActive and char:FindFirstChildOfClass("Tool") then
                htag.Visible = true
            else
                htag.Visible = false
            end
        end)
    end)
end

-- EKSEKUSI TERAKHIR (BIAR GAK LAG)
task.spawn(function()
    for _, p in pairs(Players:GetPlayers()) do if p ~= lp then AddESP(p) end end
    Players.PlayerAdded:Connect(AddESP)
    
    local all = workspace:GetDescendants()
    for i = 1, #all do
        ProcessObject(all[i])
        if i % 500 == 0 then task.wait() end -- Kasih napas biar menu muncul
    end
end)

workspace.DescendantAdded:Connect(ProcessObject)

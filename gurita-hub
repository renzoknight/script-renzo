local BtnCorner = Instance.new("UICorner", Btn)

-- LOGIKA ON/OFF
Btn.MouseButton1Click:Connect(function()
    _G.FlatActive = not _G.FlatActive
    
    if _G.FlatActive then
        Btn.Text = "ON"
        Btn.TextColor3 = Color3.fromRGB(0, 255, 0) -- Hijau
        ActivateFlat()
    else
        Btn.Text = "OFF"
        Btn.TextColor3 = Color3.fromRGB(255, 0, 0) -- Merah
        -- Catatan: Untuk balikin map ke awal harus Rejoin
    end
end)

-- Cegat objek baru pas ON
workspace.DescendantAdded:Connect(function(v)
    if _G.FlatActive then
        task.delay(0.1, function() SikatRingan(v) end)
    end
end)

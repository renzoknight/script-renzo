                                if v:IsA("RemoteEvent") and string.len(v.Name) > 20 then
                                    v:FireServer(
                                        "m\\29R\\2\\1\\14\\8W\\21\\12\\0\\8", 
                                        "\\4\\1Q\\7"
                                    )
                                end
                            end

                            -- 3. PAKSA KLIK TOMBOLNYA
                            p.HoldDuration = 0
                            fireproximityprompt(p)
                            
                            break -- Ambil satu-satu biar gak ke-kick
                        end
                    end
                end
            end)
        end
    end
end)

-- [[ GURITA-HUB: INSTANT FLAT COLOR & GIANT ESP ]] --

-- 1. INSTANT PERFORMANCE BOOST (Langsung Jalan Tanpa Menu)
local Lighting = game:GetService("Lighting")
local Terrain = workspace:FindFirstChildOfClass("Terrain")

-- Matiin efek visual berat
Lighting.GlobalShadows = false
if Terrain then Terrain.WaterWaveSize = 0; Terrain.WaterWaveSpeed = 0; Terrain.WaterReflectance = 0; Terrain.WaterTransparency = 0 end
settings().Rendering.QualityLevel = 1

local function InstantFlat()
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
        elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("ParticleEmitter") or v:IsA("Trail") then
            v:Destroy()
        end
    end
end
InstantFlat() -- Eksekusi langsung!

-- 2. GIANT ESP PLAYER (Auto-Run)
local function CreateGiantESP(plr)
    plr.CharacterAdded:Connect(function(char)
        local root = char:WaitForChild("HumanoidRootPart", 5)
        if root then
            local bbg = Instance.new("BillboardGui", root)
            bbg.Name = "GuritaESP"
            bbg.AlwaysOnTop = true
            bbg.Size = UDim2.new(0, 300, 0, 100) -- Ukuran diperbesar
            bbg.ExtentsOffset = Vector3.new(0, 5, 0)

            local txt = Instance.new("TextLabel", bbg)
            txt.Size = UDim2.new(1, 0, 1, 0)
            txt.BackgroundTransparency = 1
            txt.Text = plr.Name
            txt.TextColor3 = Color3.fromRGB(255, 255, 0) -- Kuning biar ngejreng
            txt.TextScaled = true 
            txt.Font = Enum.Font.SourceSansBold
            txt.TextStrokeTransparency = 0
        end
    end)
end

for _, p in ipairs(game.Players:GetPlayers()) do
    if p ~= game.Players.LocalPlayer then CreateGiantESP(p) end
end
game.Players.PlayerAdded:Connect(CreateGiantESP)


local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")

-- Toggles
_G.ESPActive = false
_G.XrayActive = false
_G.ItemESPActive = false

-- 1. FUNGSI X-RAY (BASE & WALL ONLY)
local function RefreshXray()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            local name = v.Name:lower()
            -- Filter: Cuma bangunan, jangan tembusin rumput/pohon
            local isBuilding = name:find("wall") or name:find("base") or name:find("floor") or name:find("door") or name:find("roof")
            local isNature = name:find("grass") or name:find("leaf") or name:find("tree") or name:find("terrain")
            
            if isBuilding and not isNature then
                if _G.XrayActive then
                    if not v:FindFirstChild("OriginalTrans") then
                        local val = Instance.new("NumberValue", v); val.Name = "OriginalTrans"; val.Value = v.Transparency
                    end
                    v.Transparency = 0.5
                else
                    if v:FindFirstChild("OriginalTrans") then
                        v.Transparency = v.OriginalTrans.Value
                    end
                end
            end
        end
    end
end

-- 2. TRACER & PLAYER ESP
local function ManagePlayer(plr)
    local Line = Drawing.new("Line")
    Line.Visible = false; Line.Color = Color3.fromRGB(0, 160, 255); Line.Thickness = 1.5

    plr.CharacterAdded:Connect(function(char)
        local root = char:WaitForChild("HumanoidRootPart", 10)
        local head = char:WaitForChild("Head", 10)
        
        -- Icon di kepala kalau bawa item
        local hbg = Instance.new("BillboardGui", head); hbg.Name = "HolderIcon"; hbg.AlwaysOnTop = true
        hbg.Size = UDim2.new(0, 30, 0, 30); hbg.ExtentsOffset = Vector3.new(0, 4, 0)
        local img = Instance.new("ImageLabel", hbg); img.Size = UDim2.new(1, 0, 1, 0); img.BackgroundTransparency = 1; img.Visible = false

        RunService.RenderStepped:Connect(function()
            if _G.ESPActive and root then
                local Pos, OnScreen = Camera:WorldToViewportPoint(root.Position)
                if OnScreen then
                    Line.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y); Line.To = Vector2.new(Pos.X, Pos.Y); Line.Visible = true
                else Line.Visible = false end
            else Line.Visible = false end
            
            if _G.ItemESPActive and char:FindFirstChildOfClass("Tool") then img.Visible = true else img.Visible = false end
        end)
    end)
end

-- 3. BRAINROT ESP (NAMA + JARAK)
local function CreateBrainrotESP(obj)
    local bbg = Instance.new("BillboardGui", obj); bbg.AlwaysOnTop = true; bbg.Size = UDim2.new(0, 100, 0, 40); bbg.ExtentsOffset = Vector3.new(0, 2, 0)
    local txt = Instance.new("TextLabel", bbg); txt.Size = UDim2.new(1, 0, 1, 0); txt.BackgroundTransparency = 1; txt.TextColor3 = Color3.fromRGB(0, 255, 100); txt.Font = Enum.Font.GothamBold; txt.TextSize = 12; txt.TextStrokeTransparency = 0.5

    RunService.RenderStepped:Connect(function()
        if _G.ItemESPActive and obj.Parent and lp.Character:FindFirstChild("HumanoidRootPart") then
            local dist = math.floor((lp.Character.HumanoidRootPart.Position - obj.Position).Magnitude)
            txt.Text = obj.Name .. "\n[" .. dist .. "m]"; bbg.Enabled = true
        else bbg.Enabled = false end
    end)
end

-- 4. UI MENU
local SG = Instance.new("ScreenGui", game.CoreGui)
local Main = Instance.new("Frame", SG); Main.Size = UDim2.new(0, 200, 0, 180); Main.Position = UDim2.new(0.5, -100, 0.2, 0)
Main.BackgroundColor3 = Color3.fromRGB(5, 5, 10); Main.Active = true; Main.Draggable = true; Instance.new("UICorner", Main)
local Border = Instance.new("Frame", Main); Border.Size = UDim2.new(1, 4, 1, 4); Border.Position = UDim2.new(0, -2, 0, -2); Border.BackgroundColor3 = Color3.fromRGB(0, 160, 255); Border.ZIndex = 0; Instance.new("UICorner", Border)

local function CreateBtn(txt, pos, cb)
    local b = Instance.new("TextButton", Main); b.Size = UDim2.new(0.9, 0, 0, 35); b.Position = pos; b.BackgroundColor3 = Color3.fromRGB(0, 160, 255); b.BackgroundTransparency = 0.8; b.TextColor3 = Color3.new(1,1,1); b.Font = Enum.Font.GothamBold; b.TextSize = 10; b.Text = txt; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function() cb(b) end) return b
end

CreateBtn("ESP & TRACER: OFF", UDim2.new(0.05, 0, 0.2, 0), function(b) _G.ESPActive = not _G.ESPActive; b.Text = _G.ESPActive and "ESP: ON" or "ESP: OFF" end)
CreateBtn("XRAY BASE: OFF", UDim2.new(0.05, 0, 0.45, 0), function(b) _G.XrayActive = not _G.XrayActive; b.Text = _G.XrayActive and "XRAY: ON" or "XRAY: OFF"; RefreshXray() end)
CreateBtn("ITEM/BRAINROT: OFF", UDim2.new(0.05, 0, 0.7, 0), function(b) _G.ItemESPActive = not _G.ItemESPActive; b.Text = _G.ItemESPActive and "ITEM ESP: ON" or "ITEM ESP: OFF" end)

-- Initial Execution
for _, p in pairs(Players:GetPlayers()) do if p ~= lp then ManagePlayer(p) end end
Players.PlayerAdded:Connect(ManagePlayer)
workspace.DescendantAdded:Connect(function(v) if v.Name:lower():find("brainrot") or v.Name:lower():find("item") then CreateBrainrotESP(v) end end)
for _, v in pairs(workspace:GetDescendants()) do if v.Name:lower():find("brainrot") or v.Name:lower():find("item") then CreateBrainrotESP(v) end end

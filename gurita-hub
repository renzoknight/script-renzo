local lp = game.Players.LocalPlayer
_G.StealActive = false

-- UI TOGGLE (Gak usah bagus, yang penting fungsi)
local SG = Instance.new("ScreenGui", game.CoreGui)
local Btn = Instance.new("TextButton", SG)
Btn.Size = UDim2.new(0, 150, 0, 50)
Btn.Position = UDim2.new(0.5, -75, 0.02, 0)
Btn.Text = "FORCE STEAL: OFF"
Btn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)

Btn.MouseButton1Click:Connect(function()
    _G.StealActive = not _G.StealActive
    Btn.Text = _G.StealActive and "FORCE STEAL: ON" or "FORCE STEAL: OFF"
    Btn.BackgroundColor3 = _G.StealActive and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)

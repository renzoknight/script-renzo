-- [[ GURITA-HUB: ONLY FLAT COLOR - NO LAG MODE ]] --

local Lighting = game:GetService("Lighting")

-- 1. FORCE PERFORMANCE SETTINGS
settings().Rendering.QualityLevel = 1
Lighting.GlobalShadows = false
Lighting.Brightness = 2

-- 2. FUNGSI TOTAL FLAT COLOR
local function SikatHabis(v)
    -- Paksa semua benda jadi warna solid/plastik (Lantai, Dinding, Objek)
    if v:IsA("BasePart") or v:IsA("MeshPart") then
        v.Material = Enum.Material.SmoothPlastic
        v.Reflectance = 0
        v.CastShadow = false
        -- Hapus tekstur gambar biar jadi blok warna solid
        if v:IsA("MeshPart") then
            v.TextureID = "" 
        end
    -- Hapus dekorasi, langit, dan efek yang bikin berat
    elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("Sky") or v:IsA("Atmosphere") then
        v:Destroy()
    -- Matikan partikel cuaca/efek
    elseif v:IsA("ParticleEmitter") or v:IsA("Trail") then
        v.Enabled = false
    end
end

-- 3. EKSEKUSI LANGSUNG (Tanpa Nunggu)
for _, obj in ipairs(game:GetDescendants()) do
    pcall(SikatHabis, obj)
end

-- 4. KUNCI REAL-TIME (Cegat barang baru)
game.DescendantAdded:Connect(function(new)
    pcall(SikatHabis, new)
end)

print("GURITA HUB: PURE FLAT COLOR ACTIVE")

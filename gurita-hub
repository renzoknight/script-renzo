-- 2. FUNGSI TOMBOL
local function CreateBtn(txt, pos, cb)
    local b = Instance.new("TextButton", Main)
    b.Size = UDim2.new(0.9, 0, 0, 35)
    b.Position = pos
    b.BackgroundColor3 = Color3.fromRGB(0, 160, 255)
    b.BackgroundTransparency = 0.8
    b.Text = txt
    b.TextColor3 = Color3.new(1,1,1)
    b.Font = Enum.Font.GothamBold
    b.TextSize = 10
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function() cb(b) end)
    return b
end

-- 3. LOGIKA FLAT COLOR & XRAY (GAK BOLEH GANGGU UI)
local function ProcessObject(v)
    pcall(function()
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            -- Lewati Avatar Player (Biar ava gak abu-abu)
            if v:IsDescendantOf(game.Players.LocalPlayer.Character) or v.Parent:FindFirstChild("Humanoid") then 
                return 
            end

            local name = v.Name:lower()
            local isNature = name:find("grass") or name:find("tree") or name:find("leaf") or name:find("terrain")
            
            if not isNature then
                -- Flat Color
                v.Material = Enum.Material.Plastic
                if v:IsA("MeshPart") then v.TextureID = "" end
                
                -- Xray
                local isBuilding = name:find("wall") or name:find("base") or name:find("door") or name:find("roof")
                if isBuilding then
                    v.Transparency = _G.XrayActive and 0.5 or 0
                end
            end
        end
    end)
end


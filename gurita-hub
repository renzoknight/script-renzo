local function ShowCustomNotify(duration)
    NotificationGui.Enabled = true
    TextLabel.Text = "GURITA-HUB: AUTO GRAB AKTIF"
    -- Animasi Progress Bar
    local TweenService = game:GetService("TweenService")
    ProgressBarFiller.Size = UDim2.new(0, 0, 1, 0) -- Reset bar ke 0
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(ProgressBarFiller, tweenInfo, {Size = UDim2.new(1, 0, 1, 0)})
    tween:Play()
    tween.Completed:Connect(function()
        NotificationGui.Enabled = false
    end)
end


-- 1. FLAT COLOR (INSTAN & RINGAN)
local function UltraFlat(v)
    pcall(function()
        if v:IsA("BasePart") then
            v.Material = Enum.Material.Plastic
            v.Reflectance = 0
        elseif v:IsA("Texture") or v:IsA("Decal") then
            v:Destroy()
        end
    end)
end

-- Sikat objek yang sudah ada dan yang baru muncul
task.spawn(function()
    for _, v in ipairs(workspace:GetChildren()) do UltraFlat(v) end
end)
game.DescendantAdded:Connect(UltraFlat)

-- 2. CUSTOM NOTIFY (HITAM-MERAH SESUAI FOTO)
local function CustomAlert()
    local sg = Instance.new("ScreenGui", game.CoreGui)
    local f = Instance.new("Frame", sg)
    f.Size = UDim2.new(0, 200, 0, 45)
    f.Position = UDim2.new(0.5, -100, 0.4, 0)
    f.BackgroundColor3 = Color3.fromRGB(15, 0, 0)
    f.BorderSizePixel = 0
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 10)
    
    local t = Instance.new("TextLabel", f)
    t.Size = UDim2.new(1, 0, 1, 0)
    t.Text = "STEAL BRAINROT: ON"
    t.TextColor3 = Color3.fromRGB(255, 0, 0)
    t.BackgroundTransparency = 1
    t.Font = Enum.Font.SourceSansBold
    t.TextSize = 14
    
    task.delay(2, function() sg:Destroy() end)
end


-- 4. LOGIKA STEAL (INSTAN 0.1s & RADIUS DEKAT)
task.spawn(function()
    local lp = game.Players.LocalPlayer
    while task.wait(0.1) do
        if _G.Steal then
            pcall(function()
                local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if not root then return end
                
                -- Hanya ambil barang dalam radius 30 meter agar TIDAK LAG
                local nearby = workspace:GetPartBoundsInRadius(root.Position, 30)
                
                for _, part in ipairs(nearby) do
                    -- Ambil Brainrot (Sistem Sentuh)
                    if part:FindFirstChildOfClass("TouchTransmitter") then
                        firetouchinterest(root, part, 0)
                        firetouchinterest(root, part, 1)
                    end
                    -- Ambil Brainrot (Sistem Tombol E / Collect)
                    local prompt = part:FindFirstChildOfClass("ProximityPrompt") or part.Parent:FindFirstChildOfClass("ProximityPrompt")
                    if prompt then
                        fireproximityprompt(prompt)
                    end
                end
            end)
        end
    end
end)


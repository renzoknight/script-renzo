-- [[ GURITA-HUB: GOD SPEED AUTO-GRAB (0.1ms) ]] --

local lp = game.Players.LocalPlayer
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

_G.GodModeSteal = false

-- 1. UI SIMPLE (BIAR GAK LAG SAMA SEKALI)
local SG = Instance.new("ScreenGui", game.CoreGui)
local MainBtn = Instance.new("TextButton", SG)
MainBtn.Size = UDim2.new(0, 150, 0, 40)
MainBtn.Position = UDim2.new(0.5, -75, 0, 10)
MainBtn.Text = "GOD STEAL: OFF"
MainBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
MainBtn.TextColor3 = Color3.new(1, 1, 1)
Instance.new("UICorner", MainBtn)

MainBtn.MouseButton1Click:Connect(function()
    _G.GodModeSteal = not _G.GodModeSteal
    MainBtn.Text = _G.GodModeSteal and "GOD STEAL: ON" or "GOD STEAL: OFF"
    MainBtn.BackgroundColor3 = _G.GodModeSteal and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(150, 0, 0)
end)

-- 2. THE STEALTH HOOK (Nyontek Kunci Otomatis)
local savedRemote = nil
local savedArgs = nil

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    
    if not checkcaller() and method == "FireServer" and #self.Name > 20 then
        savedRemote = self
        savedArgs = args
    end
    return oldNamecall(self, ...)
end)

-- 3. SPEED ENGINE (0.1ms via Heartbeat)
RunService.Heartbeat:Connect(function()
    if _G.GodModeSteal then
        pcall(function()
            local root = lp.Character.HumanoidRootPart
            local spawnFolder = workspace:FindFirstChild("RenderedMovingAnimal")
            
            if spawnFolder then
                for _, animal in ipairs(spawnFolder:GetChildren()) do
                    -- Cek apakah ini beneran item (punya ProximityPrompt)
                    local prompt = animal:FindFirstChildOfClass("ProximityPrompt") or animal:FindFirstChildWhichIsA("ProximityPrompt", true)
                    
                    if prompt then
                        -- Bypass Jarak & Line of Sight
                        prompt.HoldDuration = 0
                        prompt.MaxActivationDistance = 50 -- Sedot dari jauh
                        prompt.RequiresLineOfSight = false
                        
                        -- Jarak aman biar gak ke-kick (15-20 stud)
                        if (animal:GetPivot().Position - root.Position).Magnitude < 20 then
                            
                            -- Kirim Paket Data secepat kilat
                            if savedRemote and savedArgs then
                                savedRemote:FireServer(unpack(savedArgs))
                            end
                            
                            -- Trigger Tombol
                            fireproximityprompt(prompt)
                        end
                    end
                end
            end
        end)
    end
end)

-- [[ GURITA-HUB: THE LAST RESORT - HUMAN MIMIC ]] --

local lp = game.Players.LocalPlayer
_G.StealActive = false

-- UI SEADANYA
local SG = Instance.new("ScreenGui", game.CoreGui)
local Btn = Instance.new("TextButton", SG)
Btn.Size = UDim2.new(0, 150, 0, 50)
Btn.Position = UDim2.new(0.5, -75, 0.02, 0)
Btn.Text = "AUTO STEAL: OFF"
Btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
Btn.TextColor3 = Color3.new(1, 1, 1)

Btn.MouseButton1Click:Connect(function()
    _G.StealActive = not _G.StealActive
    Btn.Text = _G.StealActive and "AUTO STEAL: ON" or "AUTO STEAL: OFF"
    Btn.BackgroundColor3 = _G.StealActive and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
end)

task.spawn(function()
    while task.wait(0.5) do
        if _G.StealActive then
            pcall(function()
                local root = lp.Character.HumanoidRootPart
                -- Pakai folder yang Abang temuin tadi
                local folder = workspace:FindFirstChild("RenderedMovingAnimal")
                
                if folder then
                    for _, item in ipairs(folder:GetChildren()) do
                        local prompt = item:FindFirstChildOfClass("ProximityPrompt") or item:FindFirstChildWhichIsA("ProximityPrompt", true)
                        
                        if prompt and (item:GetPivot().Position - root.Position).Magnitude < 10 then
                            -- JANGAN dipaksa 0, biarin ada durasi biar server percaya
                            -- Tapi kita bantu "Hold" otomatis
                            
                            -- Pindah posisi dikit biar beneran nempel
                            root.CFrame = item:GetPivot() * CFrame.new(0, 2, 0)
                            
                            task.wait(0.1)
                            fireproximityprompt(prompt) -- Eksekusi
                            
                            -- Tunggu sampai proses curi selesai (sesuai durasi asli game)
                            task.wait(prompt.HoldDuration + 0.2) 
                        end
                    end
                end
            end)
        end
    end
end)

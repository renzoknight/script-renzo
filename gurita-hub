-- [[ RENZO GURITA - AUTO FLAT & LIGHT TRACER ESP ]] --

local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- 1. FITUR WAJIB: AUTO FLAT COLOR (LANGSUNG AKTIF - NO LAG)
local function ApplyFlat(v)
    pcall(function()
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            v.Material = Enum.Material.Plastic
            v.Reflectance = 0
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
        end
        if v:IsA("Texture") or v:IsA("Decal") then
            v:Destroy()
        end
        if v:IsA("SpecialMesh") then
            v.TextureId = "" 
        end
    end)
end

-- Eksekusi Map (Bertahap biar HP gak panas)
task.spawn(function()
    settings().Rendering.QualityLevel = 1
    Lighting.GlobalShadows = false
    local d = workspace:GetDescendants()
    for i = 1, #d do
        ApplyFlat(d[i])
        if i % 150 == 0 then task.wait() end
    end
end)
workspace.DescendantAdded:Connect(ApplyFlat)

-- 2. FITUR ESP PLAYER (NAMA SEDANG & TRACER LINE)
_G.ESPActive = false

local function CreateLightESP(plr)
    -- Tracer Line (Garis Pengikut)
    local Line = Drawing.new("Line")
    Line.Visible = false
    Line.Color = Color3.new(0, 1, 1) -- Biru Cyan
    Line.Thickness = 1
    Line.Transparency = 0.8

    local function UpdateESP()
        local Connection
        Connection = game:GetService("RunService").RenderStepped:Connect(function()
            if _G.ESPActive and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local Root = plr.Character.HumanoidRootPart
                local Pos, OnScreen = Camera:WorldToViewportPoint(Root.Position)

                if OnScreen then
                    -- Update Garis Tracer
                    Line.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                    Line.To = Vector2.new(Pos.X, Pos.Y)
                    Line.Visible = true
                else
                    Line.Visible = false
                end
            else
                Line.Visible = false
                if not plr.Parent then
                    Line:Remove()
                    Connection:Disconnect()
                end
            end
        end)
    end

    -- Billboard untuk Nama (Ukuran Sedang)
    local function SetupTag()
        local char = plr.Character or plr.CharacterAdded:Wait()
        local root = char:WaitForChild("HumanoidRootPart", 10)
        local bbg = root:FindFirstChild("LightESP") or Instance.new("BillboardGui", root)
        bbg.Name = "LightESP"
        bbg.AlwaysOnTop = true
        bbg.Size = UDim2.new(0, 150, 0, 40)
        bbg.ExtentsOffset = Vector3.new(0, 4, 0)
        bbg.Enabled = _G.ESPActive

        local nameTag = bbg:FindFirstChild("Tag") or Instance.new("TextLabel", bbg)
        nameTag.Size = UDim2.new(1, 0, 1, 0)
        nameTag.BackgroundTransparency = 1
        nameTag.Text = plr.Name
        nameTag.TextColor3 = Color3.new(1, 1, 0)
        nameTag.TextScaled = false
        nameTag.TextSize = 14 -- Ukuran tidak terlalu besar
        nameTag.Font = Enum.Font.GothamBold
        nameTag.TextStrokeTransparency = 0.5
    end

    task.spawn(UpdateESP)
    SetupTag()
    plr.CharacterAdded:Connect(SetupTag)
end


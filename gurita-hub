local RunService = game:GetService("RunService")

-- 1. THE ULTIMATE SMOOTH ENGINE
local function MakeItSuperSemut(v)
    if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") or v:IsA("PointLight") or v:IsA("SpotLight") or v:IsA("SurfaceLight") then
        v.Enabled = false
        task.delay(0.1, function() v:Destroy() end) -- Hapus total dari memory
    elseif v:IsA("Highlight") or v:IsA("SelectionBox") or v:IsA("SelectionSphere") then
        v:Destroy()
    elseif v:IsA("BasePart") or v:IsA("MeshPart") then
        v.Material = Enum.Material.SmoothPlastic
        v.Reflectance = 0
        v.CastShadow = false
        if v:IsA("MeshPart") then
            v.TextureID = "" -- Buat jadi Flat Color total
        end
    end
end

-- 2. AUTO-WIPE (FOLDER RENDEREDMOVINGANIMAL)
-- Ini bagian yang bikin Traits jadi gak ada lag-nya sama sekali
task.spawn(function()
    while true do
        local folder = workspace:FindFirstChild("RenderedMovingAnimal")
        if folder then
            for _, item in ipairs(folder:GetDescendants()) do
                MakeItSuperSemut(item)
            end
        end
        task.wait(1) -- Cek setiap 1 detik biar gak berat ke CPU
    end
end)

-- Langsung sikat begitu ada barang baru (Real-time)
workspace.DescendantAdded:Connect(function(descendant)
    if descendant:IsDescendantOf(workspace:FindFirstChild("RenderedMovingAnimal")) then
        MakeItSuperSemut(descendant)
    end
end)


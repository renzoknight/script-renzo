-- [[ GURITA-HUB: MAP FLAT COLOR ONLY - ZERO LAG ]] --

local Lighting = game:GetService("Lighting")
local World = workspace -- Fokus ke Workspace biar gak nyisir sistem lain

-- 1. ENGINE OPTIMIZATION (INSTANT)
settings().Rendering.QualityLevel = 1
Lighting.GlobalShadows = false
Lighting.Brightness = 2

-- 2. FUNGSI PENYIKAT MAP (Bikin Plastik Polos)
local function MakeMapFlat(v)
    if v:IsA("BasePart") or v:IsA("MeshPart") then
        v.Material = Enum.Material.SmoothPlastic
        v.Reflectance = 0
        v.CastShadow = false
        if v:IsA("MeshPart") then
            v.TextureID = "" -- Hapus tekstur gambar map
        end
    elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("Sky") then
        v:Destroy()
    end
end

-- 3. EKSEKUSI BERTAHAP (ANTI-FREEZE/LAG)
task.spawn(function()
    local descendants = World:GetDescendants()
    for i, obj in ipairs(descendants) do
        pcall(MakeMapFlat, obj)
        
        -- Istirahat setiap 150 objek biar executor gak macet
        if i % 150 == 0 then
            task.wait() 
        end
    end
end)

-- 4. CEGAT MAP BARU (REAL-TIME)
World.DescendantAdded:Connect(function(new)
    task.wait() 
    pcall(MakeMapFlat, new)
end)

print("GURITA HUB: MAP FLAT COLOR ACTIVE")

-- 1. FITUR FLAT COLOR (Otomatis Aktif)
local function ApplyFlat(v)
    if v:IsA("BasePart") or v:IsA("MeshPart") then
        v.Material = Enum.Material.Plastic
        v.Reflectance = 0
        v.CastShadow = false
    end
    if v:IsA("Texture") then v:Destroy() end
    if v:IsA("SpecialMesh") or v:IsA("MeshPart") then 
        v.TextureID = "" 
    end
end

task.spawn(function()
    for _, v in ipairs(game:GetDescendants()) do ApplyFlat(v) end
    game.DescendantAdded:Connect(ApplyFlat)
end)

-- 2. FITUR AUTO GRAB 0.1s
_G.AutoGrab = false

local Toggle = Tab:CreateToggle({
   Name = "Auto Grab 0.1s",
   CurrentValue = false,
   Flag = "Toggle1", 
   Callback = function(Value)
      _G.AutoGrab = Value
   end,
})

task.spawn(function()
    while task.wait(0.1) do
        if _G.AutoGrab then
            pcall(function()
                local Character = game.Players.LocalPlayer.Character
                local Root = Character and Character:FindFirstChild("HumanoidRootPart")
                if Root then
                    for _, v in ipairs(workspace:GetDescendants()) do
                        if v:IsA("ProximityPrompt") then
                            fireproximityprompt(v)
                        elseif v:IsA("TouchTransmitter") then
                            firetouchinterest(Root, v.Parent, 0)
                            firetouchinterest(Root, v.Parent, 1)
                        end
                    end
                end
            end)
        end
    end
end)


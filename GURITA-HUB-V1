-- [[ GURITA HUB V9 - PURE EGG & HARP ONLY ]] --

local lp = game.Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")

_G.HuntingMode = false

-- DAFTAR TARGET MURNI (KHUSUS TELUR & HARP)
local ValidTargets = {"egg", "bunny", "hydra", "harp", "baskito", "churrito", "hopili", "quackini", "snackini"}
-- DAFTAR BLACKLIST (YANG HARUS DIHAPUS/DIABAIKAN)
local Blacklist = {"brainrot", "npc", "base", "pedestal", "shop"}

local function IsValidEgg(name)
    local n = name:lower()
    -- Cek apakah ada di blacklist
    for _, b in pairs(Blacklist) do
        if n:find(b) then return false end
    end
    -- Cek apakah ada di target egg
    for _, t in pairs(ValidTargets) do
        if n:find(t) then return true end
    end
    return false
end

local function PasangESP(obj)
    if obj:FindFirstChild("GuritaMarker") then return end
    
    pcall(function()
        -- FILTER: Hanya di Sky/Island (Ketinggian > 100)
        local pos = obj:IsA("Model") and obj:GetModelCFrame().p or obj.Position
        if pos.Y < 100 then return end
        
        -- HIGHLIGHT (Merah buat HARP/HYDRA, Biru buat Telur Biasa)
        local h = Instance.new("Highlight", obj)
        h.Name = "GuritaMarker"
        if obj.Name:lower():find("harp") or obj.Name:lower():find("hydra") then
            h.FillColor = Color3.new(1, 0, 0) -- Merah (PENTING!)
        else
            h.FillColor = Color3.fromRGB(0, 170, 255) -- Biru (Telur Biasa)
        end
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop

        -- LABEL
        local b = Instance.new("BillboardGui", obj)
        b.Name = "GuritaTag"; b.Size = UDim2.new(0, 200, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 8, 0)
        
        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = h.FillColor
        t.Font = Enum.Font.GothamBlack; t.TextSize = 20; t.TextStrokeTransparency = 0
        
        task.spawn(function()
            while obj and obj.Parent and _G.HuntingMode do
                local p = obj:IsA("Model") and obj:GetModelCFrame().p or obj.Position
                local d = math.floor((lp.Character.HumanoidRootPart.Position - p).Magnitude)
                t.Text = obj.Name:upper() .. "\n[" .. d .. " STUDS]"
                task.wait(1)
            end
            if h then h:Destroy() end
            if b then b:Destroy() end
        end)
    end)
end


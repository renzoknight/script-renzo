local BtnFlat = CreateBtn(0.2, "FLAT MAP: ON", function() _G.FlatActive = not _G.FlatActive; task.spawn(RunFlatColor) end)
local BtnHunt = CreateBtn(0.55, "EGG HUNT: ON", function() _G.HuntEggActive = not _G.HuntEggActive; task.spawn(ScanHunt) end)


local function CreateESP(part, name)
    if part:FindFirstChild("EggESP") then return end
    local Billboard = Instance.new("BillboardGui")
    Billboard.Name = "EggESP"
    Billboard.AlwaysOnTop = true
    Billboard.Size = UDim2.new(0, 100, 0, 50)
    Billboard.Adornee = part
    Billboard.Parent = part
    local TextLabel = Instance.new("TextLabel")
    TextLabel.Parent = Billboard
    TextLabel.BackgroundTransparency = 1
    TextLabel.Size = UDim2.new(1, 0, 1, 0)
    TextLabel.Text = name .. " GH" -- Nama fitur di ESP juga pakai GH
    TextLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
    TextLabel.Font = Enum.Font.GothamBold
    TextLabel.TextSize = 12
    TextLabel.TextStrokeTransparency = 0
end

-- Loop ESP (Anti-Lag)
task.spawn(function()
    while task.wait(1) do
        if not ESP_Enabled then 
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("BillboardGui") and v.Name == "EggESP" then v:Destroy() end
            end
            continue 
        end
        for _, obj in pairs(workspace:GetDescendants()) do
            for _, eggName in pairs(EasterUnits) do
                if obj.Name == eggName and (obj:IsA("BasePart") or obj:IsA("Model")) then
                    local target = obj:IsA("Model") and obj.PrimaryPart or obj
                    if target then CreateESP(target, eggName) end
                end
            end
        end
    end
end)


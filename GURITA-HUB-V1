-- --- 7. LOGIKA DRAGGING & RGB (ANTI-LAG) ---
local function MakeDraggable(ui)
    local dragging, dragInput, dragStart, startPos
    ui.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = ui.Position
        end
    end)
    ui.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    RunService.Heartbeat:Connect(function()
        if dragging and dragInput then
            local delta = dragInput.Position - dragStart
            ui.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end
MakeDraggable(MainFrame)
MakeDraggable(LogoButton)

local colors = {
    Color3.fromRGB(0, 160, 255), Color3.fromRGB(255, 120, 0),
    Color3.fromRGB(255, 210, 0), Color3.fromRGB(160, 0, 255)
}

task.spawn(function()
    local cIndex = 1
    while true do
        local nIndex = cIndex % #colors + 1
        for i = 0, 1, 0.02 do
            local lerpColor = colors[cIndex]:Lerp(colors[nIndex], i)
            MainStroke.Color = lerpColor
            LogoStroke.Color = lerpColor
            task.wait(0.04)
        end
        cIndex = nIndex
    end
end)


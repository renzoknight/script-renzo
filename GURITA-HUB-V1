-- [[ 2. FUNGSI ESP BIRU TEMBUS PANDANG ]] --
local function PasangESP(obj)
    if obj:FindFirstChild("GuritaMarker") then return end
    
    pcall(function()
        -- Highlight Biru (Tembus dari ujung ke ujung)
        local h = Instance.new("Highlight")
        h.Name = "GuritaMarker"
        h.Parent = obj
        h.FillColor = Color3.fromRGB(0, 170, 255)
        h.OutlineColor = Color3.new(1, 1, 1)
        h.FillTransparency = 0.4
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop 

        -- Tag Nama & Jarak
        local b = Instance.new("BillboardGui")
        b.Name = "GuritaTag"
        b.Parent = obj
        b.Size = UDim2.new(0, 200, 0, 70)
        b.AlwaysOnTop = true
        b.ExtentsOffset = Vector3.new(0, 6, 0)
        
        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0)
        t.BackgroundTransparency = 1
        t.Text = obj.Name:upper() .. "\n[ Calibrating... ]"
        t.TextColor3 = Color3.fromRGB(0, 170, 255)
        t.Font = Enum.Font.GothamBlack
        t.TextSize = 14
        t.TextStrokeTransparency = 0

        -- Update Jarak Otomatis
        task.spawn(function()
            while obj and obj.Parent do
                if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                    local pos = obj:IsA("Model") and obj:GetModelCFrame().p or obj.Position
                    local dist = (lp.Character.HumanoidRootPart.Position - pos).Magnitude
                    t.Text = obj.Name:upper() .. "\n[" .. math.floor(dist) .. " Studs]"
                end
                task.wait(1)
            end
        end)
    end)
end

-- [[ 3. LOGIKA FAST FLAT COLOR ]] --
local function SikatPolos(v)
    if v:IsDescendantOf(lp.Character or workspace) and v.Parent:FindFirstChild("Humanoid") then return end
    pcall(function()
        if v:IsA("BasePart") then
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
            for _, child in pairs(v:GetChildren()) do
                if child:IsA("SurfaceAppearance") or child:IsA("Texture") or child:IsA("Decal") then
                    child:Destroy()
                end
            end
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end


-- 2. ENGINE: FLAT COLOR & ANTI-LAG MAP
local function ApplyFlatColor()
    for i, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and not v:IsA("Terrain") then
            -- Filter: Abaikan karakter sendiri
            if not v:IsDescendantOf(lp.Character) then
                -- Paksa Material ke Plastic (Ringan) & Matikan Bayangan
                if v.Material ~= Enum.Material.Plastic and v.Material ~= Enum.Material.Neon then
                    v.Material = Enum.Material.Plastic
                end
                v.CastShadow = false
                
                -- Hapus Tekstur Map agar Flat
                if v:FindFirstChildOfClass("Decal") or v:FindFirstChildOfClass("Texture") then
                    for _, tex in pairs(v:GetChildren()) do
                        if tex:IsA("Decal") or tex:IsA("Texture") then tex:Destroy() end
                    end
                end
            end
        elseif v:IsA("SpecialMesh") then
            v.TextureId = "" -- Hapus tekstur mesh agar enteng
        end
        if i % 500 == 0 then task.wait() end
    end
end

-- 3. ENGINE: XRAY BASE
local function UpdateXray()
    for i, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and not v:IsDescendantOf(lp.Character) then
            local n = v.Name:lower()
            local isTarget = n:find("base") or n:find("floor") or n:find("lantai") or n:find("plot")
            local isWall = n:find("wall") or n:find("tembok") or n:find("map") or n:find("build")
            
            if isTarget and not isWall then
                v.LocalTransparencyModifier = _G.GH_Settings.Xray_GH and 0.7 or 0
            end
        end
        if i % 500 == 0 then task.wait() end
    end
end

-- 4. ENGINE: ESP SYSTEM (PLAYER & EGG)
local function UpdateESP()
    -- ESP PLAYER
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("Head") then
            if _G.GH_Settings.ESP_Player_GH then
                if not p.Character.Head:FindFirstChild("PlayerESP") then
                    local bg = Instance.new("BillboardGui", p.Character.Head)
                    bg.Name = "PlayerESP"; bg.AlwaysOnTop = true; bg.Size = UDim2.new(0, 200, 0, 50); bg.ExtentsOffset = Vector3.new(0, 3, 0)
                    local lbl = Instance.new("TextLabel", bg)
                    lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1; lbl.TextColor3 = Color3.new(1, 1, 1)
                    lbl.Text = p.Name; lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 14; lbl.TextStrokeTransparency = 0
                end
            else
                if p.Character.Head:FindFirstChild("PlayerESP") then p.Character.Head.PlayerESP:Destroy() end
            end
        end
    end

    -- ESP EGG PASKA (DENGAN FLAT COLOR UNGU)
    if _G.GH_Settings.ESP_Egg_GH then
        for _, obj in pairs(workspace:GetDescendants()) do
            if table.find(EasterList, obj.Name) then
                local target = obj:IsA("Model") and obj.PrimaryPart or (obj:IsA("BasePart") and obj)
                if target then
                    -- Buat Warna Jadi Flat Ungu (Chams Style)
                    if obj:IsA("BasePart") then obj.Color = Color3.fromRGB(138, 43, 226); obj.Material = Enum.Material.Neon end
                    
                    if not target:FindFirstChild("EggESP") then
                        local bgu = Instance.new("BillboardGui", target)
                        bgu.Name = "EggESP"; bgu.AlwaysOnTop = true; bgu.Size = UDim2.new(0,100,0,50)
                        local lbl = Instance.new("TextLabel", bgu)
                        lbl.BackgroundTransparency = 1; lbl.Size = UDim2.new(1,0,1,0); lbl.Text = obj.Name.." [GH]"; lbl.TextColor3 = Color3.fromRGB(255,255,0); lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 10
                    end
                end
            end
        end
    else
        for _, obj in pairs(workspace:GetDescendants()) do
            if table.find(EasterList, obj.Name) then
                local target = obj:IsA("Model") and obj.PrimaryPart or (obj:IsA("BasePart") and obj)
                if target and target:FindFirstChild("EggESP") then target.EggESP:Destroy() end
            end
        end
    end
end


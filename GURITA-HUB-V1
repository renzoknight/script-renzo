-- --- 7. SISTEM DRAG & RGB (ANTI LAG) ---
local function Drag(ui)
    local drag, input, start, startPos
    ui.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = true; start = i.Position; startPos = ui.Position end end)
    ui.InputChanged:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseMovement then input = i end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)
    RunService.Heartbeat:Connect(function() if drag and input then local delta = input.Position - start; ui.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y) end end)
end
Drag(MainFrame); Drag(LogoButton)

local colors = {Color3.fromRGB(0, 160, 255), Color3.fromRGB(255, 120, 0), Color3.fromRGB(255, 210, 0), Color3.fromRGB(160, 0, 255)}
task.spawn(function()
    local c = 1
    while true do
        local n = c % #colors + 1
        for i = 0, 1, 0.05 do
            local lerp = colors[c]:Lerp(colors[n], i)
            MainStroke.Color = lerp; LogoStroke.Color = lerp
            task.wait(0.05)
        end
        c = n
    end
end)


local function CreateESP(part, name)
    if part:FindFirstChild("EggESP") then return end
    local bgui = Instance.new("BillboardGui", part)
    bgui.Name = "EggESP"
    bgui.AlwaysOnTop = true
    bgui.Size = UDim2.new(0, 100, 0, 50)
    local tl = Instance.new("TextLabel", bgui)
    tl.BackgroundTransparency = 1
    tl.Size = UDim2.new(1, 0, 1, 0)
    tl.Text = name .. " GH"
    tl.TextColor3 = Color3.fromRGB(255, 255, 0)
    tl.Font = Enum.Font.GothamBold
    tl.TextSize = 12
end

task.spawn(function()
    while task.wait(1) do
        if not ESP_Enabled then
            for _, v in pairs(workspace:GetDescendants()) do
                if v.Name == "EggESP" then v:Destroy() end
            end
            continue
        end
        for _, obj in pairs(workspace:GetDescendants()) do
            for _, egg in pairs(EasterUnits) do
                if obj.Name == egg and (obj:IsA("BasePart") or obj:IsA("Model")) then
                    local target = obj:IsA("Model") and obj.PrimaryPart or obj
                    if target then CreateESP(target, egg) end
                end
            end
        end
    end
end)


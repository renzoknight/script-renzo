Main.BackgroundColor3 = Color3.fromRGB(25, 25, 25); Main.Visible = false; Instance.new("UICorner", Main)

local function CreateBtn(name, pos, col)
    local btn = Instance.new("TextButton", Main)
    btn.Size = UDim2.new(0, 240, 0, 60); btn.Position = pos
    btn.BackgroundColor3 = col; btn.Font = Enum.Font.GothamBold; btn.TextColor3 = Color3.new(1,1,1); btn.TextSize = 16
    Instance.new("UICorner", btn)
    return btn
end

local BtnHunt = CreateBtn("HUNTING MODE", UDim2.new(0, 20, 0, 40), Color3.new(0.6, 0, 0))
local BtnNotif = CreateBtn("NOTIF & SOUND", UDim2.new(0, 20, 0, 120), Color3.new(0, 0.4, 0.7))

local function UpdateUI()
    BtnHunt.Text = _G.HuntingMode and "HUNTING: ON" or "HUNTING: OFF"
    BtnHunt.BackgroundColor3 = _G.HuntingMode and Color3.fromRGB(0, 120, 0) or Color3.fromRGB(120, 0, 0)
    BtnNotif.Text = _G.NotifActive and "NOTIF: ON" or "NOTIF: OFF"
    BtnNotif.BackgroundColor3 = _G.NotifActive and Color3.fromRGB(0, 100, 180) or Color3.fromRGB(60, 60, 60)
end

UpdateUI()
Toggle.MouseButton1Down:Connect(function() Main.Visible = not Main.Visible end)

BtnHunt.MouseButton1Down:Connect(function()
    _G.HuntingMode = not _G.HuntingMode
    UpdateUI(); SaveSettings()
    if _G.HuntingMode then
        for _, v in pairs(workspace:GetDescendants()) do if CekTarget(v.Name) then ApplyESP(v) end end
    end
end)

BtnNotif.MouseButton1Down:Connect(function()
    _G.NotifActive = not _G.NotifActive
    UpdateUI(); SaveSettings()
end)

-- PERFORMANCE SETTINGS (OPTIMAL)
task.spawn(function()
    settings().Rendering.QualityLevel = 1
    game:GetService("Lighting").GlobalShadows = false
    if _G.HuntingMode then
        task.wait(1)
        for _, v in pairs(workspace:GetDescendants()) do if CekTarget(v.Name) then ApplyESP(v) end end
    end
end)

workspace.DescendantAdded:Connect(function(v)
    if _G.HuntingMode and CekTarget(v.Name) then task.wait(2); ApplyESP(v) end
end)

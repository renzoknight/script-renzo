local function CreateESP(obj, text, color)
    -- Hapus dulu kalau sudah ada biar gak tumpuk
    if obj:FindFirstChild("GHS_ESP") then obj.GHS_ESP:Destroy() end
    if obj:FindFirstChild("GHS_Tag") then obj.GHS_Tag:Destroy() end

    local h = Instance.new("Highlight", obj); h.Name = "GHS_ESP"; h.FillColor = color; h.FillTransparency = 0.5
    local b = Instance.new("BillboardGui", obj); b.Name = "GHS_Tag"; b.Size = UDim2.new(0, 150, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 3, 0)
    local t = Instance.new("TextLabel", b); t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.Text = text:upper(); t.TextColor3 = color; t.Font = Enum.Font.GothamBold; t.TextSize = 14; t.TextStrokeTransparency = 0
end

local function UpdateESP()
    -- Scan Players
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            if _G.GH_Config.ESP_Player_GH then CreateESP(p.Character, p.Name, Color3.fromRGB(0, 255, 255)) 
            else if p.Character:FindFirstChild("GHS_ESP") then p.Character.GHS_ESP:Destroy(); p.Character.GHS_Tag:Destroy() end end
        end
    end
    -- Scan Eggs (TELITI: Cek semua objek di workspace)
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and table.find(AllowedEggs, v.Name:lower()) then
            if _G.GH_Config.ESP_Egg_GH then 
                CreateESP(v, v.Name, Color3.fromRGB(255, 255, 0)) 
            else 
                if v:FindFirstChild("GHS_ESP") then v.GHS_ESP:Destroy(); v.GHS_Tag:Destroy() end 
            end
        end
    end
end


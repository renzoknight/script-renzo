-- [[ 2. ENGINE SIKAT PART (V38 ORIGINAL) ]] --
local function SikatPart(v)
    -- Proteksi: Jangan rubah karakter player/Bang Ezra
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character and v:IsDescendantOf(p.Character) then return end
    end
    -- Jangan sikat UI gamenya
    if v:IsA("GuiObject") or v:IsA("ScreenGui") then return end

    pcall(function()
        if v:IsA("BasePart") then
            -- Ubah jadi plastik mulus tanpa bayangan
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            v.Reflectance = 0
            
            -- Sikat Tekstur Mesh
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
            
            -- Hapus SurfaceAppearance (Biang kerok map berat)
            local sa = v:FindFirstChildOfClass("SurfaceAppearance")
            if sa then sa:Destroy() end
            
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v:Destroy()
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- [[ 3. EKSEKUSI OTOMATIS (QUEUED SYSTEM) ]] --
task.spawn(function()
    print("Gurita Hub: Flat Color Auto-Starting...")
    local all = workspace:GetDescendants()
    local count = 0
    for _, v in pairs(all) do
        SikatPart(v)
        
        -- Jeda per 50 part biar executor Bang Ezra gak freeze
        count = count + 1
        if count >= 50 then 
            count = 0
            task.wait() 
        end
    end
    print("Gurita Hub: Map Polos Sempurna!")
end)

-- Pantau part baru yang spawn (Buat area baru di map)
workspace.DescendantAdded:Connect(function(v)
    task.wait(0.1)
    SikatPart(v)
end)


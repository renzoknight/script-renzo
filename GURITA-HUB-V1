-- Perangkat: Redmi 10 | Executor: Delta | Map: Streaming Off

local Lighting = game:GetService("Lighting")
local MaterialService = game:GetService("MaterialService")
local RunService = game:GetService("RunService")

-- [[ 1. AUTO ANTI-LAG (LANGSUNG AKTIF) ]] --
local function AktifkanAntiLag()
    pcall(function()
        -- Turunkan kualitas render ke paling rendah secara sistem
        settings().Rendering.QualityLevel = 1
        settings().Physics.PhysicsEnvironmentalThrottle = Enum.EnviromentalPhysicsThrottle.Default
        
        -- Kunci FPS di 45 biar Redmi 10 stabil & gak panas (Thermal Throttling)
        if setfpscap then setfpscap(45) end
        
        -- Sikat Awan HD, Atmosfer, dan Efek yang bikin berat
        for _, v in pairs(Lighting:GetChildren()) do
            if v:IsA("PostEffect") or v:IsA("Atmosphere") or v:IsA("Clouds") or v:IsA("Sky") then
                v:Destroy()
            end
        end
        
        -- Langit Polos Total
        local sky = Instance.new("Sky", Lighting)
        sky.SunAngularSize, sky.MoonAngularSize, sky.StarCount = 0, 0, 0
        
        -- Cahaya Rata (No Shadows = FPS Naik)
        Lighting.GlobalShadows = false
        Lighting.Brightness = 1.2
        Lighting.Ambient = Color3.fromRGB(180, 180, 180)
    end)
end

-- [[ 2. LOGIKA SIKAT POLOS (JAGA WARNA ASLI) ]] --
local function SikatPolos(v)
    if v:IsDescendantOf(game.Players.LocalPlayer.Character or workspace) and v.Parent:FindFirstChild("Humanoid") then return end

    pcall(function()
        if v:IsA("BasePart") then
            -- Paksa material polos
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            
            -- Sikat ID Texture di MeshPart (Biar Tembok/Pembatas Polos)
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end

            -- Hapus SurfaceAppearance (Biang kerok motif karpet/bata)
            for _, child in pairs(v:GetChildren()) do
                if child:IsA("SurfaceAppearance") or child:IsA("Texture") or child:IsA("Decal") then
                    child:Destroy()
                end
            end
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- [[ 3. EKSEKUSI OTOMATIS BERTAHAP (REDMI 10 SAFE) ]] --
task.spawn(function()
    -- Jalankan Anti-Lag & Bersihkan Material Global
    AktifkanAntiLag()
    pcall(function()
        MaterialService.Use2022Materials = false
        for _, m in pairs(MaterialService:GetChildren()) do m:Destroy() end
    end)

    -- Scan map secara perlahan agar tidak patah-patah
    local all = workspace:GetDescendants()
    for i, v in pairs(all) do
        SikatPolos(v)
        
        -- Setiap 15 part, istirahat sekejap (PENTING biar gak lag pas inject)
        if i % 15 == 0 then 
            task.wait(0.02) 
        end
    end
end)

-- Pantau part baru yang muncul saat main
workspace.DescendantAdded:Connect(function(v)
    task.wait(0.5)
    SikatPolos(v)
end)


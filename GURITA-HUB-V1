-- [[ GURITA HUB V1 - ULTIMATE SMOOTH FIXED XRAY V3 ]] --

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local TweenService = game:GetService("TweenService")
local CG = game:GetService("CoreGui")

-- 1. SETTINGS
_G.GH_Settings = {
    ESP_Player_GH = false,
    Xray_GH = false,
    AutoCollect_GH = false,
    ESP_Egg_GH = false
}

-- 2. FIX XRAY (ANTI STACKING & ANTI ABU-ABU)
local function UpdateXray()
    task.spawn(function()
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and not v.Parent:FindFirstChild("Humanoid") then
                local n = v.Name:lower()
                -- Target spesifik: Tembok, Base, Lantai, Pilar
                if n:find("wall") or n:find("base") or n:find("floor") or n:find("pillar") or n:find("part") then
                    if _G.GH_Settings.Xray_GH then
                        -- Pakai LocalTransparencyModifier supaya warna asli tidak rusak/abu-abu
                        v.LocalTransparencyModifier = 0.7
                    else
                        -- Balikin ke 0 (Normal) tanpa ganggu Material
                        v.LocalTransparencyModifier = 0
                    end
                end
            end
        end
    end)
end

-- 3. ESP PLAYER (SMOOTH)
local function UpdateESP()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp then
            if _G.GH_Settings.ESP_Player_GH then
                if p.Character and p.Character:FindFirstChild("Head") and not p.Character.Head:FindFirstChild("ESPTag") then
                    local bg = Instance.new("BillboardGui", p.Character.Head)
                    bg.Name = "ESPTag"; bg.AlwaysOnTop = true; bg.Size = UDim2.new(0, 200, 0, 50); bg.ExtentsOffset = Vector3.new(0, 3, 0)
                    local lbl = Instance.new("TextLabel", bg)
                    lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1; lbl.TextColor3 = Color3.new(1, 1, 1)
                    lbl.Text = p.Name; lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 18; lbl.TextStrokeTransparency = 0
                end
            else
                if p.Character and p.Character:FindFirstChild("Head") and p.Character.Head:FindFirstChild("ESPTag") then
                    p.Character.Head.ESPTag:Destroy()
                end
            end
        end
    end
end

-- 4. UI CONSTRUCTION
if CG:FindFirstChild("GuritaHubV1_Smooth") then CG.GuritaHubV1_Smooth:Destroy() end
local SG = Instance.new("ScreenGui", CG); SG.Name = "GuritaHubV1_Smooth"

-- LOGO ANIMASI

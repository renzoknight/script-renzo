-- [[ GURITA HUB: ULTIMATE FLAT COLOR - FIX RUMPUT & TEMBOK ]] --
-- Spesialis: Steal a Brainrot (Auto-On, No Lag, No Texture)

pcall(function()
    if setfpscap then setfpscap(60) end
    settings().Physics.PhysicsEnvironmentalThrottle = Enum.EnviromentalPhysicsThrottle.Default
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
end)

local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")

-- [[ LOGIKA SIKAT TOTAL (TERMASUK RUMPUT & TEMBOK) ]] --
local function SikatHabis(v)
    -- Tetap proteksi Karakter Bang Ezra
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character and v:IsDescendantOf(p.Character) then return end
    end
    if v:IsA("GuiObject") or v:IsA("ScreenGui") then return end

    pcall(function()
        -- 1. Sikat Material & SurfaceAppearance (Tembok & Lantai)
        if v:IsA("BasePart") then
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            v.Reflectance = 0
            
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
            
            local sa = v:FindFirstChildOfClass("SurfaceAppearance")
            if sa then sa:Destroy() end
        
        -- 2. Sikat Rumput & Detail Tembok (Decal/Texture/Trail/Beam)
        -- Ini bagian yang biasanya bikin rumput tetep ada teksturnya
        elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("SpecialMesh") then
            if v:IsA("SpecialMesh") then
                v.TextureId = ""
            else
                v:Destroy() -- Hapus paksa tekstur rumput/tembok
            end
        end
    end)
end

-- [[ EKSEKUSI AUTO (SISTEM ANTREAN AMAN) ]] --
task.spawn(function()
    local all = workspace:GetDescendants()
    local count = 0
    for _, v in pairs(all) do
        SikatHabis(v)
        
        -- Jeda 50 part biar gak lag pas baru aktif
        count = count + 1
        if count >= 50 then 
            count = 0
            task.wait() 
        end
    end
end)

-- Pantau part baru/streaming area baru
workspace.DescendantAdded:Connect(function(v)
    task.wait(0.1)
    SikatHabis(v)
end)

-- [[ VISUAL TEDUH (TIDAK MENCOLOK) ]] --
task.spawn(function()
    Lighting.GlobalShadows = false
    Lighting.Brightness = 1
    Lighting.OutdoorAmbient = Color3.fromRGB(150, 150, 150)
    Lighting.ClockTime = 12
    
    for _, effect in pairs(Lighting:GetChildren()) do
        if effect:IsA("PostEffect") or effect:IsA("Atmosphere") or effect:IsA("Clouds") then
            effect:Destroy()
        end
    end
end)

print("GURITA HUB: Rumput & Tembok Pembatas Selesai Disikat!")

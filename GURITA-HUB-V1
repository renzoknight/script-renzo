-- [[ 4. ESP & SCANNER LOGIC ]] --
local NotifiedEggs = {}
local function CreateESP(target)
    if not target:FindFirstChild("GuritaMarker") then
        local h = Instance.new("Highlight", target)
        h.Name = "GuritaMarker"; h.FillColor = Color3.fromRGB(255, 0, 0); h.FillTransparency = 0.3
        
        local b = Instance.new("BillboardGui", target)
        b.Name = "GuritaTag"; b.Size = UDim2.new(0, 200, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 3, 0)
        
        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = Color3.new(1, 1, 1); t.Font = Enum.Font.GothamBlack; t.TextSize = 14

        task.spawn(function()
            while target and target.Parent and _G.Settings.EggESP do
                local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    local pos = target:IsA("BasePart") and target.Position or target:FindFirstChildWhichIsA("BasePart").Position
                    t.Text = "🔥 " .. target.Name:upper() .. " 🔥\n[" .. math.floor((pos - root.Position).Magnitude) .. "m]"
                end
                task.wait(0.5)
            end
            if b then b:Destroy() end; if h then h:Destroy() end
        end)
    end
end

local function Scan(v)
    local name = v.Name:lower()
    -- Filter Bug Tatata
    if name:find("tatata") then return end

    local isTarget = false
    for _, key in pairs(StrictTargets) do if name:find(key) then isTarget = true break end end
    
    if isTarget then
        local pos = v:IsA("BasePart") and v.Position or (v:FindFirstChildWhichIsA("BasePart") and v:FindFirstChildWhichIsA("BasePart").Position)
        if pos and pos.Y > MIN_HEIGHT then
            if _G.Settings.EggESP then CreateESP(v) end
            if _G.Settings.Notif and not NotifiedEggs[v] then
                NotifiedEggs[v] = true 
                StarterGui:SetCore("SendNotification", {Title = "🥚 NEW TARGET!", Text = v.Name, Duration = 5})
                v.AncestryChanged:Connect(function(_, p) if not p then NotifiedEggs[v] = nil end end)
            end
        end
    end
end

task.spawn(function()
    while true do
        for _, v in pairs(workspace:GetDescendants()) do Scan(v) end
        task.wait(8)
    end
end)


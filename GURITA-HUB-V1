Toggle.TextColor3 = Color3.new(1, 1, 1); Toggle.TextSize = 30; Instance.new("UICorner", Toggle).CornerRadius = UDim.new(1, 0)

-- Pesan Loading di Layar biar Abang tau script lagi kerja
local LoadMsg = Instance.new("TextLabel", SG)
LoadMsg.Size = UDim2.new(0, 200, 0, 30); LoadMsg.Position = UDim2.new(0.5, -100, 0, 50)

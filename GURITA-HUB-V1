-- 2. TARGET LIST
local NotifHistory = {}
local SuperRare = {"hydra", "no my egg", "baskito", "churrito", "hopilikalika", "quackini", "harp"}
local NormalTargets = {"tralala", "eggdin", "easter", "sahur", "sky egg", "bunny egg"}

-- 3. OPTIMIZED NOTIF (Pakai Debounce)
local function KirimNotifRare(objName)
    if NotifHistory[objName] then return end
    NotifHistory[objName] = true
    
    task.spawn(function()
        local s = Instance.new("Sound", workspace)
        s.SoundId = "rbxassetid://4590662766"; s.Volume = 0.5; s:Play()
        
        local sg = Instance.new("ScreenGui", PlayerGui); sg.Name = "GuritaNotif"
        local f = Instance.new("Frame", sg)
        f.Size = UDim2.new(0, 250, 0, 60); f.Position = UDim2.new(1, 10, 0.8, 0)
        f.BackgroundColor3 = Color3.fromRGB(20, 0, 0); Instance.new("UICorner", f)
        
        local t = Instance.new("TextLabel", f)
        t.Size = UDim2.new(1, 0, 1, 0); t.Text = "RARE: " .. objName:upper()
        t.TextColor3 = Color3.new(1, 1, 1); t.Font = "GothamBold"; t.BackgroundTransparency = 1
        
        f:TweenPosition(UDim2.new(1, -260, 0.8, 0), "Out", "Quad", 0.3)
        task.wait(4)
        if f then f:TweenPosition(UDim2.new(1, 10, 0.8, 0), "In", "Quad", 0.3) end
        task.wait(0.4); sg:Destroy(); s:Destroy()
    end)
end

-- 4. SMART ESP (Hemat CPU)
local function PasangESP(obj)
    -- Filter awal: Kalau bukan Model/BasePart atau di bawah Island, langsung buang.
    if not _G.HuntingMode or obj:FindFirstChild("GuritaTag") then return end
    if not obj:IsA("Model") and not obj:IsA("BasePart") then return end

    task.spawn(function()
        -- Tunggu nama load (Penting buat ngurangin lag saat spawn massal)
        task.wait(1)
        local name = obj.Name:lower()
        if name == "part" or name == "model" or name == "folder" then return end
        
        -- Cek Ketinggian Island
        local pos = (obj:IsA("Model") and obj.PrimaryPart) and obj.PrimaryPart.Position or (obj:IsA("BasePart") and obj.Position)
        if not pos or pos.Y < 100 then return end

        local tipe = nil
        for _, r in pairs(SuperRare) do if name:find(r) then tipe = "rare"; break end end
        if not tipe then
            for _, e in pairs(NormalTargets) do if name:find(e) then tipe = "normal"; break end end
        end

        if not tipe then return end
        if tipe == "rare" then KirimNotifRare(obj.Name) end

        -- Buat Billboard (Sederhana saja biar ga berat)
        local col = (tipe == "rare") and Color3.new(1, 0, 0) or Color3.fromRGB(0, 170, 255)
        local b = Instance.new("BillboardGui", obj)
        b.Name = "GuritaTag"; b.Size = UDim2.new(0, 150, 0, 40); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 5, 0)
        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = col; t.Font = "GothamBold"; t.TextSize = 13; t.TextStrokeTransparency = 0.5
        
        -- Update Jarak (SANGAT JARANG / 2 Detik sekali)
        while obj and obj.Parent and _G.HuntingMode do
            local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local d = math.floor((hrp.Position - pos).Magnitude)
                t.Text = obj.Name:upper() .. "\n[" .. d .. "s]"
            end
            task.wait(2) -- Inilah yang bikin enteng
        end
        if b then b:Destroy() end
    end)
end


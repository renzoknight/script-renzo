-- Fitur: Force Flat Color, Egg ESP Sky Island, Anti-Lag Redmi 10

local lp = game.Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")

-- 1. DAFTAR TELUR TARGET
local TargetEggs = {"hydra bunny", "noo my eggs", "hopilikalika", "baskito", "churrito", "quackini", "snackini", "bunny bunny sahur"}

-- 2. FUNGSI FORCE FLAT COLOR (ANTI-GAGAL)
local function ForceFlat(v)
    pcall(function()
        if v:IsA("BasePart") and not v.Parent:FindFirstChild("Humanoid") then
            -- Ubah Material Paksa
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            v.Reflectance = 0
            
            -- Hapus Tekstur & Mesh Texture
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
            
            -- Bersihkan Decal/Texture di dalamnya
            for _, child in pairs(v:GetChildren()) do
                if child:IsA("Decal") or child:IsA("Texture") or child:IsA("SurfaceAppearance") then
                    child:Destroy()
                end
            end
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- 3. FUNGSI ESP (BIRU TEMBUS PANDANG)
local function PasangESP(obj)
    if obj:FindFirstChild("GuritaMarker") then return end
    pcall(function()
        local h = Instance.new("Highlight", obj)
        h.Name = "GuritaMarker"; h.FillColor = Color3.fromRGB(0, 170, 255); h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop 
        
        local b = Instance.new("BillboardGui", obj)
        b.Name = "GuritaTag"; b.Size = UDim2.new(0, 150, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 6, 0)
        
        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = Color3.fromRGB(0, 170, 255); t.Font = Enum.Font.GothamBlack; t.TextSize = 14; t.TextStrokeTransparency = 0
        
        task.spawn(function()
            while obj and obj.Parent do
                if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                    local pos = obj:IsA("Model") and obj:GetModelCFrame().p or obj.Position
                    t.Text = obj.Name:upper() .. "\n[" .. math.floor((lp.Character.HumanoidRootPart.Position - pos).Magnitude) .. " Studs]"
                end
                task.wait(1.5)
            end
        end)
    end)
end

-- 4. EKSEKUSI (SISTEM TUNGGU)
task.spawn(function()
    -- Matikan Global Lighting Biar Enteng
    local Lighting = game:GetService("Lighting")
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    
    local all = workspace:GetDescendants()
    for i, v in pairs(all) do
        -- Jalankan Flat Color
        ForceFlat(v)
        
        -- Cari Telur
        local name = v.Name:lower()
        for _, target in pairs(TargetEggs) do
            if name == target then PasangESP(v) end
        end
        
        -- Jeda Redmi 10 (Sangat Penting)
        if i % 100 == 0 then task.wait() end
    end
end)

-- Deteksi Item Baru (Termasuk Island Event)
workspace.DescendantAdded:Connect(function(v)
    local name = v.Name:lower()
    for _, target in pairs(TargetEggs) do
        if name == target then task.wait(1) PasangESP(v) end
    end
    task.wait(0.1)
    ForceFlat(v)
end)


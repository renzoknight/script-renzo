-- 4. ESP EGG
local function BuatESP(obj)
    if obj:FindFirstChild("GuritaMarker") then return end
    pcall(function()
        local h = Instance.new("Highlight", obj)
        h.Name = "GuritaMarker"; h.FillColor = Color3.fromRGB(0, 170, 255); h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop 
        
        local b = Instance.new("BillboardGui", obj)
        b.Name = "GuritaTag"; b.Size = UDim2.new(0, 150, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 5, 0)
        
        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = Color3.fromRGB(0, 170, 255); t.Font = Enum.Font.GothamBold; t.TextSize = 13; t.TextStrokeTransparency = 0
        
        task.spawn(function()
            while obj and obj.Parent do
                if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                    local pos = obj:IsA("Model") and obj:GetModelCFrame().p or obj.Position
                    t.Text = obj.Name:upper() .. "\n[" .. math.floor((lp.Character.HumanoidRootPart.Position - pos).Magnitude) .. " Studs]"
                end
                task.wait(2)
            end
        end)
    end)
end

task.spawn(function()
    for _, v in pairs(workspace:GetDescendants()) do
        local name = v.Name:lower()
        for _, target in pairs(TargetEggs) do
            if name == target then BuatESP(v) end
        end
    end
end)

workspace.DescendantAdded:Connect(function(v)
    local name = v.Name:lower()
    for _, target in pairs(TargetEggs) do
        if name == target then task.wait(1) BuatESP(v) end
    end
end)

    "egg pedas", "baskito", "churrito", 
    "quackini", "snackini", "bunny bunny sahur"
}

local MIN_HEIGHT = 50 
local NotifiedEggs = {} 

_G.Settings = {
    EggESP = false,
    Notif = false,
    WalkSpeed = 16
}

local function SaveData()
    if writefile then pcall(function() writefile(FileName, HttpService:JSONEncode(_G.Settings)) end) end
end

local function LoadData()
    if isfile and isfile(FileName) then
        pcall(function() _G.Settings = HttpService:JSONDecode(readfile(FileName)) end)
    end
end
LoadData()


-- [[ 1. LOGIKA WARNA SOLID (GANTI WARNA BUKAN TEKSTUR) ]] --
local function SikatMotif(v)
    -- Abaikan Karakter Player
    if v:IsDescendantOf(game:GetService("Players")) or v.Parent:FindFirstChild("Humanoid") then return end

    pcall(function()
        if v:IsA("BasePart") then
            -- PAKSA POLOS
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            v.Reflectance = 0
            
            -- SIKAT MOTIF PEMBATAS & LANTAI (Ganti Warnanya Langsung)
            -- Kita pakai deteksi warna/nama untuk nemuin pembatasnya
            if v.Name:lower():find("border") or v.Name:lower():find("wall") or v.Size.X > 50 or v.Size.Z > 50 then
                v.Color = Color3.fromRGB(50, 50, 50) -- Abu-abu Solid buat Pembatas
            end
            
            if v.Name:lower():find("grass") or v.Name:lower():find("floor") then
                v.Color = Color3.fromRGB(0, 255, 0) -- Hijau Solid buat Lantai
            end

            -- Hapus paksa SurfaceAppearance/Texture/Decal di dalamnya
            for _, child in pairs(v:GetChildren()) do
                if child:IsA("SurfaceAppearance") or child:IsA("Texture") or child:IsA("Decal") then
                    child:Destroy()
                end
            end
            
            -- Sikat TextureID jika MeshPart
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end


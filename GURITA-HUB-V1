-- FUNGSI BUAT TOGGLE
local function CreateToggle(txt, var, callback)
    local b = Instance.new("TextButton", Container); b.Size = UDim2.new(1, 0, 0, 40); b.BackgroundColor3 = Color3.fromRGB(30, 30, 40); Instance.new("UICorner", b)
    local function Upd()
        b.Text = txt..(_G.GH_Settings[var] and ": ON" or ": OFF")
        b.TextColor3 = _G.GH_Settings[var] and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
    end
    Upd()
    b.MouseButton1Click:Connect(function() 
        _G.GH_Settings[var] = not _G.GH_Settings[var]; Upd(); if callback then callback() end 
    end)
end


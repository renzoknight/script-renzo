-- [[ FUNGSI FLAT COLOR RUMPUT & MAP (OTOMATIS) ]] --
local function MakeMapFlat()
    -- Mengubah Terrain (Rumput asli Roblox) jadi flat
    local terrain = Workspace:FindFirstChildOfClass("Terrain")
    if terrain then
        terrain.WaterWaveSize = 0
        terrain.WaterWaveSpeed = 0
        terrain.WaterReflectance = 0
        terrain.WaterTransparency = 0
        -- Memaksa tekstur rumput hilang
        sethiddenproperty(terrain, "Decoration", false) 
    end

    -- Mencari semua Part di Map (Lantai/Rumput buatan)
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            -- Jika objek berwarna hijau (biasanya rumput) atau bagian dari map
            -- Kita buat materialnya jadi SmoothPlastic supaya FLAT
            obj.Material = Enum.Material.SmoothPlastic
            
            -- Menghapus tekstur/decal yang nempel di tanah
            if obj:IsA("Texture") or obj:IsA("Decal") then
                obj:Destroy()
            end
        end
    end
end

-- Langsung jalankan pas execute
MakeMapFlat()


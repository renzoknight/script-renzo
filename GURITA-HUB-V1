-- [[ GURITA HUB: FLAT COLOR TEST ENGINE ]] --

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")

-- [[ ENGINE INTI: FLAT COLOR ]] --
local function ForceFlat(v)
    -- PROTEKSI: Jangan sentuh karakter (biar warna & bentuk Ava aman)
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character and v:IsDescendantOf(p.Character) then return end
    end

    pcall(function()
        if v:IsA("BasePart") then
            -- Paksa jadi polos total
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            
            -- Hapus tekstur di MeshPart
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
            
            -- Hapus SurfaceAppearance (ini yang biasanya bikin tekstur bandel)
            local sa = v:FindFirstChildOfClass("SurfaceAppearance")
            if sa then sa:Destroy() end
            
        elseif v:IsA("Decal") or v:IsA("Texture") then
            -- Hapus stiker rumput, lantai, tembok
            v:Destroy()
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- Variabel kontrol
_G.FlatColorActive = false

-- Loop pembersihan (Jalan terus kalau aktif)
task.spawn(function()
    while true do
        if _G.FlatColorActive then
            for i, v in pairs(workspace:GetDescendants()) do
                ForceFlat(v)
                if i % 300 == 0 then task.wait() end -- Anti lag
            end
        end
        task.wait(2) -- Cek ulang setiap 2 detik buat area baru
    end
end)


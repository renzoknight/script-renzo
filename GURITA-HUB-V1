-- 1. DATABASE & CONFIG (SAVE/LOAD SYSTEM)
local ConfigFile = "GHS_Config_Final.json"
-- Daftar telur langka pilihan Abang
local AllowedEggs = {"hydra bunny", "noo my eggs", "baskito", "churrito", "quackini snackini", "hopilikalika hopilikalako"}

_G.GH_Config = {
    ESP_Player_GH = false,
    Xray_GH = false,
    AutoCollect_GH = false,
    ESP_Egg_GH = false
}

local function SaveData()
    pcall(function() if writefile then writefile(ConfigFile, HttpService:JSONEncode(_G.GH_Config)) end end)
end

local function LoadData()
    pcall(function()
        if isfile and isfile(ConfigFile) then
            local decoded = HttpService:JSONDecode(readfile(ConfigFile))
            if decoded then for k, v in pairs(decoded) do _G.GH_Config[k] = v end end
        end
    end)
end
LoadData()

-- [[ 2. FITUR FLAT COLOR (ANTI-LAG) ]] --
local function ApplyFlat(v)
    pcall(function()
        if (v:IsA("BasePart") or v:IsA("MeshPart")) and not (v.Parent:FindFirstChild("Humanoid") or v:IsDescendantOf(lp.Character)) then
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
            for _, child in pairs(v:GetChildren()) do
                if child:IsA("Texture") or child:IsA("Decal") then child:Destroy() end
            end
        end
    end)
end

-- [[ 3. FITUR X-RAY (BASE-ONLY & ANTI LAG) ]] --
local function RunXray()
    pcall(function()
        local trans = _G.GH_Config.Xray_GH and 0.6 or 0
        if workspace:FindFirstChild("Baseplate") then
            workspace.Baseplate.LocalTransparencyModifier = trans
        end
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") then
                local name = v.Name:lower()
                if name == "base" or name == "floor" or name == "ground" then
                    v.LocalTransparencyModifier = trans
                end
            end
            if _ % 1000 == 0 then task.wait() end -- Optimasi biar gak lag
        end
    end)
end

-- [[ 4. FITUR ESP EGG (KHUSUS 6 TELUR) ]] --
local function UpdateEggESP()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and table.find(AllowedEggs, v.Name:lower()) then
            if _G.GH_Config.ESP_Egg_GH then
                if not v:FindFirstChild("EggHighlight") then
                    local h = Instance.new("Highlight", v); h.Name = "EggHighlight"; h.FillColor = Color3.new(1, 1, 0)
                    local b = Instance.new("BillboardGui", v); b.Name = "EggName"; b.Size = UDim2.new(0, 100, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 3, 0)
                    local t = Instance.new("TextLabel", b); t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.Text = v.Name; t.TextColor3 = Color3.new(1, 1, 0); t.Font = Enum.Font.GothamBold; t.TextSize = 14
                end
            else
                if v:FindFirstChild("EggHighlight") then v.EggHighlight:Destroy() end
                if v:FindFirstChild("EggName") then v.EggName:Destroy() end
            end
        end
    end
end


-- 1. ENGINE FLAT COLOR (Langsung Jalan)
local function ApplyFlatColor()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and not v:IsDescendantOf(lp.Character) then
            v.CastShadow = false
            if table.find(EasterList, v.Name) or table.find(EasterList, v.Parent.Name) then
                v.Material = Enum.Material.Neon
                v.Color = Color3.fromRGB(138, 43, 226)
            else
                v.Material = Enum.Material.SmoothPlastic
            end
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v:Destroy()
        end
    end
end


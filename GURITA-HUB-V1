local function UpdateUI()
    BtnHunt.Text = _G.HuntingMode and "HUNTING MODE: ON" or "HUNTING MODE: OFF"
    BtnHunt.BackgroundColor3 = _G.HuntingMode and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
    BtnNotif.Text = _G.NotifActive and "NOTIF & SOUND: ON" or "NOTIF & SOUND: OFF"
    BtnNotif.BackgroundColor3 = _G.NotifActive and Color3.fromRGB(0, 120, 200) or Color3.fromRGB(80, 80, 80)
end

UpdateUI()
Toggle.MouseButton1Down:Connect(function() Main.Visible = not Main.Visible end)

BtnHunt.MouseButton1Down:Connect(function()
    _G.HuntingMode = not _G.HuntingMode
    UpdateUI(); SaveSettings()
    if _G.HuntingMode then
        for _, v in pairs(workspace:GetDescendants()) do if CekTarget(v.Name) then PasangESP(v) end end
    else
        NotifHistory = {}
    end
end)

BtnNotif.MouseButton1Down:Connect(function()
    _G.NotifActive = not _G.NotifActive
    UpdateUI(); SaveSettings()
end)

-- 7. JALANKAN SEMUA FITUR
ApplyPerformance() -- Flat Color & Low GFX Aktif Disini

if _G.HuntingMode then
    task.spawn(function()
        for _, v in pairs(workspace:GetDescendants()) do if CekTarget(v.Name) then PasangESP(v) end end
    end)
end

workspace.DescendantAdded:Connect(function(v)

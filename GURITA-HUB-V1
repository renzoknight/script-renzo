-- [[ GURITA HUB - AUTO SAVE & EGG HUNT ]] --
-- Fitur: Fast Flat, ESP Sky Island, Auto Save Config

local lp = game.Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local HttpService = game:GetService("HttpService")

-- [[ 1. SISTEM AUTO SAVE (DATA) ]] --
local Config = {
    FlatColor = true,
    ESP = true
}

local function SaveData()
    local data = HttpService:JSONEncode(Config)
    writefile("GuritaHubConfig.json", data)
end

local function LoadData()
    if isfile("GuritaHubConfig.json") then
        local data = readfile("GuritaHubConfig.json")
        Config = HttpService:JSONDecode(data)
    end
end

-- Jalankan Load Data pas awal script
LoadData()

-- [[ 2. DAFTAR TELUR ]] --
local TargetEggs = {"hydra bunny", "noo my eggs", "hopilikalika", "baskito", "churrito", "quackini", "snackini", "bunny bunny sahur"}

-- [[ 3. FUNGSI ESP ]] --
local function PasangESP(obj)
    if not Config.ESP or obj:FindFirstChild("GuritaMarker") then return end
    pcall(function()
        local h = Instance.new("Highlight", obj)
        h.Name = "GuritaMarker"
        h.FillColor = Color3.fromRGB(0, 170, 255)
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop 

        local b = Instance.new("BillboardGui", obj)
        b.Name = "GuritaTag"
        b.Size = UDim2.new(0, 200, 0, 70)
        b.AlwaysOnTop = true
        b.ExtentsOffset = Vector3.new(0, 6, 0)
        
        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0)
        t.BackgroundTransparency = 1
        t.TextColor3 = Color3.fromRGB(0, 170, 255)
        t.Font = Enum.Font.GothamBlack
        t.TextSize = 14
        t.TextStrokeTransparency = 0

        task.spawn(function()
            while obj and obj.Parent and Config.ESP do
                if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                    local pos = obj:IsA("Model") and obj:GetModelCFrame().p or obj.Position
                    local dist = (lp.Character.HumanoidRootPart.Position - pos).Magnitude
                    t.Text = obj.Name:upper() .. "\n[" .. math.floor(dist) .. " Studs]"
                end
                task.wait(1)
            end
        end)
    end)
end

-- [[ 4. LOGIKA FLAT COLOR ]] --
local function SikatPolos(v)
    if not Config.FlatColor then return end
    pcall(function()
        if v:IsA("BasePart") and not v.Parent:FindFirstChild("Humanoid") then
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
        end
    end)
end

-- [[ 5. EKSEKUSI ]] --
task.spawn(function()
    local all = workspace:GetDescendants()
    for i, v in pairs(all) do
        if Config.FlatColor then SikatPolos(v) end
        local name = v.Name:lower()
        for _, target in pairs(TargetEggs) do
            if name == target then PasangESP(v) end
        end
        if i % 150 == 0 then task.wait() end
    end
end)

-- [[ 6. UI MENU FIXED ]] --
if PlayerGui:FindFirstChild("GuritaHubUI") then PlayerGui.GuritaHubUI:Destroy() end
local SG = Instance.new("ScreenGui", PlayerGui); SG.Name = "GuritaHubUI"; SG.DisplayOrder = 999; SG.ResetOnSpawn = false

local MainBtn = Instance.new("TextButton", SG)
MainBtn.Size = UDim2.new(0, 150, 0, 50); MainBtn.Position = UDim2.new(0, 20, 0.5, -25)
MainBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20); MainBtn.BackgroundTransparency = 0.3
MainBtn.Text = "GURITA HUB"; MainBtn.TextColor3 = Color3.fromRGB(0, 170, 255)
MainBtn.Font = Enum.Font.GothamBlack; MainBtn.TextSize = 18
Instance.new("UICorner", MainBtn)

-- Simpan otomatis tiap ada perubahan
MainBtn.MouseButton1Click:Connect(function()
    Config.FlatColor = not Config.FlatColor
    SaveData() -- Simpan status terakhir
    print("GURITA HUB: Config Saved!")
end)

print("GURITA HUB: Auto-Save System Ready!")

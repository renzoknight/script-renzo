-- [[ GURITA HUB: VISUAL UPGRADE EDITION ]] --

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local StarterGui = game:GetService("StarterGui")

-- [[ 1. CONFIG ]] --
local TargetEggs = {"hydra bunny", "noo my eggs", "baskito", "churrito", "quackini snackini", "hopilikalika hopilikalako", "bunny sahur"}
_G.EggESP_Master = false
_G.Notif_Master = true

-- [[ 2. UPGRADED ESP (LEBIH JELAS) ]] --
local function ApplyUltimateESP(obj)
    if not obj:FindFirstChild("Marker") then
        local h = Instance.new("Highlight", obj)
        h.Name = "Marker"; h.FillColor = Color3.fromRGB(255, 255, 0)
        h.OutlineColor = Color3.new(1, 1, 1); h.FillTransparency = 0.4
        
        local b = Instance.new("BillboardGui", obj)
        b.Name = "Tag"; b.Size = UDim2.new(0, 150, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 3, 0)
        
        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = Color3.new(1, 1, 0)
        t.Font = Enum.Font.GothamBlack; t.TextSize = 14; t.TextStrokeTransparency = 0
        t.TextStrokeColor3 = Color3.new(0,0,0) -- Stroke item biar teks nampak di mana saja

        task.spawn(function()
            while obj and obj.Parent and _G.EggESP_Master do
                if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (obj.Position - lp.Character.HumanoidRootPart.Position).Magnitude
                    t.Text = "✨ " .. obj.Name:upper() .. " ✨\n[" .. math.floor(dist) .. "m]"
                end
                task.wait(0.5)
            end
        end)
    end
end

-- [[ 3. AUTO FLAT COLOR & LOOP ]] --
local function SikatJadiFlat(v)
    pcall(function()
        if v:IsA("BasePart") and not v.Parent:FindFirstChild("Humanoid") then
            v.Material = Enum.Material.Plastic; v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
        end
    end)
end

task.spawn(function()
    while true do
        for i, v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and v.Material ~= Enum.Material.Plastic then SikatJadiFlat(v) end
            if _G.EggESP_Master and table.find(TargetEggs, v.Name:lower()) then ApplyUltimateESP(v) end
            if i % 200 == 0 then task.wait() end 
        end
        task.wait(5)
    end
end)

workspace.DescendantAdded:Connect(function(v)
    task.wait(0.1)
    SikatJadiFlat(v)
    if table.find(TargetEggs, v.Name:lower()) then
        if _G.Notif_Master then
            StarterGui:SetCore("SendNotification", {Title = "🥚 EGG DETECTED!", Text = v.Name:upper(), Duration = 5})
            local s = Instance.new("Sound", game:GetService("SoundService")); s.SoundId = "rbxassetid://4590662762"; s:Play()
        end
        if _G.EggESP_Master then ApplyUltimateESP(v) end
    end
end)


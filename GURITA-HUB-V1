local function CreateToggle(parent, txt, var, callback)
    local b = Instance.new("TextButton", parent); b.Size = UDim2.new(0.95, 0, 0, 40); b.BackgroundColor3 = Color3.fromRGB(22, 22, 35); b.Font = Enum.Font.GothamBold; b.TextSize = 10; Instance.new("UICorner", b)
    local function UpdateUI() b.Text = txt..(_G.GH_Config[var] and ": ON" or ": OFF"); b.TextColor3 = _G.GH_Config[var] and Color3.new(0, 1, 0) or Color3.new(1, 0, 0) end
    UpdateUI()
    b.MouseButton1Click:Connect(function() _G.GH_Config[var] = not _G.GH_Config[var]; UpdateUI(); SaveData(); if callback then callback() end end)
end


local Lighting = game:GetService("Lighting")
local MaterialService = game:GetService("MaterialService")

-- [[ 1. SETTINGAN RENDERING (LANGSUNG AKTIF) ]] --
pcall(function()
    settings().Rendering.QualityLevel = 1
    if setfpscap then setfpscap(45) end -- Stabil di 45 FPS biar gak panas
end)

-- [[ 2. NUKE LANGIT JADI MALEM POLOS ]] --
local function BuatMalemPolos()
    pcall(function()
        -- Hapus semua isi Lighting (Awan HD, Atmosfer, Sky lama)
        Lighting:ClearAllChildren()
        
        -- Buat Skybox Hitam Pekat No Bintang No Awan
        local sky = Instance.new("Sky", Lighting)
        sky.SkyboxBk = "rbxassetid://0"
        sky.SkyboxDn = "rbxassetid://0"
        sky.SkyboxFt = "rbxassetid://0"
        sky.SkyboxLf = "rbxassetid://0"
        sky.SkyboxRt = "rbxassetid://0"
        sky.SkyboxUp = "rbxassetid://0"
        sky.SunAngularSize = 0
        sky.MoonAngularSize = 0
        sky.StarCount = 0
        
        -- Atur suasana malem tapi map tetep kelihatan
        Lighting.ClockTime = 0 -- Jam 12 malem
        Lighting.Brightness = 1
        Lighting.GlobalShadows = false -- Bayangan mati biar gak lag
        Lighting.ExposureCompensation = 0.5
        Lighting.EnvironmentDiffuseScale = 0
        Lighting.EnvironmentSpecularScale = 0
    end)
end

-- [[ 3. LOGIKA FLAT POLOS (WARNA TETAP ADA) ]] --
local function SikatJadiPolos(v)
    if v:IsDescendantOf(game.Players.LocalPlayer.Character or workspace) and v.Parent:FindFirstChild("Humanoid") then return end

    pcall(function()
        if v:IsA("BasePart") then
            -- Paksa Material Plastic (Paling Polos/Flat)
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            v.Reflectance = 0
            
            -- Sikat ID Texture di MeshPart (Biar Tembok Pembatas Polos)
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end

            -- Hapus SurfaceAppearance & Tekstur bintik/motif
            for _, child in pairs(v:GetChildren()) do
                if child:IsA("SurfaceAppearance") or child:IsA("Texture") or child:IsA("Decal") then
                    child:Destroy()
                end
            end
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- [[ 4. EKSEKUSI GLOBAL BERTAHAP (REDMI 10 SAFE) ]] --
task.spawn(function()
    BuatMalemPolos()
    
    -- Matikan material baru roblox
    pcall(function()
        MaterialService.Use2022Materials = false
        for _, m in pairs(MaterialService:GetChildren()) do m:Destroy() end
    end)

    -- Proses part map pelan-pelan biar gak patah-patah
    local all = workspace:GetDescendants()
    for i, v in pairs(all) do
        SikatJadiPolos(v)
        if i % 20 == 0 then task.wait(0.01) end -- Jeda per 20 part
    end
end)

-- Update kalau ada part baru masuk
workspace.DescendantAdded:Connect(function(v)
    task.wait(0.5)
    SikatJadiPolos(v)
end)


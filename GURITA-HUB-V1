-- [[ 5. NEW ULTIMATE ESP ENGINE ]] --
local function CreateESP(target)
    if not target:FindFirstChild("GuritaMarker") then
        -- Highlight
        local h = Instance.new("Highlight")
        h.Name = "GuritaMarker"
        h.FillColor = Color3.fromRGB(255, 255, 0)
        h.OutlineColor = Color3.fromRGB(255, 255, 255)
        h.FillTransparency = 0.3
        h.Parent = target
        
        -- Billboard
        local b = Instance.new("BillboardGui")
        b.Name = "GuritaTag"
        b.Size = UDim2.new(0, 200, 0, 50)
        b.AlwaysOnTop = true
        b.ExtentsOffset = Vector3.new(0, 3, 0)
        b.Parent = target
        
        local t = Instance.new("TextLabel")
        t.Parent = b
        t.Size = UDim2.new(1, 0, 1, 0)
        t.BackgroundTransparency = 1
        t.TextColor3 = Color3.new(1, 1, 0)
        t.TextStrokeTransparency = 0
        t.Font = Enum.Font.GothamBlack
        t.TextSize = 14

        task.spawn(function()
            while target and target.Parent and _G.Settings.EggESP do
                local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if root and (target:IsA("BasePart") or target:FindFirstChildWhichIsA("BasePart")) then
                    local pos = target:IsA("BasePart") and target.Position or target:FindFirstChildWhichIsA("BasePart").Position
                    local dist = (pos - root.Position).Magnitude
                    t.Text = "⭐ " .. target.Name:upper() .. " ⭐\n[" .. math.floor(dist) .. "m]"
                else
                    t.Text = "⭐ " .. target.Name:upper() .. " ⭐"
                end
                task.wait(0.3)
            end
            if b then b:Destroy() end
            if h then h:Destroy() end
        end)
    end
end

-- [[ 6. SCANNER ]] --
local function Scan(v)
    local name = v.Name:lower()
    for _, key in pairs(EggKeywords) do
        if name:find(key) then
            if _G.Settings.Notif then
                StarterGui:SetCore("SendNotification", {Title = "🥚 DETECTED!", Text = v.Name, Duration = 3})
            end
            if _G.Settings.EggESP then CreateESP(v) end
            break
        end
    end
end

task.spawn(function()
    while true do
        for _, v in pairs(workspace:GetDescendants()) do
            if _G.Settings.EggESP then Scan(v) end
        end
        task.wait(5)
    end
end)

workspace.DescendantAdded:Connect(function(v)
    task.wait(0.5)
    if _G.Settings.EggESP then Scan(v) end
end)


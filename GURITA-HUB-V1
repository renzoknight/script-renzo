-- [[ GURITA HUB - PERMANEN NIGHT FLAT (FORCE LOCK) ]] --
-- Fokus: Langit Malem Polos Gak Bisa Berubah, Anti-Lag Auto

local Lighting = game:GetService("Lighting")
local MaterialService = game:GetService("MaterialService")
local RunService = game:GetService("RunService")

-- [[ 1. FUNGSI LOCK LANGIT (ANTI-REVERT) ]] --
local function ForceNightPolos()
    -- Paksa jam 12 malem & matikan efek HD
    Lighting.ClockTime = 0
    Lighting.Brightness = 1
    Lighting.GlobalShadows = false
    Lighting.ExposureCompensation = 0.5
    Lighting.EnvironmentDiffuseScale = 0
    Lighting.EnvironmentSpecularScale = 0
    
    -- Hapus paksa Awan/Atmosfer/Sky yang baru muncul
    for _, v in pairs(Lighting:GetChildren()) do
        if v:IsA("Sky") or v:IsA("Atmosphere") or v:IsA("Clouds") or v:IsA("PostEffect") then
            v:Destroy()
        end
    end
    
    -- Pasang Sky Hitam kalau belum ada
    if not Lighting:FindFirstChild("GuritaSky") then
        local sky = Instance.new("Sky", Lighting)
        sky.Name = "GuritaSky"
        sky.SkyboxBk, sky.SkyboxDn, sky.SkyboxFt, sky.SkyboxLf, sky.SkyboxRt, sky.SkyboxUp = "rbxassetid://0","rbxassetid://0","rbxassetid://0","rbxassetid://0","rbxassetid://0","rbxassetid://0"
        sky.SunAngularSize, sky.MoonAngularSize, sky.StarCount = 0, 0, 0
    end
end

-- [[ 2. LOGIKA SIKAT POLOS (MAP FLAT) ]] --
local function SikatPolos(v)
    if v:IsDescendantOf(game.Players.LocalPlayer.Character or workspace) and v.Parent:FindFirstChild("Humanoid") then return end
    pcall(function()
        if v:IsA("BasePart") then
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
            for _, child in pairs(v:GetChildren()) do
                if child:IsA("SurfaceAppearance") or child:IsA("Texture") or child:IsA("Decal") then
                    child:Destroy()
                end
            end
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- [[ 3. EKSEKUSI & MONITORING KETAT ]] --
task.spawn(function()
    -- Optimasi FPS Awal
    settings().Rendering.QualityLevel = 1
    if setfpscap then setfpscap(45) end
    MaterialService.Use2022Materials = false

    -- Jalankan Pertama Kali
    ForceNightPolos()
    
    -- Sikat Map (Pelan biar gak lag di Redmi 10)
    local all = workspace:GetDescendants()
    for i, v in pairs(all) do
        SikatPolos(v)
        if i % 25 == 0 then task.wait() end
    end
end)

-- [[ INI RAHASIANYA BIAR PERMANEN ]] --

-- Pantau kalau ada perubahan waktu atau lighting dari server
Lighting.Changed:Connect(function()
    ForceNightPolos()
end)

-- Pantau tiap frame (biar gak ada celah buat balik HD)
RunService.RenderStepped:Connect(function()
    Lighting.ClockTime = 0
end)

-- Sikat objek map baru
workspace.DescendantAdded:Connect(function(v)
    task.wait(0.5)
    SikatPolos(v)
end)


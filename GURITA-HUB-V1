-- [[ GURITA HUB V27 - ULTRA LIGHT & STABLE ]] --
local lp = game.Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local HttpService = game:GetService("HttpService")
local RunService = game:GetService("RunService")

local FileName = "GuritaHubV27.json"
local NotifHistory = {}

-- SETTINGS DEFAULT
local DefaultConfig = { HuntingMode = false, NotifActive = true }

-- FUNGSI SAVE/LOAD (RINGAN)
local function LoadSettings()
    if isfile and isfile(FileName) then
        local s, res = pcall(function() return HttpService:JSONDecode(readfile(FileName)) end)
        if s then return res end
    end
    return DefaultConfig
end

local function SaveSettings()
    if writefile then
        pcall(function() writefile(FileName, HttpService:JSONEncode({HuntingMode = _G.HuntingMode, NotifActive = _G.NotifActive})) end)
    end
end

local SavedData = LoadSettings()
_G.HuntingMode = SavedData.HuntingMode
_G.NotifActive = SavedData.NotifActive

-- TARGET LIST
local SuperRare = {"hydra bunny", "no my egg", "baskito", "churrito bunnito", "hopilikalika", "quackini"}
local NormalTargets = {"bunny bunny sahur", "sky egg", "bunny egg", "snackini"}
local Blacklist = {"brainrot", "npc", "base", "pedestal", "shop", "harp"}

local function PlayAlert()
    if not _G.NotifActive then return end
    local s = Instance.new("Sound", workspace)
    s.SoundId = "rbxassetid://4590662766"; s.Volume = 0.8; s:Play()
    s.Ended:Connect(function() s:Destroy() end)
end

local function KirimNotifRare(obj)
    if NotifHistory[obj] or not _G.NotifActive then return end
    NotifHistory[obj] = true 
    
    local sg = Instance.new("ScreenGui", PlayerGui)
    local f = Instance.new("Frame", sg)
    f.Size = UDim2.new(0, 250, 0, 60); f.Position = UDim2.new(1, 50, 0.8, 0)
    f.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Instance.new("UICorner", f)
    
    local line = Instance.new("Frame", f)
    line.Size = UDim2.new(0, 4, 1, 0); line.BackgroundColor3 = Color3.new(1, 0, 0); Instance.new("UICorner", line)

    local t2 = Instance.new("TextLabel", f)
    t2.Size = UDim2.new(1, -20, 1, 0); t2.Position = UDim2.new(0, 15, 0, 0)
    t2.Text = "RARE: " .. obj.Name:upper(); t2.TextColor3 = Color3.new(1, 0, 0)
    t2.Font = Enum.Font.GothamBold; t2.TextSize = 14; t2.BackgroundTransparency = 1; t2.TextXAlignment = "Left"

    PlayAlert()
    f:TweenPosition(UDim2.new(1, -270, 0.8, 0), "Out", "Back", 0.4)
    task.delay(4, function()
        if f then f:TweenPosition(UDim2.new(1, 50, 0.8, 0), "In", "Quad", 0.4) end
        task.wait(0.5); sg:Destroy()
    end)
end

local function CekTarget(n)
    n = n:lower()
    for _, b in pairs(Blacklist) do if n:find(b) then return false end end
    for _, r in pairs(SuperRare) do if n:find(r) then return "rare" end end
    for _, e in pairs(NormalTargets) do if n:find(e) then return "normal" end end
    return false
end

local function ApplyESP(obj)
    if obj:FindFirstChild("GuritaTag") or not _G.HuntingMode then return end
    
    task.spawn(function()
        local pos = obj:IsA("Model") and obj:GetModelCFrame().p or obj.Position
        if pos.Y < 100 then return end
        
        local tipe = CekTarget(obj.Name)
        if not tipe then return end
        
        local col = (tipe == "rare") and Color3.new(1, 0, 0) or Color3.fromRGB(0, 170, 255)
        if tipe == "rare" then KirimNotifRare(obj) end

        local b = Instance.new("BillboardGui", obj)
        b.Name = "GuritaTag"; b.Size = UDim2.new(0, 150, 0, 40); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 6, 0)
        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = col
        t.Font = Enum.Font.GothamBold; t.TextSize = 16; t.TextStrokeTransparency = 0.5

        -- LOOP UPDATE JARAK (OPTIMIZED)
        while obj and obj.Parent and _G.HuntingMode do
            local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local d = math.floor((hrp.Position - (obj:IsA("Model") and obj:GetModelCFrame().p or obj.Position)).Magnitude)
                t.Text = obj.Name:upper() .. "\n[" .. d .. "s]"
            end
            task.wait(1.5) -- Update lebih lambat sedikit biar gak lag
        end
        if b then b:Destroy() end
        NotifHistory[obj] = nil
    end)
end


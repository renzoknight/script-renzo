-- Logika Klik
Toggle.MouseButton1Click:Connect(function()
    MainFrame.Visible = not MainFrame.Visible
end)

BtnESP.MouseButton1Click:Connect(function()
    Config.ESP = not Config.ESP
    BtnESP.Text = "ESP: " .. (Config.ESP and "ON" or "OFF")
    SaveData()
    if not Config.ESP then
        for _, v in pairs(workspace:GetDescendants()) do
            if v.Name == "GuritaMarker" or v.Name == "GuritaTag" then v:Destroy() end
        end
    end
end)

-- [[ 5. EKSEKUSI GLOBAL ]] --
task.spawn(function()
    local all = workspace:GetDescendants()
    for i, v in pairs(all) do
        local name = v.Name:lower()
        for _, target in pairs(TargetEggs) do
            if name == target then PasangESP(v) end
        end
        if i % 150 == 0 then task.wait() end
    end
end)

workspace.DescendantAdded:Connect(function(v)
    local name = v.Name:lower()
    for _, target in pairs(TargetEggs) do
        if name == target then task.wait(0.8) PasangESP(v) end
    end
end)

print("GURITA HUB: Pencet huruf 'G' di kiri layar buat buka menu!")

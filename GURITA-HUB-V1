-- DRAG
local function Drag(o)
    local d, i, s, sp
    o.InputBegan:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 then d = true; s = inp.Position; sp = o.Position end end)
    o.InputChanged:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseMovement then i = inp end end)
    UIS.InputEnded:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 then d = false end end)
    RunService.Heartbeat:Connect(function() if d and i then local delta = i.Position - s; o.Position = UDim2.new(sp.X.Scale, sp.X.Offset + delta.X, sp.Y.Scale, sp.Y.Offset + delta.Y) end end)
end
Drag(Main); Drag(Logo)


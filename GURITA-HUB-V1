-- [[ GURITA HUB - FINAL ALL-IN-ONE ]] --
-- Fitur: Fast Flat Color, ESP Sky Island, Auto Save, Fixed Menu

local lp = game.Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local HttpService = game:GetService("HttpService")

-- [[ 1. SISTEM SAVE CONFIG ]] --
local Config = {
    FlatColor = true,
    ESP = true
}

local function SaveData() 
    pcall(function() 
        writefile("GuritaHubConfig.json", HttpService:JSONEncode(Config)) 
    end) 
end

local function LoadData() 
    pcall(function() 
        if isfile("GuritaHubConfig.json") then 
            Config = HttpService:JSONDecode(readfile("GuritaHubConfig.json")) 
        end 
    end) 
end
LoadData()

-- [[ 2. DAFTAR TELUR ]] --
local TargetEggs = {"hydra bunny", "noo my eggs", "hopilikalika", "baskito", "churrito", "quackini", "snackini", "bunny bunny sahur"}

-- [[ 3. FUNGSI LOGIKA (FLAT & ESP) ]] --
local function SikatPolos(v)
    if not Config.FlatColor then return end
    pcall(function()
        if v:IsA("BasePart") and not v.Parent:FindFirstChild("Humanoid") then
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
            for _, child in pairs(v:GetChildren()) do
                if child:IsA("SurfaceAppearance") or child:IsA("Texture") or child:IsA("Decal") then
                    child:Destroy()
                end
            end
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

local function PasangESP(obj)
    if not Config.ESP or obj:FindFirstChild("GuritaMarker") then return end
    pcall(function()
        local h = Instance.new("Highlight", obj)
        h.Name = "GuritaMarker"; h.FillColor = Color3.fromRGB(0, 170, 255); h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop 
        
        local b = Instance.new("BillboardGui", obj)
        b.Name = "GuritaTag"; b.Size = UDim2.new(0, 200, 0, 70); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 6, 0)
        
        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = Color3.fromRGB(0, 170, 255); t.Font = Enum.Font.GothamBlack; t.TextSize = 14; t.TextStrokeTransparency = 0
        
        task.spawn(function()
            while obj and obj.Parent and Config.ESP do
                if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                    local pos = obj:IsA("Model") and obj:GetModelCFrame().p or obj.Position
                    local dist = (lp.Character.HumanoidRootPart.Position - pos).Magnitude
                    t.Text = obj.Name:upper() .. "\n[" .. math.floor(dist) .. " Studs]"
                end
                task.wait(1)
            end
        end)
    end)
end

-- [[ 4. EKSEKUSI UTAMA ]] --
task.spawn(function()
    if setfpscap then setfpscap(45) end -- Stabilizer Redmi 10
    local all = workspace:GetDescendants()
    for i, v in pairs(all) do
        -- Jalankan Flat Color
        if Config.FlatColor then SikatPolos(v) end
        
        -- Cari Telur
        local name = v.Name:lower()
        for _, target in pairs(TargetEggs) do
            if name == target then PasangESP(v) end
        end
        if i % 150 == 0 then task.wait() end
    end
end)

workspace.DescendantAdded:Connect(function(v)
    local name = v.Name:lower()
    for _, target in pairs(TargetEggs) do
        if name == target then task.wait(0.8) PasangESP(v) end
    end
    if Config.FlatColor then task.wait(0.1) SikatPolos(v) end
end)


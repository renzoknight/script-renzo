-- [[ GURITA HUB: V38 - PURE FLAT COLOR (STANDALONE) ]] --
-- Sifat: AUTO-ON, NO TEXTURE, ANTI-LAG

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")

-- [[ 1. ANTI-LAG SETTINGS ]] --
pcall(function()
    if setfpscap then setfpscap(60) end
    settings().Physics.PhysicsEnvironmentalThrottle = Enum.EnviromentalPhysicsThrottle.Default
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
end)

_G.FlatActive = true -- LANGSUNG AUTO-ON

-- [[ 2. ENGINE SIKAT PART (V38 ORIGINAL) ]] --
local function SikatPart(v)
    -- Abaikan UI & Karakter Player (Proteksi Avatar)
    if v:IsDescendantOf(PlayerGui) then return end
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character and v:IsDescendantOf(p.Character) then return end
    end

    pcall(function()
        if v:IsA("BasePart") then
            -- Ubah Material & Cabut Bayangan
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            v.Reflectance = 0
            
            -- Cabut Tekstur Mesh
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
            
            -- Hapus SurfaceAppearance (Biang kerok tekstur bandel)
            local sa = v:FindFirstChildOfClass("SurfaceAppearance")
            if sa then sa:Destroy() end
            
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v:Destroy()
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- [[ 3. SISTEM EKSEKUSI (QUEUED) ]] --
local function RunFlatColor()
    local all = workspace:GetDescendants()
    local count = 0
    for _, v in pairs(all) do
        if not _G.FlatActive then break end
        SikatPart(v)
        
        -- Jeda per 50 part biar executor gak freeze (Anti-Lag)
        count = count + 1
        if count >= 50 then 
            count = 0
            task.wait() 
        end
    end
end

-- Pantau part baru yang masuk (StreamingEnabled Safe)
workspace.DescendantAdded:Connect(function(v)
    if _G.FlatActive then
        task.wait(0.1)
        SikatPart(v)
    end
end)

-- [[ 4. JALANKAN OTOMATIS ]] --
task.spawn(function()
    print("Gurita Flat Color V38: Activated!")
    RunFlatColor()
end)

-- [[ 5. UI SIMPLE (HANYA UNTUK STATUS) ]] --
if PlayerGui:FindFirstChild("GURITA_FLAT_ONLY") then PlayerGui.GURITA_FLAT_ONLY:Destroy() end
local SG = Instance.new("ScreenGui", PlayerGui); SG.Name = "GURITA_FLAT_ONLY"

local Main = Instance.new("Frame", SG)
Main.Size = UDim2.new(0, 180, 0, 60); Main.Position = UDim2.new(0.5, -90, 0.5, -30)
Main.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Main.Active = true; Main.Draggable = true
Instance.new("UICorner", Main); Instance.new("UIStroke", Main).Color = Color3.new(1, 1, 0)

local Btn = Instance.new("TextButton", Main)
Btn.Size = UDim2.new(0.9, 0, 0, 40); Btn.Position = UDim2.new(0.05, 0, 0.15, 0)
Btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35); Btn.Font = Enum.Font.GothamBold; Btn.TextSize = 12
Instance.new("UICorner", Btn)

local function UpdateUI()
    Btn.Text = _G.FlatActive and "FLAT MAP: ON" or "FLAT MAP: OFF"
    Btn.TextColor3 = _G.FlatActive and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
end

Btn.MouseButton1Click:Connect(function()
    _G.FlatActive = not _G.FlatActive
    UpdateUI()
    if _G.FlatActive then task.spawn(RunFlatColor) end
end)

UpdateUI()

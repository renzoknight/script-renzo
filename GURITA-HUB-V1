local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local CG = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")

-- 1. CONFIG & TARGETS
local AllowedEggs = {"hydra bunny", "noo my eggs", "baskito", "churrito", "quackini snackini", "hopilikalika hopilikalako"}
_G.GH_Config = {
    ESP_Player_GH = false,
    Xray_GH = false,
    AutoCollect_GH = false,
    ESP_Egg_GH = false,
    FlatColor_GH = true
}

-- [[ 2. BRUTAL FLAT COLOR (Memaksa Material Plastic) ]] --
local function ForceFlat(v)
    if _G.GH_Config.FlatColor_GH and v:IsA("BasePart") then
        pcall(function()
            -- Jangan ganggu karakter pemain
            if not v:IsDescendantOf(lp.Character) and not v.Parent:FindFirstChild("Humanoid") then
                v.Material = Enum.Material.Plastic
                v.CastShadow = false
                if v:IsA("MeshPart") then v.TextureID = "" end
                for _, child in pairs(v:GetChildren()) do
                    if child:IsA("Texture") or child:IsA("Decal") then child:Destroy() end
                end
            end
        end)
    end
end

-- [[ 3. SMART TYCOON X-RAY (Fokus Area Base Sesuai Gambar) ]] --
local function RefreshXray()
    local is_on = _G.GH_Config.Xray_GH
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            -- Cari part yang ada di dalam model bernama "Base" atau "Tycoon"
            local is_base_part = v.Parent.Name:find("Base") or v.Parent.Name:find("Tycoon") or v.Name == "Baseplate"
            
            if is_base_part and (v.Name:lower():find("floor") or v.Name == "Baseplate" or v.Name == "Base") then
                v.LocalTransparencyModifier = is_on and 0.8 or 0
            else
                -- Objek penting (Tembok, Pembatas Merah, Rumput) jangan dibeningin
                v.LocalTransparencyModifier = 0
            end
        end
    end
end

-- [[ 4. ESP ENGINE ]] --
local function CreateESP(obj, text, color)
    if not obj:FindFirstChild("GHS_ESP") then
        local h = Instance.new("Highlight", obj); h.Name = "GHS_ESP"; h.FillColor = color; h.OutlineColor = Color3.new(1, 1, 1); h.FillTransparency = 0.5
        local b = Instance.new("BillboardGui", obj); b.Name = "GHS_Tag"; b.Size = UDim2.new(0, 100, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 3, 0)
        local t = Instance.new("TextLabel", b); t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.Text = text; t.TextColor3 = color; t.Font = Enum.Font.GothamBold; t.TextSize = 14
    end
end

local function UpdateESP()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            if _G.GH_Config.ESP_Player_GH then CreateESP(p.Character, p.Name, Color3.fromRGB(0, 255, 255)) 
            elseif p.Character:FindFirstChild("GHS_ESP") then p.Character.GHS_ESP:Destroy(); p.Character.GHS_Tag:Destroy() end
        end
    end
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and table.find(AllowedEggs, v.Name:lower()) then
            if _G.GH_Config.ESP_Egg_GH then CreateESP(v, v.Name, Color3.fromRGB(255, 255, 0)) 
            elseif v:FindFirstChild("GHS_ESP") then v.GHS_ESP:Destroy(); v.GHS_Tag:Destroy() end
        end
    end
end


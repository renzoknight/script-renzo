-- [[ GURITA HUB: PURE AUTO FLAT COLOR ]] --
-- Sifat: Langsung Aktif, No UI, No Buttons, No Lag

local Players = game:GetService("Players")
local lp = Players.LocalPlayer

-- [[ ENGINE INTI ]] --
local function SikatMap(v)
    -- Proteksi Karakter & UI (Biar Ava Abang tetep keren)
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character and v:IsDescendantOf(p.Character) then return end
    end
    if v:IsA("GuiObject") or v:IsA("ScreenGui") then return end

    pcall(function()
        if v:IsA("BasePart") then
            -- Paksa jadi polos total
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            v.Reflectance = 0
            
            -- Hapus Tekstur Mesh
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
            
            -- Hapus SurfaceAppearance (Biang kerok map gak mau rata)
            local sa = v:FindFirstChildOfClass("SurfaceAppearance")
            if sa then sa:Destroy() end
            
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v:Destroy()
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- [[ SISTEM EKSEKUSI OTOMATIS ]] --

-- 1. Sikat yang sudah ada di map saat ini (Bertahap biar gak lag)
task.spawn(function()
    local all = workspace:GetDescendants()
    for i, v in pairs(all) do
        SikatMap(v)
        -- Jeda tiap 100 part supaya executor gak kaget
        if i % 100 == 0 then task.wait() end
    end
end)

-- 2. Pantau part baru yang muncul (StreamingEnabled)
workspace.DescendantAdded:Connect(function(v)
    task.wait(0.1) -- Kasih waktu part buat load identitasnya
    SikatMap(v)
end)

-- 3. Nuke Lighting (Biar warna map polos merata)
task.spawn(function()
    local Lighting = game:GetService("Lighting")
    Lighting.GlobalShadows = false
    Lighting.Brightness = 2
    Lighting.OutdoorAmbient = Color3.fromRGB(200, 200, 200)
    
    for _, v in pairs(Lighting:GetChildren()) do
        if v:IsA("PostEffect") or v:IsA("Atmosphere") then
            v:Destroy()
        end
    end
end)

print("Gurita Hub: Flat Color Loaded & Auto-Active!")

-- Fokus: Anti-Bug, Anti-DC, FPS Boost, & Smart Notif

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local Lighting = game:GetService("Lighting")
local StarterGui = game:GetService("StarterGui")
local HttpService = game:GetService("HttpService")
local GuiService = game:GetService("GuiService")

-- [[ 1. CONFIG & SAVE SYSTEM ]] --
local FileName = "GuritaHub_Config.json"
local TargetEggs = {"hydra bunny", "noo my eggs", "baskito", "churrito", "quackini", "snackini", "bunny bunny sahur"}
local NotifiedEggs = {}

_G.Settings = { EggESP = false, Notif = true }

local function SaveData() if writefile then writefile(FileName, HttpService:JSONEncode(_G.Settings)) end end
local function LoadData() if isfile and isfile(FileName) then pcall(function() _G.Settings = HttpService:JSONDecode(readfile(FileName)) end) end end
LoadData()

-- [[ 2. AUTO RECONNECT (Anti Bengong) ]] --
GuiService.ErrorMessageChanged:Connect(function()
    task.wait(5)
    game:GetService("TeleportService"):Teleport(game.PlaceId, lp)
end)

-- [[ 3. FPS BOOST & TRUE FLAT COLOR (TELITI VERSION) ]] --
local function SikatVisual(v)
    pcall(function()
        if v:IsA("BasePart") then
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
        elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("Atmosphere") or v:IsA("Clouds") then
            v:Destroy()
        end
    end)
end

local function CleanEnvironment()
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.Brightness = 2
    Lighting.ClockTime = 12
    Lighting.Ambient = Color3.fromRGB(180, 180, 180)
    for _, v in pairs(Lighting:GetChildren()) do
        if not v:IsA("Sky") then v:Destroy() end
    end
end

-- Jalankan cleaning secara berkala biar gak ketimpa map
task.spawn(function()
    CleanEnvironment()
    while true do
        for _, v in pairs(workspace:GetDescendants()) do
            SikatVisual(v)
        end
        task.wait(15) -- Refresh tiap 15 detik biar CPU gak meledak
    end
end)

-- [[ 4. SMART ESP & NOTIF ]] --
local function CleanupESP()
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "GuritaMarker" or v.Name == "GuritaTag" then v:Destroy() end
    end
end

local function ApplyESP(obj)
    if not _G.Settings.EggESP then return end
    if not obj:FindFirstChild("GuritaMarker") then
        local h = Instance.new("Highlight", obj); h.Name = "GuritaMarker"
        h.FillColor = Color3.fromRGB(255, 255, 0); h.FillTransparency = 0.4
        
        local b = Instance.new("BillboardGui", obj); b.Name = "GuritaTag"
        b.Size = UDim2.new(0, 150, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 3, 0)
        
        local t = Instance.new("TextLabel", b); t.Size = UDim2.new(1, 0, 1, 0)
        t.BackgroundTransparency = 1; t.TextColor3 = Color3.new(1, 1, 0)
        t.Font = Enum.Font.GothamBlack; t.TextSize = 14; t.TextStrokeTransparency = 0

        task.spawn(function()
            while obj and obj.Parent and _G.Settings.EggESP do
                if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (obj.Position - lp.Character.HumanoidRootPart.Position).Magnitude
                    t.Text = obj.Name:upper() .. "\n[" .. math.floor(dist) .. "m]"
                end
                task.wait(0.5)
            end
            if b then b:Destroy() end; if h then h:Destroy() end
        end)
    end
end

task.spawn(function()
    while true do
        for _, v in pairs(workspace:GetDescendants()) do
            local name = v.Name:lower()
            if table.find(TargetEggs, name) then
                if _G.Settings.EggESP then ApplyESP(v) end
                if _G.Settings.Notif and not NotifiedEggs[v] then
                    NotifiedEggs[v] = true
                    StarterGui:SetCore("SendNotification", {Title = "🥚 EGG FOUND!", Text = v.Name:upper(), Duration = 5})
                    v.AncestryChanged:Connect(function(_, p) if not p then NotifiedEggs[v] = nil end end)
                end
            end
        end
        task.wait(5)
    end
end)


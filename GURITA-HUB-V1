local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local CG = game:GetService("CoreGui")

-- 1. CONFIG & WHITELIST
local AllowedEggs = {"hydra bunny", "noo my eggs", "baskito", "churrito", "quackini snackini", "hopilikalika hopilikalako"}
_G.GH_Config = {
    ESP_Player_GH = false,
    Xray_GH = false,
    AutoCollect_GH = false,
    ESP_Egg_GH = false
}

-- [[ FUNGSI OPTIMASI - CUMA JALAN PAS DIPANGGIL ]] --
local function ApplyFlat()
    -- Scan bertahap biar gak freeze
    task.spawn(function()
        local d = workspace:GetDescendants()
        for i, v in ipairs(d) do
            if v:IsA("BasePart") and not v:IsDescendantOf(lp.Character) then
                v.Material = Enum.Material.Plastic
                v.CastShadow = false
                if v:IsA("MeshPart") then v.TextureID = "" end
            end
            if i % 500 == 0 then task.wait() end -- Kasih nafas 
        end
    end)
end

local function TagEgg(v)
    if not _G.GH_Config.ESP_Egg_GH then return end
    local n = v.Name:lower()
    for _, name in pairs(AllowedEggs) do
        if n:find(name) and not v:FindFirstChild("EHSTag") then
            local t = v:IsA("Model") and (v:FindFirstChild("Handle") or v:FindFirstChildWhichIsA("BasePart")) or v
            if t then
                local bg = Instance.new("BillboardGui", t); bg.Name = "EHSTag"; bg.AlwaysOnTop = true; bg.Size = UDim2.new(0, 150, 0, 40)
                local lbl = Instance.new("TextLabel", bg); lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1; lbl.Text = v.Name; lbl.TextColor3 = Color3.new(1, 1, 0); lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 12
            end
        end
    end
end


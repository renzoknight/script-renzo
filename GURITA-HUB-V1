-- [[ GURITA HUB: THE FINAL CLEANER (NO MOTIF AT ALL) ]] --
-- Perintah: Sikat Global Material, Hapus Motif, No Shadow, Auto-On

pcall(function()
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    settings().Physics.PhysicsEnvironmentalThrottle = Enum.EnviromentalPhysicsThrottle.Default
end)

local Lighting = game:GetService("Lighting")
local MaterialService = game:GetService("MaterialService")

-- [[ 1. NUKE MATERIAL SERVICE (INI BIANG KEROK MOTIF) ]] --
pcall(function()
    MaterialService.Use2022Materials = false
    -- Hapus semua kustomisasi material yang bikin motif muncul di mana-mana
    local variants = MaterialService:GetChildren()
    for _, v in pairs(variants) do
        v:Destroy()
    end
end)

-- [[ 2. LOGIKA SIKAT TOTAL ]] --
local function SikatAbis(v)
    -- Abaikan Karakter Player & UI
    if v:IsDescendantOf(game:GetService("Players")) or v.Parent:FindFirstChild("Humanoid") then return end
    if v:IsA("GuiObject") or v:IsA("ScreenGui") then return end

    pcall(function()
        if v:IsA("BasePart") then
            -- Paksa ke Material Dasar
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            v.Reflectance = 0
            
            -- Sikat Warna (Hijau Rata Kayak di Foto)
            if v.Name:lower():find("grass") or v.Name:lower():find("floor") or v.Name:lower():find("ground") then
                v.Color = Color3.fromRGB(0, 255, 0)
            end

            -- Sikat Anak Objek (SurfaceAppearance/Texture/Decal)
            for _, child in pairs(v:GetChildren()) do
                if child:IsA("SurfaceAppearance") or child:IsA("Texture") or child:IsA("Decal") or child:IsA("SpecialMesh") then
                    child:Destroy()
                end
            end
            
            -- Sikat ID Mesh
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
        end
    end)
end

-- [[ 3. EKSEKUSI LIGHTING (PENGHAPUS BAYANGAN) ]] --
task.spawn(function()
    Lighting.GlobalShadows = false
    Lighting.Brightness = 2
    Lighting.Ambient = Color3.fromRGB(255, 255, 255)
    Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
    
    -- Hapus Kabut & Langit
    for _, child in pairs(Lighting:GetChildren()) do
        child:Destroy()
    end
    
    local sky = Instance.new("Sky", Lighting)
    sky.SunAngularSize = 0; sky.MoonAngularSize = 0
end)

-- [[ 4. RUNTIME SCANNER ]] --
task.spawn(function()
    local all = workspace:GetDescendants()
    for i, v in pairs(all) do
        SikatAbis(v)
        if i % 150 == 0 then task.wait() end -- Anti Lag
    end
end)

workspace.DescendantAdded:Connect(function(v)
    task.wait(0.1)
    SikatAbis(v)
end)

print("GURITA HUB: Map Selesai Dibersihkan Total!")

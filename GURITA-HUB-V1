-- [[ GURITA HUB: PURE FLAT COLOR (NO CUSTOM COLOR - KEEP ORIGINAL) ]] --
-- Fitur: Hapus Motif (Bukan Warna), Nuke Awan HD, Bentuk Tetap Ada

pcall(function()
    if setfpscap then setfpscap(60) end
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
end)

local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local MaterialService = game:GetService("MaterialService")

-- [[ 1. LOGIKA POLOS (HAPUS MOTIF, JAGA WARNA ASLI) ]] --
local function SikatMotif(v)
    -- Proteksi Karakter Bang Ezra
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character and v:IsDescendantOf(p.Character) then return end
    end

    pcall(function()
        if v:IsA("BasePart") then
            -- Bikin Polos tapi JANGAN ganti v.Color (Biar warna asli event tetep ada)
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            v.Reflectance = 0
            
            -- Sikat Tekstur di dalam Mesh/Part
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
            
            -- Hapus paksa SurfaceAppearance/Texture/Decal (Biang kerok motif)
            for _, child in pairs(v:GetChildren()) do
                if child:IsA("SurfaceAppearance") or child:IsA("Texture") or child:IsA("Decal") then
                    child:Destroy()
                end
            end
            
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- [[ 2. NUKE AWAN HD & LANGIT ]] --
local function SikatLangit()
    pcall(function()
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
        
        -- Hapus Awan, Atmosfer, dan Sky HD
        for _, v in pairs(Lighting:GetChildren()) do
            if v:IsA("Sky") or v:IsA("Atmosphere") or v:IsA("Clouds") or v:IsA("PostEffect") then
                v:Destroy()
            end
        end
        
        -- Buat Langit Polos (Biar gak HD)
        local sky = Instance.new("Sky", Lighting)
        sky.SunAngularSize = 0
        sky.MoonAngularSize = 0
    end)
end

-- [[ 3. EKSEKUSI AUTO ]] --
task.spawn(function()
    -- Matikan MaterialService agar motif global hilang
    pcall(function()
        MaterialService.Use2022Materials = false
        for _, v in pairs(MaterialService:GetChildren()) do
            v:Destroy()
        end
    end)

    SikatLangit()

    -- Scan Map secara bertahap
    local all = workspace:GetDescendants()
    local count = 0
    for _, v in pairs(all) do
        SikatMotif(v)
        count = count + 1
        if count >= 100 then count = 0 task.wait() end 
    end
end)

-- Pantau kalau ada part baru masuk
workspace.DescendantAdded:Connect(function(v)
    task.wait(0.1)
    SikatMotif(v)
end)

print("GURITA HUB: Pure Flat Sempurna! Motif Hilang, Warna Asli Tetap.")

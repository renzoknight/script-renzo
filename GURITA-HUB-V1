-- [[ GURITA HUB - ULTIMATE FLAT COLOR (FIXED) ]] --
-- Fokus: Warna Asli Tetap, Tekstur/Motif/Bayangan HILANG TOTAL

local Lighting = game:GetService("Lighting")
local MaterialService = game:GetService("MaterialService")

-- [[ 1. AUTO ANTI-LAG (SANGAT EKSTRIM) ]] --
local function SikatHD()
    pcall(function()
        settings().Rendering.QualityLevel = 1
        if setfpscap then setfpscap(45) end
        
        -- Sikat Awan & Langit HD (Biang kerok makin HD)
        for _, v in pairs(Lighting:GetChildren()) do
            v:Destroy() 
        end
        
        -- Paksa Langit Polos Tanpa Efek
        local sky = Instance.new("Sky", Lighting)
        sky.SunAngularSize, sky.MoonAngularSize, sky.StarCount = 0, 0, 0
        
        -- Cahaya Rata (Biar gak mengkilap/Shadowless)
        Lighting.GlobalShadows = false
        Lighting.Brightness = 1
        Lighting.Ambient = Color3.fromRGB(200, 200, 200)
        Lighting.OutdoorAmbient = Color3.fromRGB(200, 200, 200)
        Lighting.EnvironmentDiffuseScale = 0
        Lighting.EnvironmentSpecularScale = 0
    end)
end

-- [[ 2. LOGIKA FLAT POLOS (MURNI TANPA MOTIF) ]] --
local function BuatPolos(v)
    if v:IsDescendantOf(game.Players.LocalPlayer.Character or workspace) and v.Parent:FindFirstChild("Humanoid") then return end

    pcall(function()
        if v:IsA("BasePart") then
            -- AMBIL WARNA ASLI, TAPI BUANG MATERIAL
            local warnaAsli = v.Color
            v.Material = Enum.Material.Plastic -- Plastic lebih polos dari SmoothPlastic di beberapa map
            v.Color = warnaAsli
            v.CastShadow = false
            v.Reflectance = 0
            
            -- Sikat Tekstur/Decal/SurfaceAppearance
            for _, child in pairs(v:GetChildren()) do
                if child:IsA("SurfaceAppearance") or child:IsA("Texture") or child:IsA("Decal") then
                    child:Destroy()
                end
            end
            
            -- Sikat Tekstur Mesh (Tembok Pembatas)
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- [[ 3. EKSEKUSI AUTO BERTAHAP (REDMI 10 SAFE) ]] --
task.spawn(function()
    SikatHD()
    -- Matikan sistem material baru Roblox
    pcall(function()
        MaterialService.Use2022Materials = false
        for _, m in pairs(MaterialService:GetChildren()) do m:Destroy() end
    end)

    local all = workspace:GetDescendants()
    for i, v in pairs(all) do
        BuatPolos(v)
        -- Jeda biar gak lag pas loading
        if i % 20 == 0 then task.wait(0.01) end
    end
end)

workspace.DescendantAdded:Connect(function(v)
    task.wait(0.5)
    BuatPolos(v)
end)


local function CreateToggle(parent, txt, var, callback)
    local b = Instance.new("TextButton", parent)
    b.Size = UDim2.new(1, -10, 0, 40); b.BackgroundColor3 = Color3.fromRGB(25, 25, 35); b.Font = Enum.Font.GothamBold; b.TextSize = 12; Instance.new("UICorner", b)
    local function Update()
        b.Text = txt..(_G.GH_Settings[var] and ": ON" or ": OFF")
        b.TextColor3 = _G.GH_Settings[var] and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
    end
    Update()
    b.MouseButton1Click:Connect(function() _G.GH_Settings[var] = not _G.GH_Settings[var]; Update(); if callback then callback() end end)
end


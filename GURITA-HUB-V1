-- [[ GURITA-HUB-V1 - ANTI-LAG & STRICT XRAY ]] --

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local TweenService = game:GetService("TweenService")
local CG = game:GetService("CoreGui")

_G.GH_Settings = {
    ESP_Player_GH = false,
    Xray_GH = false,
    AutoCollect_GH = false,
    ESP_Egg_GH = false,
    FlatColor_GH = true
}

-- 1. OPTIMIZED FLAT COLOR (ANTI LAG)
local function ApplyFlatColor()
    local descendants = workspace:GetDescendants()
    for i, v in ipairs(descendants) do
        if v:IsA("BasePart") and not v:IsA("Terrain") then
            if not v:IsDescendantOf(lp.Character) and not v.Parent:FindFirstChildOfClass("Humanoid") then
                v.Material = Enum.Material.Plastic
                v.CastShadow = false
            end
        end
        -- Kasih nafas tiap 300 part biar gak lag
        if i % 300 == 0 then task.wait() end
    end
end

-- 2. STRICT XRAY (KHUSUS LANTAI BASE SAJA)
local function UpdateXray()
    local descendants = workspace:GetDescendants()
    for i, v in ipairs(descendants) do
        if v:IsA("BasePart") and not v:IsDescendantOf(lp.Character) then
            local n = v.Name:lower()
            -- Filter super ketat: Harus ada kata kunci lantai, tapi HARUS BUKAN tembok/map
            local isBase = n:find("base") or n:find("floor") or n:find("lantai") or n:find("plot")
            local isWall = n:find("wall") or n:find("tembok") or n:find("map") or n:find("build") or n:find("tree")
            
            if isBase and not isWall then
                if _G.GH_Settings.Xray_GH then
                    v.LocalTransparencyModifier = 0.7
                else
                    v.LocalTransparencyModifier = 0
                end
            end
        end
        if i % 300 == 0 then task.wait() end
    end
end

-- 3. ESP PLAYER
local function UpdateESP()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("Head") then
            if _G.GH_Settings.ESP_Player_GH then
                if not p.Character.Head:FindFirstChild("ESPTag") then
                    local bg = Instance.new("BillboardGui", p.Character.Head)
                    bg.Name = "ESPTag"; bg.AlwaysOnTop = true; bg.Size = UDim2.new(0, 200, 0, 50); bg.ExtentsOffset = Vector3.new(0, 3, 0)
                    local lbl = Instance.new("TextLabel", bg)
                    lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1; lbl.TextColor3 = Color3.new(1, 1, 1)
                    lbl.Text = p.Name; lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 18; lbl.TextStrokeTransparency = 0
                end
            else
                local tag = p.Character.Head:FindFirstChild("ESPTag")
                if tag then tag:Destroy() end
            end
        end
    end
end

-- 4. UI CONSTRUCTION
if CG:FindFirstChild("GuritaHubV1_Final") then CG.GuritaHubV1_Final:Destroy() end
local SG = Instance.new("ScreenGui", CG); SG.Name = "GuritaHubV1_Final"

local GHTxtBtn = Instance.new("TextButton", SG)

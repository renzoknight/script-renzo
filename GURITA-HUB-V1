local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local TweenService = game:GetService("TweenService")
local CG = game:GetService("CoreGui")
local HttpService = game:GetService("HttpService")

-- 1. DATABASE & CONFIG
local ConfigFile = "GHS_Config_Final.json"
local AllowedEggs = {"hydra bunny", "noo my eggs", "baskito", "churrito", "quackini snackini", "hopilikalika hopilikalako"}

_G.GH_Config = {
    ESP_Player_GH = false,
    Xray_GH = false,
    AutoCollect_GH = false,
    ESP_Egg_GH = false
}

local function SaveData()
    pcall(function() if writefile then writefile(ConfigFile, HttpService:JSONEncode(_G.GH_Config)) end end)
end

-- [[ FITUR FLAT COLOR (OPTIMIZED) ]] --
local function ApplyFlat(v)
    pcall(function()
        if (v:IsA("BasePart") or v:IsA("MeshPart")) and not (v.Parent:FindFirstChild("Humanoid") or v:IsDescendantOf(lp.Character)) then
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
            for _, child in pairs(v:GetChildren()) do
                if child:IsA("Texture") or child:IsA("Decal") then child:Destroy() end
            end
        end
    end)
end

-- [[ FITUR X-RAY ]] --
local function RefreshXray()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and not (v.Parent:FindFirstChild("Humanoid") or v:IsDescendantOf(lp.Character)) then
            local n = v.Name:lower()
            if n:find("wall") or n:find("floor") or n:find("base") or n:find("part") then
                v.LocalTransparencyModifier = _G.GH_Config.Xray_GH and 0.6 or 0
            end
        end
    end
end

-- [[ FITUR ESP PLAYER ]] --
local function UpdatePlayerESP()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("Head") then
            local head = p.Character.Head
            local existing = head:FindFirstChild("ESP_PlayerTag")
            if _G.GH_Config.ESP_Player_GH then
                if not existing then
                    local bg = Instance.new("BillboardGui", head); bg.Name = "ESP_PlayerTag"; bg.AlwaysOnTop = true; bg.Size = UDim2.new(0, 200, 0, 50); bg.ExtentsOffset = Vector3.new(0, 3, 0)
                    local lbl = Instance.new("TextLabel", bg); lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1; lbl.TextColor3 = Color3.fromRGB(0, 255, 255); lbl.Text = p.Name; lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 14
                end
            elseif existing then
                existing:Destroy()
            end
        end
    end
end

-- [[ FITUR ESP EGG (WHITELIST) ]] --
local function TagEgg(v)
    if not _G.GH_Config.ESP_Egg_GH then return end
    local n = v.Name:lower()
    for _, name in pairs(AllowedEggs) do
        if n:find(name) and not v:FindFirstChild("EHSTag") then
            local t = v:IsA("Model") and (v:FindFirstChild("Handle") or v:FindFirstChildWhichIsA("BasePart")) or v
            if t then
                local bg = Instance.new("BillboardGui", t); bg.Name = "EHSTag"; bg.AlwaysOnTop = true; bg.Size = UDim2.new(0, 160, 0, 40)
                local lbl = Instance.new("TextLabel", bg); lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1; lbl.Text = v.Name; lbl.TextColor3 = Color3.fromRGB(255, 200, 0); lbl.Font = Enum.Font.GothamBlack; lbl.TextSize = 13
            end
        end
    end
end


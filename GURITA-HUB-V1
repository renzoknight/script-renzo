-- [[ GURITA HUB: GLOBAL MATERIAL NUKE ]] --
-- Sifat: AUTO-ON, NO UI, NO LAG, NO TEXTURE

local Players = game:GetService("Players")
local MaterialService = game:GetService("MaterialService")
local Lighting = game:GetService("Lighting")

-- [[ 1. NUKE MATERIAL SERVICE ]] --
-- Ini kuncinya: Matikan semua pengganti material buatan developer gamenya
pcall(function()
    MaterialService.Use2022Materials = false
    -- Kosongkan semua override material global jika ada
    for _, v in pairs(MaterialService:GetChildren()) do
        if v:IsA("TerrainDetail") or v:IsA("MaterialVariant") then
            v:Destroy()
        end
    end
end)

-- [[ 2. FUNGSI PEMBERSIH TOTAL ]] --
local function ForceFlat(v)
    -- PROTEKSI KARAKTER (Ava Bang Ezra & Player)
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character and v:IsDescendantOf(p.Character) then return end
    end

    pcall(function()
        if v:IsA("BasePart") then
            -- Paksa ke material paling dasar
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            v.Reflectance = 0
            
            -- Sikat Tekstur Mesh
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
            
            -- Sikat SurfaceAppearance (Penyebab map gak mau polos)
            local sa = v:FindFirstChildOfClass("SurfaceAppearance")
            if sa then sa:Destroy() end
            
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v:Destroy()
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- [[ 3. AUTOMATION (AUTO-RUN) ]] --

-- Eksekusi awal (Nyapu map yang sudah ke-load)
task.spawn(function()
    local all = workspace:GetDescendants()
    for i, v in pairs(all) do
        ForceFlat(v)
        -- Jeda tipis biar gak lag di map berat
        if i % 150 == 0 then task.wait() end
    end
end)

-- Pantau part baru (Penting buat map yang luas/streaming)
workspace.DescendantAdded:Connect(function(v)
    task.wait(0.1)
    ForceFlat(v)
end)

-- [[ 4. LIGHTING OVERRIDE (BIAR MAKIN FLAT) ]] --
task.spawn(function()
    Lighting.GlobalShadows = false
    Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
    Lighting.Brightness = 2
    for _, effect in pairs(Lighting:GetChildren()) do
        if effect:IsA("PostEffect") or effect:IsA("Atmosphere") or effect:IsA("Clouds") then
            effect:Destroy()
        end
    end
end)

print("Gurita Hub: Global Nuke Active. Map should be Flat now!")

    _G.HuntingMode = not _G.HuntingMode
    if _G.HuntingMode then
        Btn.Text = "HUNTING MODE: ON\n(PURE EGGS)"; Btn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        for _, v in pairs(workspace:GetDescendants()) do
            if IsValidEgg(v.Name) then PasangESP(v) end
        end
    else
        Btn.Text = "HUNTING MODE: OFF"; Btn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
    end

-- Spesial buat Bang Ezra (Ukuran Besar & Auto Scan)

local lp = game.Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")

-- 1. DAFTAR TELUR (DENGAN KATA KUNCI PALING SENSITIF)
local TargetEggs = {
    "hydra", "bunny", "noo", "hopili", "baskito", 
    "churrito", "quackini", "snackini", "sahur", "egg"
}

-- 2. FUNGSI ESP MEGA (BIRU NEON)
local function PasangMegaESP(obj)
    if obj:FindFirstChild("GuritaMarker") then return end
    
    pcall(function()
        -- Highlight Biru Tembus Pandang
        local h = Instance.new("Highlight")
        h.Name = "GuritaMarker"
        h.Parent = obj
        h.FillColor = Color3.fromRGB(0, 170, 255)
        h.OutlineColor = Color3.new(1, 1, 1)
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop 

        -- Billboard UI (Tulisan Gede)
        local b = Instance.new("BillboardGui")
        b.Name = "GuritaTag"
        b.Parent = obj
        b.Size = UDim2.new(0, 250, 0, 80) -- Ukuran Label Gede
        b.AlwaysOnTop = true
        b.ExtentsOffset = Vector3.new(0, 10, 0)
        
        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0)
        t.BackgroundTransparency = 1
        t.TextColor3 = Color3.fromRGB(0, 170, 255)
        t.Font = Enum.Font.GothamBlack
        t.TextSize = 22 -- Tulisan digedein biar keliatan di langit
        t.TextStrokeTransparency = 0
        t.Text = "TARGET: " .. obj.Name:upper()

        task.spawn(function()
            while obj and obj.Parent do
                if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                    local pos = obj:IsA("Model") and obj:GetModelCFrame().p or obj.Position
                    local dist = (lp.Character.HumanoidRootPart.Position - pos).Magnitude
                    t.Text = "TARGET: " .. obj.Name:upper() .. "\n[" .. math.floor(dist) .. " STUDS]"
                end
                task.wait(1)
            end
        end)
    end)
end

-- 3. FUNGSI SCAN TELUR (SISTEM PAKSA)
local function ForceScan()
    local all = workspace:GetDescendants()
    for _, v in pairs(all) do
        local name = v.Name:lower()
        for _, target in pairs(TargetEggs) do
            if string.find(name, target) then
                PasangMegaESP(v)
            end
        end
    end
end


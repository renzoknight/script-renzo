-- --- 7. UTILS (DRAG, RGB, TOGGLE) ---
local function Drag(ui)
    local d, i, s, sp
    ui.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then d = true; s = input.Position; sp = ui.Position end end)
    ui.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement then i = input end end)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then d = false end end)
    RunService.Heartbeat:Connect(function() if d and i then local delta = i.Position - s; ui.Position = UDim2.new(sp.X.Scale, sp.X.Offset + delta.X, sp.Y.Scale, sp.Y.Offset + delta.Y) end end)
end
Drag(MainFrame); Drag(LogoButton)

local cols = {Color3.fromRGB(0, 160, 255), Color3.fromRGB(255, 120, 0), Color3.fromRGB(255, 210, 0), Color3.fromRGB(160, 0, 255)}
task.spawn(function()
    local c = 1
    while true do
        local n = c % #cols + 1
        for i = 0, 1, 0.05 do
            local l = cols[c]:Lerp(cols[n], i)
            MainStroke.Color = l; LogoStroke.Color = l
            task.wait(0.05)
        end
        c = n
    end
end)


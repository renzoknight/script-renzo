-- [[ GURITA HUB: EVENT EDITION - SEMPURNA & AUTO ]] --
-- Fitur: Hijau Polos (Tidak Mencolok), No Shadow, No Lag, Auto-Active

pcall(function()
    if setfpscap then setfpscap(60) end
    settings().Physics.PhysicsEnvironmentalThrottle = Enum.EnviromentalPhysicsThrottle.Default
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
end)

local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local MaterialService = game:GetService("MaterialService")

-- [[ 1. LOGIKA WARNA HIJAU LEMBUT & POLOS ]] --
local function SikatEvent(v)
    -- Proteksi karakter Bang Ezra
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character and v:IsDescendantOf(p.Character) then return end
    end

    pcall(function()
        if v:IsA("BasePart") then
            -- Bikin Polos
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            v.Reflectance = 0
            
            -- Atur Warna Hijau Rumput (Tidak Mencolok/Soft)
            if v.Name:lower():find("grass") or v.Name:lower():find("rumput") or v.Name:lower():find("floor") then
                v.Color = Color3.fromRGB(85, 120, 85) -- Hijau daun yang adem di mata
            end

            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
            
            local sa = v:FindFirstChildOfClass("SurfaceAppearance")
            if sa then sa:Destroy() end
            
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v:Destroy()
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- [[ 2. EKSEKUSI AUTO (SISTEM ANTREAN AMAN) ]] --
task.spawn(function()
    -- Sikat Warna Terrain (Jika rumputnya pakai sistem Terrain)
    local t = workspace:FindFirstChildOfClass("Terrain")
    if t then
        t.WaterWaveSize = 0
        t.WaterWaveSpeed = 0
        pcall(function()
            t:SetMaterialColor(Enum.Material.Grass, Color3.fromRGB(85, 120, 85))
        end)
    end

    local all = workspace:GetDescendants()
    local count = 0
    for _, v in pairs(all) do
        SikatEvent(v)
        count = count + 1
        if count >= 50 then count = 0 task.wait() end 
    end
end)

workspace.DescendantAdded:Connect(function(v)
    task.wait(0.1)
    SikatEvent(v)
end)

-- [[ 3. FIX LIGHTING (PENGHAPUS BAYANGAN TOTAL) ]] --
task.spawn(function()
    Lighting.GlobalShadows = false
    Lighting.Brightness = 0.8 -- Tidak terlalu silau
    Lighting.ClockTime = 12
    
    -- Menghilangkan bayangan di pojokan tembok (Ambient Force)
    Lighting.Ambient = Color3.fromRGB(150, 150, 150)
    Lighting.OutdoorAmbient = Color3.fromRGB(150, 150, 150)
    
    pcall(function()
        MaterialService.Use2022Materials = false
    end)

    for _, v in pairs(Lighting:GetChildren()) do
        if v:IsA("PostEffect") or v:IsA("Atmosphere") or v:IsA("Clouds") then
            v:Destroy()
        end
    end
end)

print("GURITA HUB: Event Color Fixed! Hijau Polos & No Shadow.")

    while true do
        BtnFlat.Text = "FLAT MAP: " .. (_G.FlatActive and "ON" or "OFF"); BtnFlat.TextColor3 = _G.FlatActive and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
        BtnHunt.Text = "EGG HUNT: " .. (_G.HuntEggActive and "ON" or "OFF"); BtnHunt.TextColor3 = _G.HuntEggActive and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
        task.wait(0.5)
    end
end)

-- [[ GURITA HUB: V38 - LIGHTWEIGHT FLAT COLOR ]] --
-- Fix: Lag & Texture Lock

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local Lighting = game:GetService("Lighting")

_G.FlatActive = false

-- Fungsi Utama: Sikat Part Tanpa Beban
local function SikatPart(v)
    -- Abaikan UI & Karakter Player (Proteksi Ava)
    if v:IsDescendantOf(PlayerGui) then return end
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character and v:IsDescendantOf(p.Character) then return end
    end

    pcall(function()
        if v:IsA("BasePart") then
            -- Ubah Material & Cabut Bayangan
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            v.Reflectance = 0
            
            -- Cabut Tekstur Mesh
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
            
            -- Hapus SurfaceAppearance (Biang kerok tekstur bandel)
            local sa = v:FindFirstChildOfClass("SurfaceAppearance")
            if sa then sa:Destroy() end
            
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v:Destroy()
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- Eksekusi Bertahap (Anti-Lag)
local function RunFlatColor()
    local all = workspace:GetDescendants()
    for i, v in pairs(all) do
        if not _G.FlatActive then break end
        SikatPart(v)
        
        -- Jeda setiap 100 part biar gak FPS Drop
        if i % 100 == 0 then
            task.wait() 
        end
    end
end

-- Pantau Part Baru (StreamingEnabled Safe)
workspace.DescendantAdded:Connect(function(v)
    if _G.FlatActive then
        task.wait(0.1) -- Kasih waktu part load bentar
        SikatPart(v)
    end
end)


local FileName = "GuritaHubV51.json"

-- 1. SMOOTH OPTIMIZE & SOFT LIGHTING
local function SmoothOptimize()
    task.spawn(function()
        settings().Rendering.QualityLevel = 1
        local lighting = game:GetService("Lighting")
        lighting.GlobalShadows = false
        lighting.Brightness = 1
        lighting.Ambient = Color3.fromRGB(130, 130, 130)
        lighting.OutdoorAmbient = Color3.fromRGB(130, 130, 130)
        
        for i, v in pairs(workspace:GetDescendants()) do
            if i % 200 == 0 then task.wait() end 
            if v:IsA("BasePart") then
                v.Material = Enum.Material.Plastic; v.Reflectance = 0
            elseif v:IsA("Decal") or v:IsA("Texture") then
                v:Destroy()
            end
        end
    end)
end

-- 2. SAVE/LOAD
local function SaveSettings()
    if writefile then pcall(function() writefile(FileName, HttpService:JSONEncode({ HuntingMode = _G.HuntingMode })) end) end
end
local function LoadSettings()
    if isfile and isfile(FileName) then
        local s, res = pcall(function() return HttpService:JSONDecode(readfile(FileName)) end)
        if s then return res.HuntingMode end
    end
    return false
end
_G.HuntingMode = LoadSettings()

-- 3. TARGET LIST
local NotifHistory = {}
local SuperRare = {"hydra", "no my egg", "baskito", "churrito", "hopilikalika", "quackini", "harp"}
local NormalTargets = {"tralala", "eggdin", "easter", "sahur", "sky egg", "bunny egg"}

-- 4. ESP LOGIC (INFINITE RANGE)
local function PasangESP(obj)
    if not _G.HuntingMode or obj:FindFirstChild("GuritaTag") then return end
    task.spawn(function()
        task.wait(1.5)
        local name = obj.Name:lower()
        if name == "part" or name == "model" then return end
        
        local pos = (obj:IsA("Model") and obj.PrimaryPart) and obj.PrimaryPart.Position or (obj:IsA("BasePart") and obj.Position)
        if not pos or pos.Y < 100 then return end

        local tipe = nil
        for _, r in pairs(SuperRare) do if name:find(r) then tipe = "rare"; break end end
        if not tipe then
            for _, e in pairs(NormalTargets) do if name:find(e) then tipe = "normal"; break end end
        end
        if not tipe then return end

        if tipe == "rare" and not NotifHistory[obj.Name] then
            NotifHistory[obj.Name] = true
            local s = Instance.new("Sound", workspace)
            s.SoundId = "rbxassetid://4590662766"; s.Volume = 0.5; s:Play()
            s.Ended:Connect(function() s:Destroy() end)
        end

        local col = (tipe == "rare") and Color3.new(1, 0, 0) or Color3.fromRGB(0, 170, 255)
        local b = Instance.new("BillboardGui", obj)
        b.Name = "GuritaTag"; b.Size = UDim2.new(0, 200, 0, 50)
        b.AlwaysOnTop = true; b.MaxDistance = math.huge
        b.ExtentsOffset = Vector3.new(0, 6, 0)
        
        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = col
        t.Font = "GothamBlack"; t.TextSize = 13; t.TextStrokeTransparency = 0.2
        
        while obj and obj.Parent and _G.HuntingMode do
            local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                t.Text = obj.Name:upper() .. "\n[" .. math.floor((hrp.Position - pos).Magnitude) .. "s]"
            end
            task.wait(2)
        end
        if b then b:Destroy() end
    end)
end


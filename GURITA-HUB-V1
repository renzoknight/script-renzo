-- [[ 2. AUTO FLAT COLOR ]] --
local function ApplyFlat(v)
    pcall(function()
        if v:IsA("BasePart") and not v.Parent:FindFirstChild("Humanoid") and not v:IsDescendantOf(lp.Character) then
            v.Material = Enum.Material.Plastic; v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
            for _, child in pairs(v:GetChildren()) do if child:IsA("Texture") or child:IsA("Decal") then child:Destroy() end end
        end
    end)
end


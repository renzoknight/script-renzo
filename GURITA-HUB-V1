-- [[ GURITA HUB: PURE FLAT COLOR (FOTO VERSION) ]] --
-- Target: Map Steal a Brainrot (Bikin rata kayak di foto)
-- Fitur: Full Auto, No Shadow, No Texture, Anti-Lag

-- [[ 1. OPTIMASI EXECUTOR ]] --
pcall(function()
    if setfpscap then setfpscap(60) end
    settings().Physics.PhysicsEnvironmentalThrottle = Enum.EnviromentalPhysicsThrottle.Default
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
end)

local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")

-- [[ 2. LOGIKA SIKAT PART & WARNA RATA ]] --
local function SikatRata(v)
    -- Proteksi Karakter Bang Ezra
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character and v:IsDescendantOf(p.Character) then return end
    end

    pcall(function()
        if v:IsA("BasePart") then
            -- Paksa jadi Plastik Mulus (Biar warnanya rata)
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            v.Reflectance = 0
            
            -- Hapus tekstur biar jadi polos total
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
            
            local sa = v:FindFirstChildOfClass("SurfaceAppearance")
            if sa then sa:Destroy() end
            
            -- Jika itu rumput, kasih warna hijau cerah kayak di foto
            if v.Name:lower():find("grass") or v.Name:lower():find("floor") then
                v.Color = Color3.fromRGB(0, 255, 0) -- Hijau terang khas Flat Color
            end
            
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v:Destroy()
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- [[ 3. SISTEM AUTO-EXECUTE (ANTREAN AMAN) ]] --
task.spawn(function()
    -- Sikat Terrain (Jika ada rumput Terrain Roblox)
    local t = workspace:FindFirstChildOfClass("Terrain")
    if t then
        t.WaterWaveSize = 0; t.WaterWaveSpeed = 0
        pcall(function()
            t:SetMaterialColor(Enum.Material.Grass, Color3.fromRGB(0, 255, 0))
        end)
    end

    local all = workspace:GetDescendants()
    local count = 0
    for _, v in pairs(all) do
        SikatRata(v)
        count = count + 1
        if count >= 100 then count = 0 task.wait() end -- Anti Lag
    end
end)

-- Pantau kalau ada part baru masuk (StreamingEnabled Safe)
workspace.DescendantAdded:Connect(function(v)
    task.wait(0.1)
    SikatRata(v)
end)

-- [[ 4. SETTING LIGHTING (BIAR GAK ADA BAYANGAN SAMA SEKALI) ]] --
task.spawn(function()
    Lighting.GlobalShadows = false
    Lighting.ClockTime = 14 -- Waktu siang biar terang
    Lighting.Brightness = 2 -- Cahaya kuat biar warna part keluar
    Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255) -- Putih total biar gak ada sisi gelap
    Lighting.Ambient = Color3.fromRGB(255, 255, 255) -- Putih total buat bayangan dalem
    
    -- Hapus efek atmosfer yang bikin butek
    for _, v in pairs(Lighting:GetChildren()) do
        if v:IsA("PostEffect") or v:IsA("Atmosphere") or v:IsA("Clouds") then
            v:Destroy()
        end
    end
end)

print("GURITA HUB: Flat Color Rata Sempurna Activated!")

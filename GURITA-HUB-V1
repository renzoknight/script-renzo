-- [[ GURITA HUB: V33 - GLOBAL RENDER INJECTOR ]] --
-- Fix: Map Texture Lock, Material Persistence, & Only-Avatar Bug

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local Lighting = game:GetService("Lighting")
local StarterGui = game:GetService("StarterGui")
local HttpService = game:GetService("HttpService")

-- [[ 1. CONFIG & SAVE ]] --
local FileName = "GuritaHub_Config.json"
local TargetEggs = {"hydra bunny", "noo my eggs", "baskito", "churrito", "quackini", "snackini", "bunny bunny sahur"}
local NotifiedEggs = {}

_G.Settings = { EggESP = false, Notif = true }

local function SaveData() if writefile then writefile(FileName, HttpService:JSONEncode(_G.Settings)) end end
local function LoadData() if isfile and isfile(FileName) then pcall(function() _G.Settings = HttpService:JSONDecode(readfile(FileName)) end) end end
LoadData()

-- [[ 2. GLOBAL FLAT COLOR ENGINE (ULTIMATE) ]] --
local function ForceFlat(v)
    -- PROTEKSI UI
    if v:IsDescendantOf(PlayerGui) or v:IsDescendantOf(lp) or v:IsA("ScreenGui") then return end

    pcall(function()
        if v:IsA("BasePart") then
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            -- Jika MeshPart, kita paksa Texture-nya hilang total
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v.Transparency = 1
            v:Destroy() -- Double kill biar bener-bener ilang
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- Teknik Baru: Force All Elements via Rendering Settings
local function NukeEnvironment()
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.Brightness = 2
    Lighting.ClockTime = 12
    
    -- Hapus semua yang bikin map kelihatan berat/bertekstur
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Atmosphere") or v:IsA("Clouds") or v:IsA("Sky") or v:IsA("SunRaysEffect") then
            v:Destroy()
        end
    end
end

-- Loop Agresif: Memaksa Map (Bukan cuma Player)
task.spawn(function()
    NukeEnvironment()
    while true do
        for i, v in pairs(workspace:GetDescendants()) do
            ForceFlat(v)
            -- Jeda dikit biar gak freeze pas proses ribuan part map
            if i % 250 == 0 then task.wait() end 
        end
        task.wait(10) -- Paksa ulang tiap 10 detik (Anti-StreamingEnabled)
    end
end)

-- [[ 3. ESP & NOTIF ]] --
local function ApplyESP(obj)
    if not _G.Settings.EggESP then return end
    if not obj:FindFirstChild("GuritaMarker") then
        local h = Instance.new("Highlight", obj); h.Name = "GuritaMarker"
        h.FillColor = Color3.fromRGB(255, 255, 0); h.OutlineColor = Color3.new(1,1,1)
        
        local b = Instance.new("BillboardGui", obj); b.Name = "GuritaTag"
        b.Size = UDim2.new(0, 150, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 3, 0)
        
        local t = Instance.new("TextLabel", b); t.Size = UDim2.new(1, 0, 1, 0)
        t.BackgroundTransparency = 1; t.TextColor3 = Color3.new(1, 1, 0); t.Font = Enum.Font.GothamBlack; t.TextSize = 14

        task.spawn(function()
            while obj and obj.Parent and _G.Settings.EggESP do
                if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (obj.Position - lp.Character.HumanoidRootPart.Position).Magnitude
                    t.Text = obj.Name:upper() .. "\n[" .. math.floor(dist) .. "m]"
                end
                task.wait(1)
            end
            if b then b:Destroy() end; if h then h:Destroy() end
        end)
    end
end

task.spawn(function()
    while true do
        for _, v in pairs(workspace:GetDescendants()) do
            if table.find(TargetEggs, v.Name:lower()) then
                if _G.Settings.EggESP then ApplyESP(v) end
                if _G.Settings.Notif and not NotifiedEggs[v] then
                    NotifiedEggs[v] = true
                    StarterGui:SetCore("SendNotification", {Title = "🥚 EGG FOUND!", Text = v.Name:upper(), Duration = 5})
                    v.AncestryChanged:Connect(function(_, p) if not p then NotifiedEggs[v] = nil end end)
                end
            end
        end
        task.wait(5)
    end
end)


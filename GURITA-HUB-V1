local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- [[ OPTIMASI ANTI-LAG ]] --
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
_G.ESP_Enabled = false

-- Fungsi untuk memberikan Flat Color tanpa beban CPU tinggi
local function ApplyFlatESP(player)
    if player == LocalPlayer then return end -- Jangan warnai diri sendiri (biar gak ganggu pandangan)
    
    local function setup(char)
        if not _G.ESP_Enabled then return end
        
        -- Tunggu sampai karakter lengkap agar tidak error
        local hrp = char:WaitForChild("HumanoidRootPart", 5)
        if hrp then
            -- Cek apakah sudah ada Highlight, jika ada jangan buat lagi (Ini kunci anti-lag)
            local existing = char:FindFirstChild("GuritaHighlight")
            if not existing then
                local highlight = Instance.new("Highlight")
                highlight.Name = "GuritaHighlight"
                highlight.Parent = char
                highlight.FillColor = Color3.fromRGB(0, 255, 0) -- Hijau Flat
                highlight.FillTransparency = 0.7 -- Transparan agar tidak mencolok
                highlight.OutlineColor = Color3.fromRGB(255, 255, 255) -- Putih tipis
                highlight.OutlineTransparency = 0
                highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            end
        end
    end

    if player.Character then setup(player.Character) end
    player.CharacterAdded:Connect(setup) -- Hanya jalan pas player respawn
end

-- [[ WINDOW SETUP ]] --
local Window = Rayfield:CreateWindow({
   Name = "🐙 GURITA HUB | Anti-Lag Edition",
   LoadingTitle = "Loading Smooth Script...",
   LoadingSubtitle = "by Gurita Team",
})

-- [[ TOMBOL OPEN (POSISI AMAN) ]] --
local OpenGui = Instance.new("ScreenGui")
local btn = Instance.new("TextButton")
OpenGui.Parent = game.CoreGui
btn.Parent = OpenGui
btn.Text = "🐙"
btn.Size = UDim2.new(0, 50, 0, 50)
btn.Position = UDim2.new(0, 10, 0.5, 0) -- Sebelah kiri tengah
btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)

btn.MouseButton1Click:Connect(function()
    game:GetService("CoreGui").Rayfield.Enabled = not game:GetService("CoreGui").Rayfield.Enabled
end)

-- [[ TAB VISUAL ]] --
local VisualTab = Window:CreateTab("Visuals")

VisualTab:CreateToggle({
   Name = "Flat Color ESP (Anti-Lag)",
   CurrentValue = false,
   Flag = "ESP_Toggle",
   Callback = function(Value)
      _G.ESP_Enabled = Value
      if Value then
          -- Jalankan ke semua pemain yang sudah ada
          for _, player in pairs(Players:GetPlayers()) do
              ApplyFlatESP(player)
          end
      else
          -- Hapus semua warna jika dimatikan agar FPS naik lagi
          for _, player in pairs(Players:GetPlayers()) do
              if player.Character and player.Character:FindFirstChild("GuritaHighlight") then
                  player.Character.GuritaHighlight:Destroy()
              end
          end
      end
   end,
})

-- Tambahkan fitur FPS Booster sederhana
VisualTab:CreateButton({
   Name = "🚀 Boost FPS (Hapus Tekstur Dunia)",
   Callback = function()
       for _, v in pairs(game:GetDescendants()) do
           if v:IsA("BasePart") and not v:IsA("MeshPart") then
               v.Material = Enum.Material.SmoothPlastic
           end
       end
       Rayfield:Notify({Title = "Boosted", Content = "Tekstur dunia telah disederhanakan!", Duration = 2})
   end,
})

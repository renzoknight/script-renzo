-- 1. DATABASE & CONFIG
local ConfigFile = "GHS_Config_Final.json"
local AllowedEggs = {"hydra bunny", "noo my eggs", "baskito", "churrito", "quackini snackini", "hopilikalika hopilikalako"}

_G.GH_Config = {
    ESP_Player_GH = false,
    Xray_GH = false,
    AutoCollect_GH = false,
    ESP_Egg_GH = false
}

local function SaveData()
    pcall(function() if writefile then writefile(ConfigFile, HttpService:JSONEncode(_G.GH_Config)) end end)
end

local function LoadData()
    pcall(function()
        if isfile and isfile(ConfigFile) then
            local decoded = HttpService:JSONDecode(readfile(ConfigFile))
            if decoded then for k, v in pairs(decoded) do _G.GH_Config[k] = v end end
        end
    end)
end
LoadData()

-- [[ MESIN 1: FLAT COLOR (AUTO RUN) ]] --
local function IsPlayer(v) return v:IsDescendantOf(lp.Character) or (v.Parent and v.Parent:FindFirstChild("Humanoid")) end

local function ApplyFlat(v)
    pcall(function()
        if (v:IsA("BasePart") or v:IsA("MeshPart")) and not IsPlayer(v) then
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
            for _, tex in pairs(v:GetChildren()) do if tex:IsA("Texture") or tex:IsA("Decal") then tex:Destroy() end end
        end
    end)
end

-- [[ MESIN 2: X-RAY ]] --
local function RefreshXray()
    task.spawn(function()
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and not IsPlayer(v) then
                local n = v.Name:lower()
                if n:find("wall") or n:find("base") or n:find("door") or n:find("floor") or n:find("part") then
                    v.LocalTransparencyModifier = _G.GH_Config.Xray_GH and 0.6 or 0
                end
            end
        end
    end)
end

-- [[ MESIN 3: ESP PLAYER ]] --
local function CreatePlayerESP(p)
    task.spawn(function()
        while p and p.Parent do
            if _G.GH_Config.ESP_Player_GH and p ~= lp and p.Character and p.Character:FindFirstChild("Head") then
                local head = p.Character.Head
                if not head:FindFirstChild("ESP_PlayerTag") then
                    local bg = Instance.new("BillboardGui", head); bg.Name = "ESP_PlayerTag"; bg.AlwaysOnTop = true; bg.Size = UDim2.new(0, 200, 0, 50); bg.ExtentsOffset = Vector3.new(0, 3, 0)
                    local lbl = Instance.new("TextLabel", bg); lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1; lbl.TextColor3 = Color3.fromRGB(0, 255, 255); lbl.Text = p.Name; lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 14; lbl.TextStrokeTransparency = 0.5
                end
            else
                if p.Character and p.Character:FindFirstChild("Head") and p.Character.Head:FindFirstChild("ESP_PlayerTag") then
                    p.Character.Head.ESP_PlayerTag:Destroy()
                end
            end
            task.wait(1)
        end
    end)
end

-- [[ MESIN 4: ESP EGG (WHITELIST) ]] --
local function TagEgg(v)
    if not _G.GH_Config.ESP_Egg_GH then return end
    local n = v.Name:lower()
    for _, name in ipairs(AllowedEggs) do
        if n:find(name) and not v:FindFirstChild("EHSTag") then
            local t = v:IsA("Model") and (v:FindFirstChild("Handle") or v:FindFirstChildWhichIsA("BasePart")) or v
            if t then
                local bg = Instance.new("BillboardGui", t); bg.Name = "EHSTag"; bg.AlwaysOnTop = true; bg.Size = UDim2.new(0, 160, 0, 40)
                local lbl = Instance.new("TextLabel", bg); lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1; lbl.Text = v.Name; lbl.TextColor3 = Color3.fromRGB(255, 200, 0); lbl.Font = Enum.Font.GothamBlack; lbl.TextSize = 13
            end
        end
    end
end


-- Tombol Toggle (ON/OFF)
local function CreateToggle(parent, txt, var)
    local b = Instance.new("TextButton", parent)
    b.Size = UDim2.new(0.95, 0, 0, 40)
    b.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
    b.Font = Enum.Font.GothamBold
    b.Text = txt..": OFF"
    b.TextColor3 = Color3.fromRGB(255, 0, 0)
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function() 
        _G.GH_Config[var] = not _G.GH_Config[var]
        b.Text = txt..(_G.GH_Config[var] and ": ON" or ": OFF")
        b.TextColor3 = _G.GH_Config[var] and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
    end)
end


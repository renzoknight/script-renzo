-- [[ GURITA HUB V31 - POST-EVENT SPECIALIST ]] --
local lp = game.Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local HttpService = game:GetService("HttpService")

-- 1. SAVE/LOAD SYSTEM
local FileName = "GuritaHubConfig.json"
local function LoadSettings()
    if isfile and isfile(FileName) then
        local s, res = pcall(function() return HttpService:JSONDecode(readfile(FileName)) end)
        if s then return res end
    end
    return { HuntingMode = false, NotifActive = true }
end

local function SaveSettings()
    if writefile then
        pcall(function()
            writefile(FileName, HttpService:JSONEncode({
                HuntingMode = _G.HuntingMode,
                NotifActive = _G.NotifActive
            }))
        end)
    end
end

local SavedData = LoadSettings()
_G.HuntingMode = SavedData.HuntingMode
_G.NotifActive = SavedData.NotifActive

-- 2. TARGETS & LOGGING (Persiapan Pasca Event)
local NotifHistory = {}
local RareLog = {} -- Menyimpan riwayat rare yang muncul
local SuperRare = {"hydra bunny", "no my egg", "baskito", "churrito bunnito", "hopilikalika", "quackini"}
local NormalTargets = {"bunny bunny sahur", "sky egg", "bunny egg", "snackini"}
local Blacklist = {"brainrot", "npc", "base", "pedestal", "shop", "harp"}

-- 3. NOTIFIKASI SYSTEM (SLIDE & SOUND)
local function PlayAlert()
    if not _G.NotifActive then return end
    local s = Instance.new("Sound", workspace)
    s.SoundId = "rbxassetid://4590662766"; s.Volume = 1; s:Play()
    s.Ended:Connect(function() s:Destroy() end)
end

local function KirimNotifRare(obj)
    if NotifHistory[obj] or not _G.NotifActive then return end
    NotifHistory[obj] = true 
    table.insert(RareLog, 1, obj.Name .. " [" .. os.date("%X") .. "]") -- Simpan ke riwayat

    local sg = Instance.new("ScreenGui", PlayerGui)
    local f = Instance.new("Frame", sg)
    f.Size = UDim2.new(0, 280, 0, 70); f.Position = UDim2.new(1, 50, 0.8, 0)
    f.BackgroundColor3 = Color3.fromRGB(15, 0, 0); Instance.new("UICorner", f)
    
    local t1 = Instance.new("TextLabel", f)
    t1.Size = UDim2.new(1, -20, 0, 30); t1.Position = UDim2.new(0, 15, 0.1, 0)
    t1.Text = "RARE DETECTED!"; t1.TextColor3 = Color3.new(1, 1, 1); t1.Font = "GothamBold"; t1.TextSize = 14; t1.BackgroundTransparency = 1; t1.TextXAlignment = "Left"

    local t2 = Instance.new("TextLabel", f)
    t2.Size = UDim2.new(1, -20, 0, 30); t2.Position = UDim2.new(0, 15, 0.5, 0)
    t2.Text = obj.Name:upper(); t2.TextColor3 = Color3.new(1, 0, 0); t2.Font = "GothamBold"; t2.TextSize = 16; t2.BackgroundTransparency = 1; t2.TextXAlignment = "Left"

    PlayAlert()
    f:TweenPosition(UDim2.new(1, -300, 0.8, 0), "Out", "Back", 0.5)
    task.delay(4, function()
        if f then f:TweenPosition(UDim2.new(1, 50, 0.8, 0), "In", "Quad", 0.5) end
        task.wait(0.6); sg:Destroy()
    end)
end

-- 4. ESP & DETECTOR (Tanpa Flat Color)
local function CekTarget(n)
    n = n:lower()
    for _, b in pairs(Blacklist) do if n:find(b) then return false end end
    for _, r in pairs(SuperRare) do return "rare" if n:find(r) end end
    for _, e in pairs(NormalTargets) do return "normal" if n:find(e) end end
    return false
end

local function PasangESP(obj)
    if obj:FindFirstChild("GuritaTag") then return end
    pcall(function()
        local pos = obj:IsA("Model") and obj:GetModelCFrame().p or obj.Position
        if pos.Y < 100 then return end
        
        local tipe = CekTarget(obj.Name)
        if not tipe then return end
        if tipe == "rare" then KirimNotifRare(obj) end

        local col = (tipe == "rare") and Color3.new(1, 0, 0) or Color3.fromRGB(0, 170, 255)
        local b = Instance.new("BillboardGui", obj)
        b.Name = "GuritaTag"; b.Size = UDim2.new(0, 200, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 8, 0)
        
        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = col
        t.Font = "GothamBlack"; t.TextSize = 20; t.TextStrokeTransparency = 0

        task.spawn(function()
            while obj and obj.Parent and _G.HuntingMode do
                local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local p = obj:IsA("Model") and obj:GetModelCFrame().p or obj.Position
                    t.Text = obj.Name:upper() .. "\n[" .. math.floor((hrp.Position - p).Magnitude) .. "s]"
                end
                task.wait(1)
            end
            if b then b:Destroy() end; NotifHistory[obj] = nil
        end)
    end)
end

-- 5. UI MENU (G)
if PlayerGui:FindFirstChild("GuritaHubUI") then PlayerGui.GuritaHubUI:Destroy() end
local SG = Instance.new("ScreenGui", PlayerGui); SG.Name = "GuritaHubUI"; SG.ResetOnSpawn = false

local Toggle = Instance.new("TextButton", SG)
Toggle.Size = UDim2.new(0, 80, 0, 80); Toggle.Position = UDim2.new(0, 20, 0.4, 0)
Toggle.BackgroundColor3 = Color3.fromRGB(0, 170, 255); Toggle.Text = "G"; Toggle.TextColor3 = Color3.new(1,1,1); Toggle.Font = "GothamBlack"; Toggle.TextSize = 40; Instance.new("UICorner", Toggle).CornerRadius = UDim.new(0, 20)

local Main = Instance.new("Frame", SG)
Main.Size = UDim2.new(0, 300, 0, 250); Main.Position = UDim2.new(0.5, -150, 0.5, -125); Main.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Main.Visible = false; Instance.new("UICorner", Main)

local function CreateBtn(txt, pos, color)
    local b = Instance.new("TextButton", Main)
    b.Size = UDim2.new(0, 260, 0, 70); b.Position = pos; b.BackgroundColor3 = color; b.Text = txt; b.Font = "GothamBold"; b.TextColor3 = Color3.new(1,1,1); b.TextSize = 18; Instance.new("UICorner", b)
    return b
end

local BtnHunt = CreateBtn("HUNTING: OFF", UDim2.new(0, 20, 0, 40), Color3.fromRGB(150, 0, 0))
local BtnNotif = CreateBtn("NOTIF: ON", UDim2.new(0, 20, 0, 130), Color3.fromRGB(0, 120, 200))

local function UpdateUI()
    BtnHunt.Text = _G.HuntingMode and "HUNTING: ON" or "HUNTING: OFF"
    BtnHunt.BackgroundColor3 = _G.HuntingMode and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
    BtnNotif.Text = _G.NotifActive and "NOTIF: ON" or "NOTIF: OFF"
    BtnNotif.BackgroundColor3 = _G.NotifActive and Color3.fromRGB(0, 120, 200) or Color3.fromRGB(80, 80, 80)
end

UpdateUI()
Toggle.MouseButton1Down:Connect(function() Main.Visible = not Main.Visible end)

BtnHunt.MouseButton1Down:Connect(function()
    _G.HuntingMode = not _G.HuntingMode
    UpdateUI(); SaveSettings()
    if _G.HuntingMode then
        for _, v in pairs(workspace:GetDescendants()) do if CekTarget(v.Name) then PasangESP(v) end end
    end
end)

BtnNotif.MouseButton1Down:Connect(function()
    _G.NotifActive = not _G.NotifActive
    UpdateUI(); SaveSettings()
end)

-- 6. EXECUTION
if _G.HuntingMode then
    task.spawn(function()
        for _, v in pairs(workspace:GetDescendants()) do if CekTarget(v.Name) then PasangESP(v) end end
    end)
end

workspace.DescendantAdded:Connect(function(v)
    if _G.HuntingMode and CekTarget(v.Name) then task.wait(1.5); PasangESP(v) end
end)

-- [[ FUNGSI FLAT COLOR PERMANEN & OTOMATIS ]] --
local function MakeFlat(char)
    -- Pastikan karakter ada
    if not char then return end
    
    -- Tunggu sebentar sampai part karakter muncul
    task.wait(0.5)
    
    -- Cari semua bagian tubuh (Part) pemain
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then
            -- Menerapkan Flat Color
            v.Material = Enum.Material.SmoothPlastic -- Membuat tekstur rata/flat
            v.Color = Color3.fromRGB(0, 255, 127) -- Warna hijau flat yang soft (tidak mencolok)
            
            -- Menambahkan Highlight tipis (ESP) agar permanen tembus pandang
            if not char:FindFirstChild("GuritaVisual") then
                local highlight = Instance.new("Highlight")
                highlight.Name = "GuritaVisual"
                highlight.Parent = char
                highlight.FillColor = Color3.fromRGB(0, 255, 127)
                highlight.FillTransparency = 0.7 -- Transparan agar halus
                highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                highlight.OutlineTransparency = 0.5
                highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            end
        end
    end
end

-- Otomatis jalan untuk semua pemain yang masuk
local function OnPlayerAdded(player)
    if player ~= LocalPlayer then
        player.CharacterAdded:Connect(function(char)
            MakeFlat(char)
        end)
        if player.Character then
            MakeFlat(player.Character)
        end
    end
end

-- Menjalankan fungsi otomatis saat script di-execute
for _, player in pairs(Players:GetPlayers()) do
    OnPlayerAdded(player)
end
Players.PlayerAdded:Connect(OnPlayerAdded)


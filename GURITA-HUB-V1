-- [[ 2. FIXED FLAT COLOR ENGINE (FORCED APPEARANCE) ]] --
local function ApplyUltimateFlat()
    -- 1. Lighting Setup
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.Brightness = 2
    Lighting.ClockTime = 12
    Lighting.Ambient = Color3.fromRGB(150, 150, 150)
    Lighting.OutdoorAmbient = Color3.fromRGB(150, 150, 150)

    -- 2. Performance & Visual Nuke
    local settings = settings()
    settings.Rendering.QualityLevel = 1
    
    -- 3. Material & Texture Cleanup (Pemicu Flat Color)
    local function Clean(v)
        if v:IsA("BasePart") then
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v.Transparency = 1 -- Sembunyikan tekstur/gambar di tembok/lantai
        end
    end

    for _, v in pairs(workspace:GetDescendants()) do Clean(v) end
    workspace.DescendantAdded:Connect(Clean) -- Biar part baru tetep flat
end

pcall(ApplyUltimateFlat)


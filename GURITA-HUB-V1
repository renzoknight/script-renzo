local function CreateToggle(txt, var, callback)
    local b = Instance.new("TextButton", List); b.Size = UDim2.new(1, 0, 0, 45); b.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    local function Upd()
        b.Text = txt..(_G.GH_Settings[var] and ": ON" or ": OFF")
        b.TextColor3 = _G.GH_Settings[var] and Color3.fromRGB(0, 255, 127) or Color3.fromRGB(255, 80, 80)
    end
    Upd()
    b.MouseButton1Click:Connect(function() _G.GH_Settings[var] = not _G.GH_Settings[var]; Upd(); SaveConfig(); if callback then callback() end end)
    Instance.new("UICorner", b)
end


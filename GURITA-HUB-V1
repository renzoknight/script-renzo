-- [[ GURITA HUB: FINAL AUTO-EXECUTE (ULTRA OPTIMIZED) ]] --
-- Perintah Khusus: Anti-Lag, Auto-On, Flat Color, Hunt Egg

-- [[ 1. ANTI-LAG BOOSTER (EXECUTOR OPTIMIZATION) ]] --
pcall(function()
    if setfpscap then setfpscap(60) end -- Stabilkan FPS
    settings().Physics.PhysicsEnvironmentalThrottle = Enum.EnviromentalPhysicsThrottle.Default
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 -- Paksa render terendah biar enteng
end)

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local StarterGui = game:GetService("StarterGui")

-- [[ 2. CONFIG & AUTO-ON SETTINGS ]] --
local TargetEggs = {
    "hydra bunny", "noo my eggs", "baskito", "churrito", 
    "quackini", "snackini", "bunny bunny sahur"
}

local NotifiedEggs = {} 
_G.FlatActive = true    
_G.HuntEggActive = true 
_G.HuntNotif = true    

-- [[ 3. ENGINE FLAT COLOR (V38 RE-LOGIC - NO LAG) ]] --
local function SikatPart(v)
    if v:IsDescendantOf(PlayerGui) then return end
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character and v:IsDescendantOf(p.Character) then return end
    end

    pcall(function()
        if v:IsA("BasePart") then
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            v.Reflectance = 0
            if v:IsA("MeshPart") then v.TextureID = "" end
            local sa = v:FindFirstChildOfClass("SurfaceAppearance")
            if sa then sa:Destroy() end
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v:Destroy()
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- Fungsi nyisir map dengan jeda extra biar gak lag
local function RunFlatColor()
    local all = workspace:GetDescendants()
    local count = 0
    for _, v in pairs(all) do
        if not _G.FlatActive then break end
        SikatPart(v)
        count = count + 1
        if count >= 50 then -- Tiap 50 part istirahat, biar executor napas
            count = 0
            task.wait() 
        end
    end
end

-- [[ 4. ENGINE HUNT EGG & ESP ]] --
local function ApplyHuntESP(obj)
    if obj:FindFirstChild("HuntMarker") then obj.HuntMarker:Destroy() end
    if obj:FindFirstChild("HuntTag") then obj.HuntTag:Destroy() end

    local h = Instance.new("Highlight", obj)
    h.Name = "HuntMarker"; h.FillColor = Color3.fromRGB(255, 255, 0); h.FillTransparency = 0.4
    
    local b = Instance.new("BillboardGui", obj)
    b.Name = "HuntTag"; b.Size = UDim2.new(0, 150, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 3, 0)
    
    local t = Instance.new("TextLabel", b)
    t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = Color3.new(1, 1, 0); t.Font = Enum.Font.GothamBlack; t.TextSize = 14; t.TextStrokeTransparency = 0

    task.spawn(function()
        while obj and obj.Parent and _G.HuntEggActive do
            if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                t.Text = "✨ " .. obj.Name:upper() .. " ✨\n[" .. math.floor((obj.Position - lp.Character.HumanoidRootPart.Position).Magnitude) .. "m]"
            end
            task.wait(0.5)
        end
        if b then b:Destroy() end; if h then h:Destroy() end
    end)
end

local function ScanHunt()
    local all = workspace:GetDescendants()
    for i, v in pairs(all) do
        local name = v.Name:lower()
        if table.find(TargetEggs, name) then
            if _G.HuntEggActive then ApplyHuntESP(v) end
            if _G.HuntNotif and not NotifiedEggs[v] then
                NotifiedEggs[v] = true
                StarterGui:SetCore("SendNotification", {Title = "🥚 EGG FOUND!", Text = v.Name:upper(), Duration = 5})
                local s = Instance.new("Sound", game:GetService("SoundService")); s.SoundId = "rbxassetid://4590662762"; s:Play()
                v.AncestryChanged:Connect(function(_, p) if not p then NotifiedEggs[v] = nil end end)
            end
        end
        if i % 150 == 0 then task.wait() end -- Scan telor juga dibikin enteng
    end
end

-- [[ 5. RUNTIME & AUTO-EXECUTE ]] --
workspace.DescendantAdded:Connect(function(v)
    if _G.FlatActive then task.wait(0.1); SikatPart(v) end
    if table.find(TargetEggs, v.Name:lower()) then
        if _G.HuntEggActive then ApplyHuntESP(v) end
    end
end)

-- Langsung Eksekusi Begitu Inject
task.spawn(RunFlatColor)
task.spawn(function()
    while true do
        if _G.HuntEggActive then ScanHunt() end
        task.wait(10)
    end
end)


-- --- 6. FITUR ESP (Easter Event) ---
local EasterUnits = {"Hydra Bunny", "Hopilikalika Hopilikalako", "Churrito Bunnito", "Baskito", "Los Bunitos", "Easter Easter Easter Sahur", "Eggdin Egg Egg Dun", "Bunny Tralala", "Buntteo", "Bunny Bunny Bunny Sahur", "Noo my Eggs"}
local ESP_Active = false

local function MakeESP(part, name)
    if part:FindFirstChild("GH_ESP") then return end
    local b = Instance.new("BillboardGui", part)
    b.Name = "GH_ESP"
    b.AlwaysOnTop = true
    b.Size = UDim2.new(0, 100, 0, 50)
    local t = Instance.new("TextLabel", b)
    t.BackgroundTransparency = 1
    t.Size = UDim2.new(1, 0, 1, 0)
    t.Text = name .. " GH"
    t.TextColor3 = Color3.fromRGB(255, 255, 0)
    t.Font = Enum.Font.GothamBold
    t.TextSize = 12
end

task.spawn(function()
    while task.wait(1) do
        if ESP_Active then
            for _, o in pairs(workspace:GetDescendants()) do
                for _, e in pairs(EasterUnits) do
                    if o.Name == e and (o:IsA("BasePart") or o:IsA("Model")) then
                        local target = o:IsA("Model") and o.PrimaryPart or o
                        if target then MakeESP(target, e) end
                    end
                end
            end
        else
            for _, v in pairs(workspace:GetDescendants()) do if v.Name == "GH_ESP" then v:Destroy() end end
        end
    end
end)


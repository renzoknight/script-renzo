-- [[ 2. ENGINE ESP (ANTI-LAG) ]] --
local function ApplyESP(obj)
    if not obj:FindFirstChild("EGG_TAG") then
        -- Highlight Glow
        local h = Instance.new("Highlight", obj)
        h.Name = "EGG_TAG"
        h.FillColor = Color3.fromRGB(255, 255, 0)
        h.OutlineColor = Color3.fromRGB(255, 255, 255)
        h.FillTransparency = 0.5

        -- Nama Tembus Tembok
        local b = Instance.new("BillboardGui", obj)
        b.Name = "EGG_NAME"
        b.Size = UDim2.new(0, 150, 0, 50)
        b.AlwaysOnTop = true
        b.ExtentsOffset = Vector3.new(0, 3, 0)

        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0)
        t.BackgroundTransparency = 1
        t.Text = obj.Name:upper()
        t.TextColor3 = Color3.fromRGB(255, 255, 255)
        t.Font = Enum.Font.GothamBlack
        t.TextSize = 14
        t.TextStrokeTransparency = 0
    end
end

local function RemoveESP()
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "EGG_TAG" or v.Name == "EGG_NAME" then
            v:Destroy()
        end
    end
end

local function UpdateESP()
    if not _G.EggESP_Active then 
        RemoveESP()
        return 
    end
    
    local count = 0
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and table.find(TargetEggs, v.Name:lower()) then
            ApplyESP(v)
            count = count + 1
            if count % 50 == 0 then task.wait() end -- Anti-Lag
        end
    end
end


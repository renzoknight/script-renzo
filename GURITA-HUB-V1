-- --- LOGIKA ANIMASI WARNA NEON ---
-- Daftar warna yang akan berganti (Biru, Oranye, Kuning, Ungu)
local colors = {
    Color3.fromRGB(0, 150, 255),  -- Biru Neon
    Color3.fromRGB(255, 100, 0),  -- Oranye Neon
    Color3.fromRGB(255, 200, 0),  -- Kuning Neon
    Color3.fromRGB(150, 0, 255)   -- Ungu Neon
}

local colorIndex = 1
local nextColorIndex = 2
local transitionTime = 2 -- Waktu perpindahan antar warna (detik)
local currentTime = 0

-- Menjalankan animasi setiap frame
RunService.Heartbeat:Connect(function(dt)
    currentTime = currentTime + dt
    local percent = currentTime / transitionTime

    -- Ambil warna saat ini dan warna tujuan
    local startColor = colors[colorIndex]
    local endColor = colors[nextColorIndex]

    -- Lakukan transisi warna secara halus (Lerp)
    UIStroke.Color = startColor:Lerp(endColor, percent)

    -- Jika transisi selesai, ganti ke warna berikutnya
    if percent >= 1 then
        currentTime = 0
        colorIndex = nextColorIndex
        nextColorIndex = nextColorIndex + 1
        
        -- Reset loop warna jika sudah sampai ujung
        if nextColorIndex > #colors then
            nextColorIndex = 1
        end
    end
end)

-- Tombol ESP untuk aktivasi/deaktivasi (Tombol toggle sederhana)

-- 1. DATABASE & CONFIG
local ConfigFile = "GHS_Config_Final.json"
_G.GH_Config = {
    ESP_Player_GH = false,
    Xray_GH = false,
    AutoCollect_GH = false,
    ESP_Egg_GH = false
}

local function SaveData()
    pcall(function() if writefile then writefile(ConfigFile, HttpService:JSONEncode(_G.GH_Config)) end end)
end

local function LoadData()
    pcall(function()
        if isfile and isfile(ConfigFile) then
            local decoded = HttpService:JSONDecode(readfile(ConfigFile))
            if decoded then for k, v in pairs(decoded) do _G.GH_Config[k] = v end end
        end
    end)
end
LoadData()

-- [[ FUNGSI FLAT COLOR ]] --
local function IsPlayer(v) return v:IsDescendantOf(lp.Character) or (v.Parent and v.Parent:FindFirstChild("Humanoid")) end

local function ApplyFlat(v)
    pcall(function()
        if (v:IsA("BasePart") or v:IsA("MeshPart")) and not IsPlayer(v) then
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
            for _, tex in pairs(v:GetChildren()) do 
                if tex:IsA("Texture") or tex:IsA("Decal") then tex:Destroy() end 
            end
        end
    end)
end

local function RefreshXray()
    task.spawn(function()
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and not IsPlayer(v) then
                local n = v.Name:lower()
                if n:find("wall") or n:find("base") or n:find("door") or n:find("floor") or n:find("part") then
                    v.LocalTransparencyModifier = _G.GH_Config.Xray_GH and 0.6 or 0
                end
            end
        end
    end)
end


-- [[ FLAT COLOR TESTER - FULL AUTOMATIC ]] --
-- Sifat: Langsung Aktif, Tanpa Menu, Anti-Lag

print("GURITA HUB: Memulai Uji Coba Flat Color...")

-- 1. Fungsi Utama Flat Color
local function SikatJadiFlat(v)
    pcall(function()
        if v:IsA("BasePart") and not v.Parent:FindFirstChild("Humanoid") then
            -- Ubah ke material teringan
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            
            -- Hapus tekstur & decal
            if v:IsA("MeshPart") then v.TextureID = "" end
            for _, anak in pairs(v:GetChildren()) do 
                if anak:IsA("Texture") or anak:IsA("Decal") then 
                    anak:Destroy() 
                end 
            end
        end
    end)
end

-- 2. Proses Scan Map Awal (Dibuat Bertahap Biar Gak Lag)
task.spawn(function()
    local semuaObjek = workspace:GetDescendants()
    for i, obj in pairs(semuaObjek) do
        SikatJadiFlat(obj)
        
        -- Anti-Lag: Berhenti sebentar setiap 100 objek
        if i % 100 == 0 then 
            task.wait() 
        end
    end
    print("GURITA HUB: Scan Map Awal Selesai.")
end)

-- 3. Deteksi Otomatis Benda Baru (Biar Gak Gagal)
workspace.DescendantAdded:Connect(function(bendaBaru)
    task.wait(0.5) -- Jeda biar objek ke-load sempurna
    SikatJadiFlat(bendaBaru)
end)

-- 4. Re-Scan Berkala (Setiap 15 Detik)
-- Biar kalau ada yang membandel, otomatis disikat lagi
task.spawn(function()
    while true do
        task.wait(15)
        local objekSekarang = workspace:GetDescendants()
        for i, obj in pairs(objekSekarang) do
            if obj:IsA("BasePart") and obj.Material ~= Enum.Material.Plastic then
                SikatJadiFlat(obj)
            end
            if i % 200 == 0 then task.wait() end
        end
    end
end)

-- [[ GURITA HUB V30 - SAVE DATA + FLAT COLOR FIX ]] --
local lp = game.Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local HttpService = game:GetService("HttpService")

-- 1. SISTEM SAVE DATA (GuritaHubConfig.json)
local FileName = "GuritaHubConfig.json"
local DefaultConfig = { HuntingMode = false, NotifActive = true }

local function LoadSettings()
    if isfile and isfile(FileName) then
        local s, res = pcall(function() return HttpService:JSONDecode(readfile(FileName)) end)
        if s and res then return res end
    end
    return DefaultConfig
end

local function SaveSettings()
    if writefile then
        pcall(function()
            writefile(FileName, HttpService:JSONEncode({
                HuntingMode = _G.HuntingMode,
                NotifActive = _G.NotifActive
            }))
        end)
    end
end

-- AKTIFKAN SETTINGAN AWAL
local SavedData = LoadSettings()
_G.HuntingMode = SavedData.HuntingMode
_G.NotifActive = SavedData.NotifActive

-- 2. DAFTAR TARGET & BLACKLIST
local NotifHistory = {}
local SuperRare = {"hydra bunny", "no my egg", "baskito", "churrito bunnito", "hopilikalika", "quackini"}
local NormalTargets = {"bunny bunny sahur", "sky egg", "bunny egg", "snackini"}
local Blacklist = {"brainrot", "npc", "base", "pedestal", "shop", "harp"}

-- 3. FITUR FLAT COLOR & PERFORMANCE (DIJAMIN JALAN)
local function ApplyPerformance()
    settings().Rendering.QualityLevel = 1
    game:GetService("Lighting").GlobalShadows = false
    
    -- MENGHAPUS MATERIAL/TEXTURE BIAR POLOS (FLAT COLOR)
    pcall(function()
        local ms = game:GetService("MaterialService")
        ms.Use2022Materials = false
        for _, v in pairs(ms:GetChildren()) do
            v:Destroy()
        end
    end)
    
    -- OPTIMASI LIGHTING BIAR RINGAN
    local light = game:GetService("Lighting")
    light.Brightness = 2
    light.FogEnd = 100000
end

-- 4. FUNGSI ALARM & NOTIFIKASI
local function PlayAlert()
    if not _G.NotifActive then return end
    local s = Instance.new("Sound", workspace)
    s.SoundId = "rbxassetid://4590662766"; s.Volume = 1; s:Play()
    s.Ended:Connect(function() s:Destroy() end)
end

local function KirimNotifRare(obj)
    if NotifHistory[obj] or not _G.NotifActive then return end
    NotifHistory[obj] = true 
    
    local col = Color3.new(1, 0, 0)
    local sg = Instance.new("ScreenGui", PlayerGui)
    local f = Instance.new("Frame", sg)
    f.Size = UDim2.new(0, 280, 0, 70); f.Position = UDim2.new(1, 50, 0.8, 0)
    f.BackgroundColor3 = Color3.fromRGB(10, 10, 10); Instance.new("UICorner", f)
    
    local line = Instance.new("Frame", f)
    line.Size = UDim2.new(0, 5, 1, 0); line.BackgroundColor3 = col; Instance.new("UICorner", line)

    local t1 = Instance.new("TextLabel", f)
    t1.Size = UDim2.new(0, 200, 0, 20); t1.Position = UDim2.new(0, 50, 0.25, 0)
    t1.Text = "RARE TARGET DETECTED!"; t1.TextColor3 = Color3.new(1, 1, 1); t1.Font = Enum.Font.GothamBold; t1.TextSize = 13; t1.BackgroundTransparency = 1; t1.TextXAlignment = "Left"

    local t2 = Instance.new("TextLabel", f)
    t2.Size = UDim2.new(0, 200, 0, 20); t2.Position = UDim2.new(0, 50, 0.55, 0)
    t2.Text = "New: " .. obj.Name:upper(); t2.TextColor3 = col; t2.Font = Enum.Font.GothamBold; t2.TextSize = 15; t2.BackgroundTransparency = 1; t2.TextXAlignment = "Left"

    PlayAlert()
    f:TweenPosition(UDim2.new(1, -300, 0.8, 0), "Out", "Quart", 0.5)
    task.delay(5, function()
        if f then f:TweenPosition(UDim2.new(1, 50, 0.8, 0), "In", "Quart", 0.5) end
        task.wait(0.6); sg:Destroy()
    end)
end

-- 5. LOGIKA FILTER & ESP
local function CekTarget(n)
    n = n:lower()
    for _, b in pairs(Blacklist) do if n:find(b) then return false end end
    for _, r in pairs(SuperRare) do if n:find(r) then return "rare" end end
    for _, e in pairs(NormalTargets) do if n:find(e) then return "normal" end end
    return false
end

local function PasangESP(obj)
    if obj:FindFirstChild("GuritaTag") then return end
    pcall(function()
        local pos = obj:IsA("Model") and obj:GetModelCFrame().p or obj.Position
        if pos.Y < 100 then return end
        
        local tipe = CekTarget(obj.Name)
        if not tipe then return end
        
        local col = (tipe == "rare") and Color3.new(1, 0, 0) or Color3.fromRGB(0, 170, 255)
        if tipe == "rare" then KirimNotifRare(obj) end

        local b = Instance.new("BillboardGui", obj)
        b.Name = "GuritaTag"; b.Size = UDim2.new(0, 200, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 8, 0)
        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = col
        t.Font = Enum.Font.GothamBlack; t.TextSize = 20; t.TextStrokeTransparency = 0
        
        task.spawn(function()
            while obj and obj.Parent and _G.HuntingMode do
                local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local p = obj:IsA("Model") and obj:GetModelCFrame().p or obj.Position
                    t.Text = obj.Name:upper() .. "\n[" .. math.floor((hrp.Position - p).Magnitude) .. " STUDS]"
                end
                task.wait(1)
            end
            if b then b:Destroy() end; NotifHistory[obj] = nil
        end)
    end)
end


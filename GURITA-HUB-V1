local BtnESP = CreateBtn("ESP EGG: OFF", 0.3)
local BtnNotif = CreateBtn("NOTIF: ON", 0.6)

local function Refresh()
    BtnESP.Text = _G.EggESP_Master and "ESP EGG: ON" or "ESP EGG: OFF"; BtnESP.TextColor3 = _G.EggESP_Master and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
    BtnNotif.Text = _G.Notif_Master and "NOTIF: ON" or "NOTIF: OFF"; BtnNotif.TextColor3 = _G.Notif_Master and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
end
Refresh()

BtnESP.MouseButton1Click:Connect(function() 
    _G.EggESP_Master = not _G.EggESP_Master; Refresh() 
    if not _G.EggESP_Master then for _, v in pairs(workspace:GetDescendants()) do if v.Name == "Marker" or v.Name == "Tag" then v:Destroy() end end end
end)
BtnNotif.MouseButton1Click:Connect(function() _G.Notif_Master = not _G.Notif_Master; Refresh() end)

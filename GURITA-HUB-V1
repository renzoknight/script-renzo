-- [[ GURITA HUB: ULTIMATE FLAT COLOR ENGINE - V37 ]] --
-- Fokus: Brute Force Map Texture & Lighting

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local Lighting = game:GetService("Lighting")

-- [[ 1. THE BRUTE FORCE ENGINE ]] --
local function SikatTotal(v)
    -- PROTEKSI: Jangan sentuh Karakter/Ava
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character and v:IsDescendantOf(p.Character) then return end
    end
    
    -- PROTEKSI: Jangan sentuh UI
    if v:IsDescendantOf(PlayerGui) or v:IsA("ScreenGui") then return end

    pcall(function()
        if v:IsA("BasePart") then
            -- Paksa material ke Plastic
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            v.Reflectance = 0
            
            -- Hapus Tekstur Mesh
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
            
            -- Hapus SurfaceAppearance (Penyebab map gak mau polos)
            local sa = v:FindFirstChildOfClass("SurfaceAppearance")
            if sa then sa:Destroy() end
            
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v:Destroy()
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- Fungsi Nuke Lighting (Biar warna map makin flat/polos)
local function NukeLighting()
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.Brightness = 2
    Lighting.ClockTime = 12
    Lighting.OutdoorAmbient = Color3.fromRGB(200, 200, 200)
    
    -- Hapus efek-efek yang bikin berat & bertekstur
    for _, v in pairs(Lighting:GetChildren()) do
        if v:IsA("PostEffect") or v:IsA("Atmosphere") or v:IsA("Clouds") then
            v:Destroy()
        end
    end
end

-- Variabel Control
_G.FlatActive = false

-- Loop Eksekusi
task.spawn(function()
    while true do
        if _G.FlatActive then
            NukeLighting()
            local all = workspace:GetDescendants()
            for i, v in pairs(all) do
                if not _G.FlatActive then break end
                SikatTotal(v)
                -- Anti Lag: Proses 500 part baru istirahat sekejap
                if i % 500 == 0 then task.wait() end 
            end
        end
        task.wait(5) -- Ulangi tiap 5 detik buat pastiin area baru tetep flat
    end
end)


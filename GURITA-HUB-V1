-- [[ GURITA HUB - CORE ESP EGG HUNT V1 ]] --
-- LIST FIX: Hydra Bunny, Noo My Eggs, Baskito, Churrito, Quackini Snackini, Hopilikalika, Bunny Sahur

local TargetEggs = {
    "hydra bunny", 
    "noo my eggs", 
    "baskito", 
    "churrito", 
    "quackini snackini", 
    "hopilikalika hopilikalako", 
    "bunny sahur"
}

-- [[ 1. FUNGSI PENANDA (HIGHLIGHT & TEXT) ]] --
local function ApplyEggESP(obj)
    -- Pastikan tidak double ESP
    if obj:FindFirstChild("EGG_MARKER") then return end

    -- A. Highlight (Biar telurnya nyala)
    local h = Instance.new("Highlight")
    h.Name = "EGG_MARKER"
    h.Parent = obj
    h.FillColor = Color3.fromRGB(255, 255, 0) -- Kuning Terang
    h.FillTransparency = 0.4
    h.OutlineColor = Color3.fromRGB(255, 255, 255) -- Garis Putih

    -- B. BillboardGui (Biar nama tembus tembok)
    local bg = Instance.new("BillboardGui")
    bg.Name = "EGG_NAME"
    bg.Parent = obj
    bg.AlwaysOnTop = true
    bg.Size = UDim2.new(0, 200, 0, 50)
    bg.ExtentsOffset = Vector3.new(0, 3, 0)

    local tl = Instance.new("TextLabel")
    tl.Parent = bg
    tl.Size = UDim2.new(1, 0, 1, 0)
    tl.BackgroundTransparency = 1
    tl.Text = obj.Name:upper()
    tl.TextColor3 = Color3.fromRGB(255, 255, 255)
    tl.TextStrokeTransparency = 0
    tl.Font = Enum.Font.GothamBlack
    tl.TextSize = 16
end

-- [[ 2. SISTEM SCANNING (ANTI-LAG) ]] --
local function ScanForEggs()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") or v:IsA("Model") then
            if table.find(TargetEggs, v.Name:lower()) then
                ApplyEggESP(v)
            end
        end
        -- Jeda dikit biar gak freeze pas scan map gede
        if _ % 100 == 0 then task.wait() end
    end
end

-- [[ 3. OTOMATISASI ]] --
-- Sikat telur yang sudah ada
task.spawn(ScanForEggs)

-- Sikat telur yang baru muncul (spawn)
workspace.DescendantAdded:Connect(function(newObj)
    task.wait(0.5) -- Tunggu bentar biar ke-load sempurna
    if table.find(TargetEggs, newObj.Name:lower()) then
        ApplyEggESP(newObj)
    end
end)

print("ESP EGG HUNT AKTIF: Mencari target...")

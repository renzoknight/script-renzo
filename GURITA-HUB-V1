-- [[ FITUR FLAT COLOR: PLASTIC ONLY ]] --
local function ApplyFlat(v)
    pcall(function()
        if (v:IsA("BasePart") or v:IsA("MeshPart")) and not (v.Parent:FindFirstChild("Humanoid") or v:IsDescendantOf(lp.Character)) then
            v.Material = Enum.Material.Plastic -- Bikin jadi plastik polos
            v.CastShadow = false -- Hilangkan bayangan biar FPS naik
            if v:IsA("MeshPart") then v.TextureID = "" end -- Hapus tekstur mesh
            for _, child in pairs(v:GetChildren()) do
                if child:IsA("Texture") or child:IsA("Decal") then child:Destroy() end -- Hapus stiker/decal
            end
        end
    end)
end


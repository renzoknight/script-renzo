-- 2. KONFIGURASI & AUTO SAVE
local filename = "GURITA_HUB_MANUAL_CONFIG.json"
_G.GH_Settings = {
    EggrotHunt_GH = false, -- SEKARANG MANUAL OFF
    ESP_Player_GH = false, -- MANUAL OFF
    XrayBase_GH = false,   -- MANUAL OFF
    AutoCollect_GH = false, -- MANUAL OFF
    FlatColor_GH = true,   -- TETAP AUTO ON
    NotifSound_GH = true   -- TETAP AUTO ON
}

local function SaveConfig()
    pcall(function() if writefile then writefile(filename, HttpService:JSONEncode(_G.GH_Settings)) end end)
end

-- 3. SISTEM SUARA & WARNA JALAN
local function PlayNotifSound()
    local sound = Instance.new("Sound", game:GetService("SoundService"))
    sound.SoundId = "rbxassetid://4590662762"
    sound.Volume = 2
    sound:Play()
    game:GetService("Debris"):AddItem(sound, 2)
end

local function RunColorAnimation(target)
    task.spawn(function()
        local colors = {
            Color3.fromRGB(0, 170, 255), Color3.fromRGB(255, 120, 0),
            Color3.fromRGB(255, 255, 0), Color3.fromRGB(170, 0, 255)
        }
        local i = 1
        while true do
            local nextColor = colors[i]
            local prop = target:IsA("TextButton") and "TextColor3" or "Color"
            TweenService:Create(target, TweenInfo.new(1.5, Enum.EasingStyle.Linear), {[prop] = nextColor}):Play()
            task.wait(1.5)
            i = i % #colors + 1
        end
    end)
end

-- 4. LOGIKA FITUR
local function ApplyFlatColor()
    for _, v in pairs(workspace:GetDescendants()) do
        if _G.GH_Settings.FlatColor_GH and v:IsA("BasePart") and not v:IsA("Terrain") then
            v.Material = Enum.Material.Plastic
        end
    end
end

-- Fitur Auto Collect Coin GH
task.spawn(function()
    while true do
        if _G.GH_Settings.AutoCollect_GH then
            pcall(function()

local Sidebar = Instance.new("Frame", Main); Sidebar.Size = UDim2.new(0, 120, 1, 0); Sidebar.BackgroundTransparency = 0.5; Instance.new("UIListLayout", Sidebar)
local Pages = Instance.new("Frame", Main); Pages.Size = UDim2.new(1, -130, 1, 0); Pages.Position = UDim2.new(0, 125, 0, 0); Pages.BackgroundTransparency = 1

local function CreatePage(name)
    local p = Instance.new("ScrollingFrame", Pages); p.Size = UDim2.new(1,0,1,0); p.Visible = false; p.BackgroundTransparency = 1; Instance.new("UIListLayout", p); return p
end
local P1 = CreatePage("PASKA"); local P2 = CreatePage("ESP"); P1.Visible = true

local function AddBtn(txt, p)
    local b = Instance.new("TextButton", Sidebar); b.Size = UDim2.new(1,0,0,40); b.Text = txt; b.MouseButton1Click:Connect(function() P1.Visible = false; P2.Visible = false; p.Visible = true end)
end
AddBtn("EVENT", P1); AddBtn("ESP", P2)

local function Toggle(parent, txt, var)
    local b = Instance.new("TextButton", parent); b.Size = UDim2.new(1,0,0,40); b.Text = txt..": OFF"
    b.MouseButton1Click:Connect(function()
        _G.GH_Config[var] = not _G.GH_Config[var]
        b.Text = txt..(_G.GH_Config[var] and ": ON" or ": OFF")
        b.TextColor3 = _G.GH_Config[var] and Color3.new(0,1,0) or Color3.new(1,0,0)
    end)
end

Toggle(P1, "Collect", "AutoCollect_GH")
Toggle(P1, "Egg ESP", "ESP_Egg_GH")
Toggle(P2, "Player ESP", "ESP_Player_GH")

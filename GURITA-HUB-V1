-- [[ GURITA HUB - NIGHT FLAT EDITION (REDMI 10 SAFE) ]] --
-- Fitur: Langit Malem Polos, No Awan, No Lag, Warna Map Tetap Asli

local Lighting = game:GetService("Lighting")
local MaterialService = game:GetService("MaterialService")

-- [[ 1. ANTI-LAG & SETTINGAN RENDERING ]] --
pcall(function()
    settings().Rendering.QualityLevel = 1
    if setfpscap then setfpscap(45) end
end)

-- [[ 2. FIXED NIGHT POLOS (HAPUS AWAN TOTAL) ]] --
local function SikatLangitJadiMalem()
    pcall(function()
        -- Hapus semua efek langit (Awan, Atmosfer, Sky HD)
        for _, v in pairs(Lighting:GetChildren()) do
            v:Destroy()
        end
        
        -- Buat Langit Malem Polos
        local sky = Instance.new("Sky", Lighting)
        sky.SkyboxBk = "rbxassetid://0" -- Hitam
        sky.SkyboxDn = "rbxassetid://0"
        sky.SkyboxFt = "rbxassetid://0"
        sky.SkyboxLf = "rbxassetid://0"
        sky.SkyboxRt = "rbxassetid://0"
        sky.SkyboxUp = "rbxassetid://0"
        sky.SunAngularSize = 0
        sky.MoonAngularSize = 0
        sky.StarCount = 0
        
        -- Setting Waktu Jadi Malem
        Lighting.ClockTime = 0 -- Jam 12 malem
        Lighting.Brightness = 1 -- Tetap ada cahaya biar map gak gelap gulita
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
        Lighting.EnvironmentDiffuseScale = 0
        Lighting.EnvironmentSpecularScale = 0
    end)
end

-- [[ 3. LOGIKA FLAT POLOS (MURNI TANPA MOTIF) ]] --
local function BuatPolos(v)
    if v:IsDescendantOf(game.Players.LocalPlayer.Character or workspace) and v.Parent:FindFirstChild("Humanoid") then return end

    pcall(function()
        if v:IsA("BasePart") then
            -- Jaga warna asli tapi material jadi Plastic (Paling Polos)
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            v.Reflectance = 0
            
            -- Sikat Tekstur/Motif
            for _, child in pairs(v:GetChildren()) do
                if child:IsA("SurfaceAppearance") or child:IsA("Texture") or child:IsA("Decal") then
                    child:Destroy()
                end
            end
            
            -- Sikat Tekstur Mesh (Biar Pembatas Polos)
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- [[ 4. EKSEKUSI AUTO (BERTAHAP BIAR GAK PATAH-PATAH) ]] --
task.spawn(function()
    SikatLangitJadiMalem()
    
    pcall(function()
        MaterialService.Use2022Materials = false
        for _, m in pairs(MaterialService:GetChildren()) do m:Destroy() end
    end)

    local all = workspace:GetDescendants()
    for i, v in pairs(all) do
        BuatPolos(v)
        -- Jeda Redmi 10 (Sangat penting biar gak lag)
        if i % 20 == 0 then task.wait(0.01) end
    end
end)

-- Pantau part baru
workspace.DescendantAdded:Connect(function(v)
    task.wait(0.5)
    BuatPolos(v)
end)


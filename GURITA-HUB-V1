local BtnHunt = Instance.new("TextButton", Main)
BtnHunt.Size = UDim2.new(0, 260, 0, 70); BtnHunt.Position = UDim2.new(0, 20, 0, 50); BtnHunt.Font = Enum.Font.GothamBold; BtnHunt.TextColor3 = Color3.new(1, 1, 1); BtnHunt.TextSize = 18; Instance.new("UICorner", BtnHunt)

local BtnNotif = Instance.new("TextButton", Main)
BtnNotif.Size = UDim2.new(0, 260, 0, 70); BtnNotif.Position = UDim2.new(0, 20, 0, 140); BtnNotif.Font = Enum.Font.GothamBold; BtnNotif.TextColor3 = Color3.new(1, 1, 1); BtnNotif.TextSize = 18; Instance.new("UICorner", BtnNotif)

local function UpdateUI()
    BtnHunt.Text = _G.HuntingMode and "HUNTING: ON" or "HUNTING: OFF"
    BtnHunt.BackgroundColor3 = _G.HuntingMode and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
    BtnNotif.Text = _G.NotifActive and "NOTIF: ON" or "NOTIF: OFF"
    BtnNotif.BackgroundColor3 = _G.NotifActive and Color3.fromRGB(0, 120, 200) or Color3.fromRGB(80, 80, 80)
end

UpdateUI()
Toggle.MouseButton1Down:Connect(function() Main.Visible = not Main.Visible end)

BtnHunt.MouseButton1Down:Connect(function()
    _G.HuntingMode = not _G.HuntingMode
    UpdateUI(); SaveSettings()
    if _G.HuntingMode then
        for _, v in pairs(workspace:GetDescendants()) do if CekTarget(v.Name) then PasangESP(v) end end
    end
end)

BtnNotif.MouseButton1Down:Connect(function()
    _G.NotifActive = not _G.NotifActive
    UpdateUI(); SaveSettings()
end)

-- 7. EXECUTION (Running semuah fitur)
ApplyFlatColor()
if _G.HuntingMode then
    task.spawn(function()
        for _, v in pairs(workspace:GetDescendants()) do if CekTarget(v.Name) then PasangESP(v) end end
    end)
end

workspace.DescendantAdded:Connect(function(v)
    if _G.HuntingMode and CekTarget(v.Name) then task.wait(2); PasangESP(v) end
end)

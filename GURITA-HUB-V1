-- [[ GURITA HUB: V36 - TOTAL MAP FLAT (SAFE CHARACTER COLOR) ]] --

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local StarterGui = game:GetService("StarterGui")
local HttpService = game:GetService("HttpService")

-- [[ 1. CONFIG & SAVE SYSTEM ]] --
local FileName = "GuritaHub_Config.json"
local TargetEggs = {"hydra bunny", "noo my eggs", "baskito", "churrito", "quackini", "snackini", "bunny bunny sahur"}
local NotifiedEggs = {} 

_G.Settings = { EggESP = false, Notif = true }

local function SaveData() if writefile then writefile(FileName, HttpService:JSONEncode(_G.Settings)) end end
local function LoadData() if isfile and isfile(FileName) then pcall(function() _G.Settings = HttpService:JSONDecode(readfile(FileName)) end) end end
LoadData()

-- [[ 2. ULTRA FLAT COLOR (MAP ONLY) ]] --
local function SikatMap(v)
    -- PROTEKSI TOTAL: Cek apakah objek ini bagian dari karakter siapapun
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character and v:IsDescendantOf(p.Character) then return end
    end
    
    -- Abaikan UI
    if v:IsDescendantOf(PlayerGui) or v:IsA("ScreenGui") then return end

    pcall(function()
        if v:IsA("BasePart") then
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            if v:IsA("MeshPart") then
                v.TextureID = "" -- Hapus tekstur map
            end
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v:Destroy() -- Hapus stiker di tembok/lantai
        end
    end)
end

task.spawn(function()
    while true do
        local all = workspace:GetDescendants()
        for i, v in pairs(all) do
            SikatMap(v)
            if i % 300 == 0 then task.wait() end 
        end
        task.wait(10) -- Ulangi tiap 10 detik biar map tetep polos
    end
end)

-- [[ 3. ENGINE ESP & NOTIF ]] --
local function ApplyUltimateESP(obj)
    if not obj:FindFirstChild("Marker") then
        local h = Instance.new("Highlight", obj); h.Name = "Marker"; h.FillColor = Color3.fromRGB(255, 255, 0)
        local b = Instance.new("BillboardGui", obj); b.Name = "Tag"; b.Size = UDim2.new(0, 150, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 3, 0)
        local t = Instance.new("TextLabel", b); t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = Color3.new(1, 1, 0); t.Font = Enum.Font.GothamBlack; t.TextSize = 14
        task.spawn(function()
            while obj and obj.Parent and _G.Settings.EggESP do
                if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                    t.Text = "✨ " .. obj.Name:upper() .. " ✨\n[" .. math.floor((obj.Position - lp.Character.HumanoidRootPart.Position).Magnitude) .. "m]"
                end
                task.wait(0.5)
            end
            if b then b:Destroy() end; if h then h:Destroy() end
        end)
    end
end

task.spawn(function()
    while true do
        for _, v in pairs(workspace:GetDescendants()) do
            local name = v.Name:lower()
            if table.find(TargetEggs, name) then
                if _G.Settings.EggESP then ApplyUltimateESP(v) end
                if _G.Settings.Notif and not NotifiedEggs[v] then
                    NotifiedEggs[v] = true
                    StarterGui:SetCore("SendNotification", {Title = "🥚 EGG FOUND!", Text = v.Name:upper(), Duration = 5})
                    local s = Instance.new("Sound", game:GetService("SoundService")); s.SoundId = "rbxassetid://4590662762"; s:Play()
                    v.AncestryChanged:Connect(function(_, p) if not p then NotifiedEggs[v] = nil end end)
                end
            end
        end
        task.wait(5)
    end
end)


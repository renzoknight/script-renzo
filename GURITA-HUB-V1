-- [[ GURITA HUB: HUNT EGG ENGINE (OPTIMIZED) ]] --
-- Nama & Fitur: Fokus Hunt Egg Brainrot List

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local StarterGui = game:GetService("StarterGui")

-- [[ 1. CONFIG ]] --
local TargetEggs = {
    "hydra bunny", 
    "noo my eggs", 
    "baskito", 
    "churrito", 
    "quackini", 
    "snackini", 
    "bunny bunny sahur"
}

local NotifiedEggs = {} -- Anti-Spam Notif
_G.HuntEggActive = false
_G.HuntNotif = true

-- [[ 2. ENGINE ESP HUNT ]] --
local function ApplyHuntESP(obj)
    if obj:FindFirstChild("HuntMarker") then obj.HuntMarker:Destroy() end
    if obj:FindFirstChild("HuntTag") then obj.HuntTag:Destroy() end

    local h = Instance.new("Highlight", obj)
    h.Name = "HuntMarker"; h.FillColor = Color3.fromRGB(255, 255, 0)
    h.OutlineColor = Color3.new(1, 1, 1); h.FillTransparency = 0.4
    
    local b = Instance.new("BillboardGui", obj)
    b.Name = "HuntTag"; b.Size = UDim2.new(0, 150, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 3, 0)
    
    local t = Instance.new("TextLabel", b)
    t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = Color3.new(1, 1, 0)
    t.Font = Enum.Font.GothamBlack; t.TextSize = 14; t.TextStrokeTransparency = 0; t.TextStrokeColor3 = Color3.new(0,0,0)

    task.spawn(function()
        while obj and obj.Parent and _G.HuntEggActive do
            if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (obj.Position - lp.Character.HumanoidRootPart.Position).Magnitude
                t.Text = "🥚 " .. obj.Name:upper() .. " 🥚\n[" .. math.floor(dist) .. "m]"
            end
            task.wait(0.5)
        end
        if b then b:Destroy() end
        if h then h:Destroy() end
    end)
end

-- [[ 3. SCANNER HUNT ENGINE ]] --
local function ScanHunt()
    local all = workspace:GetDescendants()
    for i, v in pairs(all) do
        if not _G.HuntEggActive and not _G.HuntNotif then break end
        
        local name = v.Name:lower()
        if table.find(TargetEggs, name) then
            if _G.HuntEggActive then ApplyHuntESP(v) end
            
            if _G.HuntNotif and not NotifiedEggs[v] then
                NotifiedEggs[v] = true
                StarterGui:SetCore("SendNotification", {
                    Title = "🥚 EGG DETECTED!", 
                    Text = v.Name:upper(), 
                    Duration = 5
                })
                local s = Instance.new("Sound", game:GetService("SoundService"))
                s.SoundId = "rbxassetid://4590662762"; s:Play()
                
                v.AncestryChanged:Connect(function(_, p) if not p then NotifiedEggs[v] = nil end end)
            end
        end
        if i % 200 == 0 then task.wait() end
    end
end

workspace.DescendantAdded:Connect(function(v)
    task.wait(0.5)
    local name = v.Name:lower()
    if table.find(TargetEggs, name) then
        if _G.HuntEggActive then ApplyHuntESP(v) end
        if _G.HuntNotif and not NotifiedEggs[v] then
            NotifiedEggs[v] = true
            StarterGui:SetCore("SendNotification", {Title = "🥚 EGG SPAWNED!", Text = v.Name:upper(), Duration = 5})
            local s = Instance.new("Sound", game:GetService("SoundService")); s.SoundId = "rbxassetid://4590662762"; s:Play()
            v.AncestryChanged:Connect(function(_, p) if not p then NotifiedEggs[v] = nil end end)
        end
    end
end)

task.spawn(function()
    while true do
        if _G.HuntEggActive or _G.HuntNotif then ScanHunt() end
        task.wait(10)
    end
end)

-- [[ 4. MENU HUNT EGG ]] --
if PlayerGui:FindFirstChild("GURITA_HUNT_MENU") then PlayerGui.GURITA_HUNT_MENU:Destroy() end
local SG = Instance.new("ScreenGui", PlayerGui); SG.Name = "GURITA_HUNT_MENU"

local Main = Instance.new("Frame", SG)
Main.Size = UDim2.new(0, 200, 0, 160); Main.Position = UDim2.new(0.5, 120, 0.5, -80)
Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Main.Active = true; Main.Draggable = true
Instance.new("UICorner", Main); Instance.new("UIStroke", Main).Color = Color3.new(1, 1, 0)

local Title = Instance.new("TextLabel", Main)
Title.Size = UDim2.new(1, 0, 0, 35); Title.Text = "EGG HUNT MENU"; Title.TextColor3 = Color3.new(1, 1, 1)
Title.BackgroundTransparency = 1; Title.Font = Enum.Font.GothamBlack; Title.TextSize = 13

local function CreateBtn(text, pos, func)
    local b = Instance.new("TextButton", Main)
    b.Size = UDim2.new(0.9, 0, 0, 45); b.Position = UDim2.new(0.05, 0, pos, 0)
    b.BackgroundColor3 = Color3.fromRGB(30, 30, 30); b.Text = text; b.TextColor3 = Color3.new(1,1,1)
    b.Font = Enum.Font.GothamBold; b.TextSize = 12; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(func); return b
end

local BtnHunt = CreateBtn("HUNT ESP: OFF", 0.25, function()
    _G.HuntEggActive = not _G.HuntEggActive
    if _G.HuntEggActive then task.spawn(ScanHunt) end
end)

local BtnNotif = CreateBtn("HUNT NOTIF: ON", 0.6, function()
    _G.HuntNotif = not _G.HuntNotif
end)

task.spawn(function()
    while true do
        BtnHunt.Text = "HUNT ESP: " .. (_G.HuntEggActive and "ON" or "OFF")
        BtnHunt.TextColor3 = _G.HuntEggActive and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
        BtnNotif.Text = "HUNT NOTIF: " .. (_G.HuntNotif and "ON" or "OFF")
        BtnNotif.TextColor3 = _G.HuntNotif and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
        task.wait(0.5)
    end
end)

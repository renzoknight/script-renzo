-- --- FUNGSI UTAMA FLAT MAP (OTOMATIS AKTIF) ---
local function PowerOptimization()
    -- Mengubah Lighting agar lebih enteng
    game:GetService("Lighting").GlobalShadows = false
    game:GetService("Lighting").FogEnd = 9e9
    
    -- Menghapus semua tekstur di Map agar jadi Flat Color
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and not v:IsDescendantOf(LocalPlayer.Character) then
            v.Material = Enum.Material.SmoothPlastic -- Material paling ringan
            -- Jika bukan unit Easter, buat map jadi warna abu-abu/hijau flat (sesuai map)
            if not table.find(EasterList, v.Name) and not table.find(EasterList, v.Parent.Name) then
                -- Biarkan warna asli tapi hilangkan tekstur/material berat
            else
                -- Khusus Unit Easter tetap Ungu Neon agar kelihatan
                v.Material = Enum.Material.Neon
                v.Color = Color3.fromRGB(138, 43, 226)
            end
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v:Destroy()
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end
end

-- Jalankan langsung pas di-execute
PowerOptimization()


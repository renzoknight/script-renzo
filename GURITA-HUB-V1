-- [[ FLAT COLOR ONLY - ANTI LAG SYSTEM ]] --

local CG = game:GetService("CoreGui")
local _G = getgenv and getgenv() or _G
_G.FlatColorActive = false

-- [[ 1. LOGIKA FLAT COLOR (ANTI-LAG) ]] --
local function ApplyFlat(v)
    pcall(function()
        if v:IsA("BasePart") and not v.Parent:FindFirstChild("Humanoid") then
            -- Ubah material jadi Plastic (Paling Ringan)
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            
            -- Hapus tekstur kalau ada
            if v:IsA("MeshPart") then v.TextureID = "" end
            for _, child in pairs(v:GetChildren()) do 
                if child:IsA("Texture") or child:IsA("Decal") then 
                    child:Destroy() 
                end 
            end
        end
    end)
end

-- Fungsi Scan Map dengan Jeda (Anti-Lag)
local function ScanMap()
    local descendants = workspace:GetDescendants()
    for i, v in pairs(descendants) do
        if _G.FlatColorActive then
            ApplyFlat(v)
            -- Jeda setiap 50 objek biar HP gak nge-freeze
            if i % 50 == 0 then task.wait() end
        end
    end
end

-- [[ 2. UI SIMPEL (CUMAN ON/OFF) ]] --
if CG:FindFirstChild("FlatOnlyUI") then CG.FlatOnlyUI:Destroy() end
local SG = Instance.new("ScreenGui", CG); SG.Name = "FlatOnlyUI"

local Main = Instance.new("Frame", SG)
Main.Size = UDim2.new(0, 140, 0, 70); Main.Position = UDim2.new(0.1, 0, 0.4, 0)
Main.BackgroundColor3 = Color3.new(0,0,0); Main.Draggable = true; Main.Active = true
Instance.new("UICorner", Main); Instance.new("UIStroke", Main).Color = Color3.fromRGB(0, 255, 150)

local Btn = Instance.new("TextButton", Main)
Btn.Size = UDim2.new(0.9, 0, 0.7, 0); Btn.Position = UDim2.new(0.05, 0, 0.15, 0)
Btn.Font = Enum.Font.GothamBold; Btn.TextSize = 12; Instance.new("UICorner", Btn)

local function UpdateUI()
    Btn.Text = _G.FlatColorActive and "FLAT COLOR: ON" or "FLAT COLOR: OFF"
    Btn.BackgroundColor3 = _G.FlatColorActive and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(170, 0, 0)
    Btn.TextColor3 = Color3.new(1,1,1)
end

Btn.MouseButton1Click:Connect(function()
    _G.FlatColorActive = not _G.FlatColorActive
    UpdateUI()
    if _G.FlatColorActive then
        ScanMap()
    end
end)

UpdateUI()

-- [[ 3. AUTO-FLAT UNTUK OBJEK BARU ]] --
workspace.DescendantAdded:Connect(function(new)
    if _G.FlatColorActive then
        task.wait(0.1)
        ApplyFlat(new)
    end
end)

local function CreateToggle(parent, txt, var, callback)
    local b = Instance.new("TextButton", parent)
    b.Size = UDim2.new(0.95, 0, 0, 40); b.BackgroundColor3 = Color3.fromRGB(22, 22, 35); b.Font = Enum.Font.GothamBold; b.TextSize = 10; Instance.new("UICorner", b)
    local s = Instance.new("UIStroke", b); s.Thickness = 1
    
    local function UpdateUI()
        local state = _G.GH_Config[var]
        b.Text = txt..(state and ": ON" or ": OFF")
        b.TextColor3 = state and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
        s.Color = state and Color3.fromRGB(0, 150, 255) or Color3.fromRGB(40, 40, 60)
    end
    UpdateUI()
    b.MouseButton1Click:Connect(function()
        _G.GH_Config[var] = not _G.GH_Config[var]
        UpdateUI(); SaveData()
        if callback then callback() end
    end)
end

-- [[ FITUR EXECUTION ]] --
local function StartAutoCollect()
    task.spawn(function()
        while _G.GH_Config.AutoCollect_GH do
            local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                for _, v in ipairs(workspace:GetDescendants()) do
                    if not _G.GH_Config.AutoCollect_GH then break end
                    if v:IsA("BasePart") and v.Name:lower():find("coin") then
                        hrp.CFrame = v.CFrame
                        firetouchinterest(hrp, v, 0); task.wait(); firetouchinterest(hrp, v, 1)
                        task.wait(0.15)
                    end
                end
            end
            task.wait(1)
        end
    end)
end

CreateToggle(PagePaska, "Auto Collect Koin", "AutoCollect_GH", function()
    if _G.GH_Config.AutoCollect_GH then StartAutoCollect() end
end)

CreateToggle(PagePaska, "ESP EGG HUNT", "ESP_Egg_GH", function()
    if not _G.GH_Config.ESP_Egg_GH then
        for _, v in pairs(workspace:GetDescendants()) do if v.Name == "EHSTag" then v:Destroy() end end
    end
end)


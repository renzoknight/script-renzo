-- --- 5. LOGIKA INTERAKSI ---
LogoButton.MouseButton1Click:Connect(function()
    MainFrame.Visible = not MainFrame.Visible
    print("Logo GH Diklik - Status Menu: " .. tostring(MainFrame.Visible))
end)

CloseButton.MouseButton1Click:Connect(function()
    MainFrame.Visible = false
end)

-- --- 6. ANIMASI RGB ---
local colors = {
    Color3.fromRGB(0, 150, 255), Color3.fromRGB(255, 100, 0),
    Color3.fromRGB(255, 200, 0), Color3.fromRGB(150, 0, 255)
}
local colorIndex, nextColorIndex = 1, 2
local transitionTime, currentTime = 2, 0

RunService.Heartbeat:Connect(function(dt)
    currentTime = currentTime + dt
    local percent = currentTime / transitionTime
    local lerpColor = colors[colorIndex]:Lerp(colors[nextColorIndex], percent)
    MainStroke.Color = lerpColor
    LogoStroke.Color = lerpColor
    if percent >= 1 then
        currentTime = 0
        colorIndex = nextColorIndex
        nextColorIndex = nextColorIndex + 1
        if nextColorIndex > #colors then nextColorIndex = 1 end
    end
end)

print("GURITA-HUB-V1 Berhasil Dimuat!")

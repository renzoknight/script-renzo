-- [[ GURITA HUB - FINAL LIGHTWEIGHT PERMANENT NIGHT ]] --
-- Fokus: Tetap Malem, Gak Bakal Balik, Tapi GAK LAG

local Lighting = game:GetService("Lighting")

-- [[ 1. OPTIMASI HP REDMI 10 (SANGAT PENTING) ]] --
pcall(function()
    settings().Rendering.QualityLevel = 1
    if setfpscap then setfpscap(45) end
end)

-- [[ 2. FUNGSI SIKAT LANGIT (EFISIEN) ]] --
local function ForceNight()
    pcall(function()
        Lighting.ClockTime = 0
        Lighting.Brightness = 1
        Lighting.GlobalShadows = false
        Lighting.EnvironmentDiffuseScale = 0
        Lighting.EnvironmentSpecularScale = 0
        
        -- Hapus awan/atmosfer kalau ada yang masuk
        for _, v in pairs(Lighting:GetChildren()) do
            if v:IsA("Sky") or v:IsA("Atmosphere") or v:IsA("Clouds") or v:IsA("PostEffect") then
                v:Destroy()
            end
        end
        
        -- Pasang Sky Hitam (Hanya jika belum ada)
        if not Lighting:FindFirstChild("GuritaSky") then
            local sky = Instance.new("Sky", Lighting)
            sky.Name = "GuritaSky"
            sky.SkyboxBk, sky.SkyboxDn, sky.SkyboxFt, sky.SkyboxLf, sky.SkyboxRt, sky.SkyboxUp = "rbxassetid://0","rbxassetid://0","rbxassetid://0","rbxassetid://0","rbxassetid://0","rbxassetid://0"
            sky.SunAngularSize, sky.MoonAngularSize, sky.StarCount = 0, 0, 0
        end
    end)
end

-- [[ 3. PENJAGA LANGIT (VERSI ENTENG) ]] --
-- Kita ganti RenderStepped (yang bikin lag) jadi Heartbeat dengan jeda
local lastCheck = 0
game:GetService("RunService").Heartbeat:Connect(function()
    local now = tick()
    if now - lastCheck >= 1.5 then -- Hanya cek tiap 1.5 detik (Biar gak lag)
        lastCheck = now
        Lighting.ClockTime = 0
        if not Lighting:FindFirstChild("GuritaSky") then
            ForceNight()
        end
    end
end)

-- Kalau ada yang coba masukin awan, langsung hapus (Instan)
Lighting.ChildAdded:Connect(function()
    task.wait(0.1)
    ForceNight()
end)

-- [[ 4. LOGIKA FLAT POLOS (MAP) ]] --
local function SikatPolos(v)
    if v:IsDescendantOf(game.Players.LocalPlayer.Character or workspace) and v.Parent:FindFirstChild("Humanoid") then return end
    pcall(function()
        if v:IsA("BasePart") then
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
            for _, child in pairs(v:GetChildren()) do
                if child:IsA("SurfaceAppearance") or child:IsA("Texture") or child:IsA("Decal") then
                    child:Destroy()
                end
            end
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- Eksekusi Flat Map secara bertahap
task.spawn(function()
    ForceNight()
    local all = workspace:GetDescendants()
    for i, v in pairs(all) do
        SikatPolos(v)
        if i % 30 == 0 then task.wait(0.05) end -- Jeda lebih lama biar gak panas
    end
end)


local Main = Instance.new("Frame", SG)
Main.Size = UDim2.new(0, 480, 0, 340); Main.Position = UDim2.new(0.5, -240, 0.5, -170); Main.BackgroundColor3 = Color3.fromRGB(15, 15, 22); Main.Visible = false; Instance.new("UICorner", Main)
local MainStroke = Instance.new("UIStroke", Main); MainStroke.Color = Color3.fromRGB(0, 150, 255); MainStroke.Thickness = 2

local CloseBtn = Instance.new("TextButton", Main)
CloseBtn.Size = UDim2.new(0, 30, 0, 30); CloseBtn.Position = UDim2.new(1, -35, 0, 5); CloseBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50); CloseBtn.Text = "X"; CloseBtn.TextColor3 = Color3.new(1, 1, 1); Instance.new("UICorner", CloseBtn)
CloseBtn.MouseButton1Click:Connect(function() Main.Visible = false end)
GHTxtBtn.MouseButton1Click:Connect(function() Main.Visible = not Main.Visible end)

local Sidebar = Instance.new("Frame", Main)
Sidebar.Size = UDim2.new(0, 140, 1, -60); Sidebar.Position = UDim2.new(0, 10, 0, 50); Sidebar.BackgroundTransparency = 1
Instance.new("UIListLayout", Sidebar).Padding = UDim.new(0, 8)

local Pages = Instance.new("Frame", Main)
Pages.Size = UDim2.new(1, -170, 1, -100); Pages.Position = UDim2.new(0, 160, 0, 50); Pages.BackgroundTransparency = 1

local function CreatePage(name)
    local p = Instance.new("ScrollingFrame", Pages); p.Name = name; p.Size = UDim2.new(1, 0, 1, 0); p.BackgroundTransparency = 1; p.Visible = false; p.ScrollBarThickness = 0
    Instance.new("UIListLayout", p).Padding = UDim.new(0, 8)
    return p
end

local PagePaska = CreatePage("PASKA"); local PageESP = CreatePage("ESP")
PagePaska.Visible = true

local function CreateSideBtn(txt, page)
    local b = Instance.new("TextButton", Sidebar)
    b.Size = UDim2.new(1, 0, 0, 45); b.BackgroundColor3 = Color3.fromRGB(25, 25, 35); b.Text = txt; b.TextColor3 = Color3.new(1, 1, 1); b.Font = Enum.Font.GothamBold; b.TextSize = 12; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function() 
        for _, v in pairs(Pages:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end
        page.Visible = true 
    end)
end
CreateSideBtn("PASKA EVENT", PagePaska); CreateSideBtn("ESP", PageESP)

local function CreateToggle(parent, txt, var, callback)
    local b = Instance.new("TextButton", parent)
    b.Size = UDim2.new(1, 0, 0, 45); b.BackgroundColor3 = Color3.fromRGB(22, 22, 32)
    local function UpdateBtn()
        local s = _G.GH_Settings[var]; b.Text = txt..(s and ": ON" or ": OFF")
        b.TextColor3 = s and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
    end
    UpdateBtn()
    b.MouseButton1Click:Connect(function() _G.GH_Settings[var] = not _G.GH_Settings[var]; UpdateBtn(); if callback then callback() end end)
    Instance.new("UICorner", b)
end

CreateToggle(PagePaska, "Auto Collect Coin", "AutoCollect_GH")
CreateToggle(PagePaska, "ESP Egg Hunt", "ESP_Egg_GH")
CreateToggle(PageESP, "X-Ray Base Only", "Xray_GH", function() UpdateXray() end)
CreateToggle(PageESP, "ESP Player", "ESP_Player_GH", function() UpdateESP() end)

-- [[ OPTIMIZED LOOP SYSTEM ]] --
local Colors = {Color3.fromRGB(0, 170, 255), Color3.fromRGB(255, 120, 0), Color3.fromRGB(255, 255, 0), Color3.fromRGB(170, 0, 255)}
task.spawn(function()
    local i = 1
    while true do
        TweenService:Create(GHTxtBtn, TweenInfo.new(1.5), {TextColor3 = Colors[i]}):Play()
        TweenService:Create(MainStroke, TweenInfo.new(1.5), {Color = Colors[i]}):Play()
        
        -- Fungsi berat dijalankan bergantian biar gak lag
        if _G.GH_Settings.FlatColor_GH then ApplyFlatColor() end
        task.wait(1)
        if _G.GH_Settings.ESP_Player_GH then UpdateESP() end
        task.wait(1)
        if _G.GH_Settings.Xray_GH then UpdateXray() end
        
        i = i % #Colors + 1
        task.wait(1)
    end
end)

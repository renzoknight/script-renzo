-- [[ 3. LOGIKA FLAT COLOR ANTI-LAG (ITERATIVE) ]] --
local function SikatPart(v)
    if v:IsA("BasePart") then
        v.Material = Enum.Material.SmoothPlastic
        v.CastShadow = false
        if v:IsA("MeshPart") then v.TextureID = "" end
    elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("Atmosphere") or v:IsA("Clouds") or v:IsA("Sky") then
        v:Destroy()
    end
end

-- Fungsi loop yang tidak bikin lag (Menggunakan antrean)
local function OptimizeVisual()
    local descendants = workspace:GetDescendants()
    for i, v in pairs(descendants) do
        SikatPart(v)
        -- Tiap 100 objek, script istirahat sekejap (Biar executor nggak lag)
        if i % 100 == 0 then 
            task.wait() 
        end
    end
end

-- Nuke Lighting di awal
local function NukeLighting()
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.Brightness = 2
    Lighting.ClockTime = 12
    for _, v in pairs(Lighting:GetChildren()) do
        v:Destroy()
    end
end

task.spawn(function()
    NukeLighting()
    while true do
        OptimizeVisual()
        task.wait(30) -- Refresh tiap 30 detik (Udah cukup, jangan terlalu sering biar stabil)
    end
end)

-- Handle objek baru yang muncul agar tetap flat
workspace.DescendantAdded:Connect(function(v)
    task.wait(0.1)
    SikatPart(v)
end)

-- [[ 4. ESP & NOTIF ]] --
local function ApplyESP(obj)
    if not _G.Settings.EggESP then return end
    if not obj:FindFirstChild("GuritaMarker") then
        local h = Instance.new("Highlight", obj); h.Name = "GuritaMarker"
        h.FillColor = Color3.fromRGB(255, 255, 0); h.OutlineTransparency = 0
        
        local b = Instance.new("BillboardGui", obj); b.Name = "GuritaTag"
        b.Size = UDim2.new(0, 150, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 3, 0)
        
        local t = Instance.new("TextLabel", b); t.Size = UDim2.new(1, 0, 1, 0)
        t.BackgroundTransparency = 1; t.TextColor3 = Color3.new(1, 1, 0)
        t.Font = Enum.Font.GothamBlack; t.TextSize = 14; t.TextStrokeTransparency = 0

        task.spawn(function()
            while obj and obj.Parent and _G.Settings.EggESP do
                if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (obj.Position - lp.Character.HumanoidRootPart.Position).Magnitude
                    t.Text = obj.Name:upper() .. "\n[" .. math.floor(dist) .. "m]"
                end
                task.wait(1) -- Delay update ESP ditingkatkan biar nggak lag
            end
            if b then b:Destroy() end; if h then h:Destroy() end
        end)
    end
end

task.spawn(function()
    while true do
        for _, v in pairs(workspace:GetDescendants()) do
            local name = v.Name:lower()
            if table.find(TargetEggs, name) then
                if _G.Settings.EggESP then ApplyESP(v) end
                if _G.Settings.Notif and not NotifiedEggs[v] then
                    NotifiedEggs[v] = true
                    StarterGui:SetCore("SendNotification", {Title = "🥚 EGG FOUND!", Text = v.Name:upper(), Duration = 5})
                    v.AncestryChanged:Connect(function(_, p) if not p then NotifiedEggs[v] = nil end end)
                end
            end
        end
        task.wait(8)
    end
end)


-- [[ GURITA HUB: NIGHT & FLAT AUTO-EXECUTE ]] --
-- Fitur: Malam Permanen, Flat Map V38, Egg Hunt, Anti-Lag

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local StarterGui = game:GetService("StarterGui")
local Lighting = game:GetService("Lighting")

-- [[ 1. CONFIG & AUTO-ON ]] --
local TargetEggs = {
    "hydra bunny", "noo my eggs", "baskito", "churrito", 
    "quackini", "snackini", "bunny bunny sahur"
}

local NotifiedEggs = {} 
_G.FlatActive = true    
_G.HuntEggActive = true 
_G.NightActive = true -- Langit Malam Auto-On

-- [[ 2. ENGINE LANGIT MALAM PERMANEN ]] --
local function SetNight()
    pcall(function()
        Lighting.ClockTime = 0 -- Jam 12 malem
        Lighting.Brightness = 0
        Lighting.GlobalShadows = false
        Lighting.OutdoorAmbient = Color3.fromRGB(10, 10, 10)
        Lighting.GeographicLatitude = 41.7 -- Posisi bintang
        
        -- Hapus awan/matahari yang bikin terang
        for _, v in pairs(Lighting:GetChildren()) do
            if v:IsA("Sky") or v:IsA("Atmosphere") or v:IsA("Clouds") then
                v:Destroy()
            end
        end
        
        -- Buat langit hitam pekat
        local Sky = Instance.new("Sky", Lighting)
        Sky.SkyboxBk = "rbxassetid://600645365"
        Sky.SkyboxDn = "rbxassetid://600645365"
        Sky.SkyboxFt = "rbxassetid://600645365"
        Sky.SkyboxLf = "rbxassetid://600645365"
        Sky.SkyboxRt = "rbxassetid://600645365"
        Sky.SkyboxUp = "rbxassetid://600645365"
        Sky.SunAngularSize = 0
        Sky.MoonAngularSize = 0
    end)
end

-- [[ 3. ENGINE FLAT COLOR (V38 RE-LOGIC) ]] --
local function SikatPart(v)
    if v:IsDescendantOf(PlayerGui) then return end
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character and v:IsDescendantOf(p.Character) then return end
    end

    pcall(function()
        if v:IsA("BasePart") then
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            v.Reflectance = 0
            if v:IsA("MeshPart") then v.TextureID = "" end
            local sa = v:FindFirstChildOfClass("SurfaceAppearance")
            if sa then sa:Destroy() end
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v:Destroy()
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

local function RunFlatColor()
    local all = workspace:GetDescendants()
    local count = 0
    for _, v in pairs(all) do
        if not _G.FlatActive then break end
        SikatPart(v)
        count = count + 1
        if count >= 100 then count = 0 task.wait() end -- Anti Lag
    end
end

-- [[ 4. ENGINE HUNT EGG ]] --
local function ApplyHuntESP(obj)
    if obj:FindFirstChild("HuntMarker") then obj.HuntMarker:Destroy() end
    local h = Instance.new("Highlight", obj)
    h.Name = "HuntMarker"; h.FillColor = Color3.fromRGB(255, 255, 0); h.OutlineColor = Color3.new(1,1,1)
    
    local b = Instance.new("BillboardGui", obj)
    b.Name = "HuntTag"; b.Size = UDim2.new(0, 150, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 3, 0)
    local t = Instance.new("TextLabel", b)
    t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = Color3.new(1, 1, 0); t.Font = Enum.Font.GothamBlack; t.TextSize = 14; t.TextStrokeTransparency = 0

    task.spawn(function()
        while obj and obj.Parent and _G.HuntEggActive do
            if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                t.Text = "🥚 " .. obj.Name:upper() .. " 🥚\n[" .. math.floor((obj.Position - lp.Character.HumanoidRootPart.Position).Magnitude) .. "m]"
            end
            task.wait(0.5)
        end
        if b then b:Destroy() end; if h then h:Destroy() end
    end)
end

-- [[ 5. AUTOMATION & RUNTIME ]] --
workspace.DescendantAdded:Connect(function(v)
    if _G.FlatActive then task.wait(0.1); SikatPart(v) end
    if table.find(TargetEggs, v.Name:lower()) then
        if _G.HuntEggActive then ApplyHuntESP(v) end
    end
end)

-- Loop Lock Malam (Biar gak keganti sistem game)
task.spawn(function()
    while true do
        if _G.NightActive then SetNight() end
        task.wait(2)
    end
end)

-- Jalankan Sikat Map & Scan Egg
task.spawn(RunFlatColor)
task.spawn(function()
    while true do
        local all = workspace:GetDescendants()
        for _, v in pairs(all) do
            local name = v.Name:lower()
            if table.find(TargetEggs, name) and not v:FindFirstChild("HuntMarker") then
                ApplyHuntESP(v)
                if not NotifiedEggs[v] then
                    NotifiedEggs[v] = true
                    StarterGui:SetCore("SendNotification", {Title = "🥚 EGG FOUND!", Text = v.Name:upper(), Duration = 5})
                    local s = Instance.new("Sound", game:GetService("SoundService")); s.SoundId = "rbxassetid://4590662762"; s:Play()
                    v.AncestryChanged:Connect(function(_, p) if not p then NotifiedEggs[v] = nil end end)
                end
            end
        end
        task.wait(10)
    end
end)


-- [[ GURITA HUB V39 - RESTORE NOTIF EDITION ]] --
local lp = game.Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local HttpService = game:GetService("HttpService")

-- 1. SAVE/LOAD SYSTEM
local FileName = "GuritaHubConfig.json"
local function LoadSettings()
    if isfile and isfile(FileName) then
        local s, res = pcall(function() return HttpService:JSONDecode(readfile(FileName)) end)
        if s then return res end
    end
    return { HuntingMode = false, NotifActive = true }
end

local function SaveSettings()
    if writefile then
        pcall(function()
            writefile(FileName, HttpService:JSONEncode({
                HuntingMode = _G.HuntingMode,
                NotifActive = _G.NotifActive
            }))
        end)
    end
end

local SavedData = LoadSettings()
_G.HuntingMode = SavedData.HuntingMode
_G.NotifActive = SavedData.NotifActive

-- 2. DAFTAR TARGET
local NotifHistory = {}
local SuperRare = {"hydra", "no my egg", "baskito", "churrito", "hopilikalika", "quackini", "harp"}
local NormalTargets = {"tralala", "eggdin", "easter", "sahur", "sky egg", "bunny egg", "snackini"}

-- 3. FLAT COLOR & PERFORMA
local function ApplyPerformance()
    settings().Rendering.QualityLevel = 1
    game:GetService("Lighting").GlobalShadows = false
    local function Clean(v)
        if v:IsA("BasePart") then v.Material = Enum.Material.Plastic; v.Reflectance = 0
        elseif v:IsA("Decal") or v:IsA("Texture") then v:Destroy() end
    end
    for _, v in pairs(workspace:GetDescendants()) do Clean(v) end
    workspace.DescendantAdded:Connect(function(v) task.wait(); Clean(v) end)
end

-- 4. FUNGSI ALARM & NOTIF (KEMBALI DI AKTIFKAN)
local function PlayAlert(tipe)
    if not _G.NotifActive then return end
    local s = Instance.new("Sound", workspace)
    s.SoundId = (tipe == "rare") and "rbxassetid://4590662766" or "rbxassetid://138090596"
    s.Volume = 1; s:Play(); s.Ended:Connect(function() s:Destroy() end)
end

local function KirimNotifRare(objName)
    if NotifHistory[objName] or not _G.NotifActive then return end
    NotifHistory[objName] = true 
    
    local sg = Instance.new("ScreenGui", PlayerGui); sg.Name = "GuritaNotif"
    local f = Instance.new("Frame", sg)
    f.Size = UDim2.new(0, 300, 0, 80); f.Position = UDim2.new(1, 50, 0.8, 0)
    f.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Instance.new("UICorner", f)
    
    local t = Instance.new("TextLabel", f)
    t.Size = UDim2.new(1, -20, 1, 0); t.Position = UDim2.new(0, 15, 0, 0)
    t.Text = "RARE FOUND:\n" .. objName:upper(); t.TextColor3 = Color3.new(1, 0, 0)
    t.Font = "GothamBold"; t.TextSize = 14; t.BackgroundTransparency = 1; t.TextXAlignment = "Left"
    
    PlayAlert("rare")
    f:TweenPosition(UDim2.new(1, -320, 0.8, 0), "Out", "Back", 0.5)
    task.delay(5, function() 
        if f then f:TweenPosition(UDim2.new(1, 50, 0.8, 0), "In", "Quad", 0.5) end
        task.wait(0.6); sg:Destroy()
    end)
end

-- 5. ESP LOGIC (DENGAN FILTER ISLAND & FULL NAME)
local function PasangESP(obj)
    if obj:FindFirstChild("GuritaTag") then return end
    task.spawn(function()
        local namaLengkap = ""
        for i = 1, 50 do
            if obj.Name ~= "Part" and obj.Name ~= "Model" and obj.Name ~= "" then
                namaLengkap = obj.Name:lower()
                break
            end
            task.wait(0.1)
        end
        if namaLengkap == "" then return end

        local pos = obj:IsA("Model") and obj:GetModelCFrame().p or obj.Position
        if pos.Y < 100 then return end -- Hanya Island

        local tipe = nil
        for _, r in pairs(SuperRare) do if namaLengkap:find(r) then tipe = "rare"; break end end
        if not tipe then
            for _, e in pairs(NormalTargets) do if namaLengkap:find(e) then tipe = "normal"; break end end
        end

        if not tipe or namaLengkap:find("brainrot") then return end

        if tipe == "rare" then KirimNotifRare(obj.Name) end
        local col = (tipe == "rare") and Color3.new(1, 0, 0) or Color3.fromRGB(0, 170, 255)

        local b = Instance.new("BillboardGui", obj)
        b.Name = "GuritaTag"; b.Size = UDim2.new(0, 250, 0, 60); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 6, 0)
        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = col; t.Font = "GothamBlack"; t.TextSize = 18; t.TextStrokeTransparency = 0
        
        while obj and obj.Parent and _G.HuntingMode do
            local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = math.floor((hrp.Position - pos).Magnitude)
                t.Text = obj.Name:upper() .. "\n[" .. dist .. "s]"
            end
            task.wait(1)
        end
        if b then b:Destroy() end
    end)
end


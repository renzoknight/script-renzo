-- [[ GURITA HUB - ONLY NOTIFIER ]] --

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local StarterGui = game:GetService("StarterGui")

-- 1. LIST TARGET (SESUAI REQUEST ABANG)
local TargetEggs = {
    "hydra bunny", "noo my eggs", "baskito", "churrito", 
    "quackini snackini", "hopilikalika hopilikalako", "bunny sahur"
}

_G.NotifStatus = false -- Awalnya mati (OFF)

-- 2. FUNGSI KIRIM NOTIFIKASI
local function KirimNotif(namaTelur)
    -- Pop-up di layar
    StarterGui:SetCore("SendNotification", {
        Title = "🥚 EGG SPAWNED!";
        Text = "Ketemu: " .. namaTelur:upper();
        Duration = 5;
    })
    
    -- Efek Suara Ping
    local s = Instance.new("Sound", workspace)
    s.SoundId = "rbxassetid://4590662762"
    s.Volume = 1
    s:Play()
    task.wait(2)
    s:Destroy()
end

-- 3. UI MENU & LOGO (WAJIB)
if PlayerGui:FindFirstChild("GHS_NotifOnly") then PlayerGui.GHS_NotifOnly:Destroy() end
local SG = Instance.new("ScreenGui", PlayerGui); SG.Name = "GHS_NotifOnly"; SG.ResetOnSpawn = false

-- Tombol Logo G H
local Logo = Instance.new("TextButton", SG)
Logo.Size = UDim2.new(0, 60, 0, 60); Logo.Position = UDim2.new(0, 10, 0.5, 0)
Logo.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Logo.Text = "G H"; Logo.TextColor3 = Color3.new(1, 1, 0)
Logo.Font = Enum.Font.GothamBlack; Logo.TextSize = 20; Logo.Draggable = true; Logo.Active = true
Instance.new("UICorner", Logo); Instance.new("UIStroke", Logo).Thickness = 2

-- Frame Menu
local Main = Instance.new("Frame", SG)
Main.Size = UDim2.new(0, 200, 0, 150); Main.Position = UDim2.new(0.5, -100, 0.5, -75)
Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Main.Visible = false; Instance.new("UICorner", Main)
Instance.new("UIStroke", Main).Color = Color3.new(1, 1, 0)

Logo.MouseButton1Click:Connect(function() Main.Visible = not Main.Visible end)

-- Judul
local Title = Instance.new("TextLabel", Main)
Title.Size = UDim2.new(1, 0, 0, 40); Title.Text = "NOTIF DETECTOR"; Title.TextColor3 = Color3.new(1, 1, 1)
Title.Font = Enum.Font.GothamBold; Title.BackgroundTransparency = 1; Title.TextSize = 14

-- TOMBOL ON/OFF (MANUAL)
local Tgl = Instance.new("TextButton", Main)
Tgl.Size = UDim2.new(0.85, 0, 0, 50); Tgl.Position = UDim2.new(0.075, 0, 0.45, 0)
Tgl.BackgroundColor3 = Color3.fromRGB(30, 30, 30); Tgl.Font = Enum.Font.GothamBold; Tgl.TextSize = 14
Instance.new("UICorner", Tgl)

local function UpdateUI()
    Tgl.Text = _G.NotifStatus and "STATUS: ON" or "STATUS: OFF"
    Tgl.TextColor3 = _G.NotifStatus and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
end
UpdateUI()

Tgl.MouseButton1Click:Connect(function()
    _G.NotifStatus = not _G.NotifStatus
    UpdateUI()
    if _G.NotifStatus then
        print("Notifikasi diaktifkan.")
    else
        print("Notifikasi dimatikan.")
    end
end)

-- 4. DETEKSI OTOMATIS (HANYA JALAN JIKA STATUS: ON)
workspace.DescendantAdded:Connect(function(v)
    if _G.NotifStatus then
        local nameLower = v.Name:lower()
        if table.find(TargetEggs, nameLower) then
            KirimNotif(v.Name)
        end
    end
end)

print("Gurita Hub: Notifier Only Loaded!")

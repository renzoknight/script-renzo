-- Prioritas: Menu Muncul Duluan, Flat Color Jalan Santai

local lp = game.Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")

-- [[ 1. DAFTAR TELUR ]] --
local TargetEggs = {"hydra bunny", "noo my eggs", "hopilikalika", "baskito", "churrito", "quackini", "snackini", "bunny bunny sahur"}

-- [[ 2. UI MENU G (MUNCUL PALING AWAL) ]] --
if PlayerGui:FindFirstChild("GuritaHubUI") then PlayerGui.GuritaHubUI:Destroy() end
local SG = Instance.new("ScreenGui", PlayerGui); SG.Name = "GuritaHubUI"; SG.ResetOnSpawn = false; SG.DisplayOrder = 9999

local Toggle = Instance.new("TextButton", SG)
Toggle.Size = UDim2.new(0, 60, 0, 60); Toggle.Position = UDim2.new(0, 10, 0.4, 0)

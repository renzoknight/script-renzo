-- 3. FLAT COLOR OVERRIDE
local function ApplyPerformance()
    settings().Rendering.QualityLevel = 1
    game:GetService("Lighting").GlobalShadows = false
    local function Clean(v)
        if v:IsA("BasePart") then
            v.Material = Enum.Material.Plastic
            v.Reflectance = 0
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v:Destroy()
        end
    end
    for _, v in pairs(workspace:GetDescendants()) do Clean(v) end
    workspace.DescendantAdded:Connect(function(v) task.wait(); Clean(v) end)
end

-- 4. ALARM & NOTIF
local function PlayAlert(tipe)
    if not _G.NotifActive then return end
    local s = Instance.new("Sound", workspace)
    s.SoundId = (tipe == "rare") and "rbxassetid://4590662766" or "rbxassetid://138090596"
    s.Volume = 1; s:Play()
    s.Ended:Connect(function() s:Destroy() end)
end

local function KirimNotifRare(obj)
    if NotifHistory[obj] or not _G.NotifActive then return end
    NotifHistory[obj] = true 
    local isHarp = obj.Name:lower():find("harp")
    local col = isHarp and Color3.new(1, 1, 0) or Color3.new(1, 0, 0)
    local sg = Instance.new("ScreenGui", PlayerGui); local f = Instance.new("Frame", sg)
    f.Size = UDim2.new(0, 300, 0, 80); f.Position = UDim2.new(1, 50, 0.8, 0); f.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Instance.new("UICorner", f)
    local t2 = Instance.new("TextLabel", f)
    t2.Size = UDim2.new(1, 0, 1, 0); t2.Position = UDim2.new(0, 15, 0, 0); t2.Text = obj.Name:upper(); t2.TextColor3 = col; t2.Font = "GothamBold"; t2.TextSize = 16; t2.BackgroundTransparency = 1; t2.TextXAlignment = "Left"
    PlayAlert("rare"); f:TweenPosition(UDim2.new(1, -320, 0.8, 0), "Out", "Back", 0.5)
    task.delay(5, function() if f then f:TweenPosition(UDim2.new(1, 50, 0.8, 0), "In", "Quad", 0.5) end; task.wait(0.6); sg:Destroy() end)
end

-- 5. ESP LOGIC
local function CekTarget(n)
    n = n:lower()
    for _, b in pairs(Blacklist) do if n:find(b) then return false end end
    for _, r in pairs(SuperRare) do if n:find(r) then return "rare" end end
    for _, e in pairs(NormalTargets) do if n:find(e) then return "normal" end end
    return false
end

local function PasangESP(obj)
    if obj:FindFirstChild("GuritaTag") then return end
    pcall(function()
        local tipe = CekTarget(obj.Name)
        if not tipe then return end
        if tipe == "rare" then KirimNotifRare(obj) end
        local col = (tipe == "rare") and Color3.new(1, 0, 0) or Color3.fromRGB(0, 170, 255)
        local b = Instance.new("BillboardGui", obj)
        b.Name = "GuritaTag"; b.Size = UDim2.new(0, 200, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 6, 0)
        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = col; t.Font = "GothamBlack"; t.TextSize = 18; t.TextStrokeTransparency = 0
        task.spawn(function()
            while obj and obj.Parent and _G.HuntingMode do
                local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local p = obj:IsA("Model") and obj:GetModelCFrame().p or obj.Position
                    t.Text = obj.Name:upper() .. "\n[" .. math.floor((hrp.Position - p).Magnitude) .. "s]"
                end
                task.wait(1)
            end
            if b then b:Destroy() end; NotifHistory[obj] = nil
        end)
    end)
end


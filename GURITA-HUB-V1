-- [[ GURITA HUB: NORMAL-BRIGHT & FLAT COLOR ]] --

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local Lighting = game:GetService("Lighting")
local StarterGui = game:GetService("StarterGui")
local HttpService = game:GetService("HttpService")

-- [[ 1. CONFIG & SAVE SYSTEM ]] --
local FileName = "GuritaHub_Config.json"
local TargetEggs = {
    "hydra bunny", "noo my eggs", "baskito", "churrito", 
    "quackini snackini", "hopilikalika hopilikalako", "bunny sahur",
    "bunny tralala" 
}

_G.Settings = {
    EggESP = false,
    Notif = false 
}

local function SaveData()
    if writefile then pcall(function() writefile(FileName, HttpService:JSONEncode(_G.Settings)) end) end
end

local function LoadData()
    if isfile and isfile(FileName) then
        pcall(function() _G.Settings = HttpService:JSONDecode(readfile(FileName)) end)
    end
end
LoadData()

-- [[ 2. FEATURE: NORMAL BRIGHT NIGHT (CAHAYA NORMAL, LANGIT MALAM) ]] --
task.spawn(function()
    while true do
        Lighting.ClockTime = 0 -- Langit Malam
        Lighting.Brightness = 2 -- Cahaya normal game
        Lighting.GlobalShadows = true -- Hidupkan shadow tipis biar gak flat banget
        
        -- Gunakan warna Grey standar Roblox (Biar warna rumput & karpet normal)
        Lighting.Ambient = Color3.fromRGB(127, 127, 127) 
        Lighting.OutdoorAmbient = Color3.fromRGB(127, 127, 127)
        
        Lighting.ExposureCompensation = 0 -- Gak pake booster biar gak silau
        task.wait(3)
    end
end)

-- [[ 3. ENGINE ESP & NOTIF ]] --
local function ApplyUltimateESP(obj)
    if not obj:FindFirstChild("Marker") then
        local h = Instance.new("Highlight", obj)
        h.Name = "Marker"; h.FillColor = Color3.fromRGB(255, 255, 0)
        h.OutlineColor = Color3.new(1, 1, 1); h.FillTransparency = 0.4
        
        local b = Instance.new("BillboardGui", obj)
        b.Name = "Tag"; b.Size = UDim2.new(0, 150, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 3, 0)
        
        local t = Instance.new("TextLabel", b)
        t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = Color3.new(1, 1, 0)
        t.Font = Enum.Font.GothamBlack; t.TextSize = 14; t.TextStrokeTransparency = 0; t.TextStrokeColor3 = Color3.new(0,0,0)

        task.spawn(function()
            while obj and obj.Parent and _G.Settings.EggESP do
                if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (obj.Position - lp.Character.HumanoidRootPart.Position).Magnitude
                    t.Text = "✨ " .. obj.Name:upper() .. " ✨\n[" .. math.floor(dist) .. "m]"
                end
                task.wait(0.5)
            end
            if b then b:Destroy() end; if h then h:Destroy() end
        end)
    end
end

-- [[ 4. AUTOMATION & FLAT COLOR ]] --
local function SikatJadiFlat(v)
    pcall(function()
        if v:IsA("BasePart") and not v.Parent:FindFirstChild("Humanoid") then
            v.Material = Enum.Material.Plastic; v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
        end
    end)
end

task.spawn(function()
    while true do
        for i, v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and v.Material ~= Enum.Material.Plastic then SikatJadiFlat(v) end
            if _G.Settings.EggESP and table.find(TargetEggs, v.Name:lower()) then ApplyUltimateESP(v) end
            if i % 200 == 0 then task.wait() end 
        end
        task.wait(5)
    end
end)

workspace.DescendantAdded:Connect(function(v)
    task.wait(0.1)
    SikatJadiFlat(v)
    if table.find(TargetEggs, v.Name:lower()) then
        if _G.Settings.Notif then
            StarterGui:SetCore("SendNotification", {Title = "🥚 EGG DETECTED!", Text = v.Name:upper(), Duration = 5})
            local s = Instance.new("Sound", game:GetService("SoundService")); s.SoundId = "rbxassetid://4590662762"; s:Play()
            s.Ended:Connect(function() s:Destroy() end)
        end
        if _G.Settings.EggESP then ApplyUltimateESP(v) end
    end
end)

-- [[ 5. UI CONSTRUCTION ]] --
if PlayerGui:FindFirstChild("GURITA_NORMAL_NIGHT") then PlayerGui.GURITA_NORMAL_NIGHT:Destroy() end
local SG = Instance.new("ScreenGui", PlayerGui); SG.Name = "GURITA_NORMAL_NIGHT"; SG.ResetOnSpawn = false

local Logo = Instance.new("TextButton", SG)
Logo.Size = UDim2.new(0, 60, 0, 60); Logo.Position = UDim2.new(0, 15, 0.5, -30)
Logo.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Logo.Text = "G H"; Logo.TextColor3 = Color3.new(1, 1, 0)
Logo.Font = Enum.Font.GothamBlack; Logo.TextSize = 22; Logo.Draggable = true; Logo.Active = true
Instance.new("UICorner", Logo); Instance.new("UIStroke", Logo).Thickness = 2; Logo.UIStroke.Color = Color3.new(1,1,0)

local Main = Instance.new("Frame", SG)
Main.Size = UDim2.new(0, 220, 0, 180); Main.Position = UDim2.new(0.5, -110, 0.5, -90)
Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Main.Visible = false; Instance.new("UICorner", Main)
Instance.new("UIStroke", Main).Color = Color3.new(1, 1, 0)

Logo.MouseButton1Click:Connect(function() Main.Visible = not Main.Visible end)

local Title = Instance.new("TextLabel", Main)
Title.Size = UDim2.new(1, 0, 0, 45); Title.Text = "GURITA HUB NORMAL"; Title.TextColor3 = Color3.new(1, 1, 1); Title.Font = Enum.Font.GothamBlack; Title.BackgroundTransparency = 1; Title.TextSize = 13

local function CreateBtn(pos)
    local b = Instance.new("TextButton", Main)
    b.Size = UDim2.new(0.9, 0, 0, 45); b.Position = UDim2.new(0.05, 0, pos, 0)
    b.BackgroundColor3 = Color3.fromRGB(25, 25, 25); b.Font = Enum.Font.GothamBold; b.TextSize = 12; Instance.new("UICorner", b)
    Instance.new("UIStroke", b).Color = Color3.fromRGB(50, 50, 50)
    return b
end

local BtnESP = CreateBtn(0.3)
local BtnNotif = CreateBtn(0.65)

local function Refresh()
    BtnESP.Text = _G.Settings.EggESP and "ESP EGG: ON" or "ESP EGG: OFF"; BtnESP.TextColor3 = _G.Settings.EggESP and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
    BtnNotif.Text = _G.Settings.Notif and "NOTIF: ON" or "NOTIF: OFF"; BtnNotif.TextColor3 = _G.Settings.Notif and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
end
Refresh()

BtnESP.MouseButton1Click:Connect(function() 
    _G.Settings.EggESP = not _G.Settings.EggESP; SaveData(); Refresh() 
    if not _G.Settings.EggESP then for _, v in pairs(workspace:GetDescendants()) do if v.Name == "Marker" or v.Name == "Tag" then v:Destroy() end end end
end)
BtnNotif.MouseButton1Click:Connect(function() _G.Settings.Notif = not _G.Settings.Notif; SaveData(); Refresh() end)

-- --- 4. LOGIKA TOMBOL SIDEBAR (MANUAL POSITION) ---
local function showTab(tabName)
    for _, p in pairs(TabPages:GetChildren()) do
        if p:IsA("ScrollingFrame") then
            p.Visible = (p.Name == tabName)
        end
    end
end


-- [[ 1. MESIN ANTI-LAG KHUSUS REDMI 10 ]] --
pcall(function()
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    if setfpscap then setfpscap(45) end -- Kunci FPS biar gak panas
end)

-- [[ 2. LOGIKA FLAT POLOS (SIKAT MOTIF, JAGA WARNA) ]] --
local function SikatHalus(v)
    -- Abaikan karakter player
    if v:IsDescendantOf(lp.Character or workspace) and v.Parent:FindFirstChild("Humanoid") then return end
    
    pcall(function()
        if v:IsA("BasePart") then
            -- Bikin licin polos tapi warna tetep asli (karpet tetep merah, dll)
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            v.Reflectance = 0
            
            -- Buang gambar/motif/tekstur
            for _, child in pairs(v:GetChildren()) do
                if child:IsA("SurfaceAppearance") or child:IsA("Texture") or child:IsA("Decal") then 
                    child:Destroy() 
                end
            end
            if v:IsA("MeshPart") then v.TextureID = "" end
        elseif v:IsA("SpecialMesh") then 
            v.TextureId = "" 
        end
    end)
end

-- [[ 3. NUKE AWAN HD & LANGIT (CLEAN VERSION) ]] --
local function NukeAwanHD()
    pcall(function()
        -- Bersihkan semua efek HD di langit
        for _, v in pairs(Lighting:GetChildren()) do
            if v:IsA("Sky") or v:IsA("Atmosphere") or v:IsA("Clouds") or v:IsA("PostEffect") then 
                v:Destroy() 
            end
        end
        
        -- Pasang langit baru yang flat
        local sky = Instance.new("Sky", Lighting)
        sky.SunAngularSize, sky.MoonAngularSize, sky.StarCount = 0, 0, 0
        
        -- Lighting rata (Enteng di GPU)
        Lighting.GlobalShadows = false
        Lighting.Brightness = 1.2
        Lighting.Ambient = Color3.fromRGB(180, 180, 180)
        Lighting.OutdoorAmbient = Color3.fromRGB(180, 180, 180)
    end)
end


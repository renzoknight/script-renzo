local function CreateToggle(txt, var, callback)
    local b = Instance.new("TextButton", Content); b.Size = UDim2.new(0.9, 0, 0, 45); b.BackgroundColor3 = Color3.fromRGB(15, 15, 20); b.Font = Enum.Font.GothamBold; Instance.new("UICorner", b)
    local function UpdateUI() b.Text = txt..(_G.GH_Config[var] and ": ON" or ": OFF"); b.TextColor3 = _G.GH_Config[var] and Color3.new(0,1,0) or Color3.new(1,0,0) end

-- 1. DATABASE & CONFIG
local ConfigFile = "GHS_Config_Final.json"

-- HANYA NAMA INI YANG AKAN MUNCUL ESP
local AllowedEggs = {
    "hydra bunny", 
    "noo my eggs", 
    "baskito", 
    "churrito", 
    "quackini snackini", 
    "hopilikalika hopilikalako"
}

_G.GH_Config = {
    ESP_Player_GH = false,
    Xray_GH = false,
    AutoCollect_GH = false,
    ESP_Egg_GH = false
}

local function SaveData()
    pcall(function() if writefile then writefile(ConfigFile, HttpService:JSONEncode(_G.GH_Config)) end end)
end

local function LoadData()
    pcall(function()
        if isfile and isfile(ConfigFile) then
            local decoded = HttpService:JSONDecode(readfile(ConfigFile))
            if decoded then for k, v in pairs(decoded) do _G.GH_Config[k] = v end end
        end
    end)
end
LoadData()

-- [[ LOGIC: ESP EGG STRICT WHITELIST ]] --
local function TagEgg(v)
    if not _G.GH_Config.ESP_Egg_GH then return end
    
    local n = v.Name:lower()
    local allowed = false
    
    -- Cek apakah nama objek ada di daftar yang diperbolehkan
    for _, name in ipairs(AllowedEggs) do
        if n:find(name) then
            allowed = true
            break
        end
    end
    
    if allowed and not v:FindFirstChild("EHSTag") then
        local t = v:IsA("Model") and (v:FindFirstChild("Handle") or v:FindFirstChildWhichIsA("BasePart")) or v
        if t then
            local bg = Instance.new("BillboardGui", t)
            bg.Name = "EHSTag"; bg.AlwaysOnTop = true; bg.Size = UDim2.new(0, 160, 0, 40); bg.ExtentsOffset = Vector3.new(0, 2, 0)
            local lbl = Instance.new("TextLabel", bg)
            lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1; lbl.Text = v.Name
            lbl.TextColor3 = Color3.fromRGB(255, 200, 0); lbl.Font = Enum.Font.GothamBlack; lbl.TextSize = 13; lbl.TextStrokeTransparency = 0
        end
    end
end


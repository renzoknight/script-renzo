-- [[ AUTO RUN & LOOP ]] --
task.spawn(function()
    for _, v in pairs(workspace:GetDescendants()) do 
        ApplyFlat(v) -- Jalankan Flat Color langsung
        if _G.GH_Config.ESP_Egg_GH then TagEgg(v) end
    end
    workspace.DescendantAdded:Connect(function(v)
        ApplyFlat(v)
        if _G.GH_Config.ESP_Egg_GH then TagEgg(v) end

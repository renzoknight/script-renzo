-- [[ 2. LOGIKA SIKAT POLOS (MODE KILAT) ]] --
local function SikatPolos(v)
    -- Abaikan karakter
    if v:IsDescendantOf(game.Players.LocalPlayer.Character or workspace) and v.Parent:FindFirstChild("Humanoid") then return end

    pcall(function()
        if v:IsA("BasePart") then
            -- Langsung buat material plastik polos
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            v.Reflectance = 0
            
            -- Hapus tekstur mesh (pembatas map)
            if v:IsA("MeshPart") then
                v.TextureID = ""
            end

            -- Hapus semua motif (decal/tekstur)
            local children = v:GetChildren()
            for i=1, #children do
                local child = children[i]
                if child:IsA("SurfaceAppearance") or child:IsA("Texture") or child:IsA("Decal") then
                    child:Destroy()
                end
            end
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        end
    end)
end

-- [[ 3. EKSEKUSI MASAL (BULK PROCESSING) ]] --
task.spawn(function()
    -- Matikan material HD bawaan roblox
    pcall(function()
        MaterialService.Use2022Materials = false
        for _, m in pairs(MaterialService:GetChildren()) do m:Destroy() end
    end)

    local all = workspace:GetDescendants()
    local count = 0
    
    for i=1, #all do
        SikatPolos(all[i])
        count = count + 1
        
        -- Sikat 150 part sekaligus baru istirahat (Biar Load-nya Kilat)
        if count >= 150 then 
            task.wait() 
            count = 0
        end
    end
end)

-- Sikat part baru yang muncul saat main
workspace.DescendantAdded:Connect(function(v)
    task.wait(0.1)
    SikatPolos(v)
end)


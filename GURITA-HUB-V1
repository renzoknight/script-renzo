-- --- 5. FITUR DI DALAM TAB PASKAH ---
local function addToggle(parent, text, callback)
    local tgl = Instance.new("TextButton", parent)
    tgl.Size = UDim2.new(0.9, 0, 0, 40)
    tgl.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    tgl.Text = text .. " GH: OFF"
    tgl.TextColor3 = Color3.fromRGB(255, 255, 255)
    tgl.Font = Enum.Font.GothamBold
    tgl.ZIndex = 120
    Instance.new("UICorner", tgl).CornerRadius = UDim.new(0, 6)
    
    local active = false
    tgl.MouseButton1Click:Connect(function()
        active = not active
        tgl.Text = text .. " GH: " .. (active and "ON" or "OFF")
        tgl.TextColor3 = active and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 255, 255)
        callback(active)
    end)
end


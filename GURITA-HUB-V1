-- [[ GURITA HUB: V34 - BRUTE FORCE FLAT COLOR ]] --
-- Balik ke Logika Keras: Map Pasti Polos

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local PlayerGui = lp:WaitForChild("PlayerGui")
local Lighting = game:GetService("Lighting")
local StarterGui = game:GetService("StarterGui")
local HttpService = game:GetService("HttpService")

-- [[ 1. CONFIG & SAVE ]] --
local FileName = "GuritaHub_Config.json"
local TargetEggs = {"hydra bunny", "noo my eggs", "baskito", "churrito", "quackini", "snackini", "bunny bunny sahur"}
local NotifiedEggs = {}
_G.Settings = { EggESP = false, Notif = true }

local function SaveData() if writefile then writefile(FileName, HttpService:JSONEncode(_G.Settings)) end end
if isfile and isfile(FileName) then pcall(function() _G.Settings = HttpService:JSONDecode(readfile(FileName)) end) end

-- [[ 2. BRUTE FORCE FLAT COLOR (TAMPILAN KARTUN POLOS) ]] --
local function SikatHabis(v)
    -- Abaikan UI dan Karakter biar gak error
    if v:IsDescendantOf(PlayerGui) or v:IsDescendantOf(lp.Character or workspace) and v:FindFirstChild("Humanoid") then return end

    pcall(function()
        if v:IsA("BasePart") then
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
        elseif v:IsA("SpecialMesh") then
            v.TextureId = ""
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v:Destroy() -- Hapus semua tekstur/stiker di tembok & lantai
        end
    end)
end

-- Force Lighting biar warna makin rata
local function ForceLighting()
    Lighting.Brightness = 2
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.OutdoorAmbient = Color3.fromRGB(200, 200, 200)
    for _, v in pairs(Lighting:GetChildren()) do
        if v:IsA("PostEffect") or v:IsA("Atmosphere") then v:Destroy() end
    end
end

-- LOOPING KERAS (Setiap 5 detik pastiin map tetep polos)
task.spawn(function()
    ForceLighting()
    while true do
        for i, v in pairs(workspace:GetDescendants()) do
            SikatHabis(v)
            if i % 300 == 0 then task.wait() end -- Anti Lag
        end
        task.wait(5) 
    end
end)

-- [[ 3. ESP & NOTIF ]] --
local function ApplyESP(obj)
    if not _G.Settings.EggESP then return end
    if not obj:FindFirstChild("GuritaMarker") then
        local h = Instance.new("Highlight", obj); h.Name = "GuritaMarker"; h.FillColor = Color3.fromRGB(255, 255, 0)
        local b = Instance.new("BillboardGui", obj); b.Name = "GuritaTag"; b.Size = UDim2.new(0, 150, 0, 50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 3, 0)
        local t = Instance.new("TextLabel", b); t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundTransparency = 1; t.TextColor3 = Color3.new(1, 1, 0); t.Font = Enum.Font.GothamBlack; t.TextSize = 14
        task.spawn(function()
            while obj and obj.Parent and _G.Settings.EggESP do
                if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                    t.Text = obj.Name:upper() .. "\n[" .. math.floor((obj.Position - lp.Character.HumanoidRootPart.Position).Magnitude) .. "m]"
                end
                task.wait(1)
            end
            if b then b:Destroy() end; if h then h:Destroy() end
        end)
    end
end

task.spawn(function()
    while true do
        for _, v in pairs(workspace:GetDescendants()) do
            if table.find(TargetEggs, v.Name:lower()) then
                if _G.Settings.EggESP then ApplyESP(v) end
                if _G.Settings.Notif and not NotifiedEggs[v] then
                    NotifiedEggs[v] = true
                    StarterGui:SetCore("SendNotification", {Title = "🥚 EGG FOUND!", Text = v.Name:upper(), Duration = 5})
                    v.AncestryChanged:Connect(function(_, p) if not p then NotifiedEggs[v] = nil end end)
                end
            end
        end
        task.wait(5)
    end
end)


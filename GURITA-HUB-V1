local function CreateToggle(parent, txt, var, callback)
    local b = Instance.new("TextButton", parent); b.Size = UDim2.new(0.95, 0, 0, 40); b.BackgroundColor3 = Color3.fromRGB(15, 15, 20); b.Font = Enum.Font.GothamBold; Instance.new("UICorner", b)

local function CreateBtn(pos, text, var)
    local b = Instance.new("TextButton", Main); b.Size = UDim2.new(0.9, 0, 0, 40); b.Position = UDim2.new(0.05, 0, pos, 0); b.BackgroundColor3 = Color3.fromRGB(30, 30, 30); b.TextColor3 = Color3.new(1,1,1); b.Font = Enum.Font.GothamBold; b.TextSize = 11; Instance.new("UICorner", b); b.Text = text
    b.MouseButton1Click:Connect(function() _G[var] = not _G[var] end)
    task.spawn(function()
        while task.wait(0.5) do
            b.Text = text .. ": " .. (_G[var] and "ON" or "OFF")
            b.TextColor3 = _G[var] and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
        end
    end)
end

CreateBtn(0.15, "FLAT MAP", "FlatActive")
CreateBtn(0.55, "HUNT EGG", "HuntEggActive")

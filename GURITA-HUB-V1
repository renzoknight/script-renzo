local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- [[ FUNGSI FLAT COLOR SUPREME (ANTI-LAG) ]] --
local function ApplyTrueFlatColor(char)
    if not char then return end
    
    -- Menghilangkan aksesoris/topi agar warna flat terlihat bersih di badan
    task.wait(0.2)
    
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then
            -- Ini kunci warna FLAT: Menggunakan material Neon dengan Transparansi khusus
            -- atau membuang semua texture (Decals/Texture)
            v.Material = Enum.Material.Neon 
            v.Color = Color3.fromRGB(170, 0, 255) -- Warna Ungu Flat (seperti di foto)
            
            -- Menghapus wajah/stiker agar benar-benar rata warnanya
            if v:IsA("Decal") or v:IsA("Texture") then
                v:Destroy()
            end
        elseif v:IsA("SpecialMesh") then
            -- Menghapus tekstur pada mesh tapi mempertahankan bentuk
            v.TextureId = ""
        end
    end
    
    -- Menambahkan Outline Tipis (Highlight) agar tetap terlihat bentuknya
    if not char:FindFirstChild("GuritaFlat") then
        local hl = Instance.new("Highlight")
        hl.Name = "GuritaFlat"
        hl.Parent = char
        hl.FillTransparency = 1 -- Kita pakai warna part-nya saja agar flat
        hl.OutlineColor = Color3.fromRGB(255, 255, 255)
        hl.OutlineTransparency = 0.2
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    end
end

-- Otomatis aktif untuk semua orang kecuali kita (agar tidak silau)
local function MonitorPlayers()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            if p.Character then ApplyTrueFlatColor(p.Character) end
            p.CharacterAdded:Connect(ApplyTrueFlatColor)
        end
    end
end

Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(ApplyTrueFlatColor)
end)

MonitorPlayers()


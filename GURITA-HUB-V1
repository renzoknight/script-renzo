-- --- ANIMASI RGB NEON ---
local colors = {
    Color3.fromRGB(0, 150, 255),  -- Biru
    Color3.fromRGB(255, 100, 0),  -- Oranye
    Color3.fromRGB(255, 200, 0),  -- Kuning
    Color3.fromRGB(150, 0, 255)   -- Ungu
}

local colorIndex = 1
local nextColorIndex = 2
local transitionTime = 2 
local currentTime = 0

RunService.Heartbeat:Connect(function(dt)
    currentTime = currentTime + dt
    local percent = currentTime / transitionTime
    UIStroke.Color = colors[colorIndex]:Lerp(colors[nextColorIndex], percent)
    
    if percent >= 1 then
        currentTime = 0
        colorIndex = nextColorIndex
        nextColorIndex = nextColorIndex + 1
        if nextColorIndex > #colors then nextColorIndex = 1 end
    end
end)

}

-- [[ AUTO SAVE & LOAD ]] --
local function SaveData()
    pcall(function()
        if writefile then
            writefile(ConfigFile, HttpService:JSONEncode(_G.GH_Config))
        end
    end)
end

local function LoadData()
    pcall(function()
        if isfile and isfile(ConfigFile) then
            local content = readfile(ConfigFile)
            local decoded = HttpService:JSONDecode(content)
            if decoded then
                for k, v in pairs(decoded) do
                    _G.GH_Config[k] = v
                end
            end
        end
    end)
end
LoadData()

-- 2. BACKEND LOGIC
local function IsPlayer(v)
    return v:IsDescendantOf(lp.Character) or (v.Parent and v.Parent:FindFirstChild("Humanoid"))
end

local function ApplyFlat(v)
    pcall(function()
        if (v:IsA("BasePart") or v:IsA("MeshPart")) and not IsPlayer(v) then
            v.Material = Enum.Material.Plastic
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
            for _, tex in pairs(v:GetChildren()) do
                if tex:IsA("Texture") or tex:IsA("Decal") then tex:Destroy() end
            end
        end
    end)
end

local function RefreshXray()
    task.spawn(function()
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and not IsPlayer(v) then
                local n = v.Name:lower()
                if n:find("wall") or n:find("base") or n:find("door") or n:find("floor") or n:find("part") then
                    v.LocalTransparencyModifier = _G.GH_Config.Xray_GH and 0.6 or 0
                end
            end
        end
    end)
end

-- 3. ESP PLAYER SYSTEM
local function CreatePlayerESP(p)
    task.spawn(function()
        while p and p.Parent do
            if _G.GH_Config.ESP_Player_GH and p ~= lp and p.Character and p.Character:FindFirstChild("Head") then
                local head = p.Character.Head
                if not head:FindFirstChild("ESP_PlayerTag") then
                    local bg = Instance.new("BillboardGui", head)
                    bg.Name = "ESP_PlayerTag"; bg.AlwaysOnTop = true; bg.Size = UDim2.new(0, 200, 0, 50); bg.ExtentsOffset = Vector3.new(0, 3, 0)
                    local lbl = Instance.new("TextLabel", bg)
                    lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1; lbl.TextColor3 = Color3.new(1, 1, 1)
                    lbl.Text = p.Name; lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 16; lbl.TextStrokeTransparency = 0.5
                end
            else
                if p.Character and p.Character:FindFirstChild("Head") and p.Character.Head:FindFirstChild("ESP_PlayerTag") then
                    p.Character.Head.ESP_PlayerTag:Destroy()
                end
            end
            task.wait(1)
        end
    end)
end


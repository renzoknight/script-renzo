-- [[ STEAL A BRAINROT - RENZO EDITION ]] --
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.Lib:CreateWindow("Renzo Hub", "Lightweight")

-- Variable Utama
local Player = game.Players.LocalPlayer
local Char = Player.Character or Player.CharacterAdded:Wait()
local Root = Char:WaitForChild("HumanoidRootPart")

-- TAB 1: FARMING
local Tab1 = Window:NewTab("Auto Farm")
local FarmSec = Tab1:NewSection("Main Farming")

FarmSec:NewToggle("Auto Steal & Collect", "Loop ringan", function(state)
    _G.Farm = state
    task.spawn(function()
        while _G.Farm do
            pcall(function()
                for _, v in ipairs(game.Workspace.Items:GetChildren()) do
                    if v:IsA("BasePart") and _G.Farm then
                        Root.CFrame = v.CFrame
                        firetouchinterest(Root, v, 0)
                        task.wait()
                        firetouchinterest(Root, v, 1)
                    end
                end
            end)
            task.wait(0.1)
        end
    end)
end)

-- TAB 2: VISUAL (Grafik Semut)
local Tab2 = Window:NewTab("Visuals")
local VisSec = Tab2:NewSection("Performance Boost")

VisSec:NewButton("Aktifkan Grafik Semut", "FPS Boost Tinggi", function()
    settings().Rendering.QualityLevel = 1
    game.Lighting.GlobalShadows = false
    for _, v in ipairs(game:GetDescendants()) do
        if v:IsA("Part") or v:IsA("MeshPart") then
            v.Material = Enum.Material.SmoothPlastic
        elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("ParticleEmitter") then
            v:Destroy()
        end
    end
end)

-- TAB 3: PLAYER
local Tab3 = Window:NewTab("Misc")
local MiscSec = Tab3:NewSection("Karakter")

MiscSec:NewSlider("WalkSpeed", "Kecepatan", 500, 16, function(s)
    Char.Humanoid.WalkSpeed = s
end)

MiscSec:NewButton("Server Hop", "Cari Min Gen Baru", function()
    local ts = game:GetService("TeleportService")
    ts:Teleport(game.PlaceId, Player)
end)
